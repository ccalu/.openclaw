{"type":"message","id":"43d5117d","parentId":"ef3a08a5","timestamp":"2026-03-30T14:06:04.254Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_GCJV66Z3Ju0BocRJigm9LTGq|fc_07b64bc35dd48fb50169ca8342cfc88193a5293c6d7952db54","name":"write","arguments":{"path":"C:\\Users\\User-OEM\\.openclaw\\workspace\\task_watchdog\\check_watchdog.py","content":"from __future__ import annotations\n\nimport json\nfrom pathlib import Path\nfrom typing import Any, Dict, List\n\nBASE = Path(r\"C:\\Users\\User-OEM\\.openclaw\\workspace\\task_watchdog\")\nACTIVE_PATH = BASE / \"active_tasks.json\"\nCONFIG_PATH = BASE / \"config.json\"\n\n\ndef load_json(path: Path, default: Any):\n    if not path.exists():\n        return default\n    try:\n        return json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception:\n        return default\n\n\ndef summarize(tasks: List[Dict[str, Any]]) -> Dict[str, Any]:\n    by_status: Dict[str, int] = {}\n    flagged = []\n    for task in tasks:\n        status = task.get(\"status\", \"unknown\")\n        by_status[status] = by_status.get(status, 0) + 1\n        if status in {\"stalled\", \"orphaned\", \"failed\"}:\n            flagged.append({\n                \"taskId\": task.get(\"taskId\"),\n                \"taskName\": task.get(\"taskName\"),\n                \"status\": status,\n                \"statusReason\": task.get(\"statusReason\"),\n                \"lastKnownStep\": task.get(\"lastKnownStep\"),\n            })\n    return {\n        \"totalActive\": len(tasks),\n        \"byStatus\": by_status,\n        \"flagged\": flagged,\n    }\n\n\ndef main() -> None:\n    config = load_json(CONFIG_PATH, {})\n    tasks = load_json(ACTIVE_PATH, [])\n    summary = summarize(tasks)\n    summary[\"enabled\"] = config.get(\"enabled\", True)\n    summary[\"notifyEveryMinutes\"] = config.get(\"notifyEveryMinutes\", 10)\n    summary[\"stallMinutes\"] = config.get(\"stallMinutes\", 30)\n    summary[\"orphanMinutes\"] = config.get(\"orphanMinutes\", 60)\n    print(json.dumps(summary, ensure_ascii=False, indent=2))\n\n\nif __name__ == \"__main__\":\n    main()\n"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\.openclaw\\\\workspace\\\\task_watchdog\\\\check_watchdog.py\",\"content\":\"from __future__ import annotations\\n\\nimport json\\nfrom pathlib import Path\\nfrom typing import Any, Dict, List\\n\\nBASE = Path(r\\\"C:\\\\Users\\\\User-OEM\\\\.openclaw\\\\workspace\\\\task_watchdog\\\")\\nACTIVE_PATH = BASE / \\\"active_tasks.json\\\"\\nCONFIG_PATH = BASE / \\\"config.json\\\"\\n\\n\\ndef load_json(path: Path, default: Any):\\n    if not path.exists():\\n        return default\\n    try:\\n        return json.loads(path.read_text(encoding=\\\"utf-8\\\"))\\n    except Exception:\\n        return default\\n\\n\\ndef summarize(tasks: List[Dict[str, Any]]) -> Dict[str, Any]:\\n    by_status: Dict[str, int] = {}\\n    flagged = []\\n    for task in tasks:\\n        status = task.get(\\\"status\\\", \\\"unknown\\\")\\n        by_status[status] = by_status.get(status, 0) + 1\\n        if status in {\\\"stalled\\\", \\\"orphaned\\\", \\\"failed\\\"}:\\n            flagged.append({\\n                \\\"taskId\\\": task.get(\\\"taskId\\\"),\\n                \\\"taskName\\\": task.get(\\\"taskName\\\"),\\n                \\\"status\\\": status,\\n                \\\"statusReason\\\": task.get(\\\"statusReason\\\"),\\n                \\\"lastKnownStep\\\": task.get(\\\"lastKnownStep\\\"),\\n            })\\n    return {\\n        \\\"totalActive\\\": len(tasks),\\n        \\\"byStatus\\\": by_status,\\n        \\\"flagged\\\": flagged,\\n    }\\n\\n\\ndef main() -> None:\\n    config = load_json(CONFIG_PATH, {})\\n    tasks = load_json(ACTIVE_PATH, [])\\n    summary = summarize(tasks)\\n    summary[\\\"enabled\\\"] = config.get(\\\"enabled\\\", True)\\n    summary[\\\"notifyEveryMinutes\\\"] = config.get(\\\"notifyEveryMinutes\\\", 10)\\n    summary[\\\"stallMinutes\\\"] = config.get(\\\"stallMinutes\\\", 30)\\n    summary[\\\"orphanMinutes\\\"] = config.get(\\\"orphanMinutes\\\", 60)\\n    print(json.dumps(summary, ensure_ascii=False, indent=2))\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":126,"output":524,"cacheRead":53760,"cacheWrite":0,"totalTokens":54410,"cost":{"input":0.000315,"output":0.00786,"cacheRead":0.013439999999999999,"cacheWrite":0,"total":0.021615}},"stopReason":"toolUse","timestamp":1774879551469,"responseId":"resp_07b64bc35dd48fb50169ca8341a1408193ae38a73698d35b60"}}
