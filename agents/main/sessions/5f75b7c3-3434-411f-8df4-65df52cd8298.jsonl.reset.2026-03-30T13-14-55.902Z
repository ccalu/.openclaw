e: memory/2026-03-27.md#L1-L11","source":"memory","citation":"memory/2026-03-27.md#L1-L11"}],"provider":"openai","model":"text-embedding-3-small","citations":"auto","mode":"hybrid"},"isError":false,"timestamp":1774793353019}}
