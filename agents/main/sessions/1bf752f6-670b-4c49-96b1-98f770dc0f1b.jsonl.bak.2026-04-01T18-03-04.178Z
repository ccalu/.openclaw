{"type":"message","id":"e88eb4b5","parentId":"6594ddfa","timestamp":"2026-04-01T09:45:30.340Z","message":{"role":"toolResult","toolCallId":"call_T2MilipTNnI4dsZBYuVF2EHf|fc_0785557c08065f410169cce93952a8819098fcb21f9d7fb4b8","toolName":"exec","content":[{"type":"text","text":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\tests\\__pycache__\\test_s1_start.cpython-310-pytest-9.0.2.pyc\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\tests\\test_s1_start.py"}],"details":{"status":"completed","exitCode":0,"durationMs":517,"aggregated":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\tests\\__pycache__\\test_s1_start.cpython-310-pytest-9.0.2.pyc\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\tests\\test_s1_start.py","cwd":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory"},"isError":false,"timestamp":1775036730172}}
{"type":"message","id":"d2b892c6","parentId":"e88eb4b5","timestamp":"2026-04-01T09:45:33.928Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_IHCTpNHwBkukPE8elO1WkyEG|fc_0785557c08065f410169cce93e609481909548b48c98525a73","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\tests\\test_s1_start.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\tests\\\\test_s1_start.py\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":169,"output":43,"cacheRead":77312,"cacheWrite":0,"totalTokens":77524,"cost":{"input":0.0004225,"output":0.0006450000000000001,"cacheRead":0.019327999999999998,"cacheWrite":0,"total":0.020395499999999997}},"stopReason":"toolUse","timestamp":1775036731229,"responseId":"resp_0785557c08065f410169cce93d7ab481908cef540ff5005897"}}
{"type":"message","id":"7ed23946","parentId":"d2b892c6","timestamp":"2026-04-01T09:45:34.797Z","message":{"role":"toolResult","toolCallId":"call_IHCTpNHwBkukPE8elO1WkyEG|fc_0785557c08065f410169cce93e609481909548b48c98525a73","toolName":"read","content":[{"type":"text","text":"\"\"\"Tests for the legacy S1 transitional entrypoint.\n\nThese tests still validate the compatibility path exposed by `runtime.s1.s1_start`.\nThey do not define the canonical OpenClaw runtime architecture for S1.\nLLM-dependent steps are mocked.\n\"\"\"\n\nimport pytest\nimport json\nfrom pathlib import Path\nfrom unittest.mock import patch\n\nfrom runtime.s1.s1_start import start_s1\n\nFIXTURES = Path(__file__).parent / \"fixtures\" / \"s1\"\n\nSAMPLE_JOB = {\n    \"job_id\": \"2026-03-30_004_fr_001\",\n    \"account\": \"004\",\n    \"language\": \"fr\",\n    \"channel_name\": \"C004 FRA\",\n    \"sheet_scripts_id\": \"test\",\n    \"sheet_tracking_id\": \"test\",\n    \"drive_folder_id\": \"test\",\n    \"v3_config\": \"test\",\n    \"created_at\": \"2026-03-30T15:00:00Z\",\n    \"pub_row\": 25,\n}\n\n\ndef _load(name):\n    with open(FIXTURES / name, \"r\", encoding=\"utf-8\") as f:\n        if name.endswith(\".json\"):\n            return json.load(f)\n        return f.read()\n\n\ndef _setup_run(tmp_path):\n    \"\"\"Create minimal run structure with script.\"\"\"\n    script_dir = tmp_path / \"inputs\" / \"script\"\n    script_dir.mkdir(parents=True)\n    script_text = _load(\"sample_script_raw.txt\")\n    (script_dir / \"script_raw.txt\").write_text(script_text, encoding=\"utf-8\")\n    (tmp_path / \"checkpoints\").mkdir(exist_ok=True)\n    return script_text\n\n\ndef _canonicalize_polished(screenplay, polished):\n    \"\"\"Upgrade legacy fixture/mock polish shape to canonical-compatible shape.\"\"\"\n    upgraded = []\n    for i, scene in enumerate(polished):\n        scene_id = scene.get(\"scene_id\", screenplay[i].get(\"scene_id\", f\"scene_{i+1:03d}\"))\n        narration_original = scene.get(\"narration_original\", scene.get(\"original\", screenplay[i].get(\"narration_original\", \"\")))\n        narration_tts = scene.get(\"narration_tts\", scene.get(\"polished\", narration_original))\n        upgraded.append(\n            {\n                \"scene_id\": scene_id,\n                \"narration_original\": narration_original,\n                \"narration_tts\": narration_tts,\n                \"changes\": scene.get(\"changes\", []),\n            }\n        )\n\n    while len(upgraded) < len(screenplay):\n        upgraded.append(\n            {\n                \"scene_id\": screenplay[len(upgraded)][\"scene_id\"],\n                \"narration_original\": screenplay[len(upgraded)][\"narration_original\"],\n                \"narration_tts\": screenplay[len(upgraded)][\"narration_original\"],\n                \"changes\": [],\n            }\n        )\n\n    return upgraded\n\n\nclass TestS1HappyPath:\n    @patch(\"runtime.s1.s1_start.run_tts_polish\")\n    @patch(\"runtime.s1.s1_start.run_scene_director\")\n    def test_success(self, mock_director, mock_polish, tmp_path):\n        _setup_run(tmp_path)\n        screenplay = _load(\"sample_screenplay_valid.json\")\n        polished = _canonicalize_polished(screenplay, _load(\"sample_tts_polished_valid.json\"))\n\n        mock_director.return_value = screenplay\n        mock_polish.return_value = polished\n\n        result = start_s1(SAMPLE_JOB, tmp_path)\n\n        assert result[\"success\"] is True\n        assert result[\"status\"] == \"s1_complete\"\n        assert result[\"next_step\"] == \"ready_for_s2_and_s3\"\n        assert result[\"scene_count\"] == len(screenplay)\n\n    @patch(\"runtime.s1.s1_start.run_tts_polish\")\n    @patch(\"runtime.s1.s1_start.run_scene_director\")\n    def test_all_artifacts_written(self, mock_director, mock_polish, tmp_path):\n        _setup_run(tmp_path)\n        screenplay = _load(\"sample_screenplay_valid.json\")\n        polished = _canonicalize_polished(screenplay, _load(\"sample_tts_polished_valid.json\"))\n\n        mock_director.return_value = screenplay\n        mock_polish.return_value = polished\n\n        start_s1(SAMPLE_JOB, tmp_path)\n\n        assert (tmp_path / \"b1_pre_production\" / \"screenplay.json\").exists()\n        assert (tmp_path / \"b1_pre_production\" / \"screenplay_validation.json\").exists()\n        assert (tmp_path / \"b1_pre_production\" / \"tts_polished.json\").exists()\n        assert (tmp_path / \"b1_pre_production\" / \"polish_validation.json\").exists()\n        assert (tmp_path / \"scene_bible.json\").exists()\n\n    @patch(\"runtime.s1.s1_start.run_tts_polish\")\n    @patch(\"runtime.s1.s1_start.run_scene_director\")\n    def test_all_checkpoints_written(self, mock_director, mock_polish, tmp_path):\n        _setup_run(tmp_path)\n        screenplay = _load(\"sample_screenplay_valid.json\")\n        polished = _canonicalize_polished(screenplay, _load(\"sample_tts_polished_valid.json\"))\n\n        mock_director.return_value = screenplay\n        mock_polish.return_value = polished\n\n        result = start_s1(SAMPLE_JOB, tmp_path)\n\n        expected = [\"b1_step1_screenplay.json\", \"b1_step2_screenplay_validated.json\",\n                    \"b1_step3_tts_polished.json\", \"b1_step4_polish_validated.json\",\n                    \"b1_step5_scene_bible.json\", \"b1_complete.json\"]\n        assert result[\"checkpoints_written\"] == expected\n        for cp in expected:\n            assert (tmp_path / \"checkpoints\" / cp).exists()\n\n    @patch(\"runtime.s1.s1_start.run_tts_polish\")\n    @patch(\"runtime.s1.s1_start.run_scene_director\")\n    def test_scene_bible_at_root(self, mock_director, mock_polish, tmp_path):\n        _setup_run(tmp_path)\n        screenplay = _load(\"sample_screenplay_valid.json\")\n        polished = _canonicalize_polished(screenplay, _load(\"sample_tts_polished_valid.json\"))\n\n        mock_director.return_value = screenplay\n        mock_polish.return_value = polished\n\n        start_s1(SAMPLE_JOB, tmp_path)\n\n        assert (tmp_path / \"scene_bible.json\").exists()\n        assert not (tmp_path / \"b1_pre_production\" / \"scene_bible.json\").exists()\n\n\nclass TestS1Failures:\n    def test_missing_script(self, tmp_path):\n        (tmp_path / \"checkpoints\").mkdir(parents=True)\n        result = start_s1(SAMPLE_JOB, tmp_path)\n        assert result[\"success\"] is False\n        assert \"missing_script\" in result[\"errors\"][0][\"code\"]\n\n    @patch(\"runtime.s1.s1_start.run_scene_director\")\n    def test_scene_director_failure(self, mock_director, tmp_path):\n        _setup_run(tmp_path)\n        mock_director.side_effect = Exception(\"API error\")\n\n        result = start_s1(SAMPLE_JOB, tmp_path)\n        assert result[\"success\"] is False\n        assert \"scene_director\" in result[\"errors\"][0][\"code\"]\n"}],"isError":false,"timestamp":1775036734585}}
