ls\\scene_logger.py\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\utils\\text_normalizer.py\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\utils\\__pycache__\\text_normalizer.cpython-310.pyc"}],"details":{"status":"completed","exitCode":0,"durationMs":622,"aggregated":"C:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\agents\\evaluator_agent.py\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\agents\\refinement_loop.py\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\agents\\__pycache__\\evaluator_agent.cpython-310.pyc\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\processors\\parallel_screenplay.py\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\processors\\scene_director.py\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\processors\\scene_reconstructor.py\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\processors\\scene_text_validator.py\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\processors\\scene_word_count_checker.py\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\processors\\bloco2v2\\step_02b_entity_scene_mapper.py\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\processors\\bloco2v2\\__pycache__\\step_02b_entity_scene_mapper.cpython-310.pyc\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\processors\\__pycache__\\parallel_screenplay.cpython-310.pyc\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\processors\\__pycache__\\scene_director.cpython-310.pyc\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_factory_v3\\shared\\processors\\__pycache__\\scene_reconstructor.cpython-310.pyc\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\content_fac