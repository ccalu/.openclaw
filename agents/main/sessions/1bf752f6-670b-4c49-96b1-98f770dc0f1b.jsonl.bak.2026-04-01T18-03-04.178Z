t-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\checkpoint_initializer.cpython...\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\job_input_validator.cpython-31...\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\run_metadata_writer.cpython-31...\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\script_checkpoint_writer.cpyth...\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\script_fetcher.cpython-310.pyc   \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\script_fetch_and_lock.cpython-...\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\script_locker.cpython-310.pyc    \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\script_metadata_writer.cpython...\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\video_dir_initializer.cpython-...\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\vo_start.cpython-310.pyc         \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\__init__.cpython-310.pyc"}],"details":{"status":"completed","exitCode":0,"durationMs":1242,"aggregated":"FullName                                                                                                               \r\n--------                                                                                                               \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\checkpoint_initializer.py                    \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\job_input_validator.py                       \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\run_metadata_writer.py                       \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\script_checkpoint_writer.py                  \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\script_fetcher.py                            \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\script_fetch_and_lock.py                     \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\script_locker.py                             \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\script_metadata_writer.py                    \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\video_dir_initializer.py                     \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\vo_start.py                                  \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__init__.py                                  \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\checkpoint_initializer.cpython...\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\job_input_validator.cpython-31...\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\run_metadata_writer.cpython-31...\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\script_checkpoint_writer.cpyth...\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\script_fetcher.cpython-310.pyc   \r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\vo\\__pycache__\\script_fetch_and_lock.cpython-...\r\nC:\\Users\\User-OEM\\Desktop\\content