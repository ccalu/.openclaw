 Where-Object { $_.Name -match 'script_fetcher|script_locker|script_fetch_and_lock' } | Select-Object -ExpandProperty FullName","workdir":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory","yieldMs":10000,"timeout":30},"partialJson":"{\"command\":\"Get-ChildItem -Recurse -File runtime\\\\tests | Where-Object { $_.Name -match 'script_fetcher|script_locker|script_fetch_and_lock' } | Select-Object -ExpandProperty FullName\",\"workdir\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\",\"yieldMs\":10000,\"timeout\":30}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":168621,"output":290,"cacheRead":2560,"cacheWrite":0,"totalTokens":171471,"cost":{"input":0.42155250000000005,"output":0.00435,"cacheRead":0.0006399999999999999,"cacheWrite":0,"total":0.42654250000000005}},"stopReason":"toolUse","timestamp":1775052627672,"responseId":"resp_0785557c08065f410169cd27569aac81909763f230094f3b5f"}}
{"type":"message","id":"e2bdd459","parentId":"f2793676","timestamp":"2026-04-01T14:10:42.889Z","message":{"role":"toolResult","toolCallId":"call_0YhFbG4fckEbsUZhmQ7tmfLC|fc_0785557c08065f410169cd27631064819098e13812683ba23a","toolName":"read","content":[{"type":"text","text":"{\n  \"job_id\": \"2026-03-30_004_fr_001\",\n  \"account\": \"004\",\n  \"language\": \"fr\",\n  \"channel_name\": \"C004 FRA (CHRONIQUES) (9)\",\n  \"sheet_scripts_id\": \"1S4vl3LY6Q-59vHZzUjRpmz3ul7aaW8qmOPSjj06C-Jk\",\n  \"sheet_scripts_name\": \"Pagina1\",\n  \"sheet_tracking_id\": \"1y9habAib_ZTqkxSfFPo-b54nE0cTCbIWyQh7H3GxhwE\",\n  \"drive_folder_id\": \"17QJejz4mIMLJoVMex52Mw7hR8y9e1hAT\",\n  \"channel_url\": \"\",\n  \"v3_config\": \"accounts/004_dark_culture/configs/004-fr.yaml\",\n  \"runway_days\": -17,\n  \"scripts_remaining\": 15,\n  \"reason\": \"PROD=SIM, scripts_remaining=15, runway=-17\",\n  \"priority_override\": null,\n  \"created_at\": \"2026-03-30T15:16:06.635809+00:00\",\n  \"pub_row\": 25\n}\n"}],"isError":false,"timestamp":1775052642788}}
{"type":"message","id":"f690d3a5","parentId":"e2bdd459","timestamp":"2026-04-01T14:10:42.991Z","message":{"role":"toolResult","toolCallId":"call_84E3vRtyZtjQOVIZgGlmVwtE|fc_0785557c08065f410169cd276310788190ad4a2abd205de9b5","toolName":"read","content":[{"type":"text","text":"\"\"\"Tests for VO vo_start — full bootstrap flow.\"\"\"\n\nimport json\nimport pytest\nfrom pathlib import Path\n\nfrom runtime.vo.vo_start import start_video_run\n\nFIXTURES_DIR = Path(__file__).parent / \"fixtures\" / \"vo\"\n\n\ndef _load_valid_job() -> dict:\n    return json.loads((FIXTURES_DIR / \"sample_pm_job_valid.json\").read_text(encoding=\"utf-8\"))\n\n\nclass TestHappyPath:\n    def test_success_result(self, tmp_path):\n        job = _load_valid_job()\n        result = start_video_run(job, production_root=tmp_path)\n\n        assert result[\"success\"] is True\n        assert result[\"job_id\"] == \"2026-03-30_004_fr_001\"\n        assert result[\"status\"] == \"initialized\"\n        assert result[\"next_step\"] == \"ready_for_script_fetch\"\n        assert result[\"errors\"] == []\n\n    def test_video_root_exists(self, tmp_path):\n        job = _load_valid_job()\n        result = start_video_run(job, production_root=tmp_path)\n\n        assert result[\"video_root\"] is not None\n        assert Path(result[\"video_root\"]).exists()\n\n    def test_all_paths_present(self, tmp_path):\n        job = _load_valid_job()\n        result = start_video_run(job, production_root=tmp_path)\n\n        assert \"job_json\" in result[\"paths\"]\n        assert \"run_metadata\" in result[\"paths\"]\n        assert \"checkpoint_init\" in result[\"paths\"]\n\n        for key, path_str in result[\"paths\"].items():\n            assert Path(path_str).exists(), f\"Path {key} does not exist: {path_str}\"\n\n\nclass TestJobJsonWritten:\n    def test_job_json_content(self, tmp_path):\n        job = _load_valid_job()\n        result = start_video_run(job, production_root=tmp_path)\n\n        job_json = json.loads(Path(result[\"paths\"][\"job_json\"]).read_text(encoding=\"utf-8\"))\n        assert job_json[\"job_id\"] == job[\"job_id\"]\n        assert job_json[\"account\"] == job[\"account\"]\n        assert job_json[\"language\"] == job[\"language\"]\n        assert job_json[\"channel_name\"] == job[\"channel_name\"]\n        assert job_json[\"pub_row\"] == job[\"pub_row\"]\n\n\nclass TestRunMetadataWritten:\n    def test_run_metadata_content(self, tmp_path):\n        job = _load_valid_job()\n        result = start_video_run(job, production_root=tmp_path)\n\n        metadata = json.loads(Path(result[\"paths\"][\"run_metadata\"]).read_text(encoding=\"utf-8\"))\n        assert metadata[\"job_id\"] == \"2026-03-30_004_fr_001\"\n        assert metadata[\"account\"] == \"004\"\n        assert metadata[\"language\"] == \"fr\"\n        assert metadata[\"status\"] == \"initialized\"\n        assert metadata[\"current_stage\"] == \"vo_bootstrap\"\n        assert metadata[\"started_by\"] == \"vo_minimal\"\n        assert metadata[\"job_source\"] == \"pm_job\"\n        assert \"started_at\" in metadata\n\n    def test_run_metadata_paths(self, tmp_path):\n        job = _load_valid_job()\n        result = start_video_run(job, production_root=tmp_path)\n\n        metadata = json.loads(Path(result[\"paths\"][\"run_metadata\"]).read_text(encoding=\"utf-8\"))\n        assert \"job_json\" in metadata[\"paths\"]\n        assert \"checkpoints\" in metadata[\"paths\"]\n        assert \"inputs\" in metadata[\"paths\"]\n        assert \"outputs\" in metadata[\"paths\"]\n        assert \"logs\" in metadata[\"paths\"]\n        assert \"sectors\" in metadata[\"paths\"]\n\n\nclass TestCheckpointWritten:\n    def test_checkpoint_content(self, tmp_path):\n        job = _load_valid_job()\n        result = start_video_run(job, production_root=tmp_path)\n\n        checkpoint = json.loads(Path(result[\"paths\"][\"checkpoint_init\"]).read_text(encoding=\"utf-8\"))\n        assert checkpoint[\"job_id\"] == \"2026-03-30_004_fr_001\"\n        assert checkpoint[\"status\"] == \"initialized\"\n        assert checkpoint[\"current_stage\"] == \"vo_bootstrap\"\n        assert checkpoint[\"sectors_completed\"] == []\n        assert checkpoint[\"next_step\"] == \"ready_for_script_fetch\"\n        assert \"created_at\" in checkpoint\n\n\nclass TestInvalidJob:\n    def test_invalid_job_returns_failure(self, tmp_path):\n        job = {\"job_id\": \"\", \"account\": 123}\n        result = start_video_run(job, production_root=tmp_path)\n\n        assert result[\"success\"] is False\n        assert result[\"status\"] == \"validation_failed\"\n        assert result[\"next_step\"] is None\n        assert result[\"video_root\"] is None\n        assert len(result[\"errors\"]) > 0\n        assert result[\"paths\"] == {}\n\n    def test_invalid_job_no_directory_created(self, tmp_path):\n        job = {\"job_id\": \"\", \"account\": 123}\n        start_video_run(job, production_root=tmp_path)\n\n        # tmp_path should remain empty — no production dirs created\n        contents = list(tmp_path.iterdir())\n        assert contents == []\n\n    def test_missing_required_fields(self, tmp_path):\n        job = {\"job_id\": \"test\"}\n        result = start_video_run(job, production_root=tmp_path)\n\n        assert result[\"success\"] is False\n        assert any(e[\"code\"] == \"missing_field\" for e in result[\"errors\"])\n\n\nclass TestRunAlreadyExists:\n    def test_second_run_fails(self, tmp_path):\n        job = _load_valid_job()\n        r1 = start_video_run(job, production_root=tmp_path)\n        assert r1[\"success\"] is True\n\n        r2 = start_video_run(job, production_root=tmp_path)\n        assert r2[\"success\"] is False\n        assert r2[\"status\"] == \"run_already_exists\"\n        assert any(e[\"code\"] == \"run_already_exists\" for e in r2[\"errors\"])\n\n\nclass TestResultStructure:\n    def test_all_keys_present(self, tmp_path):\n        job = _load_valid_job()\n        result = start_video_run(job, production_root=tmp_path)\n\n        expected_keys = {\"success\", \"job_id\", \"video_root\", \"paths\", \"status\", \"next_step\", \"errors\", \"warnings\"}\n        assert set(result.keys()) == expected_keys\n\n    def test_failure_all_keys_present(self, tmp_path):\n        job = {\"broken\": True}\n        result = start_video_run(job, production_root=tmp_path)\n\n        expected_keys = {\"success\", \"job_id\", \"video_root\", \"paths\", \"status\", \"next_step\", \"errors\", \"warnings\"}\n        assert set(result.keys()) == expected_keys\n"}],"isError":false,"timestamp":1775052642892}}
