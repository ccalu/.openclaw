e\": false, \"batch_id\": \"sd_004\", \"classification\": \"batch_regenerate\", \"errors\": [{\"code\": \"invalid_scene_span\", \"message\": \"Scene scene_01 span (2159-2291) is outside batch-relative range 1-744\", \"scene_ids\": [\"scene_01\"]}, {\"code\": \"invalid_scene_span\", \"message\": \"Scene scene_02 span (2292-2481) is outside batch-relative range 1-744\", \"scene_ids\": [\"scene_02\"]}, {\"code\": \"invalid_scene_span\", \"message\": \"Scene scene_03 span (2482-2660) is outside batch-relative range 1-744\", \"scene_ids\": [\"scene_03\"]}, {\"code\": \"invalid_scene_span\", \"message\": \"Scene scene_04 span (2661-2902) is outside batch-relative range 1-744\", \"scene_ids\": [\"scene_04\"]}, {\"code\": \"missing_coverage_detected\", \"message\": \"Words 1-744 are not assigned to any scene\"}], \"warnings\": [], \"stats\": {\"scene_count\": 4, \"source_word_count\": 744, \"covered_word_count\": 0}}\r\n\r\nBATCH sd_005\r\n{\"ok\": false, \"approved_for_merge\": false, \"batch_id\": \"sd_005\", \"classification\": \"batch_regenerate\", \"errors\": [{\"code\": \"invalid_scene_span\", \"message\": \"Scene scene_01 span (2903-3088) is outside batch-relative range 1-620\", \"scene_ids\": [\"scene_01\"]}, {\"code\": \"invalid_scene_span\", \"message\": \"Scene scene_02 span (3089-3251) is outside batch-relative range 1-620\", \"scene_ids\": [\"scene_02\"]}, {\"code\": \"invalid_scene_span\", \"message\": \"Scene scene_03 span (3252-3422) is outside batch-relative range 1-620\", \"scene_ids\": [\"scene_03\"]}, {\"code\": \"invalid_scene_span\", \"message\": \"Scene scene_04 span (3423-3522) is outside batch-relative range 1-620\", \"scene_ids\": [\"scene_04\"]}, {\"code\": \"missing_coverage_detected\", \"message\": \"Words 1-620 are not assigned to any scene\"}], \"warnings\": [], \"stats\": {\"scene_count\": 4, \"source_word_count\": 620, \"covered_word_count\": 0}}"}],"details":{"status":"completed","exitCode":0,"durationMs":380,"aggregated":"BATCH sd_001\r\n{\"ok\": false, \"approved_for_merge\": false, \"batch_id\": \"sd_001\", \"classification\": \"batch_regenerate\", \"errors\": [{\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_01 narration_original does not match source span 1-68\", \"scene_ids\": [\"scene_01\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_02 narration_original does not match source span 69-125\", \"scene_ids\": [\"scene_02\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_03 narration_original does not match source span 126-182\", \"scene_ids\": [\"scene_03\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_04 narration_original does not match source span 183-238\", \"scene_ids\": [\"scene_04\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_05 narration_original does not match source span 239-254\", \"scene_ids\": [\"scene_05\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_06 narration_original does not match source span 255-317\", \"scene_ids\": [\"scene_06\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_07 narration_original does not match source span 318-402\", \"scene_ids\": [\"scene_07\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_08 narration_original does not match source span 403-437\", \"scene_ids\": [\"scene_08\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_09 narration_original does not match source span 438-497\", \"scene_ids\": [\"scene_09\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_10 narration_original does not match source span 498-568\", \"scene_ids\": [\"scene_10\"]}], \"warnings\": [], \"stats\": {\"scene_count\": 13, \"source_word_count\": 717, \"covered_word_count\": 717}}\r\n\r\nBATCH sd_002\r\n{\"ok\": false, \"approved_for_merge\": false, \"batch_id\": \"sd_002\", \"classification\": \"batch_regenerate\", \"errors\": [{\"cod