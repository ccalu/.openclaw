{"type":"message","id":"aefc15bc","parentId":"982f6908","timestamp":"2026-04-01T16:39:06.127Z","message":{"role":"toolResult","toolCallId":"call_OMDQM2eFbNYoCjjssQ4y9d3g|fc_0785557c08065f410169cd4a2757308190a0bf173818337a88","toolName":"exec","content":[{"type":"text","text":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\supervisor_skills\\scene_director_io_adapter.py\r\nfrom __future__ import annotations\r\n\r\nimport json\r\nfrom pathlib import Path\r\nfrom typing import Any\r\n\r\n\r\ndef build_scene_director_payload(\r\n    *,\r\n    run_root: str | Path,\r\n    job: dict[str, Any],\r\n    batch: dict[str, Any],\r\n    channel_config: dict[str, Any],\r\n    output_path: str | Path,\r\n) -> dict[str, Any]:\r\n    run_root = Path(run_root)\r\n    output_path = Path(output_path)\r\n\r\n    account = job.get(\"account\")\r\n    language = job.get(\"language\")\r\n    job_id = job.get(\"job_id\")\r\n\r\n    payload = {\r\n        \"job_id\": job_id,\r\n        \"account\": account,\r\n        \"language\": language,\r\n        \"run_root\": str(run_root),\r\n        \"batch\": {\r\n            \"batch_id\": batch.get(\"batch_id\"),\r\n            \"start_word\": batch.get(\"start_word\"),\r\n            \"end_word\": batch.get(\"end_word\"),\r\n            \"word_count\": batch.get(\"word_count\"),\r\n            \"text\": batch.get(\"text\"),\r\n        },\r\n        \"scene_words_range\": channel_config.get(\"scene_words_range\"),\r\n        \"style_context\": {\r\n            \"channel_name\": job.get(\"channel_name\"),\r\n            \"reason\": job.get(\"reason\"),\r\n        },\r\n        \"instructions\": {\r\n            \"task\": \"Transform this script batch into an editorially intentional sequence of scenes for screenplay generation.\",\r\n            \"requirements\": [\r\n                \"Preserve narrative meaning and order.\",\r\n                \"Return scene objects only for this batch.\",\r\n                \"Each scene must include scene_local_id, scene_title, scene_summary, narrative_function, narration_original, start_word, end_word, estimated_scene_word_count.\",\r\n                \"Use batch-relative word coordinates: the first word in this batch is word 1.\",\r\n                \"scene_local_id must be sequential within the batch (scene_01, scene_02, ...).\",\r\n                \"Do not generate global scene IDs.\",\r\n                \"Do not rewrite the story beyond what is needed for clean scene segmentation.\",\r\n                \"Do not do visual planning, asset planning, prompt writing, or shot design in this step.\",\r\n                \"Do not polish for TTS in this step.\",\r\n                \"Do not leave gaps or overlaps between scene text spans.\",\r\n                \"narration_original must match the original source text assigned to each scene.\",\r\n            ],\r\n        },\r\n        \"output_path\": str(output_path),\r\n    }\r\n\r\n    return payload\r\n\r\n\r\ndef write_scene_director_payload(\r\n    *,\r\n    run_root: str | Path,\r\n    job: dict[str, Any],\r\n    batch: dict[str, Any],\r\n    channel_config: dict[str, Any],\r\n    input_path: str | Path,\r\n    output_path: str | Path,\r\n) -> dict[str, Any]:\r\n    input_path = Path(input_path)\r\n    output_path = Path(output_path)\r\n    input_path.parent.mkdir(parents=True, exist_ok=True)\r\n    output_path.parent.mkdir(parents=True, exist_ok=True)\r\n\r\n    payload = build_scene_director_payload(\r\n        run_root=run_root,\r\n        job=job,\r\n        batch=batch,\r\n        channel_config=channel_config,\r\n        output_path=output_path,\r\n    )\r\n\r\n    input_path.write_text(json.dumps(payload, indent=2, ensure_ascii=False), encoding=\"utf-8\")\r\n\r\n    return {\r\n        \"ok\": True,\r\n        \"input_path\": str(input_path),\r\n        \"output_path\": str(output_path),\r\n        \"batch_id\": batch.get(\"batch_id\"),\r\n        \"payload\": payload,\r\n        \"errors\": [],\r\n        \"warnings\": [],\r\n    }"}],"details":{"status":"completed","exitCode":0,"durationMs":424,"aggregated":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\supervisor_skills\\scene_director_io_adapter.py\r\nfrom __future__ import annotations\r\n\r\nimport json\r\nfrom pathlib import Path\r\nfrom typing import Any\r\n\r\n\r\ndef build_scene_director_payload(\r\n    *,\r\n    run_root: str | Path,\r\n    job: dict[str, Any],\r\n    batch: dict[str, Any],\r\n    channel_config: dict[str, Any],\r\n    output_path: str | Path,\r\n) -> dict[str, Any]:\r\n    run_root = Path(run_root)\r\n    output_path = Path(output_path)\r\n\r\n    account = job.get(\"account\")\r\n    language = job.get(\"language\")\r\n    job_id = job.get(\"job_id\")\r\n\r\n    payload = {\r\n        \"job_id\": job_id,\r\n        \"account\": account,\r\n        \"language\": language,\r\n        \"run_root\": str(run_root),\r\n        \"batch\": {\r\n            \"batch_id\": batch.get(\"batch_id\"),\r\n            \"start_word\": batch.get(\"start_word\"),\r\n            \"end_word\": batch.get(\"end_word\"),\r\n            \"word_count\": batch.get(\"word_count\"),\r\n            \"text\": batch.get(\"text\"),\r\n        },\r\n        \"scene_words_range\": channel_config.get(\"scene_words_range\"),\r\n        \"style_context\": {\r\n            \"channel_name\": job.get(\"channel_name\"),\r\n            \"reason\": job.get(\"reason\"),\r\n        },\r\n        \"instructions\": {\r\n            \"task\": \"Transform this script batch into an editorially intentional sequence of scenes for screenplay generation.\",\r\n            \"requirements\": [\r\n                \"Preserve narrative meaning and order.\",\r\n                \"Return scene objects only for this batch.\",\r\n                \"Each scene must include scene_local_id, scene_title, scene_summary, narrative_function, narration_original, start_word, end_word, estimated_scene_word_count.\",\r\n                \"Use batch-relative word coordinates: the first word in this batch is word 1.\",\r\n                \"scene_local_id must be sequential within the batch (scene_01, scene_02, ...).\",\r\n                \"Do not generate global scene IDs.\",\r\n                \"Do not rewrite the story beyond what is needed for clean scene segmentation.\",\r\n                \"Do not do visual planning, asset planning, prompt writing, or shot design in this step.\",\r\n                \"Do not polish for TTS in this step.\",\r\n                \"Do not leave gaps or overlaps between scene text spans.\",\r\n                \"narration_original must match the original source text assigned to each scene.\",\r\n            ],\r\n        },\r\n        \"output_path\": str(output_path),\r\n    }\r\n\r\n    return payload\r\n\r\n\r\ndef write_scene_director_payload(\r\n    *,\r\n    run_root: str | Path,\r\n    job: dict[str, Any],\r\n    batch: dict[str, Any],\r\n    channel_config: dict[str, Any],\r\n    input_path: str | Path,\r\n    output_path: str | Path,\r\n) -> dict[str, Any]:\r\n    input_path = Path(input_path)\r\n    output_path = Path(output_path)\r\n    input_path.parent.mkdir(parents=True, exist_ok=True)\r\n    output_path.parent.mkdir(parents=True, exist_ok=True)\r\n\r\n    payload = build_scene_director_payload(\r\n        run_root=run_root,\r\n        job=job,\r\n        batch=batch,\r\n        channel_config=channel_config,\r\n        output_path=output_path,\r\n    )\r\n\r\n    input_path.write_text(json.dumps(payload, indent=2, ensure_ascii=False), encoding=\"utf-8\")\r\n\r\n    return {\r\n        \"ok\": True,\r\n        \"input_path\": str(input_path),\r\n        \"output_path\": str(output_path),\r\n        \"batch_id\": batch.get(\"batch_id\"),\r\n        \"payload\": payload,\r\n        \"errors\": [],\r\n        \"warnings\": [],\r\n    }","cwd":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory"},"isError":false,"timestamp":1775061546062}}
{"type":"message","id":"fa27e11e","parentId":"aefc15bc","timestamp":"2026-04-01T16:39:40.018Z","message":{"role":"assistant","content":[{"type":"text","text":"Vou refatorar o scene_director para um desenho híbrido: o agent devolve só semântica + narration, e o substrate deriva spans/word counts deterministicamente antes da validação.","textSignature":"{\"v\":1,\"id\":\"msg_0785557c08065f410169cd4a31d0e88190b644c63c4af2e225\",\"phase\":\"commentary\"}"},{"type":"toolCall","id":"call_F60AqhCYgUtXdrTA6liM5oR0|fc_0785557c08065f410169cd4a32cbf88190a035dc56c180cb83","name":"write","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\supervisor_skills\\scene_director_output_normalizer.py","content":"from __future__ import annotations\n\nimport json\nimport re\nfrom pathlib import Path\nfrom typing import Any\n\n\nWORD_RE = re.compile(r\"\\S+\")\n\n\ndef normalize_scene_director_output(\n    *,\n    batch_payload_path: str | Path,\n    batch_output_path: str | Path,\n) -> dict[str, Any]:\n    payload_path = Path(batch_payload_path)\n    output_path = Path(batch_output_path)\n\n    payload = json.loads(payload_path.read_text(encoding=\"utf-8\"))\n    output = json.loads(output_path.read_text(encoding=\"utf-8\"))\n\n    batch = payload[\"batch\"]\n    source_text = batch[\"text\"]\n    source_tokens = _tokenize(source_text)\n    word_count = len(source_tokens)\n\n    scenes = output.get(\"scenes\")\n    if not isinstance(scenes, list):\n        return {\n            \"ok\": False,\n            \"errors\": [\n                {\n                    \"code\": \"invalid_output_shape\",\n                    \"message\": \"scene_director output does not contain a valid scenes list\",\n                }\n            ],\n        }\n\n    cursor = 1\n    normalized_scenes: list[dict[str, Any]] = []\n\n    for index, scene in enumerate(scenes, start=1):\n        if not isinstance(scene, dict):\n            return {\n                \"ok\": False,\n                \"errors\": [\n                    {\n                        \"code\": \"invalid_scene_shape\",\n                        \"message\": f\"Scene at index {index} is not an object\",\n                    }\n                ],\n            }\n\n        narration = scene.get(\"narration_original\")\n        if not isinstance(narration, str) or not narration.strip():\n            return {\n                \"ok\": False,\n                \"errors\": [\n                    {\n                        \"code\": \"missing_narration_original\",\n                        \"message\": f\"Scene at index {index} is missing narration_original\",\n                        \"scene_ids\": [scene.get(\"scene_local_id\")],\n                    }\n                ],\n            }\n\n        narration_tokens = _tokenize(narration)\n        if not narration_tokens:\n            return {\n                \"ok\": False,\n                \"errors\": [\n                    {\n                        \"code\": \"empty_narration_tokens\",\n                        \"message\": f\"Scene at index {index} produced empty narration tokens\",\n                        \"scene_ids\": [scene.get(\"scene_local_id\")],\n                    }\n                ],\n            }\n\n        if cursor > word_count:\n            return {\n                \"ok\": False,\n                \"errors\": [\n                    {\n                        \"code\": \"scene_overflow\",\n                        \"message\": f\"Cursor exceeded batch word count before scene {index}\",\n                        \"scene_ids\": [scene.get(\"scene_local_id\")],\n                    }\n                ],\n            }\n\n        matched_end = _match_scene_tokens(source_tokens, narration_tokens, cursor)\n        if matched_end is None:\n            return {\n                \"ok\": False,\n                \"errors\": [\n                    {\n                        \"code\": \"narration_alignment_failed\",\n                        \"message\": f\"Could not align narration_original for scene {index} starting at local word {cursor}\",\n                        \"scene_ids\": [scene.get(\"scene_local_id\")],\n                    }\n                ],\n            }\n\n        start_word = cursor\n        end_word = matched_end\n        exact_tokens = source_tokens[start_word - 1 : end_word]\n        exact_narration = \" \".join(exact_tokens)\n\n        normalized_scene = dict(scene)\n        normalized_scene[\"scene_local_id\"] = scene.get(\"scene_local_id\") or f\"scene_{index:02d}\"\n        normalized_scene[\"narration_original\"] = exact_narration\n        normalized_scene[\"start_word\"] = start_word\n        normalized_scene[\"end_word\"] = end_word\n        normalized_scene[\"estimated_scene_word_count\"] = end_word - start_word + 1\n        normalized_scenes.append(normalized_scene)\n\n        cursor = end_word + 1\n\n    if cursor != word_count + 1:\n        return {\n            \"ok\": False,\n            \"errors\": [\n                {\n                    \"code\": \"coverage_incomplete\",\n                    \"message\": f\"Normalized scenes covered local words 1-{cursor - 1}, expected 1-{word_count}\",\n                }\n            ],\n        }\n\n    normalized_output = {\n        \"batch_id\": output.get(\"batch_id\") or batch.get(\"batch_id\"),\n        \"operator\": output.get(\"operator\") or \"scene_director\",\n        \"scenes\": normalized_scenes,\n    }\n    output_path.write_text(json.dumps(normalized_output, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    return {\n        \"ok\": True,\n        \"output\": normalized_output,\n        \"errors\": [],\n        \"warnings\": [],\n    }\n\n\ndef _tokenize(text: str) -> list[str]:\n    return WORD_RE.findall(text.replace(\"\\r\\n\", \" \").replace(\"\\n\", \" \"))\n\n\ndef _normalize_token(token: str) -> str:\n    return token.strip()\n\n\ndef _match_scene_tokens(source_tokens: list[str], narration_tokens: list[str], cursor: int) -> int | None:\n    source_slice = source_tokens[cursor - 1 : cursor - 1 + len(narration_tokens)]\n    if len(source_slice) != len(narration_tokens):\n        return None\n\n    normalized_source = [_normalize_token(tok) for tok in source_slice]\n    normalized_narration = [_normalize_token(tok) for tok in narration_tokens]\n\n    if normalized_source != normalized_narration:\n        return None\n\n    return cursor + len(narration_tokens) - 1\n"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\supervisor_skills\\\\scene_director_output_normalizer.py\",\"content\":\"from __future__ import annotations\\n\\nimport json\\nimport re\\nfrom pathlib import Path\\nfrom typing import Any\\n\\n\\nWORD_RE = re.compile(r\\\"\\\\S+\\\")\\n\\n\\ndef normalize_scene_director_output(\\n    *,\\n    batch_payload_path: str | Path,\\n    batch_output_path: str | Path,\\n) -> dict[str, Any]:\\n    payload_path = Path(batch_payload_path)\\n    output_path = Path(batch_output_path)\\n\\n    payload = json.loads(payload_path.read_text(encoding=\\\"utf-8\\\"))\\n    output = json.loads(output_path.read_text(encoding=\\\"utf-8\\\"))\\n\\n    batch = payload[\\\"batch\\\"]\\n    source_text = batch[\\\"text\\\"]\\n    source_tokens = _tokenize(source_text)\\n    word_count = len(source_tokens)\\n\\n    scenes = output.get(\\\"scenes\\\")\\n    if not isinstance(scenes, list):\\n        return {\\n            \\\"ok\\\": False,\\n            \\\"errors\\\": [\\n                {\\n                    \\\"code\\\": \\\"invalid_output_shape\\\",\\n                    \\\"message\\\": \\\"scene_director output does not contain a valid scenes list\\\",\\n                }\\n            ],\\n        }\\n\\n    cursor = 1\\n    normalized_scenes: list[dict[str, Any]] = []\\n\\n    for index, scene in enumerate(scenes, start=1):\\n        if not isinstance(scene, dict):\\n            return {\\n                \\\"ok\\\": False,\\n                \\\"errors\\\": [\\n                    {\\n                        \\\"code\\\": \\\"invalid_scene_shape\\\",\\n                        \\\"message\\\": f\\\"Scene at index {index} is not an object\\\",\\n                    }\\n                ],\\n            }\\n\\n        narration = scene.get(\\\"narration_original\\\")\\n        if not isinstance(narration, str) or not narration.strip():\\n            return {\\n                \\\"ok\\\": False,\\n                \\\"errors\\\": [\\n                    {\\n                        \\\"code\\\": \\\"missing_narration_original\\\",\\n                        \\\"message\\\": f\\\"Scene at index {index} is missing narration_original\\\",\\n                        \\\"scene_ids\\\": [scene.get(\\\"scene_local_id\\\")],\\n                    }\\n                ],\\n            }\\n\\n        narration_tokens = _tokenize(narration)\\n        if not narration_tokens:\\n            return {\\n                \\\"ok\\\": False,\\n                \\\"errors\\\": [\\n                    {\\n                        \\\"code\\\": \\\"empty_narration_tokens\\\",\\n                        \\\"message\\\": f\\\"Scene at index {index} produced empty narration tokens\\\",\\n                        \\\"scene_ids\\\": [scene.get(\\\"scene_local_id\\\")],\\n                    }\\n                ],\\n            }\\n\\n        if cursor > word_count:\\n            return {\\n                \\\"ok\\\": False,\\n                \\\"errors\\\": [\\n                    {\\n                        \\\"code\\\": \\\"scene_overflow\\\",\\n                        \\\"message\\\": f\\\"Cursor exceeded batch word count before scene {index}\\\",\\n                        \\\"scene_ids\\\": [scene.get(\\\"scene_local_id\\\")],\\n                    }\\n                ],\\n            }\\n\\n        matched_end = _match_scene_tokens(source_tokens, narration_tokens, cursor)\\n        if matched_end is None:\\n            return {\\n                \\\"ok\\\": False,\\n                \\\"errors\\\": [\\n                    {\\n                        \\\"code\\\": \\\"narration_alignment_failed\\\",\\n                        \\\"message\\\": f\\\"Could not align narration_original for scene {index} starting at local word {cursor}\\\",\\n                        \\\"scene_ids\\\": [scene.get(\\\"scene_local_id\\\")],\\n                    }\\n                ],\\n            }\\n\\n        start_word = cursor\\n        end_word = matched_end\\n        exact_tokens = source_tokens[start_word - 1 : end_word]\\n        exact_narration = \\\" \\\".join(exact_tokens)\\n\\n        normalized_scene = dict(scene)\\n        normalized_scene[\\\"scene_local_id\\\"] = scene.get(\\\"scene_local_id\\\") or f\\\"scene_{index:02d}\\\"\\n        normalized_scene[\\\"narration_original\\\"] = exact_narration\\n        normalized_scene[\\\"start_word\\\"] = start_word\\n        normalized_scene[\\\"end_word\\\"] = end_word\\n        normalized_scene[\\\"estimated_scene_word_count\\\"] = end_word - start_word + 1\\n        normalized_scenes.append(normalized_scene)\\n\\n        cursor = end_word + 1\\n\\n    if cursor != word_count + 1:\\n        return {\\n            \\\"ok\\\": False,\\n            \\\"errors\\\": [\\n                {\\n                    \\\"code\\\": \\\"coverage_incomplete\\\",\\n                    \\\"message\\\": f\\\"Normalized scenes covered local words 1-{cursor - 1}, expected 1-{word_count}\\\",\\n                }\\n            ],\\n        }\\n\\n    normalized_output = {\\n        \\\"batch_id\\\": output.get(\\\"batch_id\\\") or batch.get(\\\"batch_id\\\"),\\n        \\\"operator\\\": output.get(\\\"operator\\\") or \\\"scene_director\\\",\\n        \\\"scenes\\\": normalized_scenes,\\n    }\\n    output_path.write_text(json.dumps(normalized_output, indent=2, ensure_ascii=False), encoding=\\\"utf-8\\\")\\n\\n    return {\\n        \\\"ok\\\": True,\\n        \\\"output\\\": normalized_output,\\n        \\\"errors\\\": [],\\n        \\\"warnings\\\": [],\\n    }\\n\\n\\ndef _tokenize(text: str) -> list[str]:\\n    return WORD_RE.findall(text.replace(\\\"\\\\r\\\\n\\\", \\\" \\\").replace(\\\"\\\\n\\\", \\\" \\\"))\\n\\n\\ndef _normalize_token(token: str) -> str:\\n    return token.strip()\\n\\n\\ndef _match_scene_tokens(source_tokens: list[str], narration_tokens: list[str], cursor: int) -> int | None:\\n    source_slice = source_tokens[cursor - 1 : cursor - 1 + len(narration_tokens)]\\n    if len(source_slice) != len(narration_tokens):\\n        return None\\n\\n    normalized_source = [_normalize_token(tok) for tok in source_slice]\\n    normalized_narration = [_normalize_token(tok) for tok in narration_tokens]\\n\\n    if normalized_source != normalized_narration:\\n        return None\\n\\n    return cursor + len(narration_tokens) - 1\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":66840,"output":1443,"cacheRead":128512,"cacheWrite":0,"totalTokens":196795,"cost":{"input":0.16710000000000003,"output":0.021645,"cacheRead":0.032128,"cacheWrite":0,"total":0.220873}},"stopReason":"toolUse","timestamp":1775061546745,"responseId":"resp_0785557c08065f410169cd4a2e8fa48190b9431d7578b119d5"}}
