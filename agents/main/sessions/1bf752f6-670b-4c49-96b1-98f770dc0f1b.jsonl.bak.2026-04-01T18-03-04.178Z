agement_system/docs/frontend/\n?? ../key_management_system/docs/frontend_redesign/\n?? ../key_management_system/docs/gemini_service_accounts/\n?? ../key_management_system/docs/implementation/screenplay_agent.md\n?? ../key_management_system/docs/implementation/tts_audio_generation.md\n?? ../key_management_system/docs/plans/\n?? ../key_management_system/docs/providers/\n?? ../key_management_system/docs/upgrade_implementation/\n?? ../key_management_system/plans/\n?? ../key_management_system/server/_import_data.sql\n?? ../nul\n?? ../runpod/\n?? ../test_key_results/\n?? ../test_new_keys.py\n?? ../test_new_keys_2.py\n?? ../test_new_keys_3.py\n?? ../test_new_keys_4.py\n?? ../test_new_keys_gemini.py\n?? ../test_service_accounts.py","cwd":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory"},"isError":false,"timestamp":1775036709584}}
{"type":"message","id":"45406fb4","parentId":"a332c0e9","timestamp":"2026-04-01T09:45:09.962Z","message":{"role":"toolResult","toolCallId":"call_hQNP5gTsEeRq6qzxMAhXLcqC|fc_0785557c08065f410169cce924769881908ec1ce8a8438d234","toolName":"read","content":[{"type":"text","text":"\"\"\"S1 Supervisor Runtime — canonical execution substrate for SM-S1.\n\nThis module is the execution substrate for the canonical S1 architecture.\nIt is intended to support the OpenClaw supervisor (`sm_s1_pre_production`) as the\nruntime brain of the sector.\n\nIt is NOT the legacy linear prototype path from `runtime.s1.s1_start`.\n\nDesign goal:\n- supervisor owns sequencing / acceptance / retry / completion decisions\n- deterministic skills and shared components perform mechanical work\n- OpenClaw operators perform semantic work\n- persisted artifacts remain operational truth\n\nInvocation strategy note:\n- canonical operator invocation should ultimately be performed through a real\n  OpenClaw runtime bridge\n- until a richer in-process bridge exists, this module may use an explicit\n  transitional adapter boundary for CLI/operator invocation\n- the adapter boundary is kept narrow on purpose so the architecture stays clear\n\nCurrent status:\n- scaffold / skeleton only\n- lane decomposition established\n- operator invocation hooks intentionally left explicit and narrow\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport shutil\nimport subprocess\nfrom pathlib import Path\nfrom typing import Any\n\nimport yaml\n\nfrom runtime.s1.checkpoint_writer import write_checkpoint\nfrom runtime.s1.polish_validator import validate_polish\nfrom runtime.s1.scene_bible_builder import build_scene_bible, write_scene_bible\nfrom runtime.s1.scene_bible_schema_validator import validate_scene_bible_schema\nfrom runtime.s1.screenplay_validator import validate_screenplay\nfrom runtime.s1.supervisor_skills.operator_batch_scheduler import (\n    build_batch_schedule,\n    summarize_batch_execution,\n)\nfrom runtime.s1.supervisor_skills.retry_planner import plan_retry\nfrom runtime.s1.supervisor_skills.s1_paths_resolver import resolve_paths\nfrom runtime.s1.supervisor_skills.s1_preflight_checker import run_preflight\nfrom runtime.s1.supervisor_skills.s1_result_summarizer import summarize_s1_result\nfrom runtime.s1.supervisor_skills.scene_director_io_adapter import write_scene_director_payload\nfrom runtime.s1.supervisor_skills.scene_director_output_validator import validate_scene_director_output\nfrom runtime.s1.supervisor_skills.screenplay_merger import merge_screenplay_batches\nfrom runtime.s1.supervisor_skills.script_batch_planner import plan_script_batches_from_file\nfrom runtime.s1.supervisor_skills.tts_polish_batch_planner import plan_tts_polish_batches\nfrom runtime.s1.supervisor_skills.tts_polish_io_adapter import write_tts_polish_payload\nfrom runtime.s1.supervisor_skills.tts_polish_merger import merge_tts_polish_batches\n\n\nACCOUNTS_DIR = Path(__file__).parent.parent.parent / \"accounts\"\nDEFAULT_SCENE_DIRECTOR_CONCURRENCY = 2\nDEFAULT_TTS_POLISH_CONCURRENCY = 4\nDEFAULT_MAX_RETRIES = 3\n\n\ndef run_s1_supervisor_runtime(\n    *,\n    run_root: str | Path,\n    job: dict[str, Any] | None = None,\n    channel_config: dict[str, Any] | None = None,\n    model: str = \"gpt-4.1-mini\",\n    max_retries: int = DEFAULT_MAX_RETRIES,\n) -> dict[str, Any]:\n    \"\"\"Canonical execution substrate for S1 under supervisor authority.\n\n    This function intentionally decomposes the sector into lanes that map to the\n    canonical OpenClaw architecture.\n\n    Important:\n    - this module is the execution substrate, not the supervisor brain itself\n    - decision sovereignty still belongs to the supervisor layer\n    - operator invocation is left behind explicit hooks to avoid hiding architecture\n    \"\"\"\n    run_root = Path(run_root)\n    checkpoints_written: list[str] = []\n    all_warnings: list[dict[str, Any]] = []\n    all_errors: list[dict[str, Any]] = []\n\n    preflight = run_preflight(run_root)\n    if not preflight.get(\"ok\"):\n        return _failed_result(run_root, preflight.get(\"errors\", []), preflight.get(\"warnings\", []))\n    all_warnings.extend(preflight.get(\"warnings\", []))\n\n    if job is None:\n        job = preflight.get(\"job\", {})\n\n    account = job.get(\"account\")\n    language = job.get(\"language\")\n    if channel_config is None:\n        channel_config = _load_config(account, language)\n\n    paths_result = resolve_paths(run_root, create_dirs=True)\n    paths = paths_result.get(\"paths\", {})\n    all_warnings.extend(paths_result.get(\"warnings\", []))\n\n    script_path = Path(preflight[\"paths\"][\"script_raw\"])\n    script_raw = script_path.read_text(encoding=\"utf-8\")\n\n    screenplay_lane = _run_scene_director_lane(\n        run_root=run_root,\n        job=job,\n        channel_config=channel_config,\n        paths=paths,\n        script_path=script_path,\n        script_raw=script_raw,\n        model=model,\n        max_retries=max_retries,\n    )\n    all_warnings.extend(screenplay_lane.get(\"warnings\", []))\n    if not screenplay_lane.get(\"ok\"):\n        all_errors.extend(screenplay_lane.get(\"errors\", []))\n        return _failed_result(run_root, all_errors, all_warnings)\n\n    checkpoints_written.extend(screenplay_lane.get(\"checkpoints_written\", []))\n    screenplay = screenplay_lane[\"screenplay\"]\n    screenplay_result = screenplay_lane[\"screenplay_result\"]\n\n    polish_lane = _run_tts_polish_lane(\n        run_root=run_root,\n        job=job,\n        channel_config=channel_config,\n        paths=paths,\n        screenplay=screenplay,\n        model=model,\n        max_retries=max_retries,\n    )\n    all_warnings.extend(polish_lane.get(\"warnings\", []))\n    if not polish_lane.get(\"ok\"):\n        all_errors.extend(polish_lane.get(\"errors\", []))\n        return _failed_result(run_root, all_errors, all_warnings)\n\n    checkpoints_written.extend(polish_lane.get(\"checkpoints_written\", []))\n    polished = polish_lane[\"tts_polished\"]\n    polish_result = polish_lane[\"polish_result\"]\n\n    scene_bible_result = _run_scene_bible_lane(\n        run_root=run_root,\n        job=job,\n        screenplay=screenplay,\n        polished=polished,\n        paths=paths,\n    )\n    all_warnings.extend(scene_bible_result.get(\"warnings\", []))\n    if not scene_bible_result.get(\"ok\"):\n        all_errors.extend(scene_bible_result.get(\"errors\", []))\n        return _failed_result(run_root, all_errors, all_warnings)\n\n    checkpoints_written.extend(scene_bible_result.get(\"checkpoints_written\", []))\n\n    write_checkpoint(\n        run_root,\n        \"b1_complete\",\n        \"sm_s1_pre_production\",\n        [\n            \"b1_pre_production/screenplay.json\",\n            \"b1_pre_production/screenplay_validation.json\",\n            \"b1_pre_production/tts_polished.json\",\n            \"b1_pre_production/polish_validation.json\",\n            \"scene_bible.json\",\n        ],\n        extra={\n            \"scene_count\": scene_bible_result.get(\"scene_count\", 0),\n            \"screenplay_validated\": True,\n            \"polish_validated\": True,\n            \"scene_bible_schema_valid\": True,\n        },\n    )\n    checkpoints_written.append(\"b1_complete.json\")\n\n    return summarize_s1_result(\n        run_root=run_root,\n        screenplay_result=screenplay_result,\n        polish_result=polish_result,\n        scene_bible_path=scene_bible_result.get(\"scene_bible_path\"),\n        checkpoints_written=checkpoints_written,\n        warnings=all_warnings,\n        errors=all_errors,\n    )\n\n\ndef _run_scene_director_lane(\n    *,\n    run_root: Path,\n    job: dict[str, Any],\n    channel_config: dict[str, Any],\n    paths: dict[str, Any],\n    script_path: Path,\n    script_raw: str,\n    model: str,\n    max_retries: int,\n) -> dict[str, Any]:\n    warnings: list[dict[str, Any]] = []\n    errors: list[dict[str, Any]] = []\n    checkpoints_written: list[str] = []\n\n    batch_plan = plan_script_batches_from_file(script_path)\n    warnings.extend(batch_plan.get(\"warnings\", []))\n    if not batch_plan.get(\"ok\"):\n        return _lane_fail(batch_plan.get(\"errors\", []), warnings)\n\n    prepared_batches = []\n    for batch in batch_plan.get(\"batches\", []):\n        batch_id = batch[\"batch_id\"]\n        input_path = Path(paths[\"scene_director_inputs_root\"]) / f\"{batch_id}_input.json\"\n        output_path = Path(paths[\"scene_director_intermediate_root\"]) / f\"{batch_id}_output.json\"\n        payload_result = write_scene_director_payload(\n            run_root=run_root,\n            job=job,\n            batch=batch,\n            channel_config=channel_config,\n            input_path=input_path,\n            output_path=output_path,\n        )\n        prepared_batches.append(\n            {\n                \"batch_id\": batch_id,\n                \"input_path\": payload_result[\"input_path\"],\n                \"output_path\": payload_result[\"output_path\"],\n                \"status\": \"queued\",\n            }\n        )\n\n    schedule = build_batch_schedule(\n        operator_name=\"scene_director\",\n        batches=prepared_batches,\n        concurrency_cap=DEFAULT_SCENE_DIRECTOR_CONCURRENCY,\n    )\n    if not schedule.get(\"ok\"):\n        return _lane_fail(schedule.get(\"errors\", []), warnings)\n\n    execution_results = []\n    for wave in schedule.get(\"waves\", []):\n        for batch in wave.get(\"batches\", []):\n            execution_results.append(\n                _invoke_scene_director_batch(\n                    input_path=batch[\"input_path\"],\n                    output_path=batch[\"output_path\"],\n                    model=model,\n                )\n            )\n\n    execution_summary = summarize_batch_execution(\n        operator_name=\"scene_director\",\n        concurrency_cap=DEFAULT_SCENE_DIRECTOR_CONCURRENCY,\n        execution_results=execution_results,\n    )\n    warnings.extend(execution_summary.get(\"warnings\", []))\n\n    approved_batch_files: list[str] = []\n    failed_batch_ids: list[str] = []\n    for batch in prepared_batches:\n        validation = validate_scene_director_output(\n            batch_payload_path=batch[\"input_path\"],\n            batch_output_path=batch[\"output_path\"],\n        )\n        if validation.get(\"approved_for_merge\"):\n            approved_batch_files.append(batch[\"output_path\"])\n        else:\n            failed_batch_ids.append(batch[\"batch_id\"])\n            errors.extend(validation.get(\"errors\", []))\n\n    if failed_batch_ids:\n        retry_decision = plan_retry(\n            step_name=\"scene_director\",\n            failure_type=\"screenplay_validation_failed\",\n            retry_count=0,\n            affected_batches=failed_batch_ids,\n            max_retries=max_retries,\n        )\n        errors.append(\n            {\n                \"code\": \"scene_director_lane_incomplete\",\n                \"message\": f\"Scene director lane still requires retry orchestration: {retry_decision}\",\n            }\n        )\n        return _lane_fail(errors, warnings)\n\n    screenplay_result = merge_screenplay_batches(\n        approved_batch_files,\n        output_path=paths[\"screenplay_path\"],\n    )\n    warnings.extend(screenplay_result.get(\"warnings\", []))\n    if not screenplay_result.get(\"ok\"):\n        return _lane_fail(screenplay_result.get(\"errors\", []), warnings)\n\n    screenplay = screenplay_result[\"screenplay\"]\n    validation = validate_screenplay(script_raw, screenplay.get(\"scenes\", []))\n    validation_path = Path(paths[\"screenplay_validation_path\"])\n    validation_path.write_text(json.dumps(validation, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    if not validation.get(\"valid\"):\n        retry_decision = plan_retry(\n            step_name=\"scene_director\",\n            failure_type=\"screenplay_validation_failed\",\n            retry_count=0,\n            affected_batches=[],\n            max_retries=max_retries,\n        )\n        errors.append(\n            {\n                \"code\": \"screenplay_validation_failed\",\n                \"message\": f\"Canonical screenplay failed validation and still needs supervisor retry control: {retry_decision}\",\n            }\n        )\n        return _lane_fail(errors, warnings)\n\n    write_checkpoint(\n        run_root,\n        \"b1_step1_screenplay\",\n        \"scene_director\",\n        [\"b1_pre_production/screenplay.json\"],\n        extra={\"scene_count\": screenplay_result.get(\"scene_count\", 0), \"model\": model},\n    )\n    checkpoints_written.append(\"b1_step1_screenplay.json\")\n\n    write_checkpoint(\n        run_root,\n        \"b1_step2_screenplay_validated\",\n        \"screenplay_validator\",\n        [\"b1_pre_production/screenplay_validation.json\"],\n        retries=0,\n        validation_passed=True,\n    )\n    checkpoints_written.append(\"b1_step2_screenplay_validated.json\")\n\n    return {\n        \"ok\": True,\n        \"screenplay\": screenplay,\n        \"screenplay_result\": screenplay_result,\n        \"checkpoints_written\": checkpoints_written,\n        \"warnings\": warnings,\n        \"errors\": [],\n    }\n\n\ndef _run_tts_polish_lane(\n    *,\n    run_root: Path,\n    job: dict[str, Any],\n    channel_config: dict[str, Any],\n    paths: dict[str, Any],\n    screenplay: dict[str, Any],\n    model: str,\n    max_retries: int,\n) -> dict[str, Any]:\n    warnings: list[dict[str, Any]] = []\n    errors: list[dict[str, Any]] = []\n    checkpoints_written: list[str] = []\n\n    batch_plan = plan_tts_polish_batches(screenplay)\n    warnings.extend(batch_plan.get(\"warnings\", []))\n    if not batch_plan.get(\"ok\"):\n        return _lane_fail(batch_plan.get(\"errors\", []), warnings)\n\n    prepared_batches = []\n    for batch in batch_plan.get(\"batches\", []):\n        batch_id = batch[\"batch_id\"]\n        input_path = Path(paths[\"tts_polish_inputs_root\"]) / f\"{batch_id}_input.json\"\n        output_path = Path(paths[\"tts_polish_intermediate_root\"]) / f\"{batch_id}_output.json\"\n        payload_result = write_tts_polish_payload(\n            run_root=run_root,\n            job=job,\n            screenplay=screenplay,\n            batch=batch,\n            channel_config=channel_config,\n            input_path=input_path,\n            output_path=output_path,\n        )\n        prepared_batches.append(\n            {\n                \"batch_id\": batch_id,\n                \"input_path\": payload_result[\"input_path\"],\n                \"output_path\": payload_result[\"output_path\"],\n                \"status\": \"queued\",\n            }\n        )\n\n    schedule = build_batch_schedule(\n        operator_name=\"tts_polish\",\n        batches=prepared_batches,\n        concurrency_cap=DEFAULT_TTS_POLISH_CONCURRENCY,\n    )\n    if not schedule.get(\"ok\"):\n        return _lane_fail(schedule.get(\"errors\", []), warnings)\n\n    execution_results = []\n    for wave in schedule.get(\"waves\", []):\n        for batch in wave.get(\"batches\", []):\n            execution_results.append(\n                _invoke_tts_polish_batch(\n                    input_path=batch[\"input_path\"],\n                    output_path=batch[\"output_path\"],\n                    model=model,\n                )\n            )\n\n    execution_summary = summarize_batch_execution(\n        operator_name=\"tts_polish\",\n        concurrency_cap=DEFAULT_TTS_POLISH_CONCURRENCY,\n        execution_results=execution_results,\n    )\n    warnings.extend(execution_summary.get(\"warnings\", []))\n\n    # NOTE: canonical runtime still needs a real `tts_polish_output_validator`\n    # integration here. For now, treat batch execution completion as insufficient\n    # for approval and fail explicitly so the architecture does not silently drift.\n    errors.append(\n        {\n            \"code\": \"tts_polish_output_validator_not_implemented\",\n            \"message\": \"Canonical TTS polish lane still requires explicit per-batch output validation before merge.\",\n        }\n    )\n    retry_decision = plan_retry(\n        step_name=\"tts_polish\",\n        failure_type=\"polish_validation_failed\",\n        retry_count=0,\n        affected_batches=execution_summary.get(\"failed_batches\", []),\n        max_retries=max_retries,\n    )\n    errors.append(\n        {\n            \"code\": \"tts_polish_lane_incomplete\",\n            \"message\": f\"TTS polish lane still requires validator/reviewer runtime wiring: {retry_decision}\",\n        }\n    )\n\n    return _lane_fail(errors, warnings)\n\n\ndef _run_scene_bible_lane(\n    *,\n    run_root: Path,\n    job: dict[str, Any],\n    screenplay: dict[str, Any],\n    polished: list[dict[str, Any]],\n    paths: dict[str, Any],\n) -> dict[str, Any]:\n    warnings: list[dict[str, Any]] = []\n    errors: list[dict[str, Any]] = []\n    checkpoints_written: list[str] = []\n\n    bible = build_scene_bible(polished, job, screenplay.get(\"scenes\", []))\n    schema_validation = validate_scene_bible_schema(bible)\n    warnings.extend(schema_validation.get(\"warnings\", []))\n    if not schema_validation.get(\"valid\"):\n        return _lane_fail(schema_validation.get(\"errors\", []), warnings)\n\n    scene_bible_path = write_scene_bible(bible, run_root)\n    write_checkpoint(\n        run_root,\n        \"b1_step5_scene_bible\",\n        \"scene_bible_builder\",\n        [\"scene_bible.json\"],\n        extra={\"scene_count\": len(bible.get(\"scenes\", []))},\n    )\n    checkpoints_written.append(\"b1_step5_scene_bible.json\")\n\n    return {\n        \"ok\": True,\n        \"scene_bible_path\": scene_bible_path,\n        \"scene_count\": len(bible.get(\"scenes\", [])),\n        \"checkpoints_written\": checkpoints_written,\n        \"warnings\": warnings,\n        \"errors\": errors,\n    }\n\n\ndef _invoke_scene_director_batch(*, input_path: str, output_path: str, model: str) -> dict[str, Any]:\n    \"\"\"Transitional adapter hook for OpenClaw scene_director invocation.\n\n    Current behavior:\n    - attempts a narrow CLI-based compatibility invocation if `openclaw` is available\n    - fails explicitly otherwise\n    - never fabricates a successful operator result\n\n    Important:\n    - this is still a transitional adapter boundary\n    - the long-term goal is a cleaner runtime bridge to OpenClaw operators\n    \"\"\"\n    batch_id = Path(input_path).stem.replace(\"_input\", \"\")\n    openclaw_bin = shutil.which(\"openclaw\")\n    if not openclaw_bin:\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [\n                {\n                    \"code\": \"openclaw_cli_not_found\",\n                    \"message\": \"Cannot invoke scene_director: `openclaw` CLI not found in PATH.\",\n                }\n            ],\n            \"warnings\": [],\n        }\n\n    command = [\n        openclaw_bin,\n        \"agent\",\n        \"--agent\",\n        \"op_s1_scene_director\",\n        \"--message\",\n        _build_scene_director_agent_message(input_path, output_path),\n        \"--json\",\n    ]\n    env = None\n\n    try:\n        result = subprocess.run(\n            command,\n            text=True,\n            capture_output=True,\n            check=False,\n            timeout=300,\n            env=env,\n        )\n    except subprocess.TimeoutExpired:\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [\n                {\n                    \"code\": \"operator_timeout\",\n                    \"message\": f\"scene_director invocation timed out for batch {batch_id}.\",\n                }\n            ],\n            \"warnings\": [],\n        }\n    except Exception as exc:  # noqa: BLE001\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [\n                {\n                    \"code\": \"operator_invocation_failed\",\n                    \"message\": f\"scene_director invocation raised exception: {exc}\",\n                }\n            ],\n            \"warnings\": [],\n        }\n\n    if result.returncode != 0:\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [\n                {\n                    \"code\": \"operator_nonzero_exit\",\n                    \"message\": (\n                        f\"scene_director CLI exited with code {result.returncode}: \"\n                        f\"{(result.stderr or result.stdout or '').strip()}\"\n                    ),\n                }\n            ],\n            \"warnings\": [],\n        }\n\n    if not Path(output_path).exists():\n        stdout_text = (result.stdout or \"\").strip()\n        if stdout_text:\n            try:\n                parsed = json.loads(stdout_text)\n                Path(output_path).write_text(json.dumps(parsed, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n            except Exception:  # noqa: BLE001\n                pass\n\n    if not Path(output_path).exists():\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [\n                {\n                    \"code\": \"operator_no_output\",\n                    \"message\": \"scene_director invocation completed but no output artifact was produced.\",\n                }\n            ],\n            \"warnings\": [],\n        }\n\n    return {\n        \"batch_id\": batch_id,\n        \"status\": \"completed\",\n        \"output_path\": output_path,\n        \"errors\": [],\n        \"warnings\": [],\n    }\n\n\ndef _invoke_tts_polish_batch(*, input_path: str, output_path: str, model: str) -> dict[str, Any]:\n    \"\"\"Hook for canonical OpenClaw TTS polish invocation.\n\n    Current status:\n    - scaffold only\n    - does not yet invoke the real OpenClaw operator runtime\n    \"\"\"\n    return {\n        \"batch_id\": Path(input_path).stem.replace(\"_input\", \"\"),\n        \"status\": \"failed\",\n        \"output_path\": output_path,\n        \"errors\": [\n            {\n                \"code\": \"operator_invocation_not_implemented\",\n                \"message\": \"Canonical tts_polish invocation hook still needs OpenClaw runtime wiring.\",\n            }\n        ],\n        \"warnings\": [],\n    }\n\n\ndef _build_scene_director_agent_message(input_path: str, output_path: str) -> str:\n    return (\n        \"You are executing one canonical S1 scene_director batch. \"\n        f\"Read the batch payload JSON at: {input_path}. \"\n        \"Follow the op_s1_scene_director workspace contract exactly. \"\n        \"Write only the final batch result JSON to the output_path declared in the payload. \"\n        f\"Expected output artifact path: {output_path}. \"\n        \"Do not do visual planning, TTS polish, merge logic, or supervisor logic. \"\n        \"If the payload is invalid or impossible, fail clearly instead of improvising.\"\n    )\n\n\ndef _load_config(account: str, language: str) -> dict[str, Any]:\n    config_path = ACCOUNTS_DIR / str(account) / f\"{language}.yaml\"\n    if not config_path.exists():\n        raise FileNotFoundError(f\"Channel config not found: {config_path}\")\n    with open(config_path, \"r\", encoding=\"utf-8\") as f:\n        return yaml.safe_load(f) or {}\n\n\ndef _lane_fail(errors: list[dict[str, Any]], warnings: list[dict[str, Any]]) -> dict[str, Any]:\n    return {\n        \"ok\": False,\n        \"errors\": errors,\n        \"warnings\": warnings,\n    }\n\n\ndef _failed_result(\n    run_root: Path,\n    errors: list[dict[str, Any]],\n    warnings: list[dict[str, Any]],\n) -> dict[str, Any]:\n    return summarize_s1_result(\n        run_root=run_root,\n        screenplay_result={},\n        polish_result={},\n        scene_bible_path=None,\n        checkpoints_written=[],\n        warnings=warnings,\n        errors=errors,\n    )\n"}],"isError":false,"timestamp":1775036709776}}
{"type":"message","id":"695b2b44","parentId":"45406fb4","timestamp":"2026-04-01T09:45:10.154Z","message":{"role":"toolResult","toolCallId":"call_cvlClDUew13N3LYSXzjt5yW1|fc_0785557c08065f410169cce92476a08190b8999912c833c0b4","toolName":"read","content":[{"type":"text","text":"# S1 Supervisor Contract\n\n_Status: v2 draft. Defines the canonical role, authority, workflow, and component boundaries of the S1 (Pre-Production) Supervisor._\n\n_Last updated: 2026-03-31_\n\n---\n\n## Purpose\n\nThe S1 Supervisor is the canonical runtime brain for Pre-Production.\n\nIts job is to take a run that is `ready_for_s1` and coordinate the sector until it produces:\n- `screenplay.json`\n- `screenplay_validation.json`\n- `tts_polished.json`\n- `polish_validation.json`\n- `scene_bible.json`\n- `b1_*` checkpoints\n\nThe supervisor is an **OpenClaw LLM supervisor**.\nIt is not:\n- a purely conversational helper\n- a passive documentation artifact\n- a monolithic Python script that absorbs the whole sector itself\n\nThe canonical operating model for S1 is:\n- **`sm_s1_pre_production` = canonical runtime supervisor**\n- **OpenClaw operators = semantic specialists**\n- **deterministic Python components = execution substrate**\n- **persisted run artifacts = operational truth**\n\n---\n\n## Canonical runtime rule\n\nThe canonical runtime authority for S1 belongs to:\n- `sm_s1_pre_production`\n\nThis means the supervisor is the authoritative owner of:\n- sector sequencing\n- operator invocation decisions\n- validation interpretation\n- retry / fail / continue / escalate decisions\n- sector completion decisions\n\n### Important non-canonical component\n`runtime/s1/s1_start.py` must be treated as:\n- bootstrap layer\n- compatibility shim\n- transition helper\n- temporary orchestration bridge where still needed\n\nIt must **not** be treated as the long-term canonical brain of the sector.\n\nThe direction of travel is:\n- more authority in the OpenClaw supervisor\n- less sector intelligence embedded in `s1_start.py`\n\n---\n\n## Core principle\n\n### Supervisor = brain\n### Skills = hands\n### Operators = specialists\n### Persisted artifacts = truth\n\nThe S1 Supervisor should:\n- decide the order of operations\n- decide when to call an operator vs a deterministic component\n- interpret validation results\n- decide retry / fail / continue / escalate\n- decide when outputs are accepted into canonical artifacts\n- write or trigger checkpoints\n- determine final sector completion\n\nThe S1 Supervisor should **not** directly absorb:\n- semantic scene generation\n- TTS polish generation\n- low-level file/path mechanics\n- deterministic validation logic\n- JSON merge/reindex mechanics\n- scene bible construction internals\n\nThose belong to:\n- S1 operators\n- supervisor deterministic skills\n- shared deterministic sector components\n\n---\n\n## Component classes inside S1\n\nThe S1 sector is composed of four distinct component classes.\n\n### 1. Canonical supervisor\n- `sm_s1_pre_production`\n\n### 2. OpenClaw semantic operators\n- `scene_director`\n- `tts_polish`\n- `tts_polish_semantic_reviewer`\n\n### 3. Supervisor deterministic skills\nThese are deterministic components directly used by the supervisor to plan, bridge, validate, merge, schedule, and summarize the sector flow.\n\nImplemented now:\n- `s1_preflight_checker`\n- `s1_paths_resolver`\n- `script_batch_planner`\n- `scene_director_io_adapter`\n- `scene_director_output_validator`\n- `screenplay_merger`\n- `tts_polish_batch_planner`\n- `tts_polish_io_adapter`\n- `tts_polish_merger`\n- `retry_planner`\n- `operator_batch_scheduler`\n- `s1_result_summarizer`\n\n### 4. Shared deterministic sector components\nThese are deterministic runtime components used by the sector, but they are not supervisor-local planning/bridging skills.\n\nShared components currently used by S1:\n- `screenplay_validator`\n- `polish_validator`\n- `scene_bible_builder`\n- `scene_bible_schema_validator`\n- `checkpoint_writer`\n\nThis distinction is important:\n- supervisor skills shape supervision flow\n- shared deterministic components perform reusable sector mechanics\n\n---\n\n## File contract principle\n\nThe supervisor must operate on persisted run artifacts.\n\n### Minimum expected inputs before S1 begins\n- `job.json`\n- `run_metadata.json`\n- `inputs/script/script_raw.txt`\n- `inputs/script/script_metadata.json`\n- `inputs/script/script_lock.json`\n- `checkpoints/vo_script_ready.json`\n\n### Minimum expected outputs after S1 completes\n- `b1_pre_production/screenplay.json`\n- `b1_pre_production/screenplay_validation.json`\n- `b1_pre_production/tts_polished.json`\n- `b1_pre_production/polish_validation.json`\n- `scene_bible.json`\n- `checkpoints/b1_step1_screenplay.json`\n- `checkpoints/b1_step2_screenplay_validated.json`\n- `checkpoints/b1_step3_tts_polished.json`\n- `checkpoints/b1_step4_polish_validated.json`\n- `checkpoints/b1_step5_scene_bible.json`\n- `checkpoints/b1_complete.json`\n\nThe supervisor should reason over persisted artifacts rather than hidden in-memory assumptions.\n\n---\n\n## Naming convention\n\nThe canonical checkpoint and sector naming for Pre-Production is:\n- `b1_pre_production/`\n- `b1_*` checkpoints\n\nOlder `s1_*` naming is not canonical and should not be expanded further.\n\n---\n\n## Canonical authority map\n\n### Supervisor owns\n- sector order of operations\n- operator invocation decisions\n- acceptance/rejection of batch outputs\n- retry decisions\n- escalation decisions\n- final sector status\n\n### Operators own\n- semantic scene structuring (`scene_director`)\n- semantic TTS-oriented oral normalization (`tts_polish`)\n- semantic borderline review for polish when needed (`tts_polish_semantic_reviewer`)\n\n### Supervisor skills own\n- preflight\n- path resolution\n- batching\n- operator payload bridge construction\n- per-batch structural validation where defined\n- merge preparation/composition\n- controlled scheduling plans\n- retry recommendation logic\n- final result summarization\n\n### Shared deterministic components own\n- whole-screenplay validation\n- whole-polish validation\n- scene bible build\n- scene bible schema validation\n- checkpoint writing\n\n---\n\n## Canonical sector workflow\n\nThe canonical S1 flow is:\n\n1. Run `s1_preflight_checker`\n2. Run `s1_paths_resolver`\n3. Plan script batches via `script_batch_planner`\n4. Build `scene_director` payloads via `scene_director_io_adapter`\n5. Schedule `scene_director` batches via `operator_batch_scheduler`\n6. Invoke `scene_director` batches under supervisor control\n7. Validate each batch via `scene_director_output_validator`\n8. If needed, classify retry via `retry_planner`\n9. Merge approved batch outputs via `screenplay_merger`\n10. Validate canonical screenplay via `screenplay_validator`\n11. If screenplay validation fails, use `retry_planner`\n12. Plan polish batches via `tts_polish_batch_planner`\n13. Build `tts_polish` payloads via `tts_polish_io_adapter`\n14. Schedule `tts_polish` batches via `operator_batch_scheduler`\n15. Invoke `tts_polish` batches under supervisor control\n16. If needed, route borderline cases to `tts_polish_semantic_reviewer`\n17. Merge approved polish outputs via `tts_polish_merger`\n18. Validate canonical polish via `polish_validator`\n19. If polish validation fails, use `retry_planner`\n20. Build `scene_bible.json` via `scene_bible_builder`\n21. Validate scene bible schema via `scene_bible_schema_validator`\n22. Write/check checkpoints via `checkpoint_writer`\n23. Summarize the final result via `s1_result_summarizer`\n24. Complete or fail the sector\n\n---\n\n## Controlled parallelism policy\n\nThe S1 Supervisor should support controlled parallelism for batchable operators.\n\n### Initial concurrency caps\n- `scene_director_concurrency_cap = 2`\n- `tts_polish_concurrency_cap = 4`\n\n### Parallelism rules\n- only batchable operators should be parallelized\n- validators, mergers, builders, schema validation, checkpointing, and preflight remain sequential/deterministic\n- the supervisor should not launch all batches at once without a cap\n- batches should be processed in controlled waves/windows\n- failed batches should be retried selectively when possible\n\n### Important current limitation\n`operator_batch_scheduler` currently provides:\n- wave planning\n- concurrency capping\n- execution summary structure\n\nIt does **not** by itself invoke OpenClaw operators.\nThe supervisor still owns the actual invocation/control loop.\n\n---\n\n## Current operator model\n\nThe intended operator structure for S1 is:\n- `scene_director` -> OpenClaw operator\n- `tts_polish` -> OpenClaw operator\n- `tts_polish_semantic_reviewer` -> OpenClaw operator used only where semantic review is needed\n\nThese operators communicate with the supervisor via explicit file contracts:\n- supervisor prepares input payload/file\n- operator reads input\n- operator writes output file\n- supervisor validates and decides next step\n\nThe supervisor must not delegate its authority away.\nOperators are specialists, not sector owners.\n\n---\n\n## Supervisor deterministic skills\n\n## `s1_preflight_checker`\n\n### Purpose\nValidate that a run is structurally ready to enter S1 before any operator or semantic step is invoked.\n\n### Scope\nChecks:\n- run root exists\n- required input files exist\n- `job.json` is readable and contains `job_id`, `account`, `language`\n- channel config exists at `accounts/{account}/{language}.yaml`\n- `script_raw.txt` is readable and not empty\n- `vo_script_ready` checkpoint exists\n- run state is minimally compatible with entering S1\n\n### Out of scope\n- create sector outputs\n- call operators\n- validate screenplay semantics\n- decide batching\n- modify the run\n\n---\n\n## `s1_paths_resolver`\n\n### Purpose\nResolve and centralize the canonical S1 paths for the run.\n\n### Scope\nResolves and optionally creates the directory structure for:\n- `b1_pre_production/`\n- `b1_pre_production/inputs/`\n- `b1_pre_production/intermediate/`\n- `inputs/scene_director/`\n- `inputs/tts_polish/`\n- `intermediate/scene_director/`\n- `intermediate/tts_polish/`\n- canonical output file paths\n- canonical `b1_*` checkpoint file paths\n\n### Out of scope\n- validate semantic readiness\n- call operators\n- inspect screenplay or polish content\n- perform batching\n\n---\n\n## `script_batch_planner`\n\n### Purpose\nSplit the raw script into manageable work batches for `scene_director` without turning the supervisor into a monolithic batching script.\n\n### Scope\n- receives raw script text or script file path\n- plans batches using target/min/max word budgets\n- prefers paragraph boundaries\n- falls back to sentence-based splitting for oversized paragraphs\n- preserves order and emits a stable `sd_###` batch sequence\n\n### Out of scope\n- divide the script into final scenes\n- call `scene_director`\n- perform semantic validation\n- merge operator outputs\n\n### Recommended v1 defaults\n- target words per batch: `750`\n- minimum words per batch: `450`\n- maximum words per batch: `950`\n\n---\n\n## `scene_director_io_adapter`\n\n### Purpose\nPrepare the explicit input/output contract between the S1 Supervisor and the `scene_director` operator for each planned script batch.\n\n### Scope\n- receives run/job context\n- receives one script batch from `script_batch_planner`\n- injects `scene_words_range` from channel config\n- writes a deterministic payload file for the operator\n- declares the expected output path for the batch result\n\n### Out of scope\n- run the operator\n- validate semantic quality\n- merge batch outputs\n- choose retry policy\n\n### Contract note\nThis component is an interface-critical bridge and should have its own dedicated contract.\n\n---\n\n## `scene_director_output_validator`\n\n### Purpose\nValidate each `scene_director` batch output independently before any merge into canonical `screenplay.json` happens.\n\n### Scope\n- validate output shape for one batch result\n- validate required scene fields\n- validate `scene_local_id` ordering/sequencing\n- validate scene span ordering and non-overlap\n- validate coverage of the intended batch source span\n- validate that `narration_original` matches the source text assigned to each scene\n- classify failures for supervisor retry handling\n\n### Out of scope\n- merge batches\n- decide final retry policy by itself\n- rewrite operator outputs directly\n- judge creative quality beyond deterministic structural/fidelity checks\n\n### Contract note\nThis component is an acceptance gate and should have its own dedicated contract.\n\n---\n\n## `screenplay_merger`\n\n### Purpose\nMerge the batch outputs of `scene_director` into one canonical `screenplay.json`.\n\n### Scope\n- loads ordered batch output files\n- validates minimum required scene fields\n- concatenates scenes in batch order\n- reassigns canonical `scene_###` IDs globally\n- writes `screenplay.json`\n\n### Out of scope\n- perform semantic validation\n- decide retry policy\n- invoke operators\n- polish TTS text\n\n### Contract note\nThis component writes a canonical sector artifact and should have its own dedicated contract.\n\n---\n\n## `tts_polish_batch_planner`\n\n### Purpose\nPlan small, stable polish batches from the merged screenplay so that `tts_polish` receives manageable groups of scenes instead of the full screenplay at once.\n\n### Scope\n- receives `screenplay.json`\n- groups scenes by count and approximate word budget\n- preserves scene order\n- emits a stable `tp_###` batch sequence\n\n### Recommended v1 defaults\n- target scenes per batch: `5`\n- minimum scenes per batch: `3`\n- maximum scenes per batch: `6`\n- maximum words per batch: `350`\n\n### Out of scope\n- perform TTS polish\n- validate semantic quality\n- merge polish outputs\n- decide retry policy\n\n---\n\n## `tts_polish_io_adapter`\n\n### Purpose\nPrepare the explicit input/output contract between the S1 Supervisor and the `tts_polish` operator for each planned polish batch.\n\n### Scope\n- receives run/job context\n- receives merged screenplay\n- receives one polish batch from `tts_polish_batch_planner`\n- injects `tts_polish_rules` from channel config\n- writes a deterministic payload file for the operator\n- declares the expected output path for the batch result\n\n### Out of scope\n- run the operator\n- validate semantic quality\n- merge polish outputs\n- choose retry policy\n\n### Contract note\nThis component is an interface-critical bridge and should have its own dedicated contract.\n\n---\n\n## `tts_polish_merger`\n\n### Purpose\nMerge the batch outputs of `tts_polish` into one canonical `tts_polished.json` while preserving screenplay order and preserving the distinction between original narration and TTS-polished narration.\n\n### Scope\n- loads ordered polish batch files\n- validates minimum required polish scene fields\n- rebuilds one ordered `tts_polished.json`\n- uses screenplay order as the canonical scene sequence\n\n### Out of scope\n- validate semantic quality of the polish\n- decide retry policy\n- invoke operators\n- overwrite the original screenplay artifact\n\n### Contract note\nThis component writes a canonical sector artifact and should have its own dedicated contract.\n\n---\n\n## `retry_planner`\n\n### Purpose\nTurn observed failures into explicit retry decisions so the S1 Supervisor can decide whether to abort, rerun a whole step, or rerun only affected batches.\n\n### Scope\n- classifies failure types into retry strategies\n- enforces retry limits\n- supports fail-fast structural errors\n- supports batch-subset retries for localized operator/semantic failures\n- supports step-level retries when failures are broader\n\n### Out of scope\n- run retries itself\n- inspect semantic payloads deeply\n- invoke operators or validators\n- write checkpoints\n\n### Decision categories in v1\n- `abort`\n- `step`\n- `batch_subset`\n\n### Contract note\nThis component encodes sector recovery policy and should have its own dedicated contract.\n\n---\n\n## `operator_batch_scheduler`\n\n### Purpose\nProvide the controlled parallelism layer for batchable operators so the supervisor can launch work in capped waves instead of all-at-once or fully sequentially.\n\n### Scope\n- receives operator batches\n- applies a concurrency cap\n- groups batches into execution waves\n- summarizes execution outcomes into completed / failed / pending sets\n\n### Initial supported operators\n- `scene_director`\n- `tts_polish`\n\n### Out of scope\n- invoke OpenClaw operators by itself\n- decide semantic retry logic\n- merge outputs\n- validate content\n\n### Contract note\nThis component defines operational scheduling semantics and should have its own dedicated contract.\n\n---\n\n## `s1_result_summarizer`\n\n### Purpose\nProduce the final structured sector result that the S1 Supervisor can return upward after the sector finishes or fails.\n\n### Scope\n- aggregates scene counts\n- aggregates batch counts\n- exposes `scene_bible_path`\n- exposes checkpoint list\n- determines final `status` / `next_step`\n- preserves warnings/errors in one final result object\n\n### Out of scope\n- run the sector\n- write checkpoints\n- validate semantic correctness\n- call operators or skills\n\n---\n\n## Shared deterministic sector components\n\nThese components are used by S1 but are not classified as supervisor-local skills:\n- `screenplay_validator`\n- `polish_validator`\n- `scene_bible_builder`\n- `scene_bible_schema_validator`\n- `checkpoint_writer`\n\nThese should remain documented as shared sector components and not be confused with semantic operators or with the supervisor brain itself.\n\n---\n\n## Contract coverage guidance\n\n### Components that should have dedicated contracts\n- `scene_director_io_adapter`\n- `scene_director_output_validator`\n- `screenplay_merger`\n- `tts_polish_io_adapter`\n- `tts_polish_merger`\n- `retry_planner`\n- `operator_batch_scheduler`\n\n### Components that may remain documented primarily inside this supervisor contract for now\n- `s1_preflight_checker`\n- `s1_paths_resolver`\n- `script_batch_planner`\n- `tts_polish_batch_planner`\n- `s1_result_summarizer`\n\n### Components that should be documented as shared deterministic sector components\n- `screenplay_validator`\n- `polish_validator`\n- `scene_bible_builder`\n- `scene_bible_schema_validator`\n- `checkpoint_writer`\n\nDedicated shared deterministic contracts should exist for:\n- `screenplay_validator`\n- `polish_validator`\n- `scene_bible_builder`\n- `scene_bible_schema_validator`\n\n---\n\n## Current status summary\n\nAt this stage:\n- the S1 Supervisor is defined as the canonical OpenClaw runtime brain for the sector\n- the component classes inside S1 are now explicitly separated\n- the intended authority of the supervisor vs operators vs deterministic components is explicit\n- `scene_director` flow is structurally well-defined from batch planning through validation and merge\n- `tts_polish` flow is structurally defined, including the existence of a semantic reviewer lane for borderline cases\n- controlled operator parallelism is defined at the planning/supervisory level\n- `s1_start.py` is explicitly demoted from canonical sector brain to bootstrap/transition role\n\nThe remaining work is no longer to invent the S1 architecture, but to ensure every agent, contract, workspace, and deterministic component is fully aligned with this canonical model.\n"}],"isError":false,"timestamp":1775036709963}}
{"type":"message","id":"d621776b","parentId":"695b2b44","timestamp":"2026-04-01T09:45:10.333Z","message":{"role":"toolResult","toolCallId":"call_DnFX5KyZ6qvmNxGBbFQxU81L|fc_0785557c08065f410169cce92476a88190beb5efd808ae3b0f","toolName":"read","content":[{"type":"text","text":"# WORKFLOW.md — SM-S1\n\n## Canonical sector flow\n1. Run `s1_preflight_checker`\n2. Run `s1_paths_resolver`\n3. Plan script batches via `script_batch_planner`\n4. Build `scene_director` payloads via `scene_director_io_adapter`\n5. Schedule `scene_director` batches with controlled parallelism via `operator_batch_scheduler`\n6. Invoke `scene_director` batches under supervisor control\n7. Validate each batch via `scene_director_output_validator`\n8. If needed, classify retry via `retry_planner`\n9. Merge approved scene batches via `screenplay_merger`\n10. Validate canonical screenplay via `screenplay_validator`\n11. If screenplay validation fails, use `retry_planner`\n12. Plan polish batches via `tts_polish_batch_planner`\n13. Build `tts_polish` payloads via `tts_polish_io_adapter`\n14. Schedule `tts_polish` batches with controlled parallelism via `operator_batch_scheduler`\n15. Invoke `tts_polish` batches under supervisor control\n16. Validate each polish batch via `tts_polish_output_validator`\n17. Route only ambiguous cases to `tts_polish_semantic_reviewer` when needed\n18. Merge approved polish outputs via `tts_polish_merger`\n19. Validate canonical polish via `polish_validator`\n20. If polish validation fails, use `retry_planner`\n21. Build `scene_bible.json` via `scene_bible_builder`\n22. Validate scene bible schema via `scene_bible_schema_validator`\n23. Write/check checkpoints via `checkpoint_writer`\n24. Summarize sector result via `s1_result_summarizer`\n25. Complete or fail the sector\n\n## Important workflow rules\n- Preserve persisted file contracts\n- Preserve original narration separately from TTS-polished narration\n- Use selective retry when possible\n- Do not overwrite original screenplay with polished narration\n- Do not allow unvalidated batch outputs into canonical merge artifacts\n- The supervisor remains the owner of sequencing and acceptance decisions\n- Semantic review is a narrow escalation lane, not a default second pass for all polish batches\n\n## Important current implementation note\n`operator_batch_scheduler` currently plans waves and summarizes execution.\nIt does **not** itself invoke OpenClaw operators.\nThe supervisor must still own the actual operator invocation/control loop.\n"}],"isError":false,"timestamp":1775036710154}}
{"type":"message","id":"6cce534d","parentId":"d621776b","timestamp":"2026-04-01T09:45:10.518Z","message":{"role":"toolResult","toolCallId":"call_MNw8hof5jud4X2n6BzdSVzWP|fc_0785557c08065f410169cce92476ac8190ab920a87487a2fc3","toolName":"read","content":[{"type":"text","text":"{\n  \"status\": \"error\",\n  \"tool\": \"read\",\n  \"error\": \"ENOENT: no such file or directory, access 'C:\\\\Users\\\\User-OEM\\\\.openclaw\\\\agents\\\\op_s1_scene_director\\\\WORKFLOW.md'\"\n}"}],"details":{"status":"error","tool":"read","error":"ENOENT: no such file or directory, access 'C:\\Users\\User-OEM\\.openclaw\\agents\\op_s1_scene_director\\WORKFLOW.md'"},"isError":false,"timestamp":1775036710333}}
{"type":"message","id":"b277712d","parentId":"6cce534d","timestamp":"2026-04-01T09:45:20.752Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_chmAc8wwkTWoDOd4ERFW0hBU|fc_0785557c08065f410169cce931f0d8819096b56f8e4da0cda3","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\.openclaw\\agents\\op_s1_scene_director\\CONTEXT.md"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\.openclaw\\\\agents\\\\op_s1_scene_director\\\\CONTEXT.md\"}"},{"type":"toolCall","id":"call_1LBk472W8rqWuxQqogB7uii9|fc_0785557c08065f410169cce931f0e88190bb387ea6f6aa48e3","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\.openclaw\\agents\\op_s1_scene_director\\IDENTITY.md"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\.openclaw\\\\agents\\\\op_s1_scene_director\\\\IDENTITY.md\"}"},{"type":"toolCall","id":"call_oQDGotNEeh6rr4bJJVuGEHAI|fc_0785557c08065f410169cce931f0f08190b7285886b7242b2a","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\supervisor_skills\\scene_director_io_adapter.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\supervisor_skills\\\\scene_director_io_adapter.py\"}"},{"type":"toolCall","id":"call_AaXJzhoYgvbrvy60ViCdvY31|fc_0785557c08065f410169cce931f0f481908b83a7681f051b53","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\supervisor_skills\\scene_director_output_validator.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\supervisor_skills\\\\scene_director_output_validator.py\"}"},{"type":"toolCall","id":"call_DEtYRLwhRq2pByumA9GRJORB|fc_0785557c08065f410169cce931f0f88190866ae4337e8c36ca","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\supervisor_skills\\tts_polish_io_adapter.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\supervisor_skills\\\\tts_polish_io_adapter.py\"}"},{"type":"toolCall","id":"call_fqam9yaNTFrAYtksU8ppvRCs|fc_0785557c08065f410169cce931f1008190989668e959a7c7fe","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\supervisor_skills\\tts_polish_merger.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\supervisor_skills\\\\tts_polish_merger.py\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":17131,"output":276,"cacheRead":52736,"cacheWrite":0,"totalTokens":70143,"cost":{"input":0.042827500000000004,"output":0.0041400000000000005,"cacheRead":0.013184,"cacheWrite":0,"total":0.060151500000000004}},"stopReason":"toolUse","timestamp":1775036711037,"responseId":"resp_0785557c08065f410169cce928e47081908592618633767295"}}
{"type":"message","id":"29e662fa","parentId":"b277712d","timestamp":"2026-04-01T09:45:22.480Z","message":{"role":"toolResult","toolCallId":"call_chmAc8wwkTWoDOd4ERFW0hBU|fc_0785557c08065f410169cce931f0d8819096b56f8e4da0cda3","toolName":"read","content":[{"type":"text","text":"# CONTEXT.md\n\n## Where This Operator Sits\n\n`op_s1_scene_director` is the first semantic/creative operator inside S1 (Pre-Production).\n\nIt acts after the supervisor has:\n- confirmed the run is ready for S1\n- prepared canonical paths\n- split the raw script into manageable batches\n- prepared an explicit payload for one batch\n\nIt acts before:\n- per-batch output validation\n- batch repair/regenerate decisions\n- deterministic merge into canonical `screenplay.json`\n- downstream S1 steps such as TTS polish and scene bible construction\n\n## What It Receives\n\nThis operator receives one supervisor-prepared script batch, not the full script.\n\nThe input is expected to provide:\n- run/job context\n- batch identity\n- batch text\n- batch metadata\n- scene sizing constraints when relevant\n- explicit output expectations\n\n## What It Must Produce\n\nFor one batch, this operator must produce an ordered sequence of scenes that:\n- preserve the full original text of the batch\n- make narrative sense\n- assign each scene a clear narrative function\n- remain structurally valid for downstream validation and merge\n\n## Why This Output Matters\n\nThe output of `op_s1_scene_director` becomes the first structured creative layer of the video.\n\nIf it is weak or structurally inconsistent, the rest of S1 and downstream sectors inherit confusion.\nIf it is strong, the rest of the pipeline receives a stable, narratively meaningful foundation.\n\n## Relationship to the Supervisor\n\nThe supervisor owns:\n- batching\n- scheduling\n- validation\n- retry policy\n- merge decisions\n- approval / reject / repair routing\n\nThis operator owns:\n- scene-level interpretation of the assigned batch\n- clean narrative division\n- faithful scene-by-scene text preservation\n\n## Repair mode\n\nWhen reinvoked in repair mode, this operator should:\n- treat the task as batch-local\n- obey the supervisor's structured correction focus\n- avoid redesigning unaffected scenes unless correction logically requires it\n- preserve already-sound parts of the batch when possible\n\n## Relationship to Downstream Work\n\nThis operator does not perform:\n- TTS polish\n- semantic validation of its own output\n- scene merge\n- visual planning\n- asset planning\n\nHowever, its output is consumed by those later layers, so clarity and structural rigor here are critical.\n"}],"isError":false,"timestamp":1775036722308}}
{"type":"message","id":"e3eab6e4","parentId":"29e662fa","timestamp":"2026-04-01T09:45:22.649Z","message":{"role":"toolResult","toolCallId":"call_1LBk472W8rqWuxQqogB7uii9|fc_0785557c08065f410169cce931f0e88190bb387ea6f6aa48e3","toolName":"read","content":[{"type":"text","text":"# IDENTITY.md\n\n## Name\nop_s1_scene_director\n\n## One-Sentence Identity\nOperador criativo do S1 responsável por transformar batches de script em cenas editorialmente intencionais, formando o primeiro esqueleto criativo do vídeo.\n\n## Mission\nInterpretar cada batch de script e convertê-lo numa sequência de cenas com divisão clara, função narrativa definida e fidelidade total ao texto-fonte.\n\n## Position in Hierarchy\n- Responde ao `sm_s1_pre_production`\n- Não é supervisor\n- Não é validator\n- Não é visual planner\n- Não é TTS polisher\n\n## Core Responsibility\nTransformar um batch de script numa estrutura de cenas que preserve integralmente o texto e explicite a função narrativa de cada cena.\n\n## What It Does Not Do\n- Não divide o script inteiro em batches\n- Não faz merge global\n- Não define retry policy\n- Não valida o próprio output\n- Não faz visual planning detalhado\n- Não faz TTS polish\n- Não decide a progressão completa do sector S1\n\n## Working Mode\n- Opera batch-a-batch\n- Trabalha com contrato explícito de input/output\n- Prioriza fidelidade estrutural + clareza narrativa\n- Recebe feedback estruturado do supervisor quando houver repair\n- Não deve improvisar fora da sua missão e boundaries\n"}],"isError":false,"timestamp":1775036722480}}
{"type":"message","id":"46e517dc","parentId":"e3eab6e4","timestamp":"2026-04-01T09:45:22.824Z","message":{"role":"toolResult","toolCallId":"call_oQDGotNEeh6rr4bJJVuGEHAI|fc_0785557c08065f410169cce931f0f08190b7285886b7242b2a","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\n\ndef build_scene_director_payload(\n    *,\n    run_root: str | Path,\n    job: dict[str, Any],\n    batch: dict[str, Any],\n    channel_config: dict[str, Any],\n    output_path: str | Path,\n) -> dict[str, Any]:\n    run_root = Path(run_root)\n    output_path = Path(output_path)\n\n    account = job.get(\"account\")\n    language = job.get(\"language\")\n    job_id = job.get(\"job_id\")\n\n    payload = {\n        \"job_id\": job_id,\n        \"account\": account,\n        \"language\": language,\n        \"run_root\": str(run_root),\n        \"batch\": {\n            \"batch_id\": batch.get(\"batch_id\"),\n            \"start_word\": batch.get(\"start_word\"),\n            \"end_word\": batch.get(\"end_word\"),\n            \"word_count\": batch.get(\"word_count\"),\n            \"text\": batch.get(\"text\"),\n        },\n        \"scene_words_range\": channel_config.get(\"scene_words_range\"),\n        \"style_context\": {\n            \"channel_name\": job.get(\"channel_name\"),\n            \"reason\": job.get(\"reason\"),\n        },\n        \"instructions\": {\n            \"task\": \"Transform this script batch into an editorially intentional sequence of scenes for screenplay generation.\",\n            \"requirements\": [\n                \"Preserve narrative meaning and order.\",\n                \"Return scene objects only for this batch.\",\n                \"Each scene must include scene_local_id, scene_title, scene_summary, narrative_function, narration_original, start_word, end_word, estimated_scene_word_count.\",\n                \"Use batch-relative word coordinates: the first word in this batch is word 1.\",\n                \"scene_local_id must be sequential within the batch (scene_01, scene_02, ...).\",\n                \"Do not generate global scene IDs.\",\n                \"Do not rewrite the story beyond what is needed for clean scene segmentation.\",\n                \"Do not do visual planning, asset planning, prompt writing, or shot design in this step.\",\n                \"Do not polish for TTS in this step.\",\n                \"Do not leave gaps or overlaps between scene text spans.\",\n                \"narration_original must match the original source text assigned to each scene.\",\n            ],\n        },\n        \"output_path\": str(output_path),\n    }\n\n    return payload\n\n\ndef write_scene_director_payload(\n    *,\n    run_root: str | Path,\n    job: dict[str, Any],\n    batch: dict[str, Any],\n    channel_config: dict[str, Any],\n    input_path: str | Path,\n    output_path: str | Path,\n) -> dict[str, Any]:\n    input_path = Path(input_path)\n    output_path = Path(output_path)\n    input_path.parent.mkdir(parents=True, exist_ok=True)\n    output_path.parent.mkdir(parents=True, exist_ok=True)\n\n    payload = build_scene_director_payload(\n        run_root=run_root,\n        job=job,\n        batch=batch,\n        channel_config=channel_config,\n        output_path=output_path,\n    )\n\n    input_path.write_text(json.dumps(payload, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    return {\n        \"ok\": True,\n        \"input_path\": str(input_path),\n        \"output_path\": str(output_path),\n        \"batch_id\": batch.get(\"batch_id\"),\n        \"payload\": payload,\n        \"errors\": [],\n        \"warnings\": [],\n    }\n"}],"isError":false,"timestamp":1775036722650}}
{"type":"message","id":"4a617999","parentId":"46e517dc","timestamp":"2026-04-01T09:45:23.025Z","message":{"role":"toolResult","toolCallId":"call_AaXJzhoYgvbrvy60ViCdvY31|fc_0785557c08065f410169cce931f0f481908b83a7681f051b53","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport json\nimport re\nfrom pathlib import Path\nfrom typing import Any\n\n\nREQUIRED_TOP_LEVEL_FIELDS = {\n    \"batch_id\",\n    \"operator\",\n    \"scenes\",\n}\n\nREQUIRED_SCENE_FIELDS = {\n    \"scene_local_id\",\n    \"scene_title\",\n    \"scene_summary\",\n    \"narrative_function\",\n    \"narration_original\",\n    \"start_word\",\n    \"end_word\",\n    \"estimated_scene_word_count\",\n}\n\nERROR_SEVERITY = {\n    \"payload_unreadable\": \"fatal_contract_error\",\n    \"output_unreadable\": \"fatal_contract_error\",\n    \"invalid_top_level_shape\": \"fatal_contract_error\",\n    \"empty_scenes\": \"fatal_contract_error\",\n    \"missing_required_field\": \"structural_patch\",\n    \"duplicate_scene_local_id\": \"structural_patch\",\n    \"non_sequential_scene_local_id\": \"structural_patch\",\n    \"invalid_scene_span\": \"batch_repair\",\n    \"scene_overlap_detected\": \"batch_repair\",\n    \"missing_coverage_detected\": \"batch_repair\",\n    \"duplicate_coverage_detected\": \"batch_repair\",\n    \"narration_source_mismatch\": \"batch_repair\",\n    \"estimated_word_count_mismatch\": \"structural_patch\",\n}\n\nCLASSIFICATION_PRIORITY = [\n    \"fatal_contract_error\",\n    \"batch_regenerate\",\n    \"batch_repair\",\n    \"structural_patch\",\n    \"ok\",\n]\n\n\ndef validate_scene_director_output(\n    *,\n    batch_payload_path: str | Path,\n    batch_output_path: str | Path,\n) -> dict[str, Any]:\n    errors: list[dict[str, Any]] = []\n    warnings: list[dict[str, Any]] = []\n\n    payload_result = _load_json(batch_payload_path, error_code=\"payload_unreadable\")\n    if not payload_result[\"ok\"]:\n        return _fatal_result(\n            batch_id=None,\n            errors=payload_result[\"errors\"],\n            warnings=warnings,\n        )\n\n    output_result = _load_json(batch_output_path, error_code=\"output_unreadable\")\n    if not output_result[\"ok\"]:\n        payload = payload_result[\"data\"]\n        batch_id = _extract_batch_id_from_payload(payload)\n        return _fatal_result(\n            batch_id=batch_id,\n            errors=output_result[\"errors\"],\n            warnings=warnings,\n        )\n\n    payload = payload_result[\"data\"]\n    output = output_result[\"data\"]\n\n    batch_id = _extract_batch_id(output) or _extract_batch_id_from_payload(payload)\n\n    source_batch = payload.get(\"batch\") if isinstance(payload, dict) else None\n    if not isinstance(source_batch, dict):\n        errors.append(_error(\n            code=\"invalid_top_level_shape\",\n            message=\"Batch payload must include a 'batch' object\",\n        ))\n        return _finalize_result(\n            batch_id=batch_id,\n            errors=errors,\n            warnings=warnings,\n            scenes=[],\n            source_tokens=[],\n            expected_batch_id=_extract_batch_id_from_payload(payload),\n        )\n\n    source_text = source_batch.get(\"text\")\n    if not isinstance(source_text, str) or not source_text.strip():\n        errors.append(_error(\n            code=\"invalid_top_level_shape\",\n            message=\"Batch payload must include non-empty batch.text\",\n        ))\n        return _finalize_result(\n            batch_id=batch_id,\n            errors=errors,\n            warnings=warnings,\n            scenes=[],\n            source_tokens=[],\n            expected_batch_id=_extract_batch_id_from_payload(payload),\n        )\n\n    scenes = _validate_top_level_output(output, errors)\n    if not scenes:\n        return _finalize_result(\n            batch_id=batch_id,\n            errors=errors,\n            warnings=warnings,\n            scenes=[],\n            source_tokens=_tokenize_text(source_text),\n            expected_batch_id=_extract_batch_id_from_payload(payload),\n        )\n\n    _validate_batch_id_match(output, payload, errors)\n    _validate_required_scene_fields(scenes, errors)\n    _validate_scene_local_ids(scenes, errors)\n    _validate_scene_spans(scenes, errors)\n\n    source_tokens = _tokenize_text(source_text)\n    _validate_coverage(scenes, len(source_tokens), errors)\n    _validate_narration_fidelity(scenes, source_tokens, errors)\n    _validate_estimated_word_counts(scenes, errors)\n\n    return _finalize_result(\n        batch_id=batch_id,\n        errors=errors,\n        warnings=warnings,\n        scenes=scenes,\n        source_tokens=source_tokens,\n        expected_batch_id=_extract_batch_id_from_payload(payload),\n    )\n\n\ndef _load_json(path: str | Path, *, error_code: str) -> dict[str, Any]:\n    path = Path(path)\n    try:\n        data = json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception as exc:  # noqa: BLE001\n        return {\n            \"ok\": False,\n            \"errors\": [_error(error_code, f\"Failed to read JSON from {path}: {exc}\")],\n        }\n    return {\n        \"ok\": True,\n        \"data\": data,\n    }\n\n\ndef _validate_top_level_output(output: Any, errors: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    if not isinstance(output, dict):\n        errors.append(_error(\n            code=\"invalid_top_level_shape\",\n            message=\"Scene director output must be a JSON object\",\n        ))\n        return []\n\n    missing_top_level = sorted(REQUIRED_TOP_LEVEL_FIELDS - set(output.keys()))\n    if missing_top_level:\n        errors.append(_error(\n            code=\"invalid_top_level_shape\",\n            message=f\"Output is missing top-level fields: {', '.join(missing_top_level)}\",\n        ))\n\n    scenes = output.get(\"scenes\")\n    if not isinstance(scenes, list):\n        errors.append(_error(\n            code=\"invalid_top_level_shape\",\n            message=\"Output 'scenes' must be a list\",\n        ))\n        return []\n\n    if not scenes:\n        errors.append(_error(\n            code=\"empty_scenes\",\n            message=\"Output 'scenes' list is empty\",\n        ))\n        return []\n\n    valid_scenes: list[dict[str, Any]] = []\n    for index, scene in enumerate(scenes, start=1):\n        if not isinstance(scene, dict):\n            errors.append(_error(\n                code=\"missing_required_field\",\n                message=f\"Scene at index {index} must be an object\",\n                scene_ids=[f\"scene_index_{index}\"],\n            ))\n            continue\n        valid_scenes.append(scene)\n\n    return valid_scenes\n\n\ndef _validate_batch_id_match(output: dict[str, Any], payload: dict[str, Any], errors: list[dict[str, Any]]) -> None:\n    output_batch_id = _extract_batch_id(output)\n    expected_batch_id = _extract_batch_id_from_payload(payload)\n    if output_batch_id and expected_batch_id and output_batch_id != expected_batch_id:\n        errors.append(_error(\n            code=\"missing_required_field\",\n            message=f\"Output batch_id '{output_batch_id}' does not match expected '{expected_batch_id}'\",\n        ))\n\n\ndef _validate_required_scene_fields(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\n    for scene in scenes:\n        missing_fields = sorted(REQUIRED_SCENE_FIELDS - set(scene.keys()))\n        if missing_fields:\n            errors.append(_error(\n                code=\"missing_required_field\",\n                message=(\n                    f\"Scene {scene.get('scene_local_id', '<unknown>')} is missing required fields: \"\n                    f\"{', '.join(missing_fields)}\"\n                ),\n                scene_ids=[scene.get(\"scene_local_id\")],\n            ))\n\n\ndef _validate_scene_local_ids(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\n    seen: set[str] = set()\n    expected_index = 1\n\n    for scene in scenes:\n        scene_local_id = scene.get(\"scene_local_id\")\n        if not isinstance(scene_local_id, str):\n            continue\n\n        if scene_local_id in seen:\n            errors.append(_error(\n                code=\"duplicate_scene_local_id\",\n                message=f\"Duplicate scene_local_id detected: {scene_local_id}\",\n                scene_ids=[scene_local_id],\n            ))\n        else:\n            seen.add(scene_local_id)\n\n        expected_id = f\"scene_{expected_index:02d}\"\n        if scene_local_id != expected_id:\n            errors.append(_error(\n                code=\"non_sequential_scene_local_id\",\n                message=f\"Expected {expected_id} but found {scene_local_id}\",\n                scene_ids=[scene_local_id],\n            ))\n        expected_index += 1\n\n\ndef _validate_scene_spans(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\n    previous_end: int | None = None\n    previous_scene_id: str | None = None\n\n    for scene in scenes:\n        scene_id = scene.get(\"scene_local_id\")\n        start_word = scene.get(\"start_word\")\n        end_word = scene.get(\"end_word\")\n\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\n            errors.append(_error(\n                code=\"invalid_scene_span\",\n                message=f\"Scene {scene_id} must have integer start_word/end_word\",\n                scene_ids=[scene_id],\n            ))\n            continue\n\n        if start_word < 1 or end_word < 1 or start_word > end_word:\n            errors.append(_error(\n                code=\"invalid_scene_span\",\n                message=f\"Scene {scene_id} has invalid span ({start_word}-{end_word})\",\n                scene_ids=[scene_id],\n            ))\n            continue\n\n        if previous_end is not None and start_word <= previous_end:\n            errors.append(_error(\n                code=\"scene_overlap_detected\",\n                message=(\n                    f\"Scene {scene_id} overlaps with {previous_scene_id} \"\n                    f\"({start_word} <= previous end {previous_end})\"\n                ),\n                scene_ids=[previous_scene_id, scene_id],\n            ))\n\n        previous_end = end_word\n        previous_scene_id = scene_id\n\n\ndef _validate_coverage(scenes: list[dict[str, Any]], source_word_count: int, errors: list[dict[str, Any]]) -> None:\n    if source_word_count == 0:\n        return\n\n    coverage = [0] * source_word_count\n\n    for scene in scenes:\n        start_word = scene.get(\"start_word\")\n        end_word = scene.get(\"end_word\")\n        scene_id = scene.get(\"scene_local_id\")\n\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\n            continue\n        if start_word < 1 or end_word > source_word_count or start_word > end_word:\n            errors.append(_error(\n                code=\"invalid_scene_span\",\n                message=(\n                    f\"Scene {scene_id} span ({start_word}-{end_word}) is outside batch-relative range \"\n                    f\"1-{source_word_count}\"\n                ),\n                scene_ids=[scene_id],\n            ))\n            continue\n\n        for index in range(start_word - 1, end_word):\n            coverage[index] += 1\n\n    missing_ranges = _collect_ranges([i + 1 for i, count in enumerate(coverage) if count == 0])\n    duplicate_ranges = _collect_ranges([i + 1 for i, count in enumerate(coverage) if count > 1])\n\n    for start_word, end_word in missing_ranges:\n        errors.append(_error(\n            code=\"missing_coverage_detected\",\n            message=f\"Words {start_word}-{end_word} are not assigned to any scene\",\n        ))\n\n    for start_word, end_word in duplicate_ranges:\n        errors.append(_error(\n            code=\"duplicate_coverage_detected\",\n            message=f\"Words {start_word}-{end_word} are assigned to multiple scenes\",\n        ))\n\n\ndef _validate_narration_fidelity(\n    scenes: list[dict[str, Any]],\n    source_tokens: list[str],\n    errors: list[dict[str, Any]],\n) -> None:\n    for scene in scenes:\n        scene_id = scene.get(\"scene_local_id\")\n        start_word = scene.get(\"start_word\")\n        end_word = scene.get(\"end_word\")\n        narration_original = scene.get(\"narration_original\")\n\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\n            continue\n        if not isinstance(narration_original, str):\n            continue\n        if start_word < 1 or end_word > len(source_tokens) or start_word > end_word:\n            continue\n\n        source_span_text = \" \".join(source_tokens[start_word - 1:end_word])\n        if _normalize_text(narration_original) != _normalize_text(source_span_text):\n            errors.append(_error(\n                code=\"narration_source_mismatch\",\n                message=f\"Scene {scene_id} narration_original does not match source span {start_word}-{end_word}\",\n                scene_ids=[scene_id],\n            ))\n\n\ndef _validate_estimated_word_counts(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\n    for scene in scenes:\n        scene_id = scene.get(\"scene_local_id\")\n        start_word = scene.get(\"start_word\")\n        end_word = scene.get(\"end_word\")\n        estimated_scene_word_count = scene.get(\"estimated_scene_word_count\")\n\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\n            continue\n        if not isinstance(estimated_scene_word_count, int):\n            errors.append(_error(\n                code=\"estimated_word_count_mismatch\",\n                message=f\"Scene {scene_id} must have integer estimated_scene_word_count\",\n                scene_ids=[scene_id],\n            ))\n            continue\n\n        actual_count = end_word - start_word + 1\n        if estimated_scene_word_count != actual_count:\n            errors.append(_error(\n                code=\"estimated_word_count_mismatch\",\n                message=(\n                    f\"Scene {scene_id} estimated_scene_word_count={estimated_scene_word_count} \"\n                    f\"but span implies {actual_count}\"\n                ),\n                scene_ids=[scene_id],\n            ))\n\n\ndef _tokenize_text(text: str) -> list[str]:\n    normalized = _normalize_text(text)\n    if not normalized:\n        return []\n    return normalized.split(\" \")\n\n\ndef _normalize_text(text: str) -> str:\n    text = text.replace(\"\\r\\n\", \" \").replace(\"\\n\", \" \").replace(\"\\t\", \" \")\n    text = re.sub(r\"\\s+\", \" \", text).strip()\n    return text\n\n\ndef _collect_ranges(word_indices: list[int]) -> list[tuple[int, int]]:\n    if not word_indices:\n        return []\n\n    ranges: list[tuple[int, int]] = []\n    start = word_indices[0]\n    previous = word_indices[0]\n\n    for current in word_indices[1:]:\n        if current == previous + 1:\n            previous = current\n            continue\n        ranges.append((start, previous))\n        start = current\n        previous = current\n\n    ranges.append((start, previous))\n    return ranges\n\n\ndef _extract_batch_id(output: dict[str, Any]) -> str | None:\n    batch_id = output.get(\"batch_id\")\n    return batch_id if isinstance(batch_id, str) and batch_id.strip() else None\n\n\ndef _extract_batch_id_from_payload(payload: dict[str, Any]) -> str | None:\n    batch = payload.get(\"batch\") if isinstance(payload, dict) else None\n    if not isinstance(batch, dict):\n        return None\n    batch_id = batch.get(\"batch_id\")\n    return batch_id if isinstance(batch_id, str) and batch_id.strip() else None\n\n\ndef _error(\n    code: str,\n    message: str,\n    *,\n    scene_ids: list[str | None] | None = None,\n) -> dict[str, Any]:\n    clean_scene_ids = [scene_id for scene_id in (scene_ids or []) if scene_id]\n    payload: dict[str, Any] = {\n        \"code\": code,\n        \"message\": message,\n    }\n    if clean_scene_ids:\n        payload[\"scene_ids\"] = clean_scene_ids\n    return payload\n\n\ndef _fatal_result(\n    *,\n    batch_id: str | None,\n    errors: list[dict[str, Any]],\n    warnings: list[dict[str, Any]],\n) -> dict[str, Any]:\n    return {\n        \"ok\": False,\n        \"approved_for_merge\": False,\n        \"batch_id\": batch_id,\n        \"classification\": \"fatal_contract_error\",\n        \"errors\": errors,\n        \"warnings\": warnings,\n        \"stats\": {\n            \"scene_count\": 0,\n            \"source_word_count\": 0,\n            \"covered_word_count\": 0,\n        },\n    }\n\n\ndef _finalize_result(\n    *,\n    batch_id: str | None,\n    errors: list[dict[str, Any]],\n    warnings: list[dict[str, Any]],\n    scenes: list[dict[str, Any]],\n    source_tokens: list[str],\n    expected_batch_id: str | None,\n) -> dict[str, Any]:\n    classification = _classify_errors(errors)\n    covered_word_count = _compute_covered_word_count(scenes, len(source_tokens))\n\n    if batch_id is None:\n        batch_id = expected_batch_id\n\n    return {\n        \"ok\": classification == \"ok\",\n        \"approved_for_merge\": classification == \"ok\",\n        \"batch_id\": batch_id,\n        \"classification\": classification,\n        \"errors\": errors,\n        \"warnings\": warnings,\n        \"stats\": {\n            \"scene_count\": len(scenes),\n            \"source_word_count\": len(source_tokens),\n            \"covered_word_count\": covered_word_count,\n        },\n    }\n\n\ndef _classify_errors(errors: list[dict[str, Any]]) -> str:\n    if not errors:\n        return \"ok\"\n\n    severities = [ERROR_SEVERITY.get(error.get(\"code\"), \"fatal_contract_error\") for error in errors]\n\n    if \"fatal_contract_error\" in severities:\n        return \"fatal_contract_error\"\n\n    repair_like_count = sum(1 for severity in severities if severity == \"batch_repair\")\n    if repair_like_count >= 3:\n        return \"batch_regenerate\"\n    if repair_like_count >= 1:\n        return \"batch_repair\"\n    if \"structural_patch\" in severities:\n        return \"structural_patch\"\n\n    for classification in CLASSIFICATION_PRIORITY:\n        if classification in severities:\n            return classification\n\n    return \"fatal_contract_error\"\n\n\ndef _compute_covered_word_count(scenes: list[dict[str, Any]], source_word_count: int) -> int:\n    if source_word_count <= 0:\n        return 0\n\n    covered: set[int] = set()\n    for scene in scenes:\n        start_word = scene.get(\"start_word\")\n        end_word = scene.get(\"end_word\")\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\n            continue\n        if start_word < 1 or end_word < 1 or start_word > end_word:\n            continue\n        for index in range(max(1, start_word), min(source_word_count, end_word) + 1):\n            covered.add(index)\n\n    return len(covered)\n"}],"isError":false,"timestamp":1775036722825}}
{"type":"message","id":"b5ad10a5","parentId":"4a617999","timestamp":"2026-04-01T09:45:23.196Z","message":{"role":"toolResult","toolCallId":"call_DEtYRLwhRq2pByumA9GRJORB|fc_0785557c08065f410169cce931f0f88190866ae4337e8c36ca","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\n\ndef build_tts_polish_payload(\n    *,\n    run_root: str | Path,\n    job: dict[str, Any],\n    screenplay: dict[str, Any],\n    batch: dict[str, Any],\n    channel_config: dict[str, Any],\n    output_path: str | Path,\n) -> dict[str, Any]:\n    run_root = Path(run_root)\n    output_path = Path(output_path)\n\n    scene_ids = batch.get(\"scene_ids\", [])\n    scene_map = {\n        scene.get(\"scene_id\"): scene\n        for scene in screenplay.get(\"scenes\", [])\n        if isinstance(scene, dict) and scene.get(\"scene_id\")\n    }\n    scenes = [scene_map[scene_id] for scene_id in scene_ids if scene_id in scene_map]\n\n    payload = {\n        \"job_id\": job.get(\"job_id\"),\n        \"account\": job.get(\"account\"),\n        \"language\": job.get(\"language\"),\n        \"run_root\": str(run_root),\n        \"batch\": {\n            \"batch_id\": batch.get(\"batch_id\"),\n            \"scene_ids\": scene_ids,\n            \"scene_count\": batch.get(\"scene_count\"),\n            \"word_count\": batch.get(\"word_count\"),\n        },\n        \"tts_polish_rules\": channel_config.get(\"tts_polish_rules\", []),\n        \"style_context\": {\n            \"channel_name\": job.get(\"channel_name\"),\n            \"reason\": job.get(\"reason\"),\n        },\n        \"instructions\": {\n            \"task\": \"Polish the narration text for TTS without changing meaning.\",\n            \"requirements\": [\n                \"Preserve scene order and scene IDs.\",\n                \"Do not remove the original narration layer.\",\n                \"Return narration_tts for each scene.\",\n                \"Keep meaning intact while improving speakability.\",\n                \"Return changes metadata for each scene when possible.\",\n            ],\n        },\n        \"scenes\": scenes,\n        \"output_path\": str(output_path),\n    }\n\n    return payload\n\n\ndef write_tts_polish_payload(\n    *,\n    run_root: str | Path,\n    job: dict[str, Any],\n    screenplay: dict[str, Any],\n    batch: dict[str, Any],\n    channel_config: dict[str, Any],\n    input_path: str | Path,\n    output_path: str | Path,\n) -> dict[str, Any]:\n    input_path = Path(input_path)\n    output_path = Path(output_path)\n    input_path.parent.mkdir(parents=True, exist_ok=True)\n    output_path.parent.mkdir(parents=True, exist_ok=True)\n\n    payload = build_tts_polish_payload(\n        run_root=run_root,\n        job=job,\n        screenplay=screenplay,\n        batch=batch,\n        channel_config=channel_config,\n        output_path=output_path,\n    )\n\n    input_path.write_text(json.dumps(payload, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    return {\n        \"ok\": True,\n        \"input_path\": str(input_path),\n        \"output_path\": str(output_path),\n        \"batch_id\": batch.get(\"batch_id\"),\n        \"payload\": payload,\n        \"errors\": [],\n        \"warnings\": [],\n    }\n"}],"isError":false,"timestamp":1775036723026}}
{"type":"message","id":"a361ee73","parentId":"b5ad10a5","timestamp":"2026-04-01T09:45:23.368Z","message":{"role":"toolResult","toolCallId":"call_fqam9yaNTFrAYtksU8ppvRCs|fc_0785557c08065f410169cce931f1008190989668e959a7c7fe","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\n\nREQUIRED_POLISH_FIELDS = {\n    \"scene_id\",\n    \"narration_original\",\n    \"narration_tts\",\n}\n\n\ndef merge_tts_polish_batches(\n    batch_files: list[str | Path],\n    *,\n    screenplay: dict[str, Any],\n    output_path: str | Path | None = None,\n) -> dict[str, Any]:\n    errors: list[dict[str, str]] = []\n    warnings: list[dict[str, str]] = []\n    ordered_files = sorted([Path(p) for p in batch_files], key=lambda p: p.name)\n\n    scenes = screenplay.get(\"scenes\", []) if isinstance(screenplay, dict) else []\n    ordered_scene_ids = [scene.get(\"scene_id\") for scene in scenes if isinstance(scene, dict) and scene.get(\"scene_id\")]\n\n    if not ordered_files:\n        return {\n            \"ok\": False,\n            \"scene_count\": 0,\n            \"tts_polished\": {\"scenes\": []},\n            \"errors\": [{\"code\": \"no_batch_files\", \"message\": \"No tts_polish batch files provided\"}],\n            \"warnings\": [],\n        }\n\n    polish_map: dict[str, dict[str, Any]] = {}\n    loaded_batches: list[dict[str, Any]] = []\n\n    for file_path in ordered_files:\n        if not file_path.exists():\n            errors.append({\n                \"code\": \"missing_batch_file\",\n                \"message\": f\"Polish batch file not found: {file_path}\",\n            })\n            continue\n\n        try:\n            payload = json.loads(file_path.read_text(encoding=\"utf-8\"))\n        except Exception as exc:  # noqa: BLE001\n            errors.append({\n                \"code\": \"invalid_batch_json\",\n                \"message\": f\"Failed to parse polish batch file {file_path}: {exc}\",\n            })\n            continue\n\n        batch_id = payload.get(\"batch_id\")\n        batch_scenes = payload.get(\"scenes\", [])\n        if not isinstance(batch_scenes, list):\n            errors.append({\n                \"code\": \"invalid_batch_scenes\",\n                \"message\": f\"Polish batch file {file_path} has invalid 'scenes' payload\",\n            })\n            continue\n\n        if not batch_scenes:\n            warnings.append({\n                \"code\": \"empty_polish_batch\",\n                \"message\": f\"Polish batch file {file_path} produced zero scenes\",\n            })\n\n        loaded_batches.append(\n            {\n                \"batch_id\": batch_id,\n                \"file_path\": str(file_path),\n                \"scene_count\": len(batch_scenes),\n            }\n        )\n\n        for scene in batch_scenes:\n            if not isinstance(scene, dict):\n                errors.append({\n                    \"code\": \"invalid_scene_payload\",\n                    \"message\": f\"Polish batch {batch_id or file_path.name} contains a non-object scene entry\",\n                })\n                continue\n\n            missing_fields = sorted(REQUIRED_POLISH_FIELDS - set(scene.keys()))\n            if missing_fields:\n                errors.append({\n                    \"code\": \"missing_polish_fields\",\n                    \"message\": (\n                        f\"Polish batch {batch_id or file_path.name} scene is missing required fields: \"\n                        f\"{', '.join(missing_fields)}\"\n                    ),\n                })\n                continue\n\n            scene_id = scene.get(\"scene_id\")\n            if scene_id in polish_map:\n                warnings.append({\n                    \"code\": \"duplicate_scene_polish\",\n                    \"message\": f\"Scene {scene_id} appeared more than once across polish batches; latest entry kept\",\n                })\n            polish_map[scene_id] = scene\n\n    merged_scenes: list[dict[str, Any]] = []\n    for scene_id in ordered_scene_ids:\n        polished_scene = polish_map.get(scene_id)\n        if not polished_scene:\n            errors.append({\n                \"code\": \"missing_polish_scene\",\n                \"message\": f\"No polish output found for screenplay scene {scene_id}\",\n            })\n            continue\n        merged_scenes.append(polished_scene)\n\n    tts_polished = {\n        \"scene_count\": len(merged_scenes),\n        \"scenes\": merged_scenes,\n    }\n\n    if output_path is not None:\n        output_path = Path(output_path)\n        output_path.parent.mkdir(parents=True, exist_ok=True)\n        output_path.write_text(json.dumps(tts_polished, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    return {\n        \"ok\": len(errors) == 0,\n        \"scene_count\": len(merged_scenes),\n        \"batch_count\": len(loaded_batches),\n        \"tts_polished\": tts_polished,\n        \"loaded_batches\": loaded_batches,\n        \"output_path\": str(output_path) if output_path is not None else None,\n        \"errors\": errors,\n        \"warnings\": warnings,\n    }\n"}],"isError":false,"timestamp":1775036723196}}
