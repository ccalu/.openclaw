{"type":"message","id":"b050d1f7","parentId":"4b597025","timestamp":"2026-04-01T17:14:09.633Z","message":{"role":"toolResult","toolCallId":"call_ATqVkzcmmDuyZX3n81f5MCFp|fc_0785557c08065f410169cd526021708190871192eec28f7408","toolName":"read","content":[{"type":"text","text":"{\n  \"status\": \"error\",\n  \"tool\": \"read\",\n  \"error\": \"ENOENT: no such file or directory, access 'C:\\\\Users\\\\User-OEM\\\\.openclaw\\\\workspace\\\\tmp_pm_vo_s1_real\\\\003_fr\\\\2026-04-01_003_fr_001\\\\b1_pre_production\\\\screenplay_validation.json'\"\n}"}],"details":{"status":"error","tool":"read","error":"ENOENT: no such file or directory, access 'C:\\Users\\User-OEM\\.openclaw\\workspace\\tmp_pm_vo_s1_real\\003_fr\\2026-04-01_003_fr_001\\b1_pre_production\\screenplay_validation.json'"},"isError":false,"timestamp":1775063649522}}
{"type":"message","id":"09d1a086","parentId":"b050d1f7","timestamp":"2026-04-01T17:14:09.749Z","message":{"role":"toolResult","toolCallId":"call_vHrlsEqLjXOkIYAMvQ1Qt4SY|fc_0785557c08065f410169cd526021888190ae8d7a8cf6dbbad0","toolName":"read","content":[{"type":"text","text":"{\n  \"status\": \"error\",\n  \"tool\": \"read\",\n  \"error\": \"ENOENT: no such file or directory, access 'C:\\\\Users\\\\User-OEM\\\\.openclaw\\\\workspace\\\\tmp_pm_vo_s1_real\\\\003_fr\\\\2026-04-01_003_fr_001\\\\b1_pre_production\\\\screenplay.json'\"\n}"}],"details":{"status":"error","tool":"read","error":"ENOENT: no such file or directory, access 'C:\\Users\\User-OEM\\.openclaw\\workspace\\tmp_pm_vo_s1_real\\003_fr\\2026-04-01_003_fr_001\\b1_pre_production\\screenplay.json'"},"isError":false,"timestamp":1775063649640}}
{"type":"message","id":"d8bfacc1","parentId":"09d1a086","timestamp":"2026-04-01T17:14:09.917Z","message":{"role":"toolResult","toolCallId":"call_b2tdyUTAzNpW0y7oSSG2hnpE|fc_0785557c08065f410169cd526021908190a95c61d88a85d125","toolName":"read","content":[{"type":"text","text":"\"\"\"Screenplay Validator — validates canonical merged screenplay against original script.\n\nDetects:\n- missing words\n- extra words\n- suspicious duplicate scene narration\n- source order mismatches\n\n100% deterministic, no LLM.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom collections import Counter\nfrom typing import Any\n\n\ndef validate_screenplay(\n    script_raw: str,\n    screenplay: list[dict[str, Any]],\n) -> dict[str, Any]:\n    \"\"\"Validate canonical screenplay against original script.\n\n    Args:\n        script_raw: Original script text.\n        screenplay: Canonical screenplay scene list with `scene_id` and `narration_original`.\n\n    Returns:\n        Structured deterministic validation result.\n    \"\"\"\n    original_words = _tokenize(script_raw)\n    original_counter = Counter(original_words)\n\n    screenplay_words: list[str] = []\n    scene_records: list[dict[str, Any]] = []\n    duplicated_between_scenes: list[dict[str, Any]] = []\n    warnings: list[dict[str, Any]] = []\n\n    previous_global_end: int | None = None\n    duplicate_text_map: dict[str, list[str]] = {}\n\n    for index, scene in enumerate(screenplay, start=1):\n        scene_id = scene.get(\"scene_id\", scene.get(\"scene_local_id\", f\"scene_{index:03d}\"))\n        narration = str(scene.get(\"narration_original\", \"\"))\n        words = _tokenize(narration)\n        screenplay_words.extend(words)\n\n        normalized_narration = _normalize_text(narration)\n        if normalized_narration:\n            duplicate_text_map.setdefault(normalized_narration, []).append(scene_id)\n\n        record = {\n            \"scene_id\": scene_id,\n            \"words\": words,\n            \"word_set\": set(words),\n            \"global_start_word\": scene.get(\"global_start_word\"),\n            \"global_end_word\": scene.get(\"global_end_word\"),\n            \"local_start_word\": scene.get(\"start_word\"),\n            \"local_end_word\": scene.get(\"end_word\"),\n        }\n        scene_records.append(record)\n\n        # Only validate global ordering if present\n        global_start = scene.get(\"global_start_word\")\n        global_end = scene.get(\"global_end_word\")\n        if isinstance(global_start, int) and isinstance(global_end, int):\n            if global_start > global_end:\n                warnings.append({\n                    \"code\": \"invalid_global_span\",\n                    \"scene\": scene_id,\n                    \"message\": f\"Scene {scene_id} has invalid global span {global_start}-{global_end}\",\n                })\n            if previous_global_end is not None and global_start <= previous_global_end:\n                warnings.append({\n                    \"code\": \"non_monotonic_global_order\",\n                    \"scene\": scene_id,\n                    \"message\": f\"Scene {scene_id} global span order is not strictly increasing\",\n                })\n            previous_global_end = global_end\n\n    screenplay_counter = Counter(screenplay_words)\n\n    missing_words = []\n    for word, count in original_counter.items():\n        actual = screenplay_counter.get(word, 0)\n        if actual < count:\n            missing_words.append({\"word\": word, \"missing_count\": count - actual})\n\n    extra_words = []\n    for word, count in screenplay_counter.items():\n        actual = original_counter.get(word, 0)\n        if actual < count:\n            extra_words.append({\"word\": word, \"extra_count\": count - actual})\n\n    for narration_text, scene_ids in duplicate_text_map.items():\n        if narration_text and len(scene_ids) > 1:\n            duplicated_between_scenes.append({\n                \"scene_ids\": scene_ids,\n                \"message\": \"Multiple scenes share identical narration_original text\",\n            })\n\n    affected_scenes: list[str] = []\n    significant_missing_words = {item[\"word\"] for item in missing_words if len(item[\"word\"]) > 2}\n    significant_extra_words = {item[\"word\"] for item in extra_words if len(item[\"word\"]) > 2}\n\n    for record in scene_records:\n        scene_id = record[\"scene_id\"]\n        scene_word_set = record[\"word_set\"]\n        if significant_missing_words and scene_word_set.intersection(significant_missing_words):\n            _add_affected(affected_scenes, scene_id)\n        if significant_extra_words and scene_word_set.intersection(significant_extra_words):\n            _add_affected(affected_scenes, scene_id)\n\n    for duplicate_group in duplicated_between_scenes:\n        for scene_id in duplicate_group.get(\"scene_ids\", []):\n            _add_affected(affected_scenes, scene_id)\n\n    coverage_pct = _coverage_percentage(original_words, screenplay_words)\n\n    significant_missing = [m for m in missing_words if len(m[\"word\"]) > 2]\n    significant_extra = [e for e in extra_words if len(e[\"word\"]) > 2]\n\n    valid = len(significant_missing) == 0 and len(significant_extra) == 0 and len(duplicated_between_scenes) == 0\n\n    return {\n        \"valid\": valid,\n        \"missing_words\": missing_words[:20],\n        \"extra_words\": extra_words[:20],\n        \"duplicated_between_scenes\": duplicated_between_scenes[:10],\n        \"coverage\": f\"{coverage_pct:.1f}%\",\n        \"affected_scenes\": affected_scenes,\n        \"warnings\": warnings[:20],\n        \"total_original_words\": len(original_words),\n        \"total_screenplay_words\": len(screenplay_words),\n        \"scene_count\": len(screenplay),\n        \"details\": (\n            f\"Coverage {coverage_pct:.1f}%, {len(significant_missing)} significant missing, \"\n            f\"{len(significant_extra)} significant extra, {len(duplicated_between_scenes)} duplicate-scene signals\"\n        ),\n    }\n\n\ndef _coverage_percentage(original_words: list[str], screenplay_words: list[str]) -> float:\n    if not original_words:\n        return 100.0\n    original_counter = Counter(original_words)\n    screenplay_counter = Counter(screenplay_words)\n    matched = 0\n    for word, count in original_counter.items():\n        matched += min(count, screenplay_counter.get(word, 0))\n    return (matched / len(original_words)) * 100\n\n\ndef _normalize_text(text: str) -> str:\n    text = text.replace(\"\\r\\n\", \" \").replace(\"\\n\", \" \").replace(\"\\t\", \" \")\n    return re.sub(r\"\\s+\", \" \", text).strip().lower()\n\n\ndef _add_affected(affected_scenes: list[str], scene_id: str) -> None:\n    if scene_id not in affected_scenes:\n        affected_scenes.append(scene_id)\n\n\ndef _tokenize(text: str) -> list[str]:\n    text = text.lower()\n    words = re.findall(r\"[\\w']+\", text)\n    return [w for w in words if len(w) > 0]\n"}],"isError":false,"timestamp":1775063649756}}
