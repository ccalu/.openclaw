{"type":"message","id":"183f21d3","parentId":"bbf3709a","timestamp":"2026-04-01T14:59:17.052Z","message":{"role":"toolResult","toolCallId":"call_QhlmDiZYBlHlNZy1QxecRbrF|fc_0785557c08065f410169cd32c335fc8190a1eec0e367279bbc","toolName":"exec","content":[{"type":"text","text":"BATCH sd_001\r\n{\"ok\": false, \"approved_for_merge\": false, \"batch_id\": \"sd_001\", \"classification\": \"batch_regenerate\", \"errors\": [{\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_01 narration_original does not match source span 1-68\", \"scene_ids\": [\"scene_01\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_02 narration_original does not match source span 69-125\", \"scene_ids\": [\"scene_02\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_03 narration_original does not match source span 126-182\", \"scene_ids\": [\"scene_03\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_04 narration_original does not match source span 183-238\", \"scene_ids\": [\"scene_04\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_05 narration_original does not match source span 239-254\", \"scene_ids\": [\"scene_05\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_06 narration_original does not match source span 255-317\", \"scene_ids\": [\"scene_06\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_07 narration_original does not match source span 318-402\", \"scene_ids\": [\"scene_07\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_08 narration_original does not match source span 403-437\", \"scene_ids\": [\"scene_08\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_09 narration_original does not match source span 438-497\", \"scene_ids\": [\"scene_09\"]}, {\"code\": \"narration_source_mismatch\", \"message\": \"Scene scene_10 narration_original does not match source span 498-568\", \"sce