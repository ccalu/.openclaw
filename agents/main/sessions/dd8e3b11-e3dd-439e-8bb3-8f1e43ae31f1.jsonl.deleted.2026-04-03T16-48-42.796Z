\content_factory_block2\\runtime_realcheck\\run_006\\upstream\\screenplay_analysis.json\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\architecture.md\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\inputs.md\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\operators.md\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\post_dispatch.md\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\runtime_layout.md\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\supervisor.md\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\supervisor_runtime_contract.md\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\workflow_bootstrap.md\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\contracts\\operator_dispatch_contract.md\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\contracts\\operator_registry.md\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\contracts\\supervisor_bootstrap_contract.md\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\helpers\\build_operator_dispatches.py\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\helpers\\compile_s3_entities.py\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\helpers\\emit_s3_b2_checkpoint.py\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\helpers\\generate_s3_sector_report.py\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\helpers\\validate_operator_output.py\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\schemas\\compiled_entities.schema.json\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_factory_block2\\S3\\schemas\\environment_location_output.schema.json\r\nC:\\Users\\User-OEM\\.openclaw\\workspace\\content_f