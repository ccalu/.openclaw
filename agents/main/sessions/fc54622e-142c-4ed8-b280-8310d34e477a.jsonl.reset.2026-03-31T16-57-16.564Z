{"type":"message","id":"90c48ec8","parentId":"e0a92078","timestamp":"2026-03-31T13:14:55.357Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_MiImZfh7IF0t2sFEkh6XTmSf|fc_09c2c7891525c9bd0169cbc8d160f881948dfc66442d8b81bb","name":"read","arguments":{"path":"C:/Users/User-OEM/Desktop/content-factory/auto_content_factory/runtime/s1/supervisor_skills/retry_planner.py"},"partialJson":"{\"path\":\"C:/Users/User-OEM/Desktop/content-factory/auto_content_factory/runtime/s1/supervisor_skills/retry_planner.py\"}"},{"type":"toolCall","id":"call_UIIK6jA7q8LaCFlTc0LLI21J|fc_09c2c7891525c9bd0169cbc8d1610c819486db0ed92a2cd89e","name":"read","arguments":{"path":"C:/Users/User-OEM/Desktop/content-factory/auto_content_factory/runtime/s1/supervisor_skills/scene_director_io_adapter.py"},"partialJson":"{\"path\":\"C:/Users/User-OEM/Desktop/content-factory/auto_content_factory/runtime/s1/supervisor_skills/scene_director_io_adapter.py\"}"},{"type":"toolCall","id":"call_DuyU8itpCvUsobW69Amgmhe8|fc_09c2c7891525c9bd0169cbc8d161148194921ba0f2b02ddf64","name":"read","arguments":{"path":"C:/Users/User-OEM/Desktop/content-factory/auto_content_factory/runtime/s1/supervisor_skills/screenplay_merger.py"},"partialJson":"{\"path\":\"C:/Users/User-OEM/Desktop/content-factory/auto_content_factory/runtime/s1/supervisor_skills/screenplay_merger.py\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":195,"output":140,"cacheRead":80768,"cacheWrite":0,"totalTokens":81103,"cost":{"input":0.00048750000000000003,"output":0.0021,"cacheRead":0.020191999999999998,"cacheWrite":0,"total":0.022779499999999998}},"stopReason":"toolUse","timestamp":1774962888615,"responseId":"resp_09c2c7891525c9bd0169cbc8cba35881948b489ff280bab1ad"}}
{"type":"message","id":"c5f219e1","parentId":"90c48ec8","timestamp":"2026-03-31T13:14:56.217Z","message":{"role":"toolResult","toolCallId":"call_MiImZfh7IF0t2sFEkh6XTmSf|fc_09c2c7891525c9bd0169cbc8d160f881948dfc66442d8b81bb","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nfrom typing import Any\n\n\nMAX_RETRIES_DEFAULT = 3\n\n\nFAIL_FAST_TYPES = {\n    \"preflight_structural_failure\",\n    \"missing_required_input\",\n    \"invalid_job_json\",\n    \"invalid_pipeline_state\",\n    \"empty_script\",\n    \"b1_already_complete\",\n}\n\nOPERATOR_RETRYABLE_TYPES = {\n    \"operator_timeout\",\n    \"operator_no_output\",\n    \"operator_output_missing\",\n    \"operator_invalid_json\",\n    \"operator_empty_output\",\n    \"operator_malformed_output\",\n}\n\nMERGE_RECOVERY_TYPES = {\n    \"missing_batch_file\",\n    \"invalid_batch_json\",\n    \"invalid_batch_scenes\",\n    \"missing_scene_fields\",\n    \"missing_polish_fields\",\n    \"missing_polish_scene\",\n}\n\nSEMANTIC_SCREENPLAY_TYPES = {\n    \"screenplay_validation_failed\",\n    \"coverage_too_low\",\n    \"missing_words_detected\",\n    \"extra_words_detected\",\n    \"duplicate_scene_content\",\n}\n\nSEMANTIC_POLISH_TYPES = {\n    \"polish_validation_failed\",\n    \"words_eaten\",\n    \"meaning_drift\",\n    \"unauthorized_additions\",\n}\n\nBUILDER_RETRYABLE_TYPES = {\n    \"scene_bible_write_failed\",\n    \"scene_bible_schema_invalid\",\n    \"scene_bible_builder_failed\",\n}\n\nINFRA_FAILURE_TYPES = {\n    \"filesystem_write_error\",\n    \"permission_error\",\n    \"disk_full\",\n}\n\n\ndef plan_retry(\n    *,\n    step_name: str,\n    failure_type: str,\n    retry_count: int,\n    affected_batches: list[str] | None = None,\n    affected_scenes: list[str] | None = None,\n    max_retries: int = MAX_RETRIES_DEFAULT,\n) -> dict[str, Any]:\n    affected_batches = affected_batches or []\n    affected_scenes = affected_scenes or []\n\n    if retry_count >= max_retries:\n        return _decision(\n            retry=False,\n            retry_mode=\"abort\",\n            targets=[],\n            reason=f\"Retry limit reached for step '{step_name}' ({retry_count}/{max_retries})\",\n            next_action=\"fail_sector\",\n        )\n\n    if failure_type in FAIL_FAST_TYPES:\n        return _decision(\n            retry=False,\n            retry_mode=\"abort\",\n            targets=[],\n            reason=f\"Structural failure '{failure_type}' should fail fast\",\n            next_action=\"fail_sector\",\n        )\n\n    if failure_type in OPERATOR_RETRYABLE_TYPES:\n        if affected_batches:\n            return _decision(\n                retry=True,\n                retry_mode=\"batch_subset\",\n                targets=affected_batches,\n                reason=f\"Operator execution failure '{failure_type}' — rerun affected batches\",\n                next_action=f\"rerun_{step_name}_batches\",\n            )\n        return _decision(\n            retry=True,\n            retry_mode=\"step\",\n            targets=[step_name],\n            reason=f\"Operator execution failure '{failure_type}' — rerun step\",\n            next_action=f\"rerun_{step_name}\",\n        )\n\n    if failure_type in MERGE_RECOVERY_TYPES:\n        if affected_batches:\n            return _decision(\n                retry=True,\n                retry_mode=\"batch_subset\",\n                targets=affected_batches,\n                reason=f\"Merge issue '{failure_type}' traced to missing/invalid batch outputs\",\n                next_action=\"rerun_affected_batches_then_merge\",\n            )\n        return _decision(\n            retry=False,\n            retry_mode=\"abort\",\n            targets=[],\n            reason=f\"Merge failure '{failure_type}' cannot be safely retried without affected batch mapping\",\n            next_action=\"fail_sector\",\n        )\n\n    if failure_type in SEMANTIC_SCREENPLAY_TYPES:\n        if affected_batches:\n            return _decision(\n                retry=True,\n                retry_mode=\"batch_subset\",\n                targets=affected_batches,\n                reason=f\"Screenplay semantic failure '{failure_type}' — rerun affected screenplay batches\",\n                next_action=\"rerun_scene_director_batches\",\n            )\n        return _decision(\n            retry=True,\n            retry_mode=\"step\",\n            targets=[\"scene_director\"],\n            reason=f\"Screenplay semantic failure '{failure_type}' — rerun screenplay step\",\n            next_action=\"rerun_scene_director_step\",\n        )\n\n    if failure_type in SEMANTIC_POLISH_TYPES:\n        if affected_batches:\n            return _decision(\n                retry=True,\n                retry_mode=\"batch_subset\",\n                targets=affected_batches,\n                reason=f\"Polish semantic failure '{failure_type}' — rerun affected polish batches\",\n                next_action=\"rerun_tts_polish_batches\",\n            )\n        return _decision(\n            retry=True,\n            retry_mode=\"step\",\n            targets=[\"tts_polish\"],\n            reason=f\"Polish semantic failure '{failure_type}' — rerun TTS polish step\",\n            next_action=\"rerun_tts_polish_step\",\n        )\n\n    if failure_type in BUILDER_RETRYABLE_TYPES:\n        return _decision(\n            retry=True,\n            retry_mode=\"step\",\n            targets=[\"scene_bible_builder\"],\n            reason=f\"Scene bible build failure '{failure_type}' — rerun builder step\",\n            next_action=\"rerun_scene_bible_builder\",\n        )\n\n    if failure_type in INFRA_FAILURE_TYPES:\n        return _decision(\n            retry=True,\n            retry_mode=\"step\",\n            targets=[step_name],\n            reason=f\"Infrastructure failure '{failure_type}' — allow one more controlled retry\",\n            next_action=f\"rerun_{step_name}\",\n        )\n\n    return _decision(\n        retry=False,\n        retry_mode=\"abort\",\n        targets=[],\n        reason=f\"Unknown failure type '{failure_type}' — abort by default for safety\",\n        next_action=\"fail_sector\",\n    )\n\n\ndef _decision(\n    *,\n    retry: bool,\n    retry_mode: str,\n    targets: list[str],\n    reason: str,\n    next_action: str,\n) -> dict[str, Any]:\n    return {\n        \"retry\": retry,\n        \"retry_mode\": retry_mode,\n        \"targets\": targets,\n        \"reason\": reason,\n        \"next_action\": next_action,\n    }\n"}],"isError":false,"timestamp":1774962896085}}
{"type":"message","id":"92bea78f","parentId":"c5f219e1","timestamp":"2026-03-31T13:14:56.352Z","message":{"role":"toolResult","toolCallId":"call_UIIK6jA7q8LaCFlTc0LLI21J|fc_09c2c7891525c9bd0169cbc8d1610c819486db0ed92a2cd89e","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\n\ndef build_scene_director_payload(\n    *,\n    run_root: str | Path,\n    job: dict[str, Any],\n    batch: dict[str, Any],\n    channel_config: dict[str, Any],\n    output_path: str | Path,\n) -> dict[str, Any]:\n    run_root = Path(run_root)\n    output_path = Path(output_path)\n\n    account = job.get(\"account\")\n    language = job.get(\"language\")\n    job_id = job.get(\"job_id\")\n\n    payload = {\n        \"job_id\": job_id,\n        \"account\": account,\n        \"language\": language,\n        \"run_root\": str(run_root),\n        \"batch\": {\n            \"batch_id\": batch.get(\"batch_id\"),\n            \"start_word\": batch.get(\"start_word\"),\n            \"end_word\": batch.get(\"end_word\"),\n            \"word_count\": batch.get(\"word_count\"),\n            \"text\": batch.get(\"text\"),\n        },\n        \"scene_words_range\": channel_config.get(\"scene_words_range\"),\n        \"style_context\": {\n            \"channel_name\": job.get(\"channel_name\"),\n            \"reason\": job.get(\"reason\"),\n        },\n        \"instructions\": {\n            \"task\": \"Divide this script batch into ordered scenes for screenplay generation.\",\n            \"requirements\": [\n                \"Preserve narrative meaning and order.\",\n                \"Return scene objects only for this batch.\",\n                \"Each scene must include scene_id, narration_original, visual_direction, mood, duration_estimate.\",\n                \"Do not rewrite the story beyond what is needed for clean scene segmentation.\",\n                \"Do not polish for TTS in this step.\",\n            ],\n        },\n        \"output_path\": str(output_path),\n    }\n\n    return payload\n\n\ndef write_scene_director_payload(\n    *,\n    run_root: str | Path,\n    job: dict[str, Any],\n    batch: dict[str, Any],\n    channel_config: dict[str, Any],\n    input_path: str | Path,\n    output_path: str | Path,\n) -> dict[str, Any]:\n    input_path = Path(input_path)\n    output_path = Path(output_path)\n    input_path.parent.mkdir(parents=True, exist_ok=True)\n    output_path.parent.mkdir(parents=True, exist_ok=True)\n\n    payload = build_scene_director_payload(\n        run_root=run_root,\n        job=job,\n        batch=batch,\n        channel_config=channel_config,\n        output_path=output_path,\n    )\n\n    input_path.write_text(json.dumps(payload, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    return {\n        \"ok\": True,\n        \"input_path\": str(input_path),\n        \"output_path\": str(output_path),\n        \"batch_id\": batch.get(\"batch_id\"),\n        \"payload\": payload,\n        \"errors\": [],\n        \"warnings\": [],\n    }\n"}],"isError":false,"timestamp":1774962896220}}
{"type":"message","id":"8513a7c8","parentId":"92bea78f","timestamp":"2026-03-31T13:14:56.490Z","message":{"role":"toolResult","toolCallId":"call_DuyU8itpCvUsobW69Amgmhe8|fc_09c2c7891525c9bd0169cbc8d161148194921ba0f2b02ddf64","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\n\nREQUIRED_SCENE_FIELDS = {\n    \"scene_id\",\n    \"narration_original\",\n    \"visual_direction\",\n    \"mood\",\n    \"duration_estimate\",\n}\n\n\ndef merge_screenplay_batches(\n    batch_files: list[str | Path],\n    *,\n    output_path: str | Path | None = None,\n) -> dict[str, Any]:\n    errors: list[dict[str, str]] = []\n    warnings: list[dict[str, str]] = []\n    merged_scenes: list[dict[str, Any]] = []\n    loaded_batches: list[dict[str, Any]] = []\n\n    ordered_files = sorted([Path(p) for p in batch_files], key=lambda p: p.name)\n    if not ordered_files:\n        return {\n            \"ok\": False,\n            \"scene_count\": 0,\n            \"screenplay\": {\"scenes\": []},\n            \"errors\": [{\"code\": \"no_batch_files\", \"message\": \"No scene_director batch files provided\"}],\n            \"warnings\": [],\n        }\n\n    for file_path in ordered_files:\n        if not file_path.exists():\n            errors.append({\n                \"code\": \"missing_batch_file\",\n                \"message\": f\"Batch output file not found: {file_path}\",\n            })\n            continue\n\n        try:\n            payload = json.loads(file_path.read_text(encoding=\"utf-8\"))\n        except Exception as exc:  # noqa: BLE001\n            errors.append({\n                \"code\": \"invalid_batch_json\",\n                \"message\": f\"Failed to parse batch file {file_path}: {exc}\",\n            })\n            continue\n\n        batch_id = payload.get(\"batch_id\")\n        scenes = payload.get(\"scenes\", [])\n        if not isinstance(scenes, list):\n            errors.append({\n                \"code\": \"invalid_batch_scenes\",\n                \"message\": f\"Batch file {file_path} has invalid 'scenes' payload\",\n            })\n            continue\n\n        if not scenes:\n            warnings.append({\n                \"code\": \"empty_batch_scenes\",\n                \"message\": f\"Batch file {file_path} produced zero scenes\",\n            })\n\n        loaded_batches.append({\n            \"batch_id\": batch_id,\n            \"file_path\": str(file_path),\n            \"scene_count\": len(scenes),\n        })\n\n        for index_in_batch, scene in enumerate(scenes, start=1):\n            if not isinstance(scene, dict):\n                errors.append({\n                    \"code\": \"invalid_scene_payload\",\n                    \"message\": f\"Batch {batch_id or file_path.name} contains a non-object scene entry\",\n                })\n                continue\n\n            missing_fields = sorted(REQUIRED_SCENE_FIELDS - set(scene.keys()))\n            if missing_fields:\n                errors.append({\n                    \"code\": \"missing_scene_fields\",\n                    \"message\": (\n                        f\"Batch {batch_id or file_path.name} scene {index_in_batch} \"\n                        f\"is missing required fields: {', '.join(missing_fields)}\"\n                    ),\n                })\n                continue\n\n            merged_scenes.append(\n                {\n                    \"source_batch_id\": batch_id,\n                    \"source_batch_scene_index\": index_in_batch,\n                    **scene,\n                }\n            )\n\n    for global_index, scene in enumerate(merged_scenes, start=1):\n        scene[\"scene_id\"] = f\"scene_{global_index:03d}\"\n\n    screenplay = {\n        \"scene_count\": len(merged_scenes),\n        \"scenes\": merged_scenes,\n    }\n\n    if output_path is not None:\n        output_path = Path(output_path)\n        output_path.parent.mkdir(parents=True, exist_ok=True)\n        output_path.write_text(json.dumps(screenplay, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    return {\n        \"ok\": len(errors) == 0,\n        \"scene_count\": len(merged_scenes),\n        \"batch_count\": len(loaded_batches),\n        \"screenplay\": screenplay,\n        \"loaded_batches\": loaded_batches,\n        \"output_path\": str(output_path) if output_path is not None else None,\n        \"errors\": errors,\n        \"warnings\": warnings,\n    }\n"}],"isError":false,"timestamp":1774962896352}}
{"type":"message","id":"44c1f430","parentId":"8513a7c8","timestamp":"2026-03-31T13:16:29.744Z","message":{"role":"assistant","content":[{"type":"text","text":"Vou criar a v1 da skill alinhada com o estilo actual do runtime, mas já adaptada aos contracts novos que definimos.","textSignature":"{\"v\":1,\"id\":\"msg_09c2c7891525c9bd0169cbc8da194c81949ab12e54314341e6\",\"phase\":\"commentary\"}"},{"type":"toolCall","id":"call_LrTpA5F0sojxuMfp0QE94VYN|fc_09c2c7891525c9bd0169cbc8dafb908194af09cb329a62a714","name":"write","arguments":{"path":"C:/Users/User-OEM/Desktop/content-factory/auto_content_factory/runtime/s1/supervisor_skills/scene_director_output_validator.py","content":"from __future__ import annotations\n\nimport json\nimport re\nfrom pathlib import Path\nfrom typing import Any\n\n\nREQUIRED_TOP_LEVEL_FIELDS = {\n    \"batch_id\",\n    \"operator\",\n    \"scenes\",\n}\n\nREQUIRED_SCENE_FIELDS = {\n    \"scene_local_id\",\n    \"scene_title\",\n    \"scene_summary\",\n    \"narrative_function\",\n    \"narration_original\",\n    \"start_word\",\n    \"end_word\",\n    \"estimated_scene_word_count\",\n}\n\nERROR_SEVERITY = {\n    \"payload_unreadable\": \"fatal_contract_error\",\n    \"output_unreadable\": \"fatal_contract_error\",\n    \"invalid_top_level_shape\": \"fatal_contract_error\",\n    \"empty_scenes\": \"fatal_contract_error\",\n    \"missing_required_field\": \"structural_patch\",\n    \"duplicate_scene_local_id\": \"structural_patch\",\n    \"non_sequential_scene_local_id\": \"structural_patch\",\n    \"invalid_scene_span\": \"batch_repair\",\n    \"scene_overlap_detected\": \"batch_repair\",\n    \"missing_coverage_detected\": \"batch_repair\",\n    \"duplicate_coverage_detected\": \"batch_repair\",\n    \"narration_source_mismatch\": \"batch_repair\",\n    \"estimated_word_count_mismatch\": \"structural_patch\",\n}\n\nCLASSIFICATION_PRIORITY = [\n    \"fatal_contract_error\",\n    \"batch_regenerate\",\n    \"batch_repair\",\n    \"structural_patch\",\n    \"ok\",\n]\n\n\ndef validate_scene_director_output(\n    *,\n    batch_payload_path: str | Path,\n    batch_output_path: str | Path,\n) -> dict[str, Any]:\n    errors: list[dict[str, Any]] = []\n    warnings: list[dict[str, Any]] = []\n\n    payload_result = _load_json(batch_payload_path, error_code=\"payload_unreadable\")\n    if not payload_result[\"ok\"]:\n        return _fatal_result(\n            batch_id=None,\n            errors=payload_result[\"errors\"],\n            warnings=warnings,\n        )\n\n    output_result = _load_json(batch_output_path, error_code=\"output_unreadable\")\n    if not output_result[\"ok\"]:\n        payload = payload_result[\"data\"]\n        batch_id = _extract_batch_id_from_payload(payload)\n        return _fatal_result(\n            batch_id=batch_id,\n            errors=output_result[\"errors\"],\n            warnings=warnings,\n        )\n\n    payload = payload_result[\"data\"]\n    output = output_result[\"data\"]\n\n    batch_id = _extract_batch_id(output) or _extract_batch_id_from_payload(payload)\n\n    source_batch = payload.get(\"batch\") if isinstance(payload, dict) else None\n    if not isinstance(source_batch, dict):\n        errors.append(_error(\n            code=\"invalid_top_level_shape\",\n            message=\"Batch payload must include a 'batch' object\",\n        ))\n        return _finalize_result(\n            batch_id=batch_id,\n            errors=errors,\n            warnings=warnings,\n            scenes=[],\n            source_tokens=[],\n            expected_batch_id=_extract_batch_id_from_payload(payload),\n        )\n\n    source_text = source_batch.get(\"text\")\n    if not isinstance(source_text, str) or not source_text.strip():\n        errors.append(_error(\n            code=\"invalid_top_level_shape\",\n            message=\"Batch payload must include non-empty batch.text\",\n        ))\n        return _finalize_result(\n            batch_id=batch_id,\n            errors=errors,\n            warnings=warnings,\n            scenes=[],\n            source_tokens=[],\n            expected_batch_id=_extract_batch_id_from_payload(payload),\n        )\n\n    scenes = _validate_top_level_output(output, errors)\n    if not scenes:\n        return _finalize_result(\n            batch_id=batch_id,\n            errors=errors,\n            warnings=warnings,\n            scenes=[],\n            source_tokens=_tokenize_text(source_text),\n            expected_batch_id=_extract_batch_id_from_payload(payload),\n        )\n\n    _validate_batch_id_match(output, payload, errors)\n    _validate_required_scene_fields(scenes, errors)\n    _validate_scene_local_ids(scenes, errors)\n    _validate_scene_spans(scenes, errors)\n\n    source_tokens = _tokenize_text(source_text)\n    _validate_coverage(scenes, len(source_tokens), errors)\n    _validate_narration_fidelity(scenes, source_tokens, errors)\n    _validate_estimated_word_counts(scenes, errors)\n\n    return _finalize_result(\n        batch_id=batch_id,\n        errors=errors,\n        warnings=warnings,\n        scenes=scenes,\n        source_tokens=source_tokens,\n        expected_batch_id=_extract_batch_id_from_payload(payload),\n    )\n\n\ndef _load_json(path: str | Path, *, error_code: str) -> dict[str, Any]:\n    path = Path(path)\n    try:\n        data = json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception as exc:  # noqa: BLE001\n        return {\n            \"ok\": False,\n            \"errors\": [_error(error_code, f\"Failed to read JSON from {path}: {exc}\")],\n        }\n    return {\n        \"ok\": True,\n        \"data\": data,\n    }\n\n\ndef _validate_top_level_output(output: Any, errors: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    if not isinstance(output, dict):\n        errors.append(_error(\n            code=\"invalid_top_level_shape\",\n            message=\"Scene director output must be a JSON object\",\n        ))\n        return []\n\n    missing_top_level = sorted(REQUIRED_TOP_LEVEL_FIELDS - set(output.keys()))\n    if missing_top_level:\n        errors.append(_error(\n            code=\"invalid_top_level_shape\",\n            message=f\"Output is missing top-level fields: {', '.join(missing_top_level)}\",\n        ))\n\n    scenes = output.get(\"scenes\")\n    if not isinstance(scenes, list):\n        errors.append(_error(\n            code=\"invalid_top_level_shape\",\n            message=\"Output 'scenes' must be a list\",\n        ))\n        return []\n\n    if not scenes:\n        errors.append(_error(\n            code=\"empty_scenes\",\n            message=\"Output 'scenes' list is empty\",\n        ))\n        return []\n\n    valid_scenes: list[dict[str, Any]] = []\n    for index, scene in enumerate(scenes, start=1):\n        if not isinstance(scene, dict):\n            errors.append(_error(\n                code=\"missing_required_field\",\n                message=f\"Scene at index {index} must be an object\",\n                scene_ids=[f\"scene_index_{index}\"],\n            ))\n            continue\n        valid_scenes.append(scene)\n\n    return valid_scenes\n\n\ndef _validate_batch_id_match(output: dict[str, Any], payload: dict[str, Any], errors: list[dict[str, Any]]) -> None:\n    output_batch_id = _extract_batch_id(output)\n    expected_batch_id = _extract_batch_id_from_payload(payload)\n    if output_batch_id and expected_batch_id and output_batch_id != expected_batch_id:\n        errors.append(_error(\n            code=\"missing_required_field\",\n            message=f\"Output batch_id '{output_batch_id}' does not match expected '{expected_batch_id}'\",\n        ))\n\n\ndef _validate_required_scene_fields(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\n    for scene in scenes:\n        missing_fields = sorted(REQUIRED_SCENE_FIELDS - set(scene.keys()))\n        if missing_fields:\n            errors.append(_error(\n                code=\"missing_required_field\",\n                message=(\n                    f\"Scene {scene.get('scene_local_id', '<unknown>')} is missing required fields: \"\n                    f\"{', '.join(missing_fields)}\"\n                ),\n                scene_ids=[scene.get(\"scene_local_id\")],\n            ))\n\n\ndef _validate_scene_local_ids(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\n    seen: set[str] = set()\n    expected_index = 1\n\n    for scene in scenes:\n        scene_local_id = scene.get(\"scene_local_id\")\n        if not isinstance(scene_local_id, str):\n            continue\n\n        if scene_local_id in seen:\n            errors.append(_error(\n                code=\"duplicate_scene_local_id\",\n                message=f\"Duplicate scene_local_id detected: {scene_local_id}\",\n                scene_ids=[scene_local_id],\n            ))\n        else:\n            seen.add(scene_local_id)\n\n        expected_id = f\"scene_{expected_index:02d}\"\n        if scene_local_id != expected_id:\n            errors.append(_error(\n                code=\"non_sequential_scene_local_id\",\n                message=f\"Expected {expected_id} but found {scene_local_id}\",\n                scene_ids=[scene_local_id],\n            ))\n        expected_index += 1\n\n\ndef _validate_scene_spans(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\n    previous_end: int | None = None\n    previous_scene_id: str | None = None\n\n    for scene in scenes:\n        scene_id = scene.get(\"scene_local_id\")\n        start_word = scene.get(\"start_word\")\n        end_word = scene.get(\"end_word\")\n\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\n            errors.append(_error(\n                code=\"invalid_scene_span\",\n                message=f\"Scene {scene_id} must have integer start_word/end_word\",\n                scene_ids=[scene_id],\n            ))\n            continue\n\n        if start_word < 1 or end_word < 1 or start_word > end_word:\n            errors.append(_error(\n                code=\"invalid_scene_span\",\n                message=f\"Scene {scene_id} has invalid span ({start_word}-{end_word})\",\n                scene_ids=[scene_id],\n            ))\n            continue\n\n        if previous_end is not None and start_word <= previous_end:\n            errors.append(_error(\n                code=\"scene_overlap_detected\",\n                message=(\n                    f\"Scene {scene_id} overlaps with {previous_scene_id} \"\n                    f\"({start_word} <= previous end {previous_end})\"\n                ),\n                scene_ids=[previous_scene_id, scene_id],\n            ))\n\n        previous_end = end_word\n        previous_scene_id = scene_id\n\n\ndef _validate_coverage(scenes: list[dict[str, Any]], source_word_count: int, errors: list[dict[str, Any]]) -> None:\n    if source_word_count == 0:\n        return\n\n    coverage = [0] * source_word_count\n\n    for scene in scenes:\n        start_word = scene.get(\"start_word\")\n        end_word = scene.get(\"end_word\")\n        scene_id = scene.get(\"scene_local_id\")\n\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\n            continue\n        if start_word < 1 or end_word > source_word_count or start_word > end_word:\n            errors.append(_error(\n                code=\"invalid_scene_span\",\n                message=(\n                    f\"Scene {scene_id} span ({start_word}-{end_word}) is outside batch-relative range \"\n                    f\"1-{source_word_count}\"\n                ),\n                scene_ids=[scene_id],\n            ))\n            continue\n\n        for index in range(start_word - 1, end_word):\n            coverage[index] += 1\n\n    missing_ranges = _collect_ranges([i + 1 for i, count in enumerate(coverage) if count == 0])\n    duplicate_ranges = _collect_ranges([i + 1 for i, count in enumerate(coverage) if count > 1])\n\n    for start_word, end_word in missing_ranges:\n        errors.append(_error(\n            code=\"missing_coverage_detected\",\n            message=f\"Words {start_word}-{end_word} are not assigned to any scene\",\n        ))\n\n    for start_word, end_word in duplicate_ranges:\n        errors.append(_error(\n            code=\"duplicate_coverage_detected\",\n            message=f\"Words {start_word}-{end_word} are assigned to multiple scenes\",\n        ))\n\n\ndef _validate_narration_fidelity(\n    scenes: list[dict[str, Any]],\n    source_tokens: list[str],\n    errors: list[dict[str, Any]],\n) -> None:\n    for scene in scenes:\n        scene_id = scene.get(\"scene_local_id\")\n        start_word = scene.get(\"start_word\")\n        end_word = scene.get(\"end_word\")\n        narration_original = scene.get(\"narration_original\")\n\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\n            continue\n        if not isinstance(narration_original, str):\n            continue\n        if start_word < 1 or end_word > len(source_tokens) or start_word > end_word:\n            continue\n\n        source_span_text = \" \".join(source_tokens[start_word - 1:end_word])\n        if _normalize_text(narration_original) != _normalize_text(source_span_text):\n            errors.append(_error(\n                code=\"narration_source_mismatch\",\n                message=f\"Scene {scene_id} narration_original does not match source span {start_word}-{end_word}\",\n                scene_ids=[scene_id],\n            ))\n\n\ndef _validate_estimated_word_counts(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\n    for scene in scenes:\n        scene_id = scene.get(\"scene_local_id\")\n        start_word = scene.get(\"start_word\")\n        end_word = scene.get(\"end_word\")\n        estimated_scene_word_count = scene.get(\"estimated_scene_word_count\")\n\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\n            continue\n        if not isinstance(estimated_scene_word_count, int):\n            errors.append(_error(\n                code=\"estimated_word_count_mismatch\",\n                message=f\"Scene {scene_id} must have integer estimated_scene_word_count\",\n                scene_ids=[scene_id],\n            ))\n            continue\n\n        actual_count = end_word - start_word + 1\n        if estimated_scene_word_count != actual_count:\n            errors.append(_error(\n                code=\"estimated_word_count_mismatch\",\n                message=(\n                    f\"Scene {scene_id} estimated_scene_word_count={estimated_scene_word_count} \"\n                    f\"but span implies {actual_count}\"\n                ),\n                scene_ids=[scene_id],\n            ))\n\n\ndef _tokenize_text(text: str) -> list[str]:\n    normalized = _normalize_text(text)\n    if not normalized:\n        return []\n    return normalized.split(\" \")\n\n\ndef _normalize_text(text: str) -> str:\n    text = text.replace(\"\\r\\n\", \" \").replace(\"\\n\", \" \").replace(\"\\t\", \" \")\n    text = re.sub(r\"\\s+\", \" \", text).strip()\n    return text\n\n\ndef _collect_ranges(word_indices: list[int]) -> list[tuple[int, int]]:\n    if not word_indices:\n        return []\n\n    ranges: list[tuple[int, int]] = []\n    start = word_indices[0]\n    previous = word_indices[0]\n\n    for current in word_indices[1:]:\n        if current == previous + 1:\n            previous = current\n            continue\n        ranges.append((start, previous))\n        start = current\n        previous = current\n\n    ranges.append((start, previous))\n    return ranges\n\n\ndef _extract_batch_id(output: dict[str, Any]) -> str | None:\n    batch_id = output.get(\"batch_id\")\n    return batch_id if isinstance(batch_id, str) and batch_id.strip() else None\n\n\ndef _extract_batch_id_from_payload(payload: dict[str, Any]) -> str | None:\n    batch = payload.get(\"batch\") if isinstance(payload, dict) else None\n    if not isinstance(batch, dict):\n        return None\n    batch_id = batch.get(\"batch_id\")\n    return batch_id if isinstance(batch_id, str) and batch_id.strip() else None\n\n\ndef _error(\n    code: str,\n    message: str,\n    *,\n    scene_ids: list[str | None] | None = None,\n) -> dict[str, Any]:\n    clean_scene_ids = [scene_id for scene_id in (scene_ids or []) if scene_id]\n    payload: dict[str, Any] = {\n        \"code\": code,\n        \"message\": message,\n    }\n    if clean_scene_ids:\n        payload[\"scene_ids\"] = clean_scene_ids\n    return payload\n\n\ndef _fatal_result(\n    *,\n    batch_id: str | None,\n    errors: list[dict[str, Any]],\n    warnings: list[dict[str, Any]],\n) -> dict[str, Any]:\n    return {\n        \"ok\": False,\n        \"approved_for_merge\": False,\n        \"batch_id\": batch_id,\n        \"classification\": \"fatal_contract_error\",\n        \"errors\": errors,\n        \"warnings\": warnings,\n        \"stats\": {\n            \"scene_count\": 0,\n            \"source_word_count\": 0,\n            \"covered_word_count\": 0,\n        },\n    }\n\n\ndef _finalize_result(\n    *,\n    batch_id: str | None,\n    errors: list[dict[str, Any]],\n    warnings: list[dict[str, Any]],\n    scenes: list[dict[str, Any]],\n    source_tokens: list[str],\n    expected_batch_id: str | None,\n) -> dict[str, Any]:\n    classification = _classify_errors(errors)\n    covered_word_count = _compute_covered_word_count(scenes, len(source_tokens))\n\n    if batch_id is None:\n        batch_id = expected_batch_id\n\n    return {\n        \"ok\": classification == \"ok\",\n        \"approved_for_merge\": classification == \"ok\",\n        \"batch_id\": batch_id,\n        \"classification\": classification,\n        \"errors\": errors,\n        \"warnings\": warnings,\n        \"stats\": {\n            \"scene_count\": len(scenes),\n            \"source_word_count\": len(source_tokens),\n            \"covered_word_count\": covered_word_count,\n        },\n    }\n\n\ndef _classify_errors(errors: list[dict[str, Any]]) -> str:\n    if not errors:\n        return \"ok\"\n\n    severities = [ERROR_SEVERITY.get(error.get(\"code\"), \"fatal_contract_error\") for error in errors]\n\n    if \"fatal_contract_error\" in severities:\n        return \"fatal_contract_error\"\n\n    repair_like_count = sum(1 for severity in severities if severity == \"batch_repair\")\n    if repair_like_count >= 3:\n        return \"batch_regenerate\"\n    if repair_like_count >= 1:\n        return \"batch_repair\"\n    if \"structural_patch\" in severities:\n        return \"structural_patch\"\n\n    for classification in CLASSIFICATION_PRIORITY:\n        if classification in severities:\n            return classification\n\n    return \"fatal_contract_error\"\n\n\ndef _compute_covered_word_count(scenes: list[dict[str, Any]], source_word_count: int) -> int:\n    if source_word_count <= 0:\n        return 0\n\n    covered: set[int] = set()\n    for scene in scenes:\n        start_word = scene.get(\"start_word\")\n        end_word = scene.get(\"end_word\")\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\n            continue\n        if start_word < 1 or end_word < 1 or start_word > end_word:\n            continue\n        for index in range(max(1, start_word), min(source_word_count, end_word) + 1):\n            covered.add(index)\n\n    return len(covered)\n"},"partialJson":"{\"path\":\"C:/Users/User-OEM/Desktop/content-factory/auto_content_factory/runtime/s1/supervisor_skills/scene_director_output_validator.py\",\"content\":\"from __future__ import annotations\\n\\nimport json\\nimport re\\nfrom pathlib import Path\\nfrom typing import Any\\n\\n\\nREQUIRED_TOP_LEVEL_FIELDS = {\\n    \\\"batch_id\\\",\\n    \\\"operator\\\",\\n    \\\"scenes\\\",\\n}\\n\\nREQUIRED_SCENE_FIELDS = {\\n    \\\"scene_local_id\\\",\\n    \\\"scene_title\\\",\\n    \\\"scene_summary\\\",\\n    \\\"narrative_function\\\",\\n    \\\"narration_original\\\",\\n    \\\"start_word\\\",\\n    \\\"end_word\\\",\\n    \\\"estimated_scene_word_count\\\",\\n}\\n\\nERROR_SEVERITY = {\\n    \\\"payload_unreadable\\\": \\\"fatal_contract_error\\\",\\n    \\\"output_unreadable\\\": \\\"fatal_contract_error\\\",\\n    \\\"invalid_top_level_shape\\\": \\\"fatal_contract_error\\\",\\n    \\\"empty_scenes\\\": \\\"fatal_contract_error\\\",\\n    \\\"missing_required_field\\\": \\\"structural_patch\\\",\\n    \\\"duplicate_scene_local_id\\\": \\\"structural_patch\\\",\\n    \\\"non_sequential_scene_local_id\\\": \\\"structural_patch\\\",\\n    \\\"invalid_scene_span\\\": \\\"batch_repair\\\",\\n    \\\"scene_overlap_detected\\\": \\\"batch_repair\\\",\\n    \\\"missing_coverage_detected\\\": \\\"batch_repair\\\",\\n    \\\"duplicate_coverage_detected\\\": \\\"batch_repair\\\",\\n    \\\"narration_source_mismatch\\\": \\\"batch_repair\\\",\\n    \\\"estimated_word_count_mismatch\\\": \\\"structural_patch\\\",\\n}\\n\\nCLASSIFICATION_PRIORITY = [\\n    \\\"fatal_contract_error\\\",\\n    \\\"batch_regenerate\\\",\\n    \\\"batch_repair\\\",\\n    \\\"structural_patch\\\",\\n    \\\"ok\\\",\\n]\\n\\n\\ndef validate_scene_director_output(\\n    *,\\n    batch_payload_path: str | Path,\\n    batch_output_path: str | Path,\\n) -> dict[str, Any]:\\n    errors: list[dict[str, Any]] = []\\n    warnings: list[dict[str, Any]] = []\\n\\n    payload_result = _load_json(batch_payload_path, error_code=\\\"payload_unreadable\\\")\\n    if not payload_result[\\\"ok\\\"]:\\n        return _fatal_result(\\n            batch_id=None,\\n            errors=payload_result[\\\"errors\\\"],\\n            warnings=warnings,\\n        )\\n\\n    output_result = _load_json(batch_output_path, error_code=\\\"output_unreadable\\\")\\n    if not output_result[\\\"ok\\\"]:\\n        payload = payload_result[\\\"data\\\"]\\n        batch_id = _extract_batch_id_from_payload(payload)\\n        return _fatal_result(\\n            batch_id=batch_id,\\n            errors=output_result[\\\"errors\\\"],\\n            warnings=warnings,\\n        )\\n\\n    payload = payload_result[\\\"data\\\"]\\n    output = output_result[\\\"data\\\"]\\n\\n    batch_id = _extract_batch_id(output) or _extract_batch_id_from_payload(payload)\\n\\n    source_batch = payload.get(\\\"batch\\\") if isinstance(payload, dict) else None\\n    if not isinstance(source_batch, dict):\\n        errors.append(_error(\\n            code=\\\"invalid_top_level_shape\\\",\\n            message=\\\"Batch payload must include a 'batch' object\\\",\\n        ))\\n        return _finalize_result(\\n            batch_id=batch_id,\\n            errors=errors,\\n            warnings=warnings,\\n            scenes=[],\\n            source_tokens=[],\\n            expected_batch_id=_extract_batch_id_from_payload(payload),\\n        )\\n\\n    source_text = source_batch.get(\\\"text\\\")\\n    if not isinstance(source_text, str) or not source_text.strip():\\n        errors.append(_error(\\n            code=\\\"invalid_top_level_shape\\\",\\n            message=\\\"Batch payload must include non-empty batch.text\\\",\\n        ))\\n        return _finalize_result(\\n            batch_id=batch_id,\\n            errors=errors,\\n            warnings=warnings,\\n            scenes=[],\\n            source_tokens=[],\\n            expected_batch_id=_extract_batch_id_from_payload(payload),\\n        )\\n\\n    scenes = _validate_top_level_output(output, errors)\\n    if not scenes:\\n        return _finalize_result(\\n            batch_id=batch_id,\\n            errors=errors,\\n            warnings=warnings,\\n            scenes=[],\\n            source_tokens=_tokenize_text(source_text),\\n            expected_batch_id=_extract_batch_id_from_payload(payload),\\n        )\\n\\n    _validate_batch_id_match(output, payload, errors)\\n    _validate_required_scene_fields(scenes, errors)\\n    _validate_scene_local_ids(scenes, errors)\\n    _validate_scene_spans(scenes, errors)\\n\\n    source_tokens = _tokenize_text(source_text)\\n    _validate_coverage(scenes, len(source_tokens), errors)\\n    _validate_narration_fidelity(scenes, source_tokens, errors)\\n    _validate_estimated_word_counts(scenes, errors)\\n\\n    return _finalize_result(\\n        batch_id=batch_id,\\n        errors=errors,\\n        warnings=warnings,\\n        scenes=scenes,\\n        source_tokens=source_tokens,\\n        expected_batch_id=_extract_batch_id_from_payload(payload),\\n    )\\n\\n\\ndef _load_json(path: str | Path, *, error_code: str) -> dict[str, Any]:\\n    path = Path(path)\\n    try:\\n        data = json.loads(path.read_text(encoding=\\\"utf-8\\\"))\\n    except Exception as exc:  # noqa: BLE001\\n        return {\\n            \\\"ok\\\": False,\\n            \\\"errors\\\": [_error(error_code, f\\\"Failed to read JSON from {path}: {exc}\\\")],\\n        }\\n    return {\\n        \\\"ok\\\": True,\\n        \\\"data\\\": data,\\n    }\\n\\n\\ndef _validate_top_level_output(output: Any, errors: list[dict[str, Any]]) -> list[dict[str, Any]]:\\n    if not isinstance(output, dict):\\n        errors.append(_error(\\n            code=\\\"invalid_top_level_shape\\\",\\n            message=\\\"Scene director output must be a JSON object\\\",\\n        ))\\n        return []\\n\\n    missing_top_level = sorted(REQUIRED_TOP_LEVEL_FIELDS - set(output.keys()))\\n    if missing_top_level:\\n        errors.append(_error(\\n            code=\\\"invalid_top_level_shape\\\",\\n            message=f\\\"Output is missing top-level fields: {', '.join(missing_top_level)}\\\",\\n        ))\\n\\n    scenes = output.get(\\\"scenes\\\")\\n    if not isinstance(scenes, list):\\n        errors.append(_error(\\n            code=\\\"invalid_top_level_shape\\\",\\n            message=\\\"Output 'scenes' must be a list\\\",\\n        ))\\n        return []\\n\\n    if not scenes:\\n        errors.append(_error(\\n            code=\\\"empty_scenes\\\",\\n            message=\\\"Output 'scenes' list is empty\\\",\\n        ))\\n        return []\\n\\n    valid_scenes: list[dict[str, Any]] = []\\n    for index, scene in enumerate(scenes, start=1):\\n        if not isinstance(scene, dict):\\n            errors.append(_error(\\n                code=\\\"missing_required_field\\\",\\n                message=f\\\"Scene at index {index} must be an object\\\",\\n                scene_ids=[f\\\"scene_index_{index}\\\"],\\n            ))\\n            continue\\n        valid_scenes.append(scene)\\n\\n    return valid_scenes\\n\\n\\ndef _validate_batch_id_match(output: dict[str, Any], payload: dict[str, Any], errors: list[dict[str, Any]]) -> None:\\n    output_batch_id = _extract_batch_id(output)\\n    expected_batch_id = _extract_batch_id_from_payload(payload)\\n    if output_batch_id and expected_batch_id and output_batch_id != expected_batch_id:\\n        errors.append(_error(\\n            code=\\\"missing_required_field\\\",\\n            message=f\\\"Output batch_id '{output_batch_id}' does not match expected '{expected_batch_id}'\\\",\\n        ))\\n\\n\\ndef _validate_required_scene_fields(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\\n    for scene in scenes:\\n        missing_fields = sorted(REQUIRED_SCENE_FIELDS - set(scene.keys()))\\n        if missing_fields:\\n            errors.append(_error(\\n                code=\\\"missing_required_field\\\",\\n                message=(\\n                    f\\\"Scene {scene.get('scene_local_id', '<unknown>')} is missing required fields: \\\"\\n                    f\\\"{', '.join(missing_fields)}\\\"\\n                ),\\n                scene_ids=[scene.get(\\\"scene_local_id\\\")],\\n            ))\\n\\n\\ndef _validate_scene_local_ids(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\\n    seen: set[str] = set()\\n    expected_index = 1\\n\\n    for scene in scenes:\\n        scene_local_id = scene.get(\\\"scene_local_id\\\")\\n        if not isinstance(scene_local_id, str):\\n            continue\\n\\n        if scene_local_id in seen:\\n            errors.append(_error(\\n                code=\\\"duplicate_scene_local_id\\\",\\n                message=f\\\"Duplicate scene_local_id detected: {scene_local_id}\\\",\\n                scene_ids=[scene_local_id],\\n            ))\\n        else:\\n            seen.add(scene_local_id)\\n\\n        expected_id = f\\\"scene_{expected_index:02d}\\\"\\n        if scene_local_id != expected_id:\\n            errors.append(_error(\\n                code=\\\"non_sequential_scene_local_id\\\",\\n                message=f\\\"Expected {expected_id} but found {scene_local_id}\\\",\\n                scene_ids=[scene_local_id],\\n            ))\\n        expected_index += 1\\n\\n\\ndef _validate_scene_spans(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\\n    previous_end: int | None = None\\n    previous_scene_id: str | None = None\\n\\n    for scene in scenes:\\n        scene_id = scene.get(\\\"scene_local_id\\\")\\n        start_word = scene.get(\\\"start_word\\\")\\n        end_word = scene.get(\\\"end_word\\\")\\n\\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\\n            errors.append(_error(\\n                code=\\\"invalid_scene_span\\\",\\n                message=f\\\"Scene {scene_id} must have integer start_word/end_word\\\",\\n                scene_ids=[scene_id],\\n            ))\\n            continue\\n\\n        if start_word < 1 or end_word < 1 or start_word > end_word:\\n            errors.append(_error(\\n                code=\\\"invalid_scene_span\\\",\\n                message=f\\\"Scene {scene_id} has invalid span ({start_word}-{end_word})\\\",\\n                scene_ids=[scene_id],\\n            ))\\n            continue\\n\\n        if previous_end is not None and start_word <= previous_end:\\n            errors.append(_error(\\n                code=\\\"scene_overlap_detected\\\",\\n                message=(\\n                    f\\\"Scene {scene_id} overlaps with {previous_scene_id} \\\"\\n                    f\\\"({start_word} <= previous end {previous_end})\\\"\\n                ),\\n                scene_ids=[previous_scene_id, scene_id],\\n            ))\\n\\n        previous_end = end_word\\n        previous_scene_id = scene_id\\n\\n\\ndef _validate_coverage(scenes: list[dict[str, Any]], source_word_count: int, errors: list[dict[str, Any]]) -> None:\\n    if source_word_count == 0:\\n        return\\n\\n    coverage = [0] * source_word_count\\n\\n    for scene in scenes:\\n        start_word = scene.get(\\\"start_word\\\")\\n        end_word = scene.get(\\\"end_word\\\")\\n        scene_id = scene.get(\\\"scene_local_id\\\")\\n\\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\\n            continue\\n        if start_word < 1 or end_word > source_word_count or start_word > end_word:\\n            errors.append(_error(\\n                code=\\\"invalid_scene_span\\\",\\n                message=(\\n                    f\\\"Scene {scene_id} span ({start_word}-{end_word}) is outside batch-relative range \\\"\\n                    f\\\"1-{source_word_count}\\\"\\n                ),\\n                scene_ids=[scene_id],\\n            ))\\n            continue\\n\\n        for index in range(start_word - 1, end_word):\\n            coverage[index] += 1\\n\\n    missing_ranges = _collect_ranges([i + 1 for i, count in enumerate(coverage) if count == 0])\\n    duplicate_ranges = _collect_ranges([i + 1 for i, count in enumerate(coverage) if count > 1])\\n\\n    for start_word, end_word in missing_ranges:\\n        errors.append(_error(\\n            code=\\\"missing_coverage_detected\\\",\\n            message=f\\\"Words {start_word}-{end_word} are not assigned to any scene\\\",\\n        ))\\n\\n    for start_word, end_word in duplicate_ranges:\\n        errors.append(_error(\\n            code=\\\"duplicate_coverage_detected\\\",\\n            message=f\\\"Words {start_word}-{end_word} are assigned to multiple scenes\\\",\\n        ))\\n\\n\\ndef _validate_narration_fidelity(\\n    scenes: list[dict[str, Any]],\\n    source_tokens: list[str],\\n    errors: list[dict[str, Any]],\\n) -> None:\\n    for scene in scenes:\\n        scene_id = scene.get(\\\"scene_local_id\\\")\\n        start_word = scene.get(\\\"start_word\\\")\\n        end_word = scene.get(\\\"end_word\\\")\\n        narration_original = scene.get(\\\"narration_original\\\")\\n\\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\\n            continue\\n        if not isinstance(narration_original, str):\\n            continue\\n        if start_word < 1 or end_word > len(source_tokens) or start_word > end_word:\\n            continue\\n\\n        source_span_text = \\\" \\\".join(source_tokens[start_word - 1:end_word])\\n        if _normalize_text(narration_original) != _normalize_text(source_span_text):\\n            errors.append(_error(\\n                code=\\\"narration_source_mismatch\\\",\\n                message=f\\\"Scene {scene_id} narration_original does not match source span {start_word}-{end_word}\\\",\\n                scene_ids=[scene_id],\\n            ))\\n\\n\\ndef _validate_estimated_word_counts(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\\n    for scene in scenes:\\n        scene_id = scene.get(\\\"scene_local_id\\\")\\n        start_word = scene.get(\\\"start_word\\\")\\n        end_word = scene.get(\\\"end_word\\\")\\n        estimated_scene_word_count = scene.get(\\\"estimated_scene_word_count\\\")\\n\\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\\n            continue\\n        if not isinstance(estimated_scene_word_count, int):\\n            errors.append(_error(\\n                code=\\\"estimated_word_count_mismatch\\\",\\n                message=f\\\"Scene {scene_id} must have integer estimated_scene_word_count\\\",\\n                scene_ids=[scene_id],\\n            ))\\n            continue\\n\\n        actual_count = end_word - start_word + 1\\n        if estimated_scene_word_count != actual_count:\\n            errors.append(_error(\\n                code=\\\"estimated_word_count_mismatch\\\",\\n                message=(\\n                    f\\\"Scene {scene_id} estimated_scene_word_count={estimated_scene_word_count} \\\"\\n                    f\\\"but span implies {actual_count}\\\"\\n                ),\\n                scene_ids=[scene_id],\\n            ))\\n\\n\\ndef _tokenize_text(text: str) -> list[str]:\\n    normalized = _normalize_text(text)\\n    if not normalized:\\n        return []\\n    return normalized.split(\\\" \\\")\\n\\n\\ndef _normalize_text(text: str) -> str:\\n    text = text.replace(\\\"\\\\r\\\\n\\\", \\\" \\\").replace(\\\"\\\\n\\\", \\\" \\\").replace(\\\"\\\\t\\\", \\\" \\\")\\n    text = re.sub(r\\\"\\\\s+\\\", \\\" \\\", text).strip()\\n    return text\\n\\n\\ndef _collect_ranges(word_indices: list[int]) -> list[tuple[int, int]]:\\n    if not word_indices:\\n        return []\\n\\n    ranges: list[tuple[int, int]] = []\\n    start = word_indices[0]\\n    previous = word_indices[0]\\n\\n    for current in word_indices[1:]:\\n        if current == previous + 1:\\n            previous = current\\n            continue\\n        ranges.append((start, previous))\\n        start = current\\n        previous = current\\n\\n    ranges.append((start, previous))\\n    return ranges\\n\\n\\ndef _extract_batch_id(output: dict[str, Any]) -> str | None:\\n    batch_id = output.get(\\\"batch_id\\\")\\n    return batch_id if isinstance(batch_id, str) and batch_id.strip() else None\\n\\n\\ndef _extract_batch_id_from_payload(payload: dict[str, Any]) -> str | None:\\n    batch = payload.get(\\\"batch\\\") if isinstance(payload, dict) else None\\n    if not isinstance(batch, dict):\\n        return None\\n    batch_id = batch.get(\\\"batch_id\\\")\\n    return batch_id if isinstance(batch_id, str) and batch_id.strip() else None\\n\\n\\ndef _error(\\n    code: str,\\n    message: str,\\n    *,\\n    scene_ids: list[str | None] | None = None,\\n) -> dict[str, Any]:\\n    clean_scene_ids = [scene_id for scene_id in (scene_ids or []) if scene_id]\\n    payload: dict[str, Any] = {\\n        \\\"code\\\": code,\\n        \\\"message\\\": message,\\n    }\\n    if clean_scene_ids:\\n        payload[\\\"scene_ids\\\"] = clean_scene_ids\\n    return payload\\n\\n\\ndef _fatal_result(\\n    *,\\n    batch_id: str | None,\\n    errors: list[dict[str, Any]],\\n    warnings: list[dict[str, Any]],\\n) -> dict[str, Any]:\\n    return {\\n        \\\"ok\\\": False,\\n        \\\"approved_for_merge\\\": False,\\n        \\\"batch_id\\\": batch_id,\\n        \\\"classification\\\": \\\"fatal_contract_error\\\",\\n        \\\"errors\\\": errors,\\n        \\\"warnings\\\": warnings,\\n        \\\"stats\\\": {\\n            \\\"scene_count\\\": 0,\\n            \\\"source_word_count\\\": 0,\\n            \\\"covered_word_count\\\": 0,\\n        },\\n    }\\n\\n\\ndef _finalize_result(\\n    *,\\n    batch_id: str | None,\\n    errors: list[dict[str, Any]],\\n    warnings: list[dict[str, Any]],\\n    scenes: list[dict[str, Any]],\\n    source_tokens: list[str],\\n    expected_batch_id: str | None,\\n) -> dict[str, Any]:\\n    classification = _classify_errors(errors)\\n    covered_word_count = _compute_covered_word_count(scenes, len(source_tokens))\\n\\n    if batch_id is None:\\n        batch_id = expected_batch_id\\n\\n    return {\\n        \\\"ok\\\": classification == \\\"ok\\\",\\n        \\\"approved_for_merge\\\": classification == \\\"ok\\\",\\n        \\\"batch_id\\\": batch_id,\\n        \\\"classification\\\": classification,\\n        \\\"errors\\\": errors,\\n        \\\"warnings\\\": warnings,\\n        \\\"stats\\\": {\\n            \\\"scene_count\\\": len(scenes),\\n            \\\"source_word_count\\\": len(source_tokens),\\n            \\\"covered_word_count\\\": covered_word_count,\\n        },\\n    }\\n\\n\\ndef _classify_errors(errors: list[dict[str, Any]]) -> str:\\n    if not errors:\\n        return \\\"ok\\\"\\n\\n    severities = [ERROR_SEVERITY.get(error.get(\\\"code\\\"), \\\"fatal_contract_error\\\") for error in errors]\\n\\n    if \\\"fatal_contract_error\\\" in severities:\\n        return \\\"fatal_contract_error\\\"\\n\\n    repair_like_count = sum(1 for severity in severities if severity == \\\"batch_repair\\\")\\n    if repair_like_count >= 3:\\n        return \\\"batch_regenerate\\\"\\n    if repair_like_count >= 1:\\n        return \\\"batch_repair\\\"\\n    if \\\"structural_patch\\\" in severities:\\n        return \\\"structural_patch\\\"\\n\\n    for classification in CLASSIFICATION_PRIORITY:\\n        if classification in severities:\\n            return classification\\n\\n    return \\\"fatal_contract_error\\\"\\n\\n\\ndef _compute_covered_word_count(scenes: list[dict[str, Any]], source_word_count: int) -> int:\\n    if source_word_count <= 0:\\n        return 0\\n\\n    covered: set[int] = set()\\n    for scene in scenes:\\n        start_word = scene.get(\\\"start_word\\\")\\n        end_word = scene.get(\\\"end_word\\\")\\n        if not isinstance(start_word, int) or not isinstance(end_word, int):\\n            continue\\n        if start_word < 1 or end_word < 1 or start_word > end_word:\\n            continue\\n        for index in range(max(1, start_word), min(source_word_count, end_word) + 1):\\n            covered.add(index)\\n\\n    return len(covered)\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":2793,"output":4753,"cacheRead":81024,"cacheWrite":0,"totalTokens":88570,"cost":{"input":0.006982500000000001,"output":0.071295,"cacheRead":0.020256,"cacheWrite":0,"total":0.0985335}},"stopReason":"toolUse","timestamp":1774962897501,"responseId":"resp_09c2c7891525c9bd0169cbc8d4a484