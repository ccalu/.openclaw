{"type":"message","id":"a5db473c","parentId":"9111f5b9","timestamp":"2026-03-31T18:34:18.694Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_BTEW4iITEtEW0I5Cg29Vtiby|fc_0f234d88709aef6d0169cc139753888193ac3591cc55e0f3fc","name":"write","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\scene_bible_builder.py","content":"\"\"\"Scene Bible Builder — compiles canonical scene_bible.json from screenplay + TTS polish.\n\nCreates the living document that downstream sectors consume and enrich.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\n\ndef build_scene_bible(\n    polished: list[dict[str, Any]],\n    job: dict[str, Any],\n    screenplay: list[dict[str, Any]],\n) -> dict[str, Any]:\n    \"\"\"Build the initial scene_bible.json.\n\n    Args:\n        polished: Canonical merged TTS polish scenes.\n        job: PM job dict for metadata.\n        screenplay: Canonical screenplay with structural/narrative fields.\n\n    Returns:\n        Complete scene_bible dict ready for JSON serialization.\n    \"\"\"\n    scenes = []\n\n    screenplay_map = {\n        scene.get(\"scene_id\"): scene\n        for scene in screenplay\n        if isinstance(scene, dict) and scene.get(\"scene_id\")\n    }\n    screenplay_order = [scene.get(\"scene_id\") for scene in screenplay if isinstance(scene, dict) and scene.get(\"scene_id\")]\n\n    polish_map = {\n        scene.get(\"scene_id\"): scene\n        for scene in polished\n        if isinstance(scene, dict) and scene.get(\"scene_id\")\n    }\n\n    for index, scene_id in enumerate(screenplay_order, start=1):\n        scene_sp = screenplay_map.get(scene_id, {})\n        scene_pol = polish_map.get(scene_id, {})\n\n        narration_original = str(scene_sp.get(\"narration_original\", scene_pol.get(\"narration_original\", \"\")))\n        narration_tts = _get_narration_tts(scene_pol) or narration_original\n\n        scene = {\n            # S1-owned fields\n            \"scene_id\": scene_id or f\"scene_{index:03d}\",\n            \"scene_title\": scene_sp.get(\"scene_title\", \"\"),\n            \"scene_summary\": scene_sp.get(\"scene_summary\", \"\"),\n            \"narrative_function\": scene_sp.get(\"narrative_function\", \"\"),\n            \"narration\": narration_tts,  # compatibility field; mirrors narration_tts\n            \"narration_original\": narration_original,\n            \"narration_tts\": narration_tts,\n            \"duration_estimate\": scene_sp.get(\"estimated_scene_word_count\", None),\n            \"source_scene_local_id\": scene_sp.get(\"scene_local_id\"),\n            \"start_word\": scene_sp.get(\"start_word\"),\n            \"end_word\": scene_sp.get(\"end_word\"),\n            \"global_start_word\": scene_sp.get(\"global_start_word\"),\n            \"global_end_word\": scene_sp.get(\"global_end_word\"),\n            # Reserved downstream-owned fields\n            \"audio_clip\": None,\n            \"duration_actual\": None,\n            \"word_timestamps\": None,\n            \"entities\": [],\n            \"assets\": [],\n            \"visual_brief\": None,\n            \"visual_direction\": None,\n            \"mood\": None,\n            \"composition\": None,\n            # Metadata\n            \"sectors_contributed\": [\"S1\"],\n        }\n        scenes.append(scene)\n\n    bible = {\n        \"version\": \"1.0\",\n        \"job_id\": job.get(\"job_id\", \"\"),\n        \"account\": job.get(\"account\", \"\"),\n        \"language\": job.get(\"language\", \"\"),\n        \"channel_name\": job.get(\"channel_name\", \"\"),\n        \"created_at\": datetime.now(timezone.utc).isoformat(),\n        \"created_by\": \"s1_scene_bible_builder\",\n        \"scene_count\": len(scenes),\n        \"scenes\": scenes,\n    }\n\n    return bible\n\n\ndef write_scene_bible(\n    bible: dict[str, Any],\n    video_root: Path,\n) -> str:\n    \"\"\"Write scene_bible.json to the root of the run directory.\"\"\"\n    path = Path(video_root) / \"scene_bible.json\"\n    path.write_text(\n        json.dumps(bible, indent=2, ensure_ascii=False),\n        encoding=\"utf-8\",\n    )\n    return str(path)\n\n\ndef _get_narration_tts(scene: dict[str, Any]) -> str:\n    if \"narration_tts\" in scene:\n        return str(scene.get(\"narration_tts\", \"\"))\n    if \"polished\" in scene:  # legacy compatibility\n        return str(scene.get(\"polished\", \"\"))\n    return \"\"\n"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\scene_bible_builder.py\",\"content\":\"\\\"\\\"\\\"Scene Bible Builder — compiles canonical scene_bible.json from screenplay + TTS polish.\\n\\nCreates the living document that downstream sectors consume and enrich.\\n\\\"\\\"\\\"\\n\\nfrom __future__ import annotations\\n\\nimport json\\nfrom datetime import datetime, timezone\\nfrom pathlib import Path\\nfrom typing import Any\\n\\n\\ndef build_scene_bible(\\n    polished: list[dict[str, Any]],\\n    job: dict[str, Any],\\n    screenplay: list[dict[str, Any]],\\n) -> dict[str, Any]:\\n    \\\"\\\"\\\"Build the initial scene_bible.json.\\n\\n    Args:\\n        polished: Canonical merged TTS polish scenes.\\n        job: PM job dict for metadata.\\n        screenplay: Canonical screenplay with structural/narrative fields.\\n\\n    Returns:\\n        Complete scene_bible dict ready for JSON serialization.\\n    \\\"\\\"\\\"\\n    scenes = []\\n\\n    screenplay_map = {\\n        scene.get(\\\"scene_id\\\"): scene\\n        for scene in screenplay\\n        if isinstance(scene, dict) and scene.get(\\\"scene_id\\\")\\n    }\\n    screenplay_order = [scene.get(\\\"scene_id\\\") for scene in screenplay if isinstance(scene, dict) and scene.get(\\\"scene_id\\\")]\\n\\n    polish_map = {\\n        scene.get(\\\"scene_id\\\"): scene\\n        for scene in polished\\n        if isinstance(scene, dict) and scene.get(\\\"scene_id\\\")\\n    }\\n\\n    for index, scene_id in enumerate(screenplay_order, start=1):\\n        scene_sp = screenplay_map.get(scene_id, {})\\n        scene_pol = polish_map.get(scene_id, {})\\n\\n        narration_original = str(scene_sp.get(\\\"narration_original\\\", scene_pol.get(\\\"narration_original\\\", \\\"\\\")))\\n        narration_tts = _get_narration_tts(scene_pol) or narration_original\\n\\n        scene = {\\n            # S1-owned fields\\n            \\\"scene_id\\\": scene_id or f\\\"scene_{index:03d}\\\",\\n            \\\"scene_title\\\": scene_sp.get(\\\"scene_title\\\", \\\"\\\"),\\n            \\\"scene_summary\\\": scene_sp.get(\\\"scene_summary\\\", \\\"\\\"),\\n            \\\"narrative_function\\\": scene_sp.get(\\\"narrative_function\\\", \\\"\\\"),\\n            \\\"narration\\\": narration_tts,  # compatibility field; mirrors narration_tts\\n            \\\"narration_original\\\": narration_original,\\n            \\\"narration_tts\\\": narration_tts,\\n            \\\"duration_estimate\\\": scene_sp.get(\\\"estimated_scene_word_count\\\", None),\\n            \\\"source_scene_local_id\\\": scene_sp.get(\\\"scene_local_id\\\"),\\n            \\\"start_word\\\": scene_sp.get(\\\"start_word\\\"),\\n            \\\"end_word\\\": scene_sp.get(\\\"end_word\\\"),\\n            \\\"global_start_word\\\": scene_sp.get(\\\"global_start_word\\\"),\\n            \\\"global_end_word\\\": scene_sp.get(\\\"global_end_word\\\"),\\n            # Reserved downstream-owned fields\\n            \\\"audio_clip\\\": None,\\n            \\\"duration_actual\\\": None,\\n            \\\"word_timestamps\\\": None,\\n            \\\"entities\\\": [],\\n            \\\"assets\\\": [],\\n            \\\"visual_brief\\\": None,\\n            \\\"visual_direction\\\": None,\\n            \\\"mood\\\": None,\\n            \\\"composition\\\": None,\\n            # Metadata\\n            \\\"sectors_contributed\\\": [\\\"S1\\\"],\\n        }\\n        scenes.append(scene)\\n\\n    bible = {\\n        \\\"version\\\": \\\"1.0\\\",\\n        \\\"job_id\\\": job.get(\\\"job_id\\\", \\\"\\\"),\\n        \\\"account\\\": job.get(\\\"account\\\", \\\"\\\"),\\n        \\\"language\\\": job.get(\\\"language\\\", \\\"\\\"),\\n        \\\"channel_name\\\": job.get(\\\"channel_name\\\", \\\"\\\"),\\n        \\\"created_at\\\": datetime.now(timezone.utc).isoformat(),\\n        \\\"created_by\\\": \\\"s1_scene_bible_builder\\\",\\n        \\\"scene_count\\\": len(scenes),\\n        \\\"scenes\\\": scenes,\\n    }\\n\\n    return bible\\n\\n\\ndef write_scene_bible(\\n    bible: dict[str, Any],\\n    video_root: Path,\\n) -> str:\\n    \\\"\\\"\\\"Write scene_bible.json to the root of the run directory.\\\"\\\"\\\"\\n    path = Path(video_root) / \\\"scene_bible.json\\\"\\n    path.write_text(\\n        json.dumps(bible, indent=2, ensure_ascii=False),\\n        encoding=\\\"utf-8\\\",\\n    )\\n    return str(path)\\n\\n\\ndef _get_narration_tts(scene: dict[str, Any]) -> str:\\n    if \\\"narration_tts\\\" in scene:\\n        return str(scene.get(\\\"narration_tts\\\", \\\"\\\"))\\n    if \\\"polished\\\" in scene:  # legacy compatibility\\n        return str(scene.get(\\\"polished\\\", \\\"\\\"))\\n    return \\\"\\\"\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":115161,"output":1118,"cacheRead":14848,"cacheWrite":0,"totalTokens":131127,"cost":{"input":0.2879025,"output":0.01677,"cacheRead":0.003712,"cacheWrite":0,"total":0.3083845}},"stopReason":"toolUse","timestamp":1774982035513,"responseId":"resp_0f234d88709aef6d0169cc139463948193a7ac0340326808ab"}}
