{"type":"message","id":"03f458a3","parentId":"e67f56a2","timestamp":"2026-03-31T18:50:55.869Z","message":{"role":"assistant","content":[{"type":"text","text":"Vou começar pela primeira peça concreta da última milha: desenhar e escrever o esqueleto do `supervisor_runtime.py` para o S1 canónico.","textSignature":"{\"v\":1,\"id\":\"msg_0f234d88709aef6d0169cc1735a71c8193868273c932967d64\",\"phase\":\"commentary\"}"},{"type":"toolCall","id":"call_6m6Lrlqllvu9o6jiTDnkYf30|fc_0f234d88709aef6d0169cc17367ecc819387a6269ec149d0fc","name":"write","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\supervisor_runtime.py","content":"\"\"\"S1 Supervisor Runtime — canonical execution substrate for SM-S1.\n\nThis module is the execution substrate for the canonical S1 architecture.\nIt is intended to support the OpenClaw supervisor (`sm_s1_pre_production`) as the\nruntime brain of the sector.\n\nIt is NOT the legacy linear prototype path from `runtime.s1.s1_start`.\n\nDesign goal:\n- supervisor owns sequencing / acceptance / retry / completion decisions\n- deterministic skills and shared components perform mechanical work\n- OpenClaw operators perform semantic work\n- persisted artifacts remain operational truth\n\nCurrent status:\n- scaffold / skeleton only\n- lane decomposition established\n- operator invocation hooks intentionally left explicit and narrow\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\nimport yaml\n\nfrom runtime.s1.checkpoint_writer import write_checkpoint\nfrom runtime.s1.polish_validator import validate_polish\nfrom runtime.s1.scene_bible_builder import build_scene_bible, write_scene_bible\nfrom runtime.s1.scene_bible_schema_validator import validate_scene_bible_schema\nfrom runtime.s1.screenplay_validator import validate_screenplay\nfrom runtime.s1.supervisor_skills.operator_batch_scheduler import (\n    build_batch_schedule,\n    summarize_batch_execution,\n)\nfrom runtime.s1.supervisor_skills.retry_planner import plan_retry\nfrom runtime.s1.supervisor_skills.s1_paths_resolver import resolve_paths\nfrom runtime.s1.supervisor_skills.s1_preflight_checker import run_preflight\nfrom runtime.s1.supervisor_skills.s1_result_summarizer import summarize_s1_result\nfrom runtime.s1.supervisor_skills.scene_director_io_adapter import write_scene_director_payload\nfrom runtime.s1.supervisor_skills.scene_director_output_validator import validate_scene_director_output\nfrom runtime.s1.supervisor_skills.screenplay_merger import merge_screenplay_batches\nfrom runtime.s1.supervisor_skills.script_batch_planner import plan_script_batches_from_file\nfrom runtime.s1.supervisor_skills.tts_polish_batch_planner import plan_tts_polish_batches\nfrom runtime.s1.supervisor_skills.tts_polish_io_adapter import write_tts_polish_payload\nfrom runtime.s1.supervisor_skills.tts_polish_merger import merge_tts_polish_batches\n\n\nACCOUNTS_DIR = Path(__file__).parent.parent.parent / \"accounts\"\nDEFAULT_SCENE_DIRECTOR_CONCURRENCY = 2\nDEFAULT_TTS_POLISH_CONCURRENCY = 4\nDEFAULT_MAX_RETRIES = 3\n\n\ndef run_s1_supervisor_runtime(\n    *,\n    run_root: str | Path,\n    job: dict[str, Any] | None = None,\n    channel_config: dict[str, Any] | None = None,\n    model: str = \"gpt-4.1-mini\",\n    max_retries: int = DEFAULT_MAX_RETRIES,\n) -> dict[str, Any]:\n    \"\"\"Canonical execution substrate for S1 under supervisor authority.\n\n    This function intentionally decomposes the sector into lanes that map to the\n    canonical OpenClaw architecture.\n\n    Important:\n    - this module is the execution substrate, not the supervisor brain itself\n    - decision sovereignty still belongs to the supervisor layer\n    - operator invocation is left behind explicit hooks to avoid hiding architecture\n    \"\"\"\n    run_root = Path(run_root)\n    checkpoints_written: list[str] = []\n    all_warnings: list[dict[str, Any]] = []\n    all_errors: list[dict[str, Any]] = []\n\n    preflight = run_preflight(run_root)\n    if not preflight.get(\"ok\"):\n        return _failed_result(run_root, preflight.get(\"errors\", []), preflight.get(\"warnings\", []))\n    all_warnings.extend(preflight.get(\"warnings\", []))\n\n    if job is None:\n        job = preflight.get(\"job\", {})\n\n    account = job.get(\"account\")\n    language = job.get(\"language\")\n    if channel_config is None:\n        channel_config = _load_config(account, language)\n\n    paths_result = resolve_paths(run_root, create_dirs=True)\n    paths = paths_result.get(\"paths\", {})\n    all_warnings.extend(paths_result.get(\"warnings\", []))\n\n    script_path = Path(preflight[\"paths\"][\"script_raw\"])\n    script_raw = script_path.read_text(encoding=\"utf-8\")\n\n    screenplay_lane = _run_scene_director_lane(\n        run_root=run_root,\n        job=job,\n        channel_config=channel_config,\n        paths=paths,\n        script_path=script_path,\n        script_raw=script_raw,\n        model=model,\n        max_retries=max_retries,\n    )\n    all_warnings.extend(screenplay_lane.get(\"warnings\", []))\n    if not screenplay_lane.get(\"ok\"):\n        all_errors.extend(screenplay_lane.get(\"errors\", []))\n        return _failed_result(run_root, all_errors, all_warnings)\n\n    checkpoints_written.extend(screenplay_lane.get(\"checkpoints_written\", []))\n    screenplay = screenplay_lane[\"screenplay\"]\n    screenplay_result = screenplay_lane[\"screenplay_result\"]\n\n    polish_lane = _run_tts_polish_lane(\n        run_root=run_root,\n        job=job,\n        channel_config=channel_config,\n        paths=paths,\n        screenplay=screenplay,\n        model=model,\n        max_retries=max_retries,\n    )\n    all_warnings.extend(polish_lane.get(\"warnings\", []))\n    if not polish_lane.get(\"ok\"):\n        all_errors.extend(polish_lane.get(\"errors\", []))\n        return _failed_result(run_root, all_errors, all_warnings)\n\n    checkpoints_written.extend(polish_lane.get(\"checkpoints_written\", []))\n    polished = polish_lane[\"tts_polished\"]\n    polish_result = polish_lane[\"polish_result\"]\n\n    scene_bible_result = _run_scene_bible_lane(\n        run_root=run_root,\n        job=job,\n        screenplay=screenplay,\n        polished=polished,\n        paths=paths,\n    )\n    all_warnings.extend(scene_bible_result.get(\"warnings\", []))\n    if not scene_bible_result.get(\"ok\"):\n        all_errors.extend(scene_bible_result.get(\"errors\", []))\n        return _failed_result(run_root, all_errors, all_warnings)\n\n    checkpoints_written.extend(scene_bible_result.get(\"checkpoints_written\", []))\n\n    write_checkpoint(\n        run_root,\n        \"b1_complete\",\n        \"sm_s1_pre_production\",\n        [\n            \"b1_pre_production/screenplay.json\",\n            \"b1_pre_production/screenplay_validation.json\",\n            \"b1_pre_production/tts_polished.json\",\n            \"b1_pre_production/polish_validation.json\",\n            \"scene_bible.json\",\n        ],\n        extra={\n            \"scene_count\": scene_bible_result.get(\"scene_count\", 0),\n            \"screenplay_validated\": True,\n            \"polish_validated\": True,\n            \"scene_bible_schema_valid\": True,\n        },\n    )\n    checkpoints_written.append(\"b1_complete.json\")\n\n    return summarize_s1_result(\n        run_root=run_root,\n        screenplay_result=screenplay_result,\n        polish_result=polish_result,\n        scene_bible_path=scene_bible_result.get(\"scene_bible_path\"),\n        checkpoints_written=checkpoints_written,\n        warnings=all_warnings,\n        errors=all_errors,\n    )\n\n\ndef _run_scene_director_lane(\n    *,\n    run_root: Path,\n    job: dict[str, Any],\n    channel_config: dict[str, Any],\n    paths: dict[str, Any],\n    script_path: Path,\n    script_raw: str,\n    model: str,\n    max_retries: int,\n) -> dict[str, Any]:\n    warnings: list[dict[str, Any]] = []\n    errors: list[dict[str, Any]] = []\n    checkpoints_written: list[str] = []\n\n    batch_plan = plan_script_batches_from_file(script_path)\n    warnings.extend(batch_plan.get(\"warnings\", []))\n    if not batch_plan.get(\"ok\"):\n        return _lane_fail(batch_plan.get(\"errors\", []), warnings)\n\n    prepared_batches = []\n    for batch in batch_plan.get(\"batches\", []):\n        batch_id = batch[\"batch_id\"]\n        input_path = Path(paths[\"scene_director_inputs_root\"]) / f\"{batch_id}_input.json\"\n        output_path = Path(paths[\"scene_director_intermediate_root\"]) / f\"{batch_id}_output.json\"\n        payload_result = write_scene_director_payload(\n            run_root=run_root,\n            job=job,\n            batch=batch,\n            channel_config=channel_config,\n            input_path=input_path,\n            output_path=output_path,\n        )\n        prepared_batches.append(\n            {\n                \"batch_id\": batch_id,\n                \"input_path\": payload_result[\"input_path\"],\n                \"output_path\": payload_result[\"output_path\"],\n                \"status\": \"queued\",\n            }\n        )\n\n    schedule = build_batch_schedule(\n        operator_name=\"scene_director\",\n        batches=prepared_batches,\n        concurrency_cap=DEFAULT_SCENE_DIRECTOR_CONCURRENCY,\n    )\n    if not schedule.get(\"ok\"):\n        return _lane_fail(schedule.get(\"errors\", []), warnings)\n\n    execution_results = []\n    for wave in schedule.get(\"waves\", []):\n        for batch in wave.get(\"batches\", []):\n            execution_results.append(\n                _invoke_scene_director_batch(\n                    input_path=batch[\"input_path\"],\n                    output_path=batch[\"output_path\"],\n                    model=model,\n                )\n            )\n\n    execution_summary = summarize_batch_execution(\n        operator_name=\"scene_director\",\n        concurrency_cap=DEFAULT_SCENE_DIRECTOR_CONCURRENCY,\n        execution_results=execution_results,\n    )\n    warnings.extend(execution_summary.get(\"warnings\", []))\n\n    approved_batch_files: list[str] = []\n    failed_batch_ids: list[str] = []\n    for batch in prepared_batches:\n        validation = validate_scene_director_output(\n            batch_payload_path=batch[\"input_path\"],\n            batch_output_path=batch[\"output_path\"],\n        )\n        if validation.get(\"approved_for_merge\"):\n            approved_batch_files.append(batch[\"output_path\"])\n        else:\n            failed_batch_ids.append(batch[\"batch_id\"])\n            errors.extend(validation.get(\"errors\", []))\n\n    if failed_batch_ids:\n        retry_decision = plan_retry(\n            step_name=\"scene_director\",\n            failure_type=\"screenplay_validation_failed\",\n            retry_count=0,\n            affected_batches=failed_batch_ids,\n            max_retries=max_retries,\n        )\n        errors.append(\n            {\n                \"code\": \"scene_director_lane_incomplete\",\n                \"message\": f\"Scene director lane still requires retry orchestration: {retry_decision}\",\n            }\n        )\n        return _lane_fail(errors, warnings)\n\n    screenplay_result = merge_screenplay_batches(\n        approved_batch_files,\n        output_path=paths[\"screenplay_path\"],\n    )\n    warnings.extend(screenplay_result.get(\"warnings\", []))\n    if not screenplay_result.get(\"ok\"):\n        return _lane_fail(screenplay_result.get(\"errors\", []), warnings)\n\n    screenplay = screenplay_result[\"screenplay\"]\n    validation = validate_screenplay(script_raw, screenplay.get(\"scenes\", []))\n    validation_path = Path(paths[\"screenplay_validation_path\"])\n    validation_path.write_text(json.dumps(validation, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    if not validation.get(\"valid\"):\n        retry_decision = plan_retry(\n            step_name=\"scene_director\",\n            failure_type=\"screenplay_validation_failed\",\n            retry_count=0,\n            affected_batches=[],\n            max_retries=max_retries,\n        )\n        errors.append(\n            {\n                \"code\": \"screenplay_validation_failed\",\n                \"message\": f\"Canonical screenplay failed validation and still needs supervisor retry control: {retry_decision}\",\n            }\n        )\n        return _lane_fail(errors, warnings)\n\n    write_checkpoint(\n        run_root,\n        \"b1_step1_screenplay\",\n        \"scene_director\",\n        [\"b1_pre_production/screenplay.json\"],\n        extra={\"scene_count\": screenplay_result.get(\"scene_count\", 0), \"model\": model},\n    )\n    checkpoints_written.append(\"b1_step1_screenplay.json\")\n\n    write_checkpoint(\n        run_root,\n        \"b1_step2_screenplay_validated\",\n        \"screenplay_validator\",\n        [\"b1_pre_production/screenplay_validation.json\"],\n        retries=0,\n        validation_passed=True,\n    )\n    checkpoints_written.append(\"b1_step2_screenplay_validated.json\")\n\n    return {\n        \"ok\": True,\n        \"screenplay\": screenplay,\n        \"screenplay_result\": screenplay_result,\n        \"checkpoints_written\": checkpoints_written,\n        \"warnings\": warnings,\n        \"errors\": [],\n    }\n\n\ndef _run_tts_polish_lane(\n    *,\n    run_root: Path,\n    job: dict[str, Any],\n    channel_config: dict[str, Any],\n    paths: dict[str, Any],\n    screenplay: dict[str, Any],\n    model: str,\n    max_retries: int,\n) -> dict[str, Any]:\n    warnings: list[dict[str, Any]] = []\n    errors: list[dict[str, Any]] = []\n    checkpoints_written: list[str] = []\n\n    batch_plan = plan_tts_polish_batches(screenplay)\n    warnings.extend(batch_plan.get(\"warnings\", []))\n    if not batch_plan.get(\"ok\"):\n        return _lane_fail(batch_plan.get(\"errors\", []), warnings)\n\n    prepared_batches = []\n    for batch in batch_plan.get(\"batches\", []):\n        batch_id = batch[\"batch_id\"]\n        input_path = Path(paths[\"tts_polish_inputs_root\"]) / f\"{batch_id}_input.json\"\n        output_path = Path(paths[\"tts_polish_intermediate_root\"]) / f\"{batch_id}_output.json\"\n        payload_result = write_tts_polish_payload(\n            run_root=run_root,\n            job=job,\n            screenplay=screenplay,\n            batch=batch,\n            channel_config=channel_config,\n            input_path=input_path,\n            output_path=output_path,\n        )\n        prepared_batches.append(\n            {\n                \"batch_id\": batch_id,\n                \"input_path\": payload_result[\"input_path\"],\n                \"output_path\": payload_result[\"output_path\"],\n                \"status\": \"queued\",\n            }\n        )\n\n    schedule = build_batch_schedule(\n        operator_name=\"tts_polish\",\n        batches=prepared_batches,\n        concurrency_cap=DEFAULT_TTS_POLISH_CONCURRENCY,\n    )\n    if not schedule.get(\"ok\"):\n        return _lane_fail(schedule.get(\"errors\", []), warnings)\n\n    execution_results = []\n    for wave in schedule.get(\"waves\", []):\n        for batch in wave.get(\"batches\", []):\n            execution_results.append(\n                _invoke_tts_polish_batch(\n                    input_path=batch[\"input_path\"],\n                    output_path=batch[\"output_path\"],\n                    model=model,\n                )\n            )\n\n    execution_summary = summarize_batch_execution(\n        operator_name=\"tts_polish\",\n        concurrency_cap=DEFAULT_TTS_POLISH_CONCURRENCY,\n        execution_results=execution_results,\n    )\n    warnings.extend(execution_summary.get(\"warnings\", []))\n\n    # NOTE: canonical runtime still needs a real `tts_polish_output_validator`\n    # integration here. For now, treat batch execution completion as insufficient\n    # for approval and fail explicitly so the architecture does not silently drift.\n    errors.append(\n        {\n            \"code\": \"tts_polish_output_validator_not_implemented\",\n            \"message\": \"Canonical TTS polish lane still requires explicit per-batch output validation before merge.\",\n        }\n    )\n    retry_decision = plan_retry(\n        step_name=\"tts_polish\",\n        failure_type=\"polish_validation_failed\",\n        retry_count=0,\n        affected_batches=execution_summary.get(\"failed_batches\", []),\n        max_retries=max_retries,\n    )\n    errors.append(\n        {\n            \"code\": \"tts_polish_lane_incomplete\",\n            \"message\": f\"TTS polish lane still requires validator/reviewer runtime wiring: {retry_decision}\",\n        }\n    )\n\n    return _lane_fail(errors, warnings)\n\n\ndef _run_scene_bible_lane(\n    *,\n    run_root: Path,\n    job: dict[str, Any],\n    screenplay: dict[str, Any],\n    polished: list[dict[str, Any]],\n    paths: dict[str, Any],\n) -> dict[str, Any]:\n    warnings: list[dict[str, Any]] = []\n    errors: list[dict[str, Any]] = []\n    checkpoints_written: list[str] = []\n\n    bible = build_scene_bible(polished, job, screenplay.get(\"scenes\", []))\n    schema_validation = validate_scene_bible_schema(bible)\n    warnings.extend(schema_validation.get(\"warnings\", []))\n    if not schema_validation.get(\"valid\"):\n        return _lane_fail(schema_validation.get(\"errors\", []), warnings)\n\n    scene_bible_path = write_scene_bible(bible, run_root)\n    write_checkpoint(\n        run_root,\n        \"b1_step5_scene_bible\",\n        \"scene_bible_builder\",\n        [\"scene_bible.json\"],\n        extra={\"scene_count\": len(bible.get(\"scenes\", []))},\n    )\n    checkpoints_written.append(\"b1_step5_scene_bible.json\")\n\n    return {\n        \"ok\": True,\n        \"scene_bible_path\": scene_bible_path,\n        \"scene_count\": len(bible.get(\"scenes\", [])),\n        \"checkpoints_written\": checkpoints_written,\n        \"warnings\": warnings,\n        \"errors\": errors,\n    }\n\n\ndef _invoke_scene_director_batch(*, input_path: str, output_path: str, model: str) -> dict[str, Any]:\n    \"\"\"Hook for canonical OpenClaw operator invocation.\n\n    Current status:\n    - scaffold only\n    - does not yet invoke the real OpenClaw operator runtime\n    - intentionally writes no fake success artifact\n    \"\"\"\n    return {\n        \"batch_id\": Path(input_path).stem.replace(\"_input\", \"\"),\n        \"status\": \"failed\",\n        \"output_path\": output_path,\n        \"errors\": [\n            {\n                \"code\": \"operator_invocation_not_implemented\",\n                \"message\": \"Canonical scene_director invocation hook still needs OpenClaw runtime wiring.\",\n            }\n        ],\n        \"warnings\": [],\n    }\n\n\ndef _invoke_tts_polish_batch(*, input_path: str, output_path: str, model: str) -> dict[str, Any]:\n    \"\"\"Hook for canonical OpenClaw TTS polish invocation.\n\n    Current status:\n    - scaffold only\n    - does not yet invoke the real OpenClaw operator runtime\n    \"\"\"\n    return {\n        \"batch_id\": Path(input_path).stem.replace(\"_input\", \"\"),\n        \"status\": \"failed\",\n        \"output_path\": output_path,\n        \"errors\": [\n            {\n                \"code\": \"operator_invocation_not_implemented\",\n                \"message\": \"Canonical tts_polish invocation hook still needs OpenClaw runtime wiring.\",\n            }\n        ],\n        \"warnings\": [],\n    }\n\n\ndef _load_config(account: str, language: str) -> dict[str, Any]:\n    config_path = ACCOUNTS_DIR / str(account) / f\"{language}.yaml\"\n    if not config_path.exists():\n        raise FileNotFoundError(f\"Channel config not found: {config_path}\")\n    with open(config_path, \"r\", encoding=\"utf-8\") as f:\n        return yaml.safe_load(f) or {}\n\n\ndef _lane_fail(errors: list[dict[str, Any]], warnings: list[dict[str, Any]]) -> dict[str, Any]:\n    return {\n        \"ok\": False,\n        \"errors\": errors,\n        \"warnings\": warnings,\n    }\n\n\ndef _failed_result(\n    run_root: Path,\n    errors: list[dict[str, Any]],\n    warnings: list[dict[str, Any]],\n) -> dict[str, Any]:\n    return summarize_s1_result(\n        run_root=run_root,\n        screenplay_result={},\n        polish_result={},\n        scene_bible_path=None,\n        checkpoints_written=[],\n        warnings=warnings,\n        errors=errors,\n    )\n"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\supervisor_runtime.py\",\"content\":\"\\\"\\\"\\\"S1 Supervisor Runtime — canonical execution substrate for SM-S1.\\n\\nThis module is the execution substrate for the canonical S1 architecture.\\nIt is intended to support the OpenClaw supervisor (`sm_s1_pre_production`) as the\\nruntime brain of the sector.\\n\\nIt is NOT the legacy linear prototype path from `runtime.s1.s1_start`.\\n\\nDesign goal:\\n- supervisor owns sequencing / acceptance / retry / completion decisions\\n- deterministic skills and shared components perform mechanical work\\n- OpenClaw operators perform semantic work\\n- persisted artifacts remain operational truth\\n\\nCurrent status:\\n- scaffold / skeleton only\\n- lane decomposition established\\n- operator invocation hooks intentionally left explicit and narrow\\n\\\"\\\"\\\"\\n\\nfrom __future__ import annotations\\n\\nimport json\\nfrom pathlib import Path\\nfrom typing import Any\\n\\nimport yaml\\n\\nfrom runtime.s1.checkpoint_writer import write_checkpoint\\nfrom runtime.s1.polish_validator import validate_polish\\nfrom runtime.s1.scene_bible_builder import build_scene_bible, write_scene_bible\\nfrom runtime.s1.scene_bible_schema_validator import validate_scene_bible_schema\\nfrom runtime.s1.screenplay_validator import validate_screenplay\\nfrom runtime.s1.supervisor_skills.operator_batch_scheduler import (\\n    build_batch_schedule,\\n    summarize_batch_execution,\\n)\\nfrom runtime.s1.supervisor_skills.retry_planner import plan_retry\\nfrom runtime.s1.supervisor_skills.s1_paths_resolver import resolve_paths\\nfrom runtime.s1.supervisor_skills.s1_preflight_checker import run_preflight\\nfrom runtime.s1.supervisor_skills.s1_result_summarizer import summarize_s1_result\\nfrom runtime.s1.supervisor_skills.scene_director_io_adapter import write_scene_director_payload\\nfrom runtime.s1.supervisor_skills.scene_director_output_validator import validate_scene_director_output\\nfrom runtime.s1.supervisor_skills.screenplay_merger import merge_screenplay_batches\\nfrom runtime.s1.supervisor_skills.script_batch_planner import plan_script_batches_from_file\\nfrom runtime.s1.supervisor_skills.tts_polish_batch_planner import plan_tts_polish_batches\\nfrom runtime.s1.supervisor_skills.tts_polish_io_adapter import write_tts_polish_payload\\nfrom runtime.s1.supervisor_skills.tts_polish_merger import merge_tts_polish_batches\\n\\n\\nACCOUNTS_DIR = Path(__file__).parent.parent.parent / \\\"accounts\\\"\\nDEFAULT_SCENE_DIRECTOR_CONCURRENCY = 2\\nDEFAULT_TTS_POLISH_CONCURRENCY = 4\\nDEFAULT_MAX_RETRIES = 3\\n\\n\\ndef run_s1_supervisor_runtime(\\n    *,\\n    run_root: str | Path,\\n    job: dict[str, Any] | None = None,\\n    channel_config: dict[str, Any] | None = None,\\n    model: str = \\\"gpt-4.1-mini\\\",\\n    max_retries: int = DEFAULT_MAX_RETRIES,\\n) -> dict[str, Any]:\\n    \\\"\\\"\\\"Canonical execution substrate for S1 under supervisor authority.\\n\\n    This function intentionally decomposes the sector into lanes that map to the\\n    canonical OpenClaw architecture.\\n\\n    Important:\\n    - this module is the execution substrate, not the supervisor brain itself\\n    - decision sovereignty still belongs to the supervisor layer\\n    - operator invocation is left behind explicit hooks to avoid hiding architecture\\n    \\\"\\\"\\\"\\n    run_root = Path(run_root)\\n    checkpoints_written: list[str] = []\\n    all_warnings: list[dict[str, Any]] = []\\n    all_errors: list[dict[str, Any]] = []\\n\\n    preflight = run_preflight(run_root)\\n    if not preflight.get(\\\"ok\\\"):\\n        return _failed_result(run_root, preflight.get(\\\"errors\\\", []), preflight.get(\\\"warnings\\\", []))\\n    all_warnings.extend(preflight.get(\\\"warnings\\\", []))\\n\\n    if job is None:\\n        job = preflight.get(\\\"job\\\", {})\\n\\n    account = job.get(\\\"account\\\")\\n    language = job.get(\\\"language\\\")\\n    if channel_config is None:\\n        channel_config = _load_config(account, language)\\n\\n    paths_result = resolve_paths(run_root, create_dirs=True)\\n    paths = paths_result.get(\\\"paths\\\", {})\\n    all_warnings.extend(paths_result.get(\\\"warnings\\\", []))\\n\\n    script_path = Path(preflight[\\\"paths\\\"][\\\"script_raw\\\"])\\n    script_raw = script_path.read_text(encoding=\\\"utf-8\\\")\\n\\n    screenplay_lane = _run_scene_director_lane(\\n        run_root=run_root,\\n        job=job,\\n        channel_config=channel_config,\\n        paths=paths,\\n        script_path=script_path,\\n        script_raw=script_raw,\\n        model=model,\\n        max_retries=max_retries,\\n    )\\n    all_warnings.extend(screenplay_lane.get(\\\"warnings\\\", []))\\n    if not screenplay_lane.get(\\\"ok\\\"):\\n        all_errors.extend(screenplay_lane.get(\\\"errors\\\", []))\\n        return _failed_result(run_root, all_errors, all_warnings)\\n\\n    checkpoints_written.extend(screenplay_lane.get(\\\"checkpoints_written\\\", []))\\n    screenplay = screenplay_lane[\\\"screenplay\\\"]\\n    screenplay_result = screenplay_lane[\\\"screenplay_result\\\"]\\n\\n    polish_lane = _run_tts_polish_lane(\\n        run_root=run_root,\\n        job=job,\\n        channel_config=channel_config,\\n        paths=paths,\\n        screenplay=screenplay,\\n        model=model,\\n        max_retries=max_retries,\\n    )\\n    all_warnings.extend(polish_lane.get(\\\"warnings\\\", []))\\n    if not polish_lane.get(\\\"ok\\\"):\\n        all_errors.extend(polish_lane.get(\\\"errors\\\", []))\\n        return _failed_result(run_root, all_errors, all_warnings)\\n\\n    checkpoints_written.extend(polish_lane.get(\\\"checkpoints_written\\\", []))\\n    polished = polish_lane[\\\"tts_polished\\\"]\\n    polish_result = polish_lane[\\\"polish_result\\\"]\\n\\n    scene_bible_result = _run_scene_bible_lane(\\n        run_root=run_root,\\n        job=job,\\n        screenplay=screenplay,\\n        polished=polished,\\n        paths=paths,\\n    )\\n    all_warnings.extend(scene_bible_result.get(\\\"warnings\\\", []))\\n    if not scene_bible_result.get(\\\"ok\\\"):\\n        all_errors.extend(scene_bible_result.get(\\\"errors\\\", []))\\n        return _failed_result(run_root, all_errors, all_warnings)\\n\\n    checkpoints_written.extend(scene_bible_result.get(\\\"checkpoints_written\\\", []))\\n\\n    write_checkpoint(\\n        run_root,\\n        \\\"b1_complete\\\",\\n        \\\"sm_s1_pre_production\\\",\\n        [\\n            \\\"b1_pre_production/screenplay.json\\\",\\n            \\\"b1_pre_production/screenplay_validation.json\\\",\\n            \\\"b1_pre_production/tts_polished.json\\\",\\n            \\\"b1_pre_production/polish_validation.json\\\",\\n            \\\"scene_bible.json\\\",\\n        ],\\n        extra={\\n            \\\"scene_count\\\": scene_bible_result.get(\\\"scene_count\\\", 0),\\n            \\\"screenplay_validated\\\": True,\\n            \\\"polish_validated\\\": True,\\n            \\\"scene_bible_schema_valid\\\": True,\\n        },\\n    )\\n    checkpoints_written.append(\\\"b1_complete.json\\\")\\n\\n    return summarize_s1_result(\\n        run_root=run_root,\\n        screenplay_result=screenplay_result,\\n        polish_result=polish_result,\\n        scene_bible_path=scene_bible_result.get(\\\"scene_bible_path\\\"),\\n        checkpoints_written=checkpoints_written,\\n        warnings=all_warnings,\\n        errors=all_errors,\\n    )\\n\\n\\ndef _run_scene_director_lane(\\n    *,\\n    run_root: Path,\\n    job: dict[str, Any],\\n    channel_config: dict[str, Any],\\n    paths: dict[str, Any],\\n    script_path: Path,\\n    script_raw: str,\\n    model: str,\\n    max_retries: int,\\n) -> dict[str, Any]:\\n    warnings: list[dict[str, Any]] = []\\n    errors: list[dict[str, Any]] = []\\n    checkpoints_written: list[str] = []\\n\\n    batch_plan = plan_script_batches_from_file(script_path)\\n    warnings.extend(batch_plan.get(\\\"warnings\\\", []))\\n    if not batch_plan.get(\\\"ok\\\"):\\n        return _lane_fail(batch_plan.get(\\\"errors\\\", []), warnings)\\n\\n    prepared_batches = []\\n    for batch in batch_plan.get(\\\"batches\\\", []):\\n        batch_id = batch[\\\"batch_id\\\"]\\n        input_path = Path(paths[\\\"scene_director_inputs_root\\\"]) / f\\\"{batch_id}_input.json\\\"\\n        output_path = Path(paths[\\\"scene_director_intermediate_root\\\"]) / f\\\"{batch_id}_output.json\\\"\\n        payload_result = write_scene_director_payload(\\n            run_root=run_root,\\n            job=job,\\n            batch=batch,\\n            channel_config=channel_config,\\n            input_path=input_path,\\n            output_path=output_path,\\n        )\\n        prepared_batches.append(\\n            {\\n                \\\"batch_id\\\": batch_id,\\n                \\\"input_path\\\": payload_result[\\\"input_path\\\"],\\n                \\\"output_path\\\": payload_result[\\\"output_path\\\"],\\n                \\\"status\\\": \\\"queued\\\",\\n            }\\n        )\\n\\n    schedule = build_batch_schedule(\\n        operator_name=\\\"scene_director\\\",\\n        batches=prepared_batches,\\n        concurrency_cap=DEFAULT_SCENE_DIRECTOR_CONCURRENCY,\\n    )\\n    if not schedule.get(\\\"ok\\\"):\\n        return _lane_fail(schedule.get(\\\"errors\\\", []), warnings)\\n\\n    execution_results = []\\n    for wave in schedule.get(\\\"waves\\\", []):\\n        for batch in wave.get(\\\"batches\\\", []):\\n            execution_results.append(\\n                _invoke_scene_director_batch(\\n                    input_path=batch[\\\"input_path\\\"],\\n                    output_path=batch[\\\"output_path\\\"],\\n                    model=model,\\n                )\\n            )\\n\\n    execution_summary = summarize_batch_execution(\\n        operator_name=\\\"scene_director\\\",\\n        concurrency_cap=DEFAULT_SCENE_DIRECTOR_CONCURRENCY,\\n        execution_results=execution_results,\\n    )\\n    warnings.extend(execution_summary.get(\\\"warnings\\\", []))\\n\\n    approved_batch_files: list[str] = []\\n    failed_batch_ids: list[str] = []\\n    for batch in prepared_batches:\\n        validation = validate_scene_director_output(\\n            batch_payload_path=batch[\\\"input_path\\\"],\\n            batch_output_path=batch[\\\"output_path\\\"],\\n        )\\n        if validation.get(\\\"approved_for_merge\\\"):\\n            approved_batch_files.append(batch[\\\"output_path\\\"])\\n        else:\\n            failed_batch_ids.append(batch[\\\"batch_id\\\"])\\n            errors.extend(validation.get(\\\"errors\\\", []))\\n\\n    if failed_batch_ids:\\n        retry_decision = plan_retry(\\n            step_name=\\\"scene_director\\\",\\n            failure_type=\\\"screenplay_validation_failed\\\",\\n            retry_count=0,\\n            affected_batches=failed_batch_ids,\\n            max_retries=max_retries,\\n        )\\n        errors.append(\\n            {\\n                \\\"code\\\": \\\"scene_director_lane_incomplete\\\",\\n                \\\"message\\\": f\\\"Scene director lane still requires retry orchestration: {retry_decision}\\\",\\n            }\\n        )\\n        return _lane_fail(errors, warnings)\\n\\n    screenplay_result = merge_screenplay_batches(\\n        approved_batch_files,\\n        output_path=paths[\\\"screenplay_path\\\"],\\n    )\\n    warnings.extend(screenplay_result.get(\\\"warnings\\\", []))\\n    if not screenplay_result.get(\\\"ok\\\"):\\n        return _lane_fail(screenplay_result.get(\\\"errors\\\", []), warnings)\\n\\n    screenplay = screenplay_result[\\\"screenplay\\\"]\\n    validation = validate_screenplay(script_raw, screenplay.get(\\\"scenes\\\", []))\\n    validation_path = Path(paths[\\\"screenplay_validation_path\\\"])\\n    validation_path.write_text(json.dumps(validation, indent=2, ensure_ascii=False), encoding=\\\"utf-8\\\")\\n\\n    if not validation.get(\\\"valid\\\"):\\n        retry_decision = plan_retry(\\n            step_name=\\\"scene_director\\\",\\n            failure_type=\\\"screenplay_validation_failed\\\",\\n            retry_count=0,\\n            affected_batches=[],\\n            max_retries=max_retries,\\n        )\\n        errors.append(\\n            {\\n                \\\"code\\\": \\\"screenplay_validation_failed\\\",\\n                \\\"message\\\": f\\\"Canonical screenplay failed validation and still needs supervisor retry control: {retry_decision}\\\",\\n            }\\n        )\\n        return _lane_fail(errors, warnings)\\n\\n    write_checkpoint(\\n        run_root,\\n        \\\"b1_step1_screenplay\\\",\\n        \\\"scene_director\\\",\\n        [\\\"b1_pre_production/screenplay.json\\\"],\\n        extra={\\\"scene_count\\\": screenplay_result.get(\\\"scene_count\\\", 0), \\\"model\\\": model},\\n    )\\n    checkpoints_written.append(\\\"b1_step1_screenplay.json\\\")\\n\\n    write_checkpoint(\\n        run_root,\\n        \\\"b1_step2_screenplay_validated\\\",\\n        \\\"screenplay_validator\\\",\\n        [\\\"b1_pre_production/screenplay_validation.json\\\"],\\n        retries=0,\\n        validation_passed=True,\\n    )\\n    checkpoints_written.append(\\\"b1_step2_screenplay_validated.json\\\")\\n\\n    return {\\n        \\\"ok\\\": True,\\n        \\\"screenplay\\\": screenplay,\\n        \\\"screenplay_result\\\": screenplay_result,\\n        \\\"checkpoints_written\\\": checkpoints_written,\\n        \\\"warnings\\\": warnings,\\n        \\\"errors\\\": [],\\n    }\\n\\n\\ndef _run_tts_polish_lane(\\n    *,\\n    run_root: Path,\\n    job: dict[str, Any],\\n    channel_config: dict[str, Any],\\n    paths: dict[str, Any],\\n    screenplay: dict[str, Any],\\n    model: str,\\n    max_retries: int,\\n) -> dict[str, Any]:\\n    warnings: list[dict[str, Any]] = []\\n    errors: list[dict[str, Any]] = []\\n    checkpoints_written: list[str] = []\\n\\n    batch_plan = plan_tts_polish_batches(screenplay)\\n    warnings.extend(batch_plan.get(\\\"warnings\\\", []))\\n    if not batch_plan.get(\\\"ok\\\"):\\n        return _lane_fail(batch_plan.get(\\\"errors\\\", []), warnings)\\n\\n    prepared_batches = []\\n    for batch in batch_plan.get(\\\"batches\\\", []):\\n        batch_id = batch[\\\"batch_id\\\"]\\n        input_path = Path(paths[\\\"tts_polish_inputs_root\\\"]) / f\\\"{batch_id}_input.json\\\"\\n        output_path = Path(paths[\\\"tts_polish_intermediate_root\\\"]) / f\\\"{batch_id}_output.json\\\"\\n        payload_result = write_tts_polish_payload(\\n            run_root=run_root,\\n            job=job,\\n            screenplay=screenplay,\\n            batch=batch,\\n            channel_config=channel_config,\\n            input_path=input_path,\\n            output_path=output_path,\\n        )\\n        prepared_batches.append(\\n            {\\n                \\\"batch_id\\\": batch_id,\\n                \\\"input_path\\\": payload_result[\\\"input_path\\\"],\\n                \\\"output_path\\\": payload_result[\\\"output_path\\\"],\\n                \\\"status\\\": \\\"queued\\\",\\n            }\\n        )\\n\\n    schedule = build_batch_schedule(\\n        operator_name=\\\"tts_polish\\\",\\n        batches=prepared_batches,\\n        concurrency_cap=DEFAULT_TTS_POLISH_CONCURRENCY,\\n    )\\n    if not schedule.get(\\\"ok\\\"):\\n        return _lane_fail(schedule.get(\\\"errors\\\", []), warnings)\\n\\n    execution_results = []\\n    for wave in schedule.get(\\\"waves\\\", []):\\n        for batch in wave.get(\\\"batches\\\", []):\\n            execution_results.append(\\n                _invoke_tts_polish_batch(\\n                    input_path=batch[\\\"input_path\\\"],\\n                    output_path=batch[\\\"output_path\\\"],\\n                    model=model,\\n                )\\n            )\\n\\n    execution_summary = summarize_batch_execution(\\n        operator_name=\\\"tts_polish\\\",\\n        concurrency_cap=DEFAULT_TTS_POLISH_CONCURRENCY,\\n        execution_results=execution_results,\\n    )\\n    warnings.extend(execution_summary.get(\\\"warnings\\\", []))\\n\\n    # NOTE: canonical runtime still needs a real `tts_polish_output_validator`\\n    # integration here. For now, treat batch execution completion as insufficient\\n    # for approval and fail explicitly so the architecture does not silently drift.\\n    errors.append(\\n        {\\n            \\\"code\\\": \\\"tts_polish_output_validator_not_implemented\\\",\\n            \\\"message\\\": \\\"Canonical TTS polish lane still requires explicit per-batch output validation before merge.\\\",\\n        }\\n    )\\n    retry_decision = plan_retry(\\n        step_name=\\\"tts_polish\\\",\\n        failure_type=\\\"polish_validation_failed\\\",\\n        retry_count=0,\\n        affected_batches=execution_summary.get(\\\"failed_batches\\\", []),\\n        max_retries=max_retries,\\n    )\\n    errors.append(\\n        {\\n            \\\"code\\\": \\\"tts_polish_lane_incomplete\\\",\\n            \\\"message\\\": f\\\"TTS polish lane still requires validator/reviewer runtime wiring: {retry_decision}\\\",\\n        }\\n    )\\n\\n    return _lane_fail(errors, warnings)\\n\\n\\ndef _run_scene_bible_lane(\\n    *,\\n    run_root: Path,\\n    job: dict[str, Any],\\n    screenplay: dict[str, Any],\\n    polished: list[dict[str, Any]],\\n    paths: dict[str, Any],\\n) -> dict[str, Any]:\\n    warnings: list[dict[str, Any]] = []\\n    errors: list[dict[str, Any]] = []\\n    checkpoints_written: list[str] = []\\n\\n    bible = build_scene_bible(polished, job, screenplay.get(\\\"scenes\\\", []))\\n    schema_validation = validate_scene_bible_schema(bible)\\n    warnings.extend(schema_validation.get(\\\"warnings\\\", []))\\n    if not schema_validation.get(\\\"valid\\\"):\\n        return _lane_fail(schema_validation.get(\\\"errors\\\", []), warnings)\\n\\n    scene_bible_path = write_scene_bible(bible, run_root)\\n    write_checkpoint(\\n        run_root,\\n        \\\"b1_step5_scene_bible\\\",\\n        \\\"scene_bible_builder\\\",\\n        [\\\"scene_bible.json\\\"],\\n        extra={\\\"scene_count\\\": len(bible.get(\\\"scenes\\\", []))},\\n    )\\n    checkpoints_written.append(\\\"b1_step5_scene_bible.json\\\")\\n\\n    return {\\n        \\\"ok\\\": True,\\n        \\\"scene_bible_path\\\": scene_bible_path,\\n        \\\"scene_count\\\": len(bible.get(\\\"scenes\\\", [])),\\n        \\\"checkpoints_written\\\": checkpoints_written,\\n        \\\"warnings\\\": warnings,\\n        \\\"errors\\\": errors,\\n    }\\n\\n\\ndef _invoke_scene_director_batch(*, input_path: str, output_path: str, model: str) -> dict[str, Any]:\\n    \\\"\\\"\\\"Hook for canonical OpenClaw operator invocation.\\n\\n    Current status:\\n    - scaffold only\\n    - does not yet invoke the real OpenClaw operator runtime\\n    - intentionally writes no fake success artifact\\n    \\\"\\\"\\\"\\n    return {\\n        \\\"batch_id\\\": Path(input_path).stem.replace(\\\"_input\\\", \\\"\\\"),\\n        \\\"status\\\": \\\"failed\\\",\\n        \\\"output_path\\\": output_path,\\n        \\\"errors\\\": [\\n            {\\n                \\\"code\\\": \\\"operator_invocation_not_implemented\\\",\\n                \\\"message\\\": \\\"Canonical scene_director invocation hook still needs OpenClaw runtime wiring.\\\",\\n            }\\n        ],\\n        \\\"warnings\\\": [],\\n    }\\n\\n\\ndef _invoke_tts_polish_batch(*, input_path: str, output_path: str, model: str) -> dict[str, Any]:\\n    \\\"\\\"\\\"Hook for canonical OpenClaw TTS polish invocation.\\n\\n    Current status:\\n    - scaffold only\\n    - does not yet invoke the real OpenClaw operator runtime\\n    \\\"\\\"\\\"\\n    return {\\n        \\\"batch_id\\\": Path(input_path).stem.replace(\\\"_input\\\", \\\"\\\"),\\n        \\\"status\\\": \\\"failed\\\",\\n        \\\"output_path\\\": output_path,\\n        \\\"errors\\\": [\\n            {\\n                \\\"code\\\": \\\"operator_invocation_not_implemented\\\",\\n                \\\"message\\\": \\\"Canonical tts_polish invocation hook still needs OpenClaw runtime wiring.\\\",\\n            }\\n        ],\\n        \\\"warnings\\\": [],\\n    }\\n\\n\\ndef _load_config(account: str, language: str) -> dict[str, Any]:\\n    config_path = ACCOUNTS_DIR / str(account) / f\\\"{language}.yaml\\\"\\n    if not config_path.exists():\\n        raise FileNotFoundError(f\\\"Channel config not found: {config_path}\\\")\\n    with open(config_path, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n        return yaml.safe_load(f) or {}\\n\\n\\ndef _lane_fail(errors: list[dict[str, Any]], warnings: list[dict[str, Any]]) -> dict[str, Any]:\\n    return {\\n        \\\"ok\\\": False,\\n        \\\"errors\\\": errors,\\n        \\\"warnings\\\": warnings,\\n    }\\n\\n\\ndef _failed_result(\\n    run_root: Path,\\n    errors: list[dict[str, Any]],\\n    warnings: list[dict[str, Any]],\\n) -> dict[str, Any]:\\n    return summarize_s1_result(\\n        run_root=run_root,\\n        screenplay_result={},\\n        polish_result={},\\n        scene_bible_path=None,\\n        checkpoints_written=[],\\n        warnings=warnings,\\n        errors=errors,\\n    )\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":144,"output":4996,"cacheRead":145152,"cacheWrite":0,"totalTokens":