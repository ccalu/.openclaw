{"type":"message","id":"17aa2186","parentId":"4c073a73","timestamp":"2026-03-31T18:32:36.037Z","message":{"role":"assistant","content":[{"type":"text","text":"Vou alinhar agora a implementação real desses componentes shared do S1 com os contratos canónicos.","textSignature":"{\"v\":1,\"id\":\"msg_0f234d88709aef6d0169cc13418f588193bb210913918154b3\",\"phase\":\"commentary\"}"},{"type":"toolCall","id":"call_XzMclliqcTNMrcvomn8lhINy|fc_0f234d88709aef6d0169cc1343f37481939c2f74ecbf1ad451","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\polish_validator.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\polish_validator.py\"}"},{"type":"toolCall","id":"call_bCepr6TmDTnJWilZSYhGydzE|fc_0f234d88709aef6d0169cc1343f38c819385aa6e388c96c92b","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\screenplay_validator.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\screenplay_validator.py\"}"},{"type":"toolCall","id":"call_MQ4WZpaPJspc5OvOA1aXOjso|fc_0f234d88709aef6d0169cc1343f3988193b387e70e05cfe928","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\scene_bible_builder.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\scene_bible_builder.py\"}"},{"type":"toolCall","id":"call_0DAlPXqdmD2wd2VdCnzoQGLp|fc_0f234d88709aef6d0169cc1343f3a48193b118078b8d8e6d32","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\scene_bible_schema_validator.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\scene_bible_schema_validator.py\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":140268,"output":205,"cacheRead":2560,"cacheWrite":0,"totalTokens":143033,"cost":{"input":0.35067000000000004,"output":0.003075,"cacheRead":0.0006399999999999999,"cacheWrite":0,"total":0.354385}},"stopReason":"toolUse","timestamp":1774981949162,"responseId":"resp_0f234d88709aef6d0169cc133e088481939c0e0111152776f0"}}
{"type":"message","id":"693a53d7","parentId":"17aa2186","timestamp":"2026-03-31T18:32:36.949Z","message":{"role":"toolResult","toolCallId":"call_XzMclliqcTNMrcvomn8lhINy|fc_0f234d88709aef6d0169cc1343f37481939c2f74ecbf1ad451","toolName":"read","content":[{"type":"text","text":"\"\"\"Polish Validator — verifies TTS polish preserved semantic content.\n\nDetects: eaten words, unwanted additions, dangerous changes.\n100% deterministic, no LLM.\n\"\"\"\n\nimport re\nfrom collections import Counter\nfrom typing import Any\n\n\ndef validate_polish(\n    screenplay: list[dict[str, Any]],\n    polished: list[dict[str, Any]],\n) -> dict[str, Any]:\n    \"\"\"Validate polished text against original screenplay narrations.\n\n    Args:\n        screenplay: Original screenplay scenes with 'narration_original'.\n        polished: Polished scenes with 'original' and 'polished' fields.\n\n    Returns:\n        {\"valid\": bool, \"eaten_words\": [], \"added_words\": [],\n         \"acceptable_changes\": [], \"dangerous_changes\": [], \"affected_scenes\": []}\n    \"\"\"\n    eaten_words = []\n    added_words = []\n    acceptable_changes = []\n    dangerous_changes = []\n    affected_scenes = []\n\n    for scene_sp, scene_pol in zip(screenplay, polished):\n        scene_id = scene_sp.get(\"scene_id\", scene_pol.get(\"scene_id\", \"unknown\"))\n        original = scene_sp.get(\"narration_original\", \"\")\n        polished_text = scene_pol.get(\"polished\", \"\")\n\n        orig_words = _tokenize(original)\n        pol_words = _tokenize(polished_text)\n\n        orig_counter = Counter(orig_words)\n        pol_counter = Counter(pol_words)\n\n        # Words eaten (in original but not in polished)\n        scene_eaten = []\n        for word, count in orig_counter.items():\n            if pol_counter.get(word, 0) < count and len(word) > 2:\n                diff = count - pol_counter.get(word, 0)\n                scene_eaten.append({\"word\": word, \"count\": diff, \"scene\": scene_id})\n\n        # Words added (in polished but not in original)\n        scene_added = []\n        for word, count in pol_counter.items():\n            if orig_counter.get(word, 0) < count and len(word) > 2:\n                diff = count - orig_counter.get(word, 0)\n                scene_added.append({\"word\": word, \"count\": diff, \"scene\": scene_id})\n\n        # Classify changes\n        changes = scene_pol.get(\"changes\", [])\n        for change in changes:\n            change_entry = {\"scene\": scene_id, \"change\": change}\n            # Simple heuristic: abbreviation expansions are acceptable\n            if any(kw in str(change).lower() for kw in [\"expand\", \"abbrevi\", \"accent\", \"acronym\"]):\n                acceptable_changes.append(change_entry)\n            else:\n                # Not necessarily dangerous, but flag for review\n                pass\n\n        if scene_eaten:\n            eaten_words.extend(scene_eaten)\n            affected_scenes.append(scene_id)\n        if scene_added:\n            added_words.extend(scene_added)\n            if scene_id not in affected_scenes:\n                affected_scenes.append(scene_id)\n\n    # Validity: no significant eaten words (additions from polish are often expected)\n    valid = len(eaten_words) <= 3\n\n    return {\n        \"valid\": valid,\n        \"eaten_words\": eaten_words[:20],\n        \"added_words\": added_words[:20],\n        \"acceptable_changes\": acceptable_changes[:20],\n        \"dangerous_changes\": dangerous_changes[:10],\n        \"affected_scenes\": affected_scenes,\n        \"scene_count\": len(screenplay),\n        \"details\": f\"{len(eaten_words)} eaten, {len(added_words)} added, {len(acceptable_changes)} acceptable changes\",\n    }\n\n\ndef _tokenize(text: str) -> list[str]:\n    text = text.lower()\n    words = re.findall(r\"[\\w']+\", text)\n    return [w for w in words if len(w) > 0]\n"}],"isError":false,"timestamp":1774981956827}}
{"type":"message","id":"fdff642b","parentId":"693a53d7","timestamp":"2026-03-31T18:32:37.067Z","message":{"role":"toolResult","toolCallId":"call_bCepr6TmDTnJWilZSYhGydzE|fc_0f234d88709aef6d0169cc1343f38c819385aa6e388c96c92b","toolName":"read","content":[{"type":"text","text":"\"\"\"Screenplay Validator — verifies screenplay preserves original script content.\n\nDetects: missing words, invented words, duplicated content between scenes.\n100% deterministic, no LLM.\n\"\"\"\n\nimport re\nfrom collections import Counter\nfrom typing import Any\n\n\ndef validate_screenplay(\n    script_raw: str,\n    screenplay: list[dict[str, Any]],\n) -> dict[str, Any]:\n    \"\"\"Validate screenplay against original script.\n\n    Args:\n        script_raw: Original script text.\n        screenplay: List of scene dicts with 'narration_original' field.\n\n    Returns:\n        {\"valid\": bool, \"missing_words\": [], \"extra_words\": [],\n         \"duplicated_between_scenes\": [], \"coverage\": str, \"affected_scenes\": [],\n         \"details\": str}\n    \"\"\"\n    # Normalize and tokenize original script\n    original_words = _tokenize(script_raw)\n\n    # Collect all words from screenplay narration_original fields\n    screenplay_words = []\n    scene_word_sets = []\n    for scene in screenplay:\n        narration = scene.get(\"narration_original\", \"\")\n        words = _tokenize(narration)\n        screenplay_words.extend(words)\n        scene_word_sets.append((scene.get(\"scene_id\", scene.get(\"scene_local_id\", \"unknown\")), set(words)))\n\n    # Use multiset for proper counting\n    original_counter = Counter(original_words)\n    screenplay_counter = Counter(screenplay_words)\n    original_set = set(original_words)\n    screenplay_set = set(screenplay_words)\n\n    # Find missing words (in original but not in screenplay)\n    missing_words = []\n    for word, count in original_counter.items():\n        if screenplay_counter.get(word, 0) < count:\n            diff = count - screenplay_counter.get(word, 0)\n            missing_words.append({\"word\": word, \"missing_count\": diff})\n\n    # Find extra words (in screenplay but not in original)\n    extra_words = []\n    for word, count in screenplay_counter.items():\n        if original_counter.get(word, 0) < count:\n            diff = count - original_counter.get(word, 0)\n            extra_words.append({\"word\": word, \"extra_count\": diff})\n\n    # Find duplicated content between scenes (same word appearing in multiple scenes when it shouldn't)\n    duplicated = []\n    word_scene_map: dict[str, list[str]] = {}\n    for scene_id, word_set in scene_word_sets:\n        for word in word_set:\n            if word not in word_scene_map:\n                word_scene_map[word] = []\n            word_scene_map[word].append(scene_id)\n\n    # Calculate coverage\n    if len(original_words) > 0:\n        matched = sum(1 for w in original_words if w in screenplay_set)\n        coverage_pct = (matched / len(original_words)) * 100\n    else:\n        coverage_pct = 100.0\n\n    # Determine affected scenes\n    affected_scenes: set[str] = set()\n    for item in missing_words[:10]:  # Limit check\n        for scene_id, word_set in scene_word_sets:\n            pass  # Missing words affect all scenes conceptually\n\n    # Determine validity\n    # Allow small tolerance: up to 2% missing is acceptable (formatting, whitespace diffs)\n    significant_missing = [m for m in missing_words if len(m[\"word\"]) > 2]\n    significant_extra = [e for e in extra_words if len(e[\"word\"]) > 2]\n\n    valid = len(significant_missing) <= 5 and len(significant_extra) <= 10\n\n    return {\n        \"valid\": valid,\n        \"missing_words\": missing_words[:20],  # Cap for readability\n        \"extra_words\": extra_words[:20],\n        \"duplicated_between_scenes\": duplicated[:10],\n        \"coverage\": f\"{coverage_pct:.1f}%\",\n        \"affected_scenes\": list(affected_scenes),\n        \"total_original_words\": len(original_words),\n        \"total_screenplay_words\": len(screenplay_words),\n        \"scene_count\": len(screenplay),\n        \"details\": f\"Coverage {coverage_pct:.1f}%, {len(significant_missing)} significant missing, {len(significant_extra)} significant extra\",\n    }\n\n\ndef _tokenize(text: str) -> list[str]:\n    \"\"\"Tokenize text into lowercase words, removing punctuation.\"\"\"\n    text = text.lower()\n    # Keep apostrophes within words (l'homme, don't)\n    words = re.findall(r\"[\\w']+\", text)\n    return [w for w in words if len(w) > 0]\n"}],"isError":false,"timestamp":1774981956949}}
{"type":"message","id":"eeb2a561","parentId":"fdff642b","timestamp":"2026-03-31T18:32:37.180Z","message":{"role":"toolResult","toolCallId":"call_MQ4WZpaPJspc5OvOA1aXOjso|fc_0f234d88709aef6d0169cc1343f3988193b387e70e05cfe928","toolName":"read","content":[{"type":"text","text":"\"\"\"Scene Bible Builder — compiles scene_bible.json from polished screenplay.\n\nCreates the living document that all downstream sectors consume.\n\"\"\"\n\nimport json\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\n\ndef build_scene_bible(\n    polished: list[dict[str, Any]],\n    job: dict[str, Any],\n    screenplay: list[dict[str, Any]],\n) -> dict[str, Any]:\n    \"\"\"Build the initial scene_bible.json.\n\n    Args:\n        polished: TTS-polished scenes with 'polished' text.\n        job: PM job dict for metadata.\n        screenplay: Original screenplay with structural/narrative fields from scene_director.\n\n    Returns:\n        Complete scene_bible dict ready for JSON serialization.\n    \"\"\"\n    scenes = []\n\n    for scene_pol, scene_sp in zip(polished, screenplay):\n        scene_id = scene_sp.get(\"scene_id\", scene_pol.get(\"scene_id\", f\"scene_{len(scenes)+1:03d}\"))\n\n        scene = {\n            # S1 fields (filled now)\n            \"scene_id\": scene_id,\n            \"scene_title\": scene_sp.get(\"scene_title\", \"\"),\n            \"scene_summary\": scene_sp.get(\"scene_summary\", \"\"),\n            \"narrative_function\": scene_sp.get(\"narrative_function\", \"\"),\n            \"narration\": scene_pol.get(\"polished\", scene_sp.get(\"narration_original\", \"\")),\n            \"narration_original\": scene_sp.get(\"narration_original\", \"\"),\n            \"duration_estimate\": scene_sp.get(\"estimated_scene_word_count\", None),\n            \"source_scene_local_id\": scene_sp.get(\"scene_local_id\"),\n            \"start_word\": scene_sp.get(\"start_word\"),\n            \"end_word\": scene_sp.get(\"end_word\"),\n            \"global_start_word\": scene_sp.get(\"global_start_word\"),\n            \"global_end_word\": scene_sp.get(\"global_end_word\"),\n            # S2 fields (reserved, filled by Audio sector)\n            \"audio_clip\": None,\n            \"duration_actual\": None,\n            \"word_timestamps\": None,\n            # S3/S4 fields (reserved, filled by Visual Planning / Asset Research)\n            \"entities\": [],\n            \"assets\": [],\n            # S5 fields (reserved, filled by Visual Direction)\n            \"visual_brief\": None,\n            \"visual_direction\": None,\n            \"mood\": None,\n            # S7/S8 fields (reserved, filled by Composition / Post-Production)\n            \"composition\": None,\n            # Metadata\n            \"sectors_contributed\": [\"S1\"],\n        }\n        scenes.append(scene)\n\n    bible = {\n        \"version\": \"1.0\",\n        \"job_id\": job.get(\"job_id\", \"\"),\n        \"account\": job.get(\"account\", \"\"),\n        \"language\": job.get(\"language\", \"\"),\n        \"channel_name\": job.get(\"channel_name\", \"\"),\n        \"created_at\": datetime.now(timezone.utc).isoformat(),\n        \"created_by\": \"s1_scene_bible_builder\",\n        \"scene_count\": len(scenes),\n        \"scenes\": scenes,\n    }\n\n    return bible\n\n\ndef write_scene_bible(\n    bible: dict[str, Any],\n    video_root: Path,\n) -> str:\n    \"\"\"Write scene_bible.json to the ROOT of the run directory.\n\n    Returns path to written file.\n    \"\"\"\n    path = Path(video_root) / \"scene_bible.json\"\n    path.write_text(\n        json.dumps(bible, indent=2, ensure_ascii=False),\n        encoding=\"utf-8\",\n    )\n    return str(path)\n"}],"isError":false,"timestamp":1774981957068}}
{"type":"message","id":"deec7de2","parentId":"eeb2a561","timestamp":"2026-03-31T18:32:37.339Z","message":{"role":"toolResult","toolCallId":"call_0DAlPXqdmD2wd2VdCnzoQGLp|fc_0f234d88709aef6d0169cc1343f3a48193b118078b8d8e6d32","toolName":"read","content":[{"type":"text","text":"\"\"\"Scene Bible Schema Validator — validates structure of scene_bible.json.\n\nChecks required fields, types, reserved fields presence.\n100% deterministic.\n\"\"\"\n\nfrom typing import Any\n\n\nREQUIRED_TOP_FIELDS = [\"version\", \"job_id\", \"account\", \"language\", \"scene_count\", \"scenes\"]\n\nREQUIRED_SCENE_FIELDS = [\n    \"scene_id\", \"narration\", \"visual_direction\", \"mood\",\n]\n\nRESERVED_SCENE_FIELDS = [\n    \"audio_clip\", \"duration_actual\", \"word_timestamps\",\n    \"entities\", \"assets\", \"visual_brief\", \"composition\",\n    \"sectors_contributed\",\n]\n\n\ndef validate_scene_bible_schema(bible: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Validate scene bible structure.\n\n    Returns:\n        {\"valid\": bool, \"errors\": [...], \"warnings\": [...]}\n    \"\"\"\n    errors = []\n    warnings = []\n\n    # Top-level fields\n    for field in REQUIRED_TOP_FIELDS:\n        if field not in bible:\n            errors.append({\"code\": \"missing_top_field\", \"field\": field, \"message\": f\"Missing required field: {field}\"})\n\n    if errors:\n        return {\"valid\": False, \"errors\": errors, \"warnings\": warnings}\n\n    scenes = bible.get(\"scenes\", [])\n    if not isinstance(scenes, list):\n        errors.append({\"code\": \"invalid_scenes_type\", \"field\": \"scenes\", \"message\": \"scenes must be a list\"})\n        return {\"valid\": False, \"errors\": errors, \"warnings\": warnings}\n\n    if len(scenes) == 0:\n        errors.append({\"code\": \"empty_scenes\", \"field\": \"scenes\", \"message\": \"scenes list is empty\"})\n        return {\"valid\": False, \"errors\": errors, \"warnings\": warnings}\n\n    # Validate scene count consistency\n    if bible.get(\"scene_count\") != len(scenes):\n        warnings.append({\n            \"code\": \"scene_count_mismatch\",\n            \"message\": f\"scene_count={bible.get('scene_count')} but {len(scenes)} scenes in list\",\n        })\n\n    # Validate each scene\n    for i, scene in enumerate(scenes):\n        scene_id = scene.get(\"scene_id\", f\"scene_{i}\")\n\n        # Required fields\n        for field in REQUIRED_SCENE_FIELDS:\n            if field not in scene:\n                errors.append({\n                    \"code\": \"missing_scene_field\",\n                    \"field\": f\"scenes[{i}].{field}\",\n                    \"scene_id\": scene_id,\n                    \"message\": f\"Scene {scene_id} missing required field: {field}\",\n                })\n\n        # Narration must not be empty\n        if not scene.get(\"narration\", \"\").strip():\n            errors.append({\n                \"code\": \"empty_narration\",\n                \"field\": f\"scenes[{i}].narration\",\n                \"scene_id\": scene_id,\n                \"message\": f\"Scene {scene_id} has empty narration\",\n            })\n\n        # Reserved fields should exist (even if null)\n        for field in RESERVED_SCENE_FIELDS:\n            if field not in scene:\n                warnings.append({\n                    \"code\": \"missing_reserved_field\",\n                    \"field\": f\"scenes[{i}].{field}\",\n                    \"scene_id\": scene_id,\n                    \"message\": f\"Scene {scene_id} missing reserved field: {field}\",\n                })\n\n    # Check for duplicate scene_ids\n    scene_ids = [s.get(\"scene_id\") for s in scenes]\n    seen: set[str] = set()\n    for sid in scene_ids:\n        if sid in seen:\n            errors.append({\"code\": \"duplicate_scene_id\", \"field\": \"scene_id\", \"message\": f\"Duplicate scene_id: {sid}\"})\n        seen.add(sid)\n\n    return {\n        \"valid\": len(errors) == 0,\n        \"errors\": errors,\n        \"warnings\": warnings,\n        \"scene_count\": len(scenes),\n    }\n"}],"isError":false,"timestamp":1774981957183}}
{"type":"message","id":"e4d6ec1e","parentId":"deec7de2","timestamp":"2026-03-31T18:33:18.024Z","message":{"role":"assistant","content":[{"type":"text","text":"Vou reescrever estes quatro componentes para alinhar com os contratos canónicos e remover o drift do runtime antigo.","textSignature":"{\"v\":1,\"id\":\"msg_0f234d88709aef6d0169cc13480b408193bf95ab7826096b07\",\"phase\":\"commentary\"}"},{"type":"toolCall","id":"call_nDNVmKy2MOU3mg393VxMoWhT|fc_0f234d88709aef6d0169cc1348b3348193bab0f0de6ed5973d","name":"write","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\polish_validator.py","content":"\"\"\"Polish Validator — validates canonical merged TTS polish against canonical screenplay.\n\nDetects:\n- scene identity/order mismatches\n- narration_original preservation failures\n- eaten words\n- suspicious additions\n- missing/empty narration_tts\n\n100% deterministic, no LLM.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom collections import Counter\nfrom typing import Any\n\n\nLEGACY_ORIGINAL_KEYS = (\"original\",)\nLEGACY_TTS_KEYS = (\"polished\",)\n\n\ndef validate_polish(\n    screenplay: list[dict[str, Any]],\n    polished: list[dict[str, Any]],\n) -> dict[str, Any]:\n    \"\"\"Validate canonical merged polish against canonical screenplay.\n\n    Args:\n        screenplay: Canonical screenplay scenes with `scene_id` and `narration_original`.\n        polished: Canonical merged polish scenes with `scene_id`, `narration_original`,\n            `narration_tts` (legacy `original/polished` tolerated for compatibility).\n\n    Returns:\n        Structured deterministic validation result.\n    \"\"\"\n    eaten_words: list[dict[str, Any]] = []\n    added_words: list[dict[str, Any]] = []\n    acceptable_changes: list[dict[str, Any]] = []\n    dangerous_changes: list[dict[str, Any]] = []\n    affected_scenes: list[str] = []\n    warnings: list[dict[str, Any]] = []\n\n    screenplay_map = {\n        scene.get(\"scene_id\"): scene\n        for scene in screenplay\n        if isinstance(scene, dict) and scene.get(\"scene_id\")\n    }\n    screenplay_order = [scene.get(\"scene_id\") for scene in screenplay if isinstance(scene, dict) and scene.get(\"scene_id\")]\n\n    polished_map = {\n        scene.get(\"scene_id\"): scene\n        for scene in polished\n        if isinstance(scene, dict) and scene.get(\"scene_id\")\n    }\n    polished_order = [scene.get(\"scene_id\") for scene in polished if isinstance(scene, dict) and scene.get(\"scene_id\")]\n\n    # Scene order must be preserved exactly in canonical merged artifact\n    if screenplay_order != polished_order:\n        dangerous_changes.append({\n            \"code\": \"scene_order_mismatch\",\n            \"message\": \"Canonical polish scene order does not match screenplay order\",\n        })\n        for scene_id in _ordered_union(screenplay_order, polished_order):\n            if scene_id not in affected_scenes:\n                affected_scenes.append(scene_id)\n\n    # Missing/extra scene identity mismatches\n    for scene_id in screenplay_order:\n        if scene_id not in polished_map:\n            dangerous_changes.append({\n                \"code\": \"missing_polish_scene\",\n                \"scene\": scene_id,\n                \"message\": f\"Missing polish output for screenplay scene {scene_id}\",\n            })\n            if scene_id not in affected_scenes:\n                affected_scenes.append(scene_id)\n\n    for scene_id in polished_order:\n        if scene_id not in screenplay_map:\n            dangerous_changes.append({\n                \"code\": \"unexpected_polish_scene\",\n                \"scene\": scene_id,\n                \"message\": f\"Polish output contains unexpected scene {scene_id}\",\n            })\n            if scene_id not in affected_scenes:\n                affected_scenes.append(scene_id)\n\n    # Validate only aligned scenes\n    for scene_id in screenplay_order:\n        scene_sp = screenplay_map.get(scene_id)\n        scene_pol = polished_map.get(scene_id)\n        if not scene_sp or not scene_pol:\n            continue\n\n        original = str(scene_sp.get(\"narration_original\", \"\"))\n        polished_original = _get_original_reference(scene_pol)\n        narration_tts = _get_narration_tts(scene_pol)\n\n        if polished_original != original:\n            dangerous_changes.append({\n                \"code\": \"narration_original_mismatch\",\n                \"scene\": scene_id,\n                \"message\": \"Polish layer does not preserve narration_original exactly\",\n            })\n            _add_affected(affected_scenes, scene_id)\n\n        if not narration_tts.strip():\n            dangerous_changes.append({\n                \"code\": \"empty_narration_tts\",\n                \"scene\": scene_id,\n                \"message\": \"Polish layer has empty narration_tts\",\n            })\n            _add_affected(affected_scenes, scene_id)\n            continue\n\n        orig_words = _tokenize(original)\n        tts_words = _tokenize(narration_tts)\n        orig_counter = Counter(orig_words)\n        tts_counter = Counter(tts_words)\n\n        scene_eaten = []\n        for word, count in orig_counter.items():\n            if tts_counter.get(word, 0) < count and len(word) > 2:\n                diff = count - tts_counter.get(word, 0)\n                scene_eaten.append({\"word\": word, \"count\": diff, \"scene\": scene_id})\n\n        scene_added = []\n        for word, count in tts_counter.items():\n            if orig_counter.get(word, 0) < count and len(word) > 2:\n                diff = count - orig_counter.get(word, 0)\n                scene_added.append({\"word\": word, \"count\": diff, \"scene\": scene_id})\n\n        changes = scene_pol.get(\"changes\", [])\n        for change in changes if isinstance(changes, list) else []:\n            change_text = str(change)\n            change_entry = {\"scene\": scene_id, \"change\": change_text}\n            if any(kw in change_text.lower() for kw in [\"expand\", \"abbrevi\", \"accent\", \"acronym\", \"ordinal\", \"unit\"]):\n                acceptable_changes.append(change_entry)\n            else:\n                warnings.append({\n                    \"code\": \"uncategorized_change_note\",\n                    \"scene\": scene_id,\n                    \"message\": f\"Change note not auto-classified: {change_text}\",\n                })\n\n        if scene_eaten:\n            eaten_words.extend(scene_eaten)\n            _add_affected(affected_scenes, scene_id)\n\n        if scene_added:\n            added_words.extend(scene_added)\n            _add_affected(affected_scenes, scene_id)\n\n    # Conservative validity rule:\n    # - no dangerous structural/identity mismatches\n    # - no significant eaten-word failures\n    significant_eaten = [item for item in eaten_words if item.get(\"count\", 0) > 0]\n    valid = len(dangerous_changes) == 0 and len(significant_eaten) == 0\n\n    return {\n        \"valid\": valid,\n        \"eaten_words\": eaten_words[:20],\n        \"added_words\": added_words[:20],\n        \"acceptable_changes\": acceptable_changes[:20],\n        \"dangerous_changes\": dangerous_changes[:20],\n        \"affected_scenes\": affected_scenes,\n        \"warnings\": warnings[:20],\n        \"scene_count\": len(screenplay_order),\n        \"details\": (\n            f\"{len(eaten_words)} eaten, {len(added_words)} added, \"\n            f\"{len(dangerous_changes)} dangerous, {len(acceptable_changes)} acceptable changes\"\n        ),\n    }\n\n\ndef _get_original_reference(scene: dict[str, Any]) -> str:\n    if \"narration_original\" in scene:\n        return str(scene.get(\"narration_original\", \"\"))\n    for key in LEGACY_ORIGINAL_KEYS:\n        if key in scene:\n            return str(scene.get(key, \"\"))\n    return \"\"\n\n\ndef _get_narration_tts(scene: dict[str, Any]) -> str:\n    if \"narration_tts\" in scene:\n        return str(scene.get(\"narration_tts\", \"\"))\n    for key in LEGACY_TTS_KEYS:\n        if key in scene:\n            return str(scene.get(key, \"\"))\n    return \"\"\n\n\ndef _ordered_union(a: list[str], b: list[str]) -> list[str]:\n    seen: set[str] = set()\n    result: list[str] = []\n    for item in a + b:\n        if item and item not in seen:\n            seen.add(item)\n            result.append(item)\n    return result\n\n\ndef _add_affected(affected_scenes: list[str], scene_id: str) -> None:\n    if scene_id not in affected_scenes:\n        affected_scenes.append(scene_id)\n\n\ndef _tokenize(text: str) -> list[str]:\n    text = text.lower()\n    words = re.findall(r\"[\\w']+\", text)\n    return [w for w in words if len(w) > 0]\n"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\polish_validator.py\",\"content\":\"\\\"\\\"\\\"Polish Validator — validates canonical merged TTS polish against canonical screenplay.\\n\\nDetects:\\n- scene identity/order mismatches\\n- narration_original preservation failures\\n- eaten words\\n- suspicious additions\\n- missing/empty narration_tts\\n\\n100% deterministic, no LLM.\\n\\\"\\\"\\\"\\n\\nfrom __future__ import annotations\\n\\nimport re\\nfrom collections import Counter\\nfrom typing import Any\\n\\n\\nLEGACY_ORIGINAL_KEYS = (\\\"original\\\",)\\nLEGACY_TTS_KEYS = (\\\"polished\\\",)\\n\\n\\ndef validate_polish(\\n    screenplay: list[dict[str, Any]],\\n    polished: list[dict[str, Any]],\\n) -> dict[str, Any]:\\n    \\\"\\\"\\\"Validate canonical merged polish against canonical screenplay.\\n\\n    Args:\\n        screenplay: Canonical screenplay scenes with `scene_id` and `narration_original`.\\n        polished: Canonical merged polish scenes with `scene_id`, `narration_original`,\\n            `narration_tts` (legacy `original/polished` tolerated for compatibility).\\n\\n    Returns:\\n        Structured deterministic validation result.\\n    \\\"\\\"\\\"\\n    eaten_words: list[dict[str, Any]] = []\\n    added_words: list[dict[str, Any]] = []\\n    acceptable_changes: list[dict[str, Any]] = []\\n    dangerous_changes: list[dict[str, Any]] = []\\n    affected_scenes: list[str] = []\\n    warnings: list[dict[str, Any]] = []\\n\\n    screenplay_map = {\\n        scene.get(\\\"scene_id\\\"): scene\\n        for scene in screenplay\\n        if isinstance(scene, dict) and scene.get(\\\"scene_id\\\")\\n    }\\n    screenplay_order = [scene.get(\\\"scene_id\\\") for scene in screenplay if isinstance(scene, dict) and scene.get(\\\"scene_id\\\")]\\n\\n    polished_map = {\\n        scene.get(\\\"scene_id\\\"): scene\\n        for scene in polished\\n        if isinstance(scene, dict) and scene.get(\\\"scene_id\\\")\\n    }\\n    polished_order = [scene.get(\\\"scene_id\\\") for scene in polished if isinstance(scene, dict) and scene.get(\\\"scene_id\\\")]\\n\\n    # Scene order must be preserved exactly in canonical merged artifact\\n    if screenplay_order != polished_order:\\n        dangerous_changes.append({\\n            \\\"code\\\": \\\"scene_order_mismatch\\\",\\n            \\\"message\\\": \\\"Canonical polish scene order does not match screenplay order\\\",\\n        })\\n        for scene_id in _ordered_union(screenplay_order, polished_order):\\n            if scene_id not in affected_scenes:\\n                affected_scenes.append(scene_id)\\n\\n    # Missing/extra scene identity mismatches\\n    for scene_id in screenplay_order:\\n        if scene_id not in polished_map:\\n            dangerous_changes.append({\\n                \\\"code\\\": \\\"missing_polish_scene\\\",\\n                \\\"scene\\\": scene_id,\\n                \\\"message\\\": f\\\"Missing polish output for screenplay scene {scene_id}\\\",\\n            })\\n            if scene_id not in affected_scenes:\\n                affected_scenes.append(scene_id)\\n\\n    for scene_id in polished_order:\\n        if scene_id not in screenplay_map:\\n            dangerous_changes.append({\\n                \\\"code\\\": \\\"unexpected_polish_scene\\\",\\n                \\\"scene\\\": scene_id,\\n                \\\"message\\\": f\\\"Polish output contains unexpected scene {scene_id}\\\",\\n            })\\n            if scene_id not in affected_scenes:\\n                affected_scenes.append(scene_id)\\n\\n    # Validate only aligned scenes\\n    for scene_id in screenplay_order:\\n        scene_sp = screenplay_map.get(scene_id)\\n        scene_pol = polished_map.get(scene_id)\\n        if not scene_sp or not scene_pol:\\n            continue\\n\\n        original = str(scene_sp.get(\\\"narration_original\\\", \\\"\\\"))\\n        polished_original = _get_original_reference(scene_pol)\\n        narration_tts = _get_narration_tts(scene_pol)\\n\\n        if polished_original != original:\\n            dangerous_changes.append({\\n                \\\"code\\\": \\\"narration_original_mismatch\\\",\\n                \\\"scene\\\": scene_id,\\n                \\\"message\\\": \\\"Polish layer does not preserve narration_original exactly\\\",\\n            })\\n            _add_affected(affected_scenes, scene_id)\\n\\n        if not narration_tts.strip():\\n            dangerous_changes.append({\\n                \\\"code\\\": \\\"empty_narration_tts\\\",\\n                \\\"scene\\\": scene_id,\\n                \\\"message\\\": \\\"Polish layer has empty narration_tts\\\",\\n            })\\n            _add_affected(affected_scenes, scene_id)\\n            continue\\n\\n        orig_words = _tokenize(original)\\n        tts_words = _tokenize(narration_tts)\\n        orig_counter = Counter(orig_words)\\n        tts_counter = Counter(tts_words)\\n\\n        scene_eaten = []\\n        for word, count in orig_counter.items():\\n            if tts_counter.get(word, 0) < count and len(word) > 2:\\n                diff = count - tts_counter.get(word, 0)\\n                scene_eaten.append({\\\"word\\\": word, \\\"count\\\": diff, \\\"scene\\\": scene_id})\\n\\n        scene_added = []\\n        for word, count in tts_counter.items():\\n            if orig_counter.get(word, 0) < count and len(word) > 2:\\n                diff = count - orig_counter.get(word, 0)\\n                scene_added.append({\\\"word\\\": word, \\\"count\\\": diff, \\\"scene\\\": scene_id})\\n\\n        changes = scene_pol.get(\\\"changes\\\", [])\\n        for change in changes if isinstance(changes, list) else []:\\n            change_text = str(change)\\n            change_entry = {\\\"scene\\\": scene_id, \\\"change\\\": change_text}\\n            if any(kw in change_text.lower() for kw in [\\\"expand\\\", \\\"abbrevi\\\", \\\"accent\\\", \\\"acronym\\\", \\\"ordinal\\\", \\\"unit\\\"]):\\n                acceptable_changes.append(change_entry)\\n            else:\\n                warnings.append({\\n                    \\\"code\\\": \\\"uncategorized_change_note\\\",\\n                    \\\"scene\\\": scene_id,\\n                    \\\"message\\\": f\\\"Change note not auto-classified: {change_text}\\\",\\n                })\\n\\n        if scene_eaten:\\n            eaten_words.extend(scene_eaten)\\n            _add_affected(affected_scenes, scene_id)\\n\\n        if scene_added:\\n            added_words.extend(scene_added)\\n            _add_affected(affected_scenes, scene_id)\\n\\n    # Conservative validity rule:\\n    # - no dangerous structural/identity mismatches\\n    # - no significant eaten-word failures\\n    significant_eaten = [item for item in eaten_words if item.get(\\\"count\\\", 0) > 0]\\n    valid = len(dangerous_changes) == 0 and len(significant_eaten) == 0\\n\\n    return {\\n        \\\"valid\\\": valid,\\n        \\\"eaten_words\\\": eaten_words[:20],\\n        \\\"added_words\\\": added_words[:20],\\n        \\\"acceptable_changes\\\": acceptable_changes[:20],\\n        \\\"dangerous_changes\\\": dangerous_changes[:20],\\n        \\\"affected_scenes\\\": affected_scenes,\\n        \\\"warnings\\\": warnings[:20],\\n        \\\"scene_count\\\": len(screenplay_order),\\n        \\\"details\\\": (\\n            f\\\"{len(eaten_words)} eaten, {len(added_words)} added, \\\"\\n            f\\\"{len(dangerous_changes)} dangerous, {len(acceptable_changes)} acceptable changes\\\"\\n        ),\\n    }\\n\\n\\ndef _get_original_reference(scene: dict[str, Any]) -> str:\\n    if \\\"narration_original\\\" in scene:\\n        return str(scene.get(\\\"narration_original\\\", \\\"\\\"))\\n    for key in LEGACY_ORIGINAL_KEYS:\\n        if key in scene:\\n            return str(scene.get(key, \\\"\\\"))\\n    return \\\"\\\"\\n\\n\\ndef _get_narration_tts(scene: dict[str, Any]) -> str:\\n    if \\\"narration_tts\\\" in scene:\\n        return str(scene.get(\\\"narration_tts\\\", \\\"\\\"))\\n    for key in LEGACY_TTS_KEYS:\\n        if key in scene:\\n            return str(scene.get(key, \\\"\\\"))\\n    return \\\"\\\"\\n\\n\\ndef _ordered_union(a: list[str], b: list[str]) -> list[str]:\\n    seen: set[str] = set()\\n    result: list[str] = []\\n    for item in a + b:\\n        if item and item not in seen:\\n            seen.add(item)\\n            result.append(item)\\n    return result\\n\\n\\ndef _add_affected(affected_scenes: list[str], scene_id: str) -> None:\\n    if scene_id not in affected_scenes:\\n        affected_scenes.append(scene_id)\\n\\n\\ndef _tokenize(text: str) -> list[str]:\\n    text = text.lower()\\n    words = re.findall(r\\\"[\\\\w']+\\\", text)\\n    return [w for w in words if len(w) > 0]\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":3504,"output":2087,"cacheRead":142848,"cacheWrite":0,"totalTokens":148439,"cost":{"input":0.00876,"output":0.031305,"cacheRead":0.035712,"cacheWrite":0,"total":0.07577700000000001}},"stopReason":"toolUse","timestamp":1774981957875,"responseId":"resp_0f234d88709aef6d0169cc1346c62c8193b919b7bdd2e8