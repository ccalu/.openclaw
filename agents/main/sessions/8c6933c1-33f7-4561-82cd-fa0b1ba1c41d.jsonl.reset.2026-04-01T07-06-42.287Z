n_original\\\"],\\n                \\\"changes\\\": [],\\n            }\\n        )\\n\\n    return upgraded\\n\\n\\nclass TestS1HappyPath:\\n    @patch(\\\"runtime.s1.s1_start.run_tts_polish\\\")\\n    @patch(\\\"runtime.s1.s1_start.run_scene_director\\\")\\n    def test_success(self, mock_director, mock_polish, tmp_path):\\n        _setup_run(tmp_path)\\n        screenplay = _load(\\\"sample_screenplay_valid.json\\\")\\n        polished = _canonicalize_polished(screenplay, _load(\\\"sample_tts_polished_valid.json\\\"))\\n\\n        mock_director.return_value = screenplay\\n        mock_polish.return_value = polished\\n\\n        result = start_s1(SAMPLE_JOB, tmp_path)\\n\\n        assert result[\\\"success\\\"] is True\\n        assert result[\\\"status\\\"] == \\\"s1_complete\\\"\\n        assert result[\\\"next_step\\\"] == \\\"ready_for_s2_and_s3\\\"\\n        assert result[\\\"scene_count\\\"] == len(screenplay)\\n\\n    @patch(\\\"runtime.s1.s1_start.run_tts_polish\\\")\\n    @patch(\\\"runtime.s1.s1_start.run_scene_director\\\")\\n    def test_all_artifacts_written(self, mock_director, mock_polish, tmp_path):\\n        _setup_run(tmp_path)\\n        screenplay = _load(\\\"sample_screenplay_valid.json\\\")\\n        polished = _canonicalize_polished(screenplay, _load(\\\"sample_tts_polished_valid.json\\\"))\\n\\n        mock_director.return_value = screenplay\\n        mock_polish.return_value = polished\\n\\n        start_s1(SAMPLE_JOB, tmp_path)\\n\\n        assert (tmp_path / \\\"b1_pre_production\\\" / \\\"screenplay.json\\\").exists()\\n        assert (tmp_path / \\\"b1_pre_production\\\" / \\\"screenplay_validation.json\\\").exists()\\n        assert (tmp_path / \\\"b1_pre_production\\\" / \\\"tts_polished.json\\\").exists()\\n        assert (tmp_path / \\\"b1_pre_production\\\" / \\\"polish_validation.json\\\").exists()\\n        assert (tmp_path / \\\"scene_bible.json\\\").exists()\\n\\n    @patch(\\\"runtime.s1.s1_start.run_tts_polish\\\")\\n    @patch(\\\"runtime.s1.s1_start.run_scene_director\\\")\\n    def test_all_checkpoints_written(self, mock_director, mock_polish, tmp_path):\\n        _setup_run(tmp_path)\\n        screenplay = _load(\\\"sample_screenplay_valid.json\\\")\\n        polished = _canonicalize_polished(screenplay, _load(\\\"sample_tts_polished_valid.json\\\"))\\n\\n        mock_director.return_value = screenplay\\n        mock_polish.return_value = polished\\n\\n        result = start_s1(SAMPLE_JOB, tmp_path)\\n\\n        expected = [\\\"b1_step1_screenplay.json\\\", \\\"b1_step2_screenplay_validated.json\\\",\\n                    \\\"b1_step3_tts_polished.json\\\", \\\"b1_step4_polish_validated.json\\\",\\n                    \\\"b1_step5_scene_bible.json\\\", \\\"b1_complete.json\\\"]\\n        assert result[\\\"checkpoints_written\\\"] == expected\\n        for cp in expected:\\n            assert (tmp_path / \\\"checkpoints\\\" / cp).exists()\\n\\n    @patch(\\\"runtime.s1.s1_start.run_tts_polish\\\")\\n    @patch(\\\"runtime.s1.s1_start.run_scene_director\\\")\\n    def test_scene_bible_at_root(self, mock_director, mock_polish, tmp_path):\\n        _setup_run(tmp_path)\\n        screenplay = _load(\\\"sample_screenplay_valid.json\\\")\\n        polished = _canonicalize_polished(screenplay, _load(\\\"sample_tts_polished_valid.json\\\"))\\n\\n        mock_director.return_value = screenplay\\n        mock_polish.return_value = polished\\n\\n        start_s1(SAMPLE_JOB, tmp_path)\\n\\n        assert (tmp_path / \\\"scene_bible.json\\\").exists()\\n        assert not (tmp_path / \\\"b1_pre_production\\\" / \\\"scene_bible.json\\\").exists()\\n\\n\\nclass TestS1Failures:\\n    def test_missing_script(self, tmp_path):\\n        (tmp_path / \\\"checkpoints\\\").mkdir(parents=True)\\n        result = start_s1(SAMPLE_JOB, tmp_path)\\n        assert result[\\\"success\\\"] is False\\n        assert \\\"missing_script\\\" in result[\\\"errors\\\"][0][\\\"code\\\"]\\n\\n    @patch(\\\"runtime.s1.s1_start.run_scene_director\\\")\\n    def test_scene_director_failure(self, mock_director, tmp_path):\\n        _setup_run(tmp_path)\\n        mock_director.side_effect = Exception(\\\"API error\\\")\\n\\n        result = start_s1(SAMPLE_JOB, tmp_path)\\n        assert result[\\\"success\\\"] is False\\n        assert \\\"scene_director\\\" in result[\\\"errors\\\"][0][\\\"code\\\"]\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":187,"output":1810,"cacheRead":138752,"cacheWrite":0,"totalTokens":140749,"cost":{"input":0.00046750000000000003,"output":0.02715,"cacheRead":0.034688,"cacheWrite":0,"total":0.0623055}},"stopReason":"toolUse","timestamp":1774982593898,"responseId":"resp_0f234d88709aef6d0169cc15c2b65c8193bb8e1b04df162167"}}
