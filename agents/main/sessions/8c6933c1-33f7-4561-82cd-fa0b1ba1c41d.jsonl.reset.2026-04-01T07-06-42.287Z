screenplay_validator`\\n- `polish_validator`\\n- `scene_bible_builder`\\n- `scene_bible_schema_validator`\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":195,"output":224,"cacheRead":146304,"cacheWrite":0,"totalTokens":146723,"cost":{"input":0.00048750000000000003,"output":0.00336,"cacheRead":0.036576,"cacheWrite":0,"total":0.0404235}},"stopReason":"toolUse","timestamp":1774981879119,"responseId":"resp_0f234d88709aef6d0169cc12f7ef988193bd9353e43a55f862"}}
