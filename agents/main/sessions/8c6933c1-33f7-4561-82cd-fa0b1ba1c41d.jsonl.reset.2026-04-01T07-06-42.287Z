{"type":"message","id":"78e35e8d","parentId":"5874f41e","timestamp":"2026-03-31T18:34:47.632Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_JmkzNrYCuabeh4sAGf2CA8eu|fc_0f234d88709aef6d0169cc13ae87948193a97a831991206a1b","name":"write","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\scene_bible_schema_validator.py","content":"\"\"\"Scene Bible Schema Validator — validates S1-stage structure of scene_bible.json.\n\nChecks:\n- required top-level fields\n- required-at-S1 scene fields\n- reserved downstream fields presence\n- duplicate scene IDs\n- scene_count consistency\n\n100% deterministic.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import Any\n\n\nREQUIRED_TOP_FIELDS = [\n    \"version\",\n    \"job_id\",\n    \"account\",\n    \"language\",\n    \"scene_count\",\n    \"scenes\",\n]\n\nREQUIRED_SCENE_FIELDS_S1 = [\n    \"scene_id\",\n    \"narration\",\n    \"narration_original\",\n    \"narration_tts\",\n    \"scene_title\",\n    \"scene_summary\",\n    \"narrative_function\",\n    \"sectors_contributed\",\n]\n\nRESERVED_SCENE_FIELDS = [\n    \"audio_clip\",\n    \"duration_actual\",\n    \"word_timestamps\",\n    \"entities\",\n    \"assets\",\n    \"visual_brief\",\n    \"visual_direction\",\n    \"mood\",\n    \"composition\",\n]\n\n\ndef validate_scene_bible_schema(bible: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Validate S1-stage scene bible structure.\"\"\"\n    errors: list[dict[str, Any]] = []\n    warnings: list[dict[str, Any]] = []\n\n    for field in REQUIRED_TOP_FIELDS:\n        if field not in bible:\n            errors.append({\n                \"code\": \"missing_top_field\",\n                \"field\": field,\n                \"message\": f\"Missing required field: {field}\",\n            })\n\n    if errors:\n        return {\"valid\": False, \"errors\": errors, \"warnings\": warnings}\n\n    scenes = bible.get(\"scenes\", [])\n    if not isinstance(scenes, list):\n        errors.append({\n            \"code\": \"invalid_scenes_type\",\n            \"field\": \"scenes\",\n            \"message\": \"scenes must be a list\",\n        })\n        return {\"valid\": False, \"errors\": errors, \"warnings\": warnings}\n\n    if len(scenes) == 0:\n        errors.append({\n            \"code\": \"empty_scenes\",\n            \"field\": \"scenes\",\n            \"message\": \"scenes list is empty\",\n        })\n        return {\"valid\": False, \"errors\": errors, \"warnings\": warnings}\n\n    if bible.get(\"scene_count\") != len(scenes):\n        warnings.append({\n            \"code\": \"scene_count_mismatch\",\n            \"message\": f\"scene_count={bible.get('scene_count')} but {len(scenes)} scenes in list\",\n        })\n\n    seen_scene_ids: set[str] = set()\n    for i, scene in enumerate(scenes):\n        scene_id = scene.get(\"scene_id\", f\"scene_{i}\")\n\n        for field in REQUIRED_SCENE_FIELDS_S1:\n            if field not in scene:\n                errors.append({\n                    \"code\": \"missing_scene_field\",\n                    \"field\": f\"scenes[{i}].{field}\",\n                    \"scene_id\": scene_id,\n                    \"message\": f\"Scene {scene_id} missing required S1 field: {field}\",\n                })\n\n        narration = str(scene.get(\"narration\", \"\"))\n        narration_original = str(scene.get(\"narration_original\", \"\"))\n        narration_tts = str(scene.get(\"narration_tts\", \"\"))\n\n        if not narration.strip():\n            errors.append({\n                \"code\": \"empty_narration\",\n                \"field\": f\"scenes[{i}].narration\",\n                \"scene_id\": scene_id,\n                \"message\": f\"Scene {scene_id} has empty narration\",\n            })\n\n        if not narration_original.strip():\n            errors.append({\n                \"code\": \"empty_narration_original\",\n                \"field\": f\"scenes[{i}].narration_original\",\n                \"scene_id\": scene_id,\n                \"message\": f\"Scene {scene_id} has empty narration_original\",\n            })\n\n        if not narration_tts.strip():\n            errors.append({\n                \"code\": \"empty_narration_tts\",\n                \"field\": f\"scenes[{i}].narration_tts\",\n                \"scene_id\": scene_id,\n                \"message\": f\"Scene {scene_id} has empty narration_tts\",\n            })\n\n        if narration and narration_tts and narration != narration_tts:\n            warnings.append({\n                \"code\": \"narration_field_mismatch\",\n                \"field\": f\"scenes[{i}].narration\",\n                \"scene_id\": scene_id,\n                \"message\": f\"Scene {scene_id} narration differs from narration_tts; compatibility field should normally mirror narration_tts\",\n            })\n\n        for field in RESERVED_SCENE_FIELDS:\n            if field not in scene:\n                warnings.append({\n                    \"code\": \"missing_reserved_field\",\n                    \"field\": f\"scenes[{i}].{field}\",\n                    \"scene_id\": scene_id,\n                    \"message\": f\"Scene {scene_id} missing reserved field: {field}\",\n                })\n\n        if scene_id in seen_scene_ids:\n            errors.append({\n                \"code\": \"duplicate_scene_id\",\n                \"field\": \"scene_id\",\n                \"message\": f\"Duplicate scene_id: {scene_id}\",\n            })\n        seen_scene_ids.add(scene_id)\n\n    return {\n        \"valid\": len(errors) == 0,\n        \"errors\": errors,\n        \"warnings\": warnings,\n        \"scene_count\": len(scenes),\n    }\n"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\scene_bible_schema_validator.py\",\"content\":\"\\\"\\\"\\\"Scene Bible Schema Validator — validates S1-stage structure of scene_bible.json.\\n\\nChecks:\\n- required top-level fields\\n- required-at-S1 scene fields\\n- reserved downstream fields presence\\n- duplicate scene IDs\\n- scene_count consistency\\n\\n100% deterministic.\\n\\\"\\\"\\\"\\n\\nfrom __future__ import annotations\\n\\nfrom typing import Any\\n\\n\\nREQUIRED_TOP_FIELDS = [\\n    \\\"version\\\",\\n    \\\"job_id\\\",\\n    \\\"account\\\",\\n    \\\"language\\\",\\n    \\\"scene_count\\\",\\n    \\\"scenes\\\",\\n]\\n\\nREQUIRED_SCENE_FIELDS_S1 = [\\n    \\\"scene_id\\\",\\n    \\\"narration\\\",\\n    \\\"narration_original\\\",\\n    \\\"narration_tts\\\",\\n    \\\"scene_title\\\",\\n    \\\"scene_summary\\\",\\n    \\\"narrative_function\\\",\\n    \\\"sectors_contributed\\\",\\n]\\n\\nRESERVED_SCENE_FIELDS = [\\n    \\\"audio_clip\\\",\\n    \\\"duration_actual\\\",\\n    \\\"word_timestamps\\\",\\n    \\\"entities\\\",\\n    \\\"assets\\\",\\n    \\\"visual_brief\\\",\\n    \\\"visual_direction\\\",\\n    \\\"mood\\\",\\n    \\\"composition\\\",\\n]\\n\\n\\ndef validate_scene_bible_schema(bible: dict[str, Any]) -> dict[str, Any]:\\n    \\\"\\\"\\\"Validate S1-stage scene bible structure.\\\"\\\"\\\"\\n    errors: list[dict[str, Any]] = []\\n    warnings: list[dict[str, Any]] = []\\n\\n    for field in REQUIRED_TOP_FIELDS:\\n        if field not in bible:\\n            errors.append({\\n                \\\"code\\\": \\\"missing_top_field\\\",\\n                \\\"field\\\": field,\\n                \\\"message\\\": f\\\"Missing required field: {field}\\\",\\n            })\\n\\n    if errors:\\n        return {\\\"valid\\\": False, \\\"errors\\\": errors, \\\"warnings\\\": warnings}\\n\\n    scenes = bible.get(\\\"scenes\\\", [])\\n    if not isinstance(scenes, list):\\n        errors.append({\\n            \\\"code\\\": \\\"invalid_scenes_type\\\",\\n            \\\"field\\\": \\\"scenes\\\",\\n            \\\"message\\\": \\\"scenes must be a list\\\",\\n        })\\n        return {\\\"valid\\\": False, \\\"errors\\\": errors, \\\"warnings\\\": warnings}\\n\\n    if len(scenes) == 0:\\n        errors.append({\\n            \\\"code\\\": \\\"empty_scenes\\\",\\n            \\\"field\\\": \\\"scenes\\\",\\n            \\\"message\\\": \\\"scenes list is empty\\\",\\n        })\\n        return {\\\"valid\\\": False, \\\"errors\\\": errors, \\\"warnings\\\": warnings}\\n\\n    if bible.get(\\\"scene_count\\\") != len(scenes):\\n        warnings.append({\\n            \\\"code\\\": \\\"scene_count_mismatch\\\",\\n            \\\"message\\\": f\\\"scene_count={bible.get('scene_count')} but {len(scenes)} scenes in list\\\",\\n        })\\n\\n    seen_scene_ids: set[str] = set()\\n    for i, scene in enumerate(scenes):\\n        scene_id = scene.get(\\\"scene_id\\\", f\\\"scene_{i}\\\")\\n\\n        for field in REQUIRED_SCENE_FIELDS_S1:\\n            if field not in scene:\\n                errors.append({\\n                    \\\"code\\\": \\\"missing_scene_field\\\",\\n                    \\\"field\\\": f\\\"scenes[{i}].{field}\\\",\\n                    \\\"scene_id\\\": scene_id,\\n                    \\\"message\\\": f\\\"Scene {scene_id} missing required S1 field: {field}\\\",\\n                })\\n\\n        narration = str(scene.get(\\\"narration\\\", \\\"\\\"))\\n        narration_original = str(scene.get(\\\"narration_original\\\", \\\"\\\"))\\n        narration_tts = str(scene.get(\\\"narration_tts\\\", \\\"\\\"))\\n\\n        if not narration.strip():\\n            errors.append({\\n                \\\"code\\\": \\\"empty_narration\\\",\\n                \\\"field\\\": f\\\"scenes[{i}].narration\\\",\\n                \\\"scene_id\\\": scene_id,\\n                \\\"message\\\": f\\\"Scene {scene_id} has empty narration\\\",\\n            })\\n\\n        if not narration_original.strip():\\n            errors.append({\\n                \\\"code\\\": \\\"empty_narration_original\\\",\\n                \\\"field\\\": f\\\"scenes[{i}].narration_original\\\",\\n                \\\"scene_id\\\": scene_id,\\n                \\\"message\\\": f\\\"Scene {scene_id} has empty narration_original\\\",\\n            })\\n\\n        if not narration_tts.strip():\\n            errors.append({\\n                \\\"code\\\": \\\"empty_narration_tts\\\",\\n                \\\"field\\\": f\\\"scenes[{i}].narration_tts\\\",\\n                \\\"scene_id\\\": scene_id,\\n                \\\"message\\\": f\\\"Scene {scene_id} has empty narration_tts\\\",\\n            })\\n\\n        if narration and narration_tts and narration != narration_tts:\\n            warnings.append({\\n                \\\"code\\\": \\\"narration_field_mismatch\\\",\\n                \\\"field\\\": f\\\"scenes[{i}].narration\\\",\\n                \\\"scene_id\\\": scene_id,\\n                \\\"message\\\": f\\\"Scene {scene_id} narration differs from narration_tts; compatibility field should normally mirror narration_tts\\\",\\n            })\\n\\n        for field in RESERVED_SCENE_FIELDS:\\n            if field not in scene:\\n                warnings.append({\\n                    \\\"code\\\": \\\"missing_reserved_field\\\",\\n                    \\\"field\\\": f\\\"scenes[{i}].{field}\\\",\\n                    \\\"scene_id\\\": scene_id,\\n                    \\\"message\\\": f\\\"Scene {scene_id} missing reserved field: {field}\\\",\\n                })\\n\\n        if scene_id in seen_scene_ids:\\n            errors.append({\\n                \\\"code\\\": \\\"duplicate_scene_id\\\",\\n                \\\"field\\\": \\\"scene_id\\\",\\n                \\\"message\\\": f\\\"Duplicate scene_id: {scene_id}\\\",\\n            })\\n        seen_scene_ids.add(scene_id)\\n\\n    return {\\n        \\\"valid\\\": len(errors) == 0,\\n        \\\"errors\\\": errors,\\n        \\\"warnings\\\": warnings,\\n        \\\"scene_count\\\": len(scenes),\\n    }\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":1250,"output":1392,"cacheRea