m thorough in understanding what's going wrong. I'll take my time to figure this out!\"}]}"},{"type":"toolCall","id":"call_OAdcatPpOjDGULRzTrTawKN4|fc_0408171ee7a64bae0169ce196f84308190bd9bca774c3b1cae","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\supervisor_runtime.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\supervisor_runtime.py\"}"},{"type":"toolCall","id":"call_eUvlKlO0TBV3O2KThnfuF1ba|fc_0408171ee7a64bae0169ce196f84408190a50645b20fbde964","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\supervisor_skills\\tts_polish_output_validator.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\supervisor_skills\\\\tts_polish_output_validator.py\"}"},{"type":"toolCall","id":"call_kgQTLAQ5DHFeS1nDeF9CoNTb|fc_0408171ee7a64bae0169ce196f84488190898acd29b8637408","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\supervisor_skills\\tts_polish_merger.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\supervisor_skills\\\\tts_polish_merger.py\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":1751,"output":174,"cacheRead":77440,"cacheWrite":0,"totalTokens":79365,"cost":{"input":0.0043775,"output":0.00261,"cacheRead":0.01936,"cacheWrite":0,"total":0.0263475}},"stopReason":"toolUse","timestamp":1775114592219,"responseId":"resp_0408171ee7a64bae0169ce1962127081908a73bdd302e652c6"}}
{"type":"message","id":"3b43d629","parentId":"3c9ac5a6","timestamp":"2026-04-02T07:23:27.326Z","message":{"role":"toolResult","toolCallId":"call_OAdcatPpOjDGULRzTrTawKN4|fc_0408171ee7a64bae0169ce196f84308190bd9bca774c3b1cae","toolName":"read","content":[{"type":"text","text":"\"\"\"S1 Supervisor Runtime — canonical execution substrate for SM-S1.\n\nThis module is the execution substrate for the canonical S1 architecture.\nIt is intended to support the OpenClaw supervisor (`sm_s1_pre_production`) as the\nruntime brain of the sector.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport re\nimport shutil\nimport subprocess\nfrom pathlib import Path\nfrom typing import Any\n\nimport yaml\n\nfrom runtime.s1.checkpoint_writer import write_checkpoint\nfrom runtime.s1.polish_validator import validate_polish\nfrom runtime.s1.scene_bible_builder import build_scene_bible, write_scene_bible\nfrom runtime.s1.scene_bible_schema_validator import validate_scene_bible_schema\nfrom runtime.s1.screenplay_validator import validate_screenplay\nfrom runtime.s1.supervisor_skills.operator_batch_scheduler import (\n    build_batch_schedule,\n    summarize_batch_execution,\n)\nfrom runtime.s1.supervisor_skills.retry_planner import plan_retry\nfrom runtime.s1.supervisor_skills.s1_paths_resolver import resolve_paths\nfrom runtime.s1.supervisor_skills.s1_preflight_checker import run_preflight\nfrom runtime.s1.supervisor_skills.s1_result_summarizer import summarize_s1_result\nfrom runtime.s1.supervisor_skills.scene_director_io_adapter import write_scene_director_payload\nfrom runtime.s1.supervisor_skills.scene_director_output_validator import validate_scene_director_output\nfrom runtime.s1.supervisor_skills.scene_reconstructor import reconstruct_scene_batch\nfrom runtime.s1.supervisor_skills.screenplay_merger import merge_screenplay_batches\nfrom runtime.s1.supervisor_skills.script_batch_planner import plan_script_batches_from_file\nfrom runtime.s1.supervisor_skills.tts_polish_batch_planner import plan_tts_polish_batches\nfrom runtime.s1.supervisor_skills.tts_polish_io_adapter import write_tts_polish_payload\nfrom runtime.s1.supervisor_skills.tts_polish_merger import merge_tts_polish_batches\nfrom runtime.s1.supervisor_skills.tts_polish_output_validator import validate_tts_polish_output\n\nACCOUNTS_DIR = Path(__file__).parent.parent.parent / \"accounts\"\nDEFAULT_SCENE_DIRECTOR_CONCURRENCY = 2\nDEFAULT_TTS_POLISH_CONCURRENCY = 4\nDEFAULT_MAX_RETRIES = 3\n\n\ndef run_s1_supervisor_runtime(\n    *,\n    run_root: str | Path,\n    job: dict[str, Any] | None = None,\n    channel_config: dict[str, Any] | None = None,\n    model: str = \"gpt-4.1-mini\",\n    max_retries: int = DEFAULT_MAX_RETRIES,\n) -> dict[str, Any]:\n    run_root = Path(run_root)\n    checkpoints_written: list[str] = []\n    all_warnings: list[dict[str, Any]] = []\n    all_errors: list[dict[str, Any]] = []\n\n    preflight = run_preflight(run_root)\n    if not preflight.get(\"ok\"):\n        return _failed_result(run_root, preflight.get(\"errors\", []), preflight.get(\"warnings\", []))\n    all_warnings.extend(preflight.get(\"warnings\", []))\n\n    if job is None:\n        job = preflight.get(\"job\", {})\n\n    account = job.get(\"account\")\n    language = job.get(\"language\")\n    if channel_config is None:\n        channel_config = _load_config(account, language)\n\n    paths_result = resolve_paths(run_root, create_dirs=True)\n    paths = paths_result.get(\"paths\", {})\n    all_warnings.extend(paths_result.get(\"warnings\", []))\n\n    script_path = Path(preflight[\"paths\"][\"script_raw\"])\n    script_raw = script_path.read_text(encoding=\"utf-8\")\n\n    screenplay_lane = _run_scene_director_lane(\n        run_root=run_root,\n        job=job,\n        channel_config=channel_config,\n        paths=paths,\n        script_path=script_path,\n        script_raw=script_raw,\n        model=model,\n        max_retries=max_retries,\n    )\n    all_warnings.extend(screenplay_lane.get(\"warnings\", []))\n    if not screenplay_lane.get(\"ok\"):\n        all_errors.extend(screenplay_lane.get(\"errors\", []))\n        return _failed_result(run_root, all_errors, all_warnings)\n\n    checkpoints_written.extend(screenplay_lane.get(\"checkpoints_written\", []))\n    screenplay = screenplay_lane[\"screenplay\"]\n    screenplay_result = screenplay_lane[\"screenplay_result\"]\n\n    polish_lane = _run_tts_polish_lane(\n        run_root=run_root,\n        job=job,\n        channel_config=channel_config,\n        paths=paths,\n        screenplay=screenplay,\n        model=model,\n        max_retries=max_retries,\n    )\n    all_warnings.extend(polish_lane.get(\"warnings\", []))\n    if not polish_lane.get(\"ok\"):\n        all_errors.extend(polish_lane.get(\"errors\", []))\n        return _failed_result(run_root, all_errors, all_warnings)\n\n    checkpoints_written.extend(polish_lane.get(\"checkpoints_written\", []))\n    polished = polish_lane[\"tts_polished\"]\n    polish_result = polish_lane[\"polish_result\"]\n\n    scene_bible_result = _run_scene_bible_lane(\n        run_root=run_root,\n        job=job,\n        screenplay=screenplay,\n        polished=polished,\n        paths=paths,\n    )\n    all_warnings.extend(scene_bible_result.get(\"warnings\", []))\n    if not scene_bible_result.get(\"ok\"):\n        all_errors.extend(scene_bible_result.get(\"errors\", []))\n        return _failed_result(run_root, all_errors, all_warnings)\n\n    checkpoints_written.extend(scene_bible_result.get(\"checkpoints_written\", []))\n\n    write_checkpoint(\n        run_root,\n        \"b1_complete\",\n        \"sm_s1_pre_production\",\n        [\n            \"b1_pre_production/screenplay.json\",\n            \"b1_pre_production/screenplay_validation.json\",\n            \"b1_pre_production/tts_polished.json\",\n            \"b1_pre_production/polish_validation.json\",\n            \"scene_bible.json\",\n        ],\n        extra={\n            \"scene_count\": scene_bible_result.get(\"scene_count\", 0),\n            \"screenplay_validated\": True,\n            \"polish_validated\": True,\n            \"scene_bible_schema_valid\": True,\n        },\n    )\n    checkpoints_written.append(\"b1_complete.json\")\n\n    return summarize_s1_result(\n        run_root=run_root,\n        screenplay_result=screenplay_result,\n        polish_result=polish_result,\n        scene_bible_path=scene_bible_result.get(\"scene_bible_path\"),\n        checkpoints_written=checkpoints_written,\n        warnings=all_warnings,\n        errors=all_errors,\n    )\n\n\ndef _run_scene_director_lane(\n    *,\n    run_root: Path,\n    job: dict[str, Any],\n    channel_config: dict[str, Any],\n    paths: dict[str, Any],\n    script_path: Path,\n    script_raw: str,\n    model: str,\n    max_retries: int,\n) -> dict[str, Any]:\n    warnings: list[dict[str, Any]] = []\n    errors: list[dict[str, Any]] = []\n    checkpoints_written: list[str] = []\n\n    batch_plan = plan_script_batches_from_file(script_path)\n    warnings.extend(batch_plan.get(\"warnings\", []))\n    if not batch_plan.get(\"ok\"):\n        return _lane_fail(batch_plan.get(\"errors\", []), warnings)\n\n    prepared_batches = []\n    for batch in batch_plan.get(\"batches\", []):\n        batch_id = batch[\"batch_id\"]\n        input_path = Path(paths[\"scene_director_inputs_root\"]) / f\"{batch_id}_input.json\"\n        output_path = Path(paths[\"scene_director_intermediate_root\"]) / f\"{batch_id}_output.json\"\n        payload_result = write_scene_director_payload(\n            run_root=run_root,\n            job=job,\n            batch=batch,\n            channel_config=channel_config,\n            input_path=input_path,\n            output_path=output_path,\n        )\n        prepared_batches.append(\n            {\n                \"batch_id\": batch_id,\n                \"input_path\": payload_result[\"input_path\"],\n                \"output_path\": payload_result[\"output_path\"],\n                \"status\": \"queued\",\n            }\n        )\n\n    batch_lookup = {batch[\"batch_id\"]: batch for batch in prepared_batches}\n    approved_batch_files: dict[str, str] = {}\n    failed_batch_ids: set[str] = set(batch_lookup.keys())\n    attempt = 0\n\n    while failed_batch_ids and attempt <= max_retries:\n        attempt_batches = [batch_lookup[bid] for bid in prepared_batches_order(batch_lookup, failed_batch_ids)]\n        schedule = build_batch_schedule(\n            operator_name=\"scene_director\",\n            batches=attempt_batches,\n            concurrency_cap=DEFAULT_SCENE_DIRECTOR_CONCURRENCY,\n        )\n        if not schedule.get(\"ok\"):\n            return _lane_fail(schedule.get(\"errors\", []), warnings)\n\n        execution_results = []\n        for wave in schedule.get(\"waves\", []):\n            for batch in wave.get(\"batches\", []):\n                execution_results.append(\n                    _invoke_scene_director_batch(\n                        input_path=batch[\"input_path\"],\n                        output_path=batch[\"output_path\"],\n                        model=model,\n                    )\n                )\n\n        execution_summary = summarize_batch_execution(\n            operator_name=\"scene_director\",\n            concurrency_cap=DEFAULT_SCENE_DIRECTOR_CONCURRENCY,\n            execution_results=execution_results,\n        )\n        warnings.extend(execution_summary.get(\"warnings\", []))\n\n        current_failed: set[str] = set()\n        current_errors: list[dict[str, Any]] = []\n\n        for batch in attempt_batches:\n            batch_id = batch[\"batch_id\"]\n            output_path = Path(batch[\"output_path\"])\n            if not output_path.exists():\n                current_failed.add(batch_id)\n                current_errors.append(\n                    {\n                        \"code\": \"missing_batch_output\",\n                        \"message\": f\"scene_director did not produce output artifact for {batch_id}: {output_path}\",\n                    }\n                )\n                continue\n\n            payload_data = json.loads(Path(batch[\"input_path\"]).read_text(encoding=\"utf-8\"))\n            try:\n                output_data = json.loads(output_path.read_text(encoding=\"utf-8\"))\n            except Exception as exc:  # noqa: BLE001\n                current_failed.add(batch_id)\n                current_errors.append(\n                    {\n                        \"code\": \"invalid_batch_json\",\n                        \"message\": f\"scene_director produced invalid JSON for {batch_id}: {exc}\",\n                    }\n                )\n                continue\n\n            scene_words_range = payload_data.get(\"scene_words_range\", {})\n            if isinstance(scene_words_range, dict):\n                min_words = scene_words_range.get(\"min\")\n                max_words = scene_words_range.get(\"max\")\n            elif isinstance(scene_words_range, list) and len(scene_words_range) >= 2:\n                min_words, max_words = scene_words_range[0], scene_words_range[1]\n            else:\n                min_words, max_words = 35, 75\n\n            reconstruct_result = reconstruct_scene_batch(\n                agent_output=output_data,\n                original_text=payload_data[\"batch\"][\"text\"],\n                min_words=min_words,\n                max_words=max_words,\n                batch_id=batch_id,\n            )\n            if not reconstruct_result.get(\"ok\"):\n                current_failed.add(batch_id)\n                current_errors.extend(reconstruct_result.get(\"errors\", []))\n                continue\n\n            Path(batch[\"output_path\"]).write_text(\n                json.dumps(reconstruct_result[\"output\"], indent=2, ensure_ascii=False),\n                encoding=\"utf-8\",\n            )\n\n            validation = validate_scene_director_output(\n                batch_payload_path=batch[\"input_path\"],\n                batch_output_path=batch[\"output_path\"],\n            )\n            if validation.get(\"approved_for_merge\"):\n                approved_batch_files[batch_id] = batch[\"output_path\"]\n            else:\n                current_failed.add(batch_id)\n                current_errors.extend(validation.get(\"errors\", []))\n\n        for approved_id in list(approved_batch_files.keys()):\n            current_failed.discard(approved_id)\n\n        if not current_failed:\n            failed_batch_ids = set()\n            break\n\n        if attempt >= max_retries:\n            errors.extend(current_errors)\n            failed_batch_ids = current_failed\n            break\n\n        warnings.append(\n            {\n                \"code\": \"scene_director_subset_retry\",\n                \"message\": f\"Retrying scene_director subset after attempt {attempt + 1}: {sorted(current_failed)}\",\n            }\n        )\n        failed_batch_ids = current_failed\n        attempt += 1\n\n    if failed_batch_ids:\n        retry_decision = plan_retry(\n            step_name=\"scene_director\",\n            failure_type=\"screenplay_validation_failed\",\n            retry_count=attempt,\n            affected_batches=sorted(failed_batch_ids),\n            max_retries=max_retries,\n        )\n        errors.append(\n            {\n                \"code\": \"scene_director_lane_incomplete\",\n                \"message\": f\"Scene director lane still requires retry orchestration: {retry_decision}\",\n            }\n        )\n        return _lane_fail(errors, warnings)\n\n    approved_batch_files_list = [approved_batch_files[bid] for bid in prepared_batches_order(batch_lookup, approved_batch_files.keys())]\n\n    screenplay_result = merge_screenplay_batches(\n        approved_batch_files_list,\n        output_path=paths[\"screenplay_path\"],\n    )\n    warnings.extend(screenplay_result.get(\"warnings\", []))\n    if not screenplay_result.get(\"ok\"):\n        return _lane_fail(screenplay_result.get(\"errors\", []), warnings)\n\n    screenplay = screenplay_result[\"screenplay\"]\n    validation = validate_screenplay(script_raw, screenplay.get(\"scenes\", []))\n    validation_path = Path(paths[\"screenplay_validation_path\"])\n    validation_path.write_text(json.dumps(validation, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    if not validation.get(\"valid\"):\n        retry_decision = plan_retry(\n            step_name=\"scene_director\",\n            failure_type=\"screenplay_validation_failed\",\n            retry_count=0,\n            affected_batches=[],\n            max_retries=max_retries,\n        )\n        errors.append(\n            {\n                \"code\": \"screenplay_validation_failed\",\n                \"message\": f\"Canonical screenplay failed validation and still needs supervisor retry control: {retry_decision}\",\n            }\n        )\n        return _lane_fail(errors, warnings)\n\n    write_checkpoint(\n        run_root,\n        \"b1_step1_screenplay\",\n        \"scene_director\",\n        [\"b1_pre_production/screenplay.json\"],\n        extra={\"scene_count\": screenplay_result.get(\"scene_count\", 0), \"model\": model},\n    )\n    checkpoints_written.append(\"b1_step1_screenplay.json\")\n\n    write_checkpoint(\n        run_root,\n        \"b1_step2_screenplay_validated\",\n        \"screenplay_validator\",\n        [\"b1_pre_production/screenplay_validation.json\"],\n        retries=0,\n        validation_passed=True,\n    )\n    checkpoints_written.append(\"b1_step2_screenplay_validated.json\")\n\n    return {\n        \"ok\": True,\n        \"screenplay\": screenplay,\n        \"screenplay_result\": screenplay_result,\n        \"checkpoints_written\": checkpoints_written,\n        \"warnings\": warnings,\n        \"errors\": [],\n    }\n\n\ndef _run_tts_polish_lane(\n    *,\n    run_root: Path,\n    job: dict[str, Any],\n    channel_config: dict[str, Any],\n    paths: dict[str, Any],\n    screenplay: dict[str, Any],\n    model: str,\n    max_retries: int,\n) -> dict[str, Any]:\n    warnings: list[dict[str, Any]] = []\n    errors: list[dict[str, Any]] = []\n    checkpoints_written: list[str] = []\n\n    write_checkpoint(\n        run_root,\n        \"b1_tts_lane_entered\",\n        \"s1_supervisor\",\n        [\"b1_pre_production/screenplay.json\", \"b1_pre_production/screenplay_validation.json\"],\n        extra={\"scene_count\": len(screenplay.get(\"scenes\", [])), \"model\": model},\n    )\n    checkpoints_written.append(\"b1_tts_lane_entered.json\")\n\n    batch_plan = plan_tts_polish_batches(screenplay)\n    warnings.extend(batch_plan.get(\"warnings\", []))\n    if not batch_plan.get(\"ok\"):\n        return _lane_fail(batch_plan.get(\"errors\", []), warnings)\n\n    write_checkpoint(\n        run_root,\n        \"b1_tts_batch_plan_ready\",\n        \"tts_polish_batch_planner\",\n        [\"b1_pre_production/screenplay.json\"],\n        extra={\"batch_count\": len(batch_plan.get(\"batches\", []))},\n    )\n    checkpoints_written.append(\"b1_tts_batch_plan_ready.json\")\n\n    prepared_batches = []\n    for batch in batch_plan.get(\"batches\", []):\n        batch_id = batch[\"batch_id\"]\n        input_path = Path(paths[\"tts_polish_inputs_root\"]) / f\"{batch_id}_input.json\"\n        output_path = Path(paths[\"tts_polish_intermediate_root\"]) / f\"{batch_id}_output.json\"\n        payload_result = write_tts_polish_payload(\n            run_root=run_root,\n            job=job,\n            screenplay=screenplay,\n            batch=batch,\n            channel_config=channel_config,\n            input_path=input_path,\n            output_path=output_path,\n        )\n        prepared_batches.append(\n            {\n                \"batch_id\": batch_id,\n                \"input_path\": payload_result[\"input_path\"],\n                \"output_path\": payload_result[\"output_path\"],\n                \"status\": \"queued\",\n            }\n        )\n\n    write_checkpoint(\n        run_root,\n        \"b1_tts_payloads_written\",\n        \"tts_polish_io_adapter\",\n        [\"b1_pre_production/screenplay.json\"],\n        extra={\"batch_count\": len(prepared_batches)},\n    )\n    checkpoints_written.append(\"b1_tts_payloads_written.json\")\n\n    schedule = build_batch_schedule(\n        operator_name=\"tts_polish\",\n        batches=prepared_batches,\n        concurrency_cap=DEFAULT_TTS_POLISH_CONCURRENCY,\n    )\n    if not schedule.get(\"ok\"):\n        return _lane_fail(schedule.get(\"errors\", []), warnings)\n\n    write_checkpoint(\n        run_root,\n        \"b1_tts_schedule_ready\",\n        \"operator_batch_scheduler\",\n        [\"b1_pre_production/screenplay.json\"],\n        extra={\"wave_count\": len(schedule.get(\"waves\", [])), \"concurrency_cap\": DEFAULT_TTS_POLISH_CONCURRENCY},\n    )\n    checkpoints_written.append(\"b1_tts_schedule_ready.json\")\n\n    execution_results = []\n    for wave in schedule.get(\"waves\", []):\n        for batch in wave.get(\"batches\", []):\n            write_checkpoint(\n                run_root,\n                \"b1_tts_first_batch_started\" if not execution_results else f\"b1_tts_batch_started_{batch['batch_id']}\",\n                \"tts_polish\",\n                [\"b1_pre_production/screenplay.json\"],\n                extra={\"batch_id\": batch[\"batch_id\"], \"model\": model},\n            )\n            execution_results.append(\n                _invoke_tts_polish_batch(\n                    input_path=batch[\"input_path\"],\n                    output_path=batch[\"output_path\"],\n                    model=model,\n                )\n            )\n\n    execution_summary = summarize_batch_execution(\n        operator_name=\"tts_polish\",\n        concurrency_cap=DEFAULT_TTS_POLISH_CONCURRENCY,\n        execution_results=execution_results,\n    )\n    warnings.extend(execution_summary.get(\"warnings\", []))\n    write_checkpoint(\n        run_root,\n        \"b1_tts_execution_summary_ready\",\n        \"tts_polish\",\n        [\"b1_pre_production/screenplay.json\"],\n        extra={\n            \"completed\": len(execution_summary.get(\"completed_batches\", [])),\n            \"failed\": len(execution_summary.get(\"failed_batches\", [])),\n            \"pending\": len(execution_summary.get(\"pending_batches\", [])),\n        },\n    )\n    checkpoints_written.append(\"b1_tts_execution_summary_ready.json\")\n\n    approved_batch_files: list[str] = []\n    failed_batch_ids: list[str] = []\n    localized_meaning_flags = 0\n    for batch in prepared_batches:\n        validation = validate_tts_polish_output(\n            batch_payload_path=batch[\"input_path\"],\n            batch_output_path=batch[\"output_path\"],\n        )\n        validation_errors = validation.get(\"errors\", [])\n        meaning_only = validation_errors and all(err.get(\"code\") == \"meaningful_change_detected\" for err in validation_errors)\n        localized_flag_count = sum(1 for err in validation_errors if err.get(\"code\") == \"meaningful_change_detected\")\n\n        if validation.get(\"approved_for_merge\") or (meaning_only and localized_flag_count <= 4):\n            approved_batch_files.append(batch[\"output_path\"])\n            if meaning_only and localized_flag_count <= 4:\n                localized_meaning_flags += localized_flag_count\n                warnings.append(\n                    {\n                        \"code\": \"localized_meaningful_change_tolerated\",\n                        \"message\": f\"Accepted batch {batch['batch_id']} with {localized_flag_count} localized meaningful_change_detected flags.\",\n                    }\n                )\n            continue\n\n        failed_batch_ids.append(batch[\"batch_id\"])\n        errors.extend(validation_errors)\n\n    if failed_batch_ids:\n        retry_decision = plan_retry(\n            step_name=\"tts_polish\",\n            failure_type=\"polish_validation_failed\",\n            retry_count=0,\n            affected_batches=failed_batch_ids,\n            max_retries=max_retries,\n        )\n        errors.append(\n            {\n                \"code\": \"tts_polish_lane_incomplete\",\n                \"message\": f\"TTS polish lane requires retry/reviewer orchestration for failed batches: {retry_decision}\",\n            }\n        )\n        return _lane_fail(errors, warnings)\n\n    polish_result = merge_tts_polish_batches(\n        approved_batch_files,\n        screenplay=screenplay,\n        output_path=paths[\"tts_polished_path\"],\n    )\n    warnings.extend(polish_result.get(\"warnings\", []))\n    if not polish_result.get(\"ok\"):\n        return _lane_fail(polish_result.get(\"errors\", []), warnings)\n\n    polished = polish_result[\"tts_polished\"]\n    validation = validate_polish(screenplay.get(\"scenes\", []), polished.get(\"scenes\", []))\n    validation_path = Path(paths[\"polish_validation_path\"])\n    validation_path.write_text(json.dumps(validation, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    if not validation.get(\"valid\"):\n        retry_decision = plan_retry(\n            step_name=\"tts_polish\",\n            failure_type=\"polish_validation_failed\",\n            retry_count=0,\n            affected_batches=[],\n            max_retries=max_retries,\n        )\n        errors.append(\n            {\n                \"code\": \"polish_validation_failed\",\n                \"message\": f\"Canonical TTS polish failed validation and still needs supervisor retry control: {retry_decision}\",\n            }\n        )\n        return _lane_fail(errors, warnings)\n\n    write_checkpoint(\n        run_root,\n        \"b1_step3_tts_polished\",\n        \"tts_polish\",\n        [\"b1_pre_production/tts_polished.json\"],\n        extra={\n            \"scene_count\": polish_result.get(\"scene_count\", 0),\n            \"model\": model,\n            \"localized_meaning_flags_tolerated\": localized_meaning_flags,\n        },\n    )\n    checkpoints_written.append(\"b1_step3_tts_polished.json\")\n\n    write_checkpoint(\n        run_root,\n        \"b1_step4_polish_validated\",\n        \"polish_validator\",\n        [\"b1_pre_production/polish_validation.json\"],\n        retries=0,\n        validation_passed=True,\n    )\n    checkpoints_written.append(\"b1_step4_polish_validated.json\")\n\n    return {\n        \"ok\": True,\n        \"tts_polished\": polished,\n        \"polish_result\": polish_result,\n        \"checkpoints_written\": checkpoints_written,\n        \"warnings\": warnings,\n        \"errors\": [],\n    }\n\n\ndef _run_scene_bible_lane(\n    *,\n    run_root: Path,\n    job: dict[str, Any],\n    screenplay: dict[str, Any],\n    polished: list[dict[str, Any]],\n    paths: dict[str, Any],\n) -> dict[str, Any]:\n    warnings: list[dict[str, Any]] = []\n    errors: list[dict[str, Any]] = []\n    checkpoints_written: list[str] = []\n\n    bible = build_scene_bible(polished, job, screenplay.get(\"scenes\", []))\n    schema_validation = validate_scene_bible_schema(bible)\n    warnings.extend(schema_validation.get(\"warnings\", []))\n    if not schema_validation.get(\"valid\"):\n        return _lane_fail(schema_validation.get(\"errors\", []), warnings)\n\n    scene_bible_path = write_scene_bible(bible, run_root)\n    write_checkpoint(\n        run_root,\n        \"b1_step5_scene_bible\",\n        \"scene_bible_builder\",\n        [\"scene_bible.json\"],\n        extra={\"scene_count\": len(bible.get(\"scenes\", []))},\n    )\n    checkpoints_written.append(\"b1_step5_scene_bible.json\")\n\n    return {\n        \"ok\": True,\n        \"scene_bible_path\": scene_bible_path,\n        \"scene_count\": len(bible.get(\"scenes\", [])),\n        \"checkpoints_written\": checkpoints_written,\n        \"warnings\": warnings,\n        \"errors\": errors,\n    }\n\n\ndef _invoke_scene_director_batch(*, input_path: str, output_path: str, model: str) -> dict[str, Any]:\n    batch_id = Path(input_path).stem.replace(\"_input\", \"\")\n    openclaw_bin = shutil.which(\"openclaw\")\n    if not openclaw_bin:\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [{\"code\": \"openclaw_cli_not_found\", \"message\": \"Cannot invoke scene_director: `openclaw` CLI not found in PATH.\"}],\n            \"warnings\": [],\n        }\n\n    command = [\n        openclaw_bin,\n        \"agent\",\n        \"--agent\",\n        \"op_s1_scene_director\",\n        \"--message\",\n        _build_scene_director_agent_message(input_path, output_path),\n        \"--local\",\n        \"--json\",\n    ]\n    env = None\n\n    try:\n        result = subprocess.run(command, text=True, capture_output=True, check=False, timeout=300, env=env)\n    except subprocess.TimeoutExpired:\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [{\"code\": \"operator_timeout\", \"message\": f\"scene_director invocation timed out for batch {batch_id}.\"}],\n            \"warnings\": [],\n        }\n    except Exception as exc:  # noqa: BLE001\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [{\"code\": \"operator_invocation_failed\", \"message\": f\"scene_director invocation raised exception: {exc}\"}],\n            \"warnings\": [],\n        }\n\n    if result.returncode != 0:\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [{\"code\": \"operator_nonzero_exit\", \"message\": f\"scene_director CLI exited with code {result.returncode}: {(result.stderr or result.stdout or '').strip()}\"}],\n            \"warnings\": [],\n        }\n\n    artifact_path = Path(output_path)\n    candidates: list[str] = []\n    warnings: list[dict[str, Any]] = []\n    if artifact_path.exists():\n        try:\n            file_text = artifact_path.read_text(encoding=\"utf-8\")\n            if file_text.strip():\n                candidates.append(file_text)\n        except Exception:\n            pass\n\n    stdout_text = (result.stdout or \"\").strip()\n    stderr_text = (result.stderr or \"\").strip()\n    candidates.extend(_collect_json_candidates(stdout_text))\n    candidates.extend(_collect_json_candidates(stderr_text))\n\n    for candidate in candidates:\n        parsed = _try_parse_json_candidate(candidate)\n        if parsed is None:\n            continue\n        try:\n            normalized = _normalize_scene_director_candidate(parsed, batch_id=batch_id)\n            artifact_path.write_text(json.dumps(normalized, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n            validation = validate_scene_director_output(\n                batch_payload_path=input_path,\n                batch_output_path=output_path,\n            )\n            if validation.get(\"approved_for_merge\"):\n                if candidate != stdout_text and stdout_text:\n                    warnings.append({\"code\": \"salvaged_scene_director_output\", \"message\": f\"Recovered valid scene_director JSON for {batch_id} from non-file candidate.\"})\n                return {\"batch_id\": batch_id, \"status\": \"completed\", \"output_path\": output_path, \"errors\": [], \"warnings\": warnings}\n        except Exception:\n            continue\n\n    if not artifact_path.exists():\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [{\"code\": \"operator_no_output\", \"message\": \"scene_director invocation completed but no valid output artifact was produced.\"}],\n            \"warnings\": warnings,\n        }\n\n    return {\n        \"batch_id\": batch_id,\n        \"status\": \"failed\",\n        \"output_path\": output_path,\n        \"errors\": [{\"code\": \"operator_invalid_output\", \"message\": \"scene_director invocation completed but no valid JSON candidate passed validation.\"}],\n        \"warnings\": warnings,\n    }\n\n\ndef _invoke_tts_polish_batch(*, input_path: str, output_path: str, model: str) -> dict[str, Any]:\n    batch_id = Path(input_path).stem.replace(\"_input\", \"\")\n    openclaw_bin = shutil.which(\"openclaw\")\n    if not openclaw_bin:\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [{\"code\": \"openclaw_cli_not_found\", \"message\": \"Cannot invoke tts_polish: `openclaw` CLI not found in PATH.\"}],\n            \"warnings\": [],\n        }\n\n    command = [\n        openclaw_bin,\n        \"agent\",\n        \"--agent\",\n        \"op_s1_tts_polish\",\n        \"--message\",\n        _build_tts_polish_agent_message(input_path, output_path),\n        \"--local\",\n        \"--json\",\n    ]\n    env = None\n\n    try:\n        result = subprocess.run(command, text=True, capture_output=True, check=False, timeout=300, env=env)\n    except subprocess.TimeoutExpired:\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [{\"code\": \"operator_timeout\", \"message\": f\"tts_polish invocation timed out for batch {batch_id}.\"}],\n            \"warnings\": [],\n        }\n    except Exception as exc:  # noqa: BLE001\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [{\"code\": \"operator_invocation_failed\", \"message\": f\"tts_polish invocation raised exception: {exc}\"}],\n            \"warnings\": [],\n        }\n\n    if result.returncode != 0:\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [{\"code\": \"operator_nonzero_exit\", \"message\": f\"tts_polish CLI exited with code {result.returncode}: {(result.stderr or result.stdout or '').strip()}\"}],\n            \"warnings\": [],\n        }\n\n    if not Path(output_path).exists():\n        stdout_text = (result.stdout or \"\").strip()\n        if stdout_text:\n            try:\n                parsed = json.loads(stdout_text)\n                Path(output_path).write_text(json.dumps(parsed, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n            except Exception:\n                pass\n\n    if not Path(output_path).exists():\n        return {\n            \"batch_id\": batch_id,\n            \"status\": \"failed\",\n            \"output_path\": output_path,\n            \"errors\": [{\"code\": \"operator_no_output\", \"message\": \"tts_polish invocation completed but no output artifact was produced.\"}],\n            \"warnings\": [],\n        }\n\n    return {\"batch_id\": batch_id, \"status\": \"completed\", \"output_path\": output_path, \"errors\": [], \"warnings\": []}\n\n\ndef _build_scene_director_agent_message(input_path: str, output_path: str) -> str:\n    return (\n        \"You are executing one canonical S1 scene_director batch. \"\n        f\"Read the batch payload JSON at: {input_path}. \"\n        \"Follow the op_s1_scene_director workspace contract exactly. \"\n        \"Write only the final batch result JSON to the output_path declared in the payload. \"\n        f\"Expected output artifact path: {output_path}. \"\n        \"Also print the exact same final JSON object to stdout with no markdown, no commentary, and no code fences. \"\n        \"Do not do visual planning, TTS polish, merge logic, or supervisor logic. \"\n        \"Return only scene_local_id, scene_title, scene_summary, narrative_function, and narration_original for each scene. \"\n        \"Do not output start_word, end_word, estimated_scene_word_count, or any span fields. \"\n        \"Your job is semantic grouping plus faithful narration_original text; the Python substrate owns final mechanical alignment. \"\n        \"Make sure the concatenation of narration_original across scenes preserves the batch text in order without loss or duplication. \"\n        \"Return valid JSON only. Escape newlines inside strings correctly. If the payload is invalid or impossible, fail clearly instead of improvising.\"\n    )\n\n\ndef _build_tts_polish_agent_message(input_path: str, output_path: str) -> str:\n    return (\n        \"You are executing one canonical S1 tts_polish batch. \"\n        f\"Read the batch payload JSON at: {input_path}. \"\n        \"Follow the op_s1_tts_polish workspace contract exactly. \"\n        \"Write only the final batch result JSON to the output_path declared in the payload. \"\n        f\"Expected output artifact path: {output_path}. \"\n        \"Do not do scene restructuring, merge logic, validation ownership, or supervisor logic. \"\n        \"If the payload is invalid or impossible, fail clearly instead of improvising.\"\n    )\n\n\ndef _load_config(account: str, language: str) -> dict[str, Any]:\n    candidate_paths = [\n        ACCOUNTS_DIR / str(account) / f\"{language}.yaml\",\n        Path(__file__).resolve().parents[2] / \"accounts\" / str(account) / f\"{language}.yaml\",\n    ]\n    for config_path in candidate_paths:\n        if config_path.exists():\n            with open(config_path, \"r\", encoding=\"utf-8\") as f:\n                return yaml.safe_load(f) or {}\n    raise FileNotFoundError(f\"Channel config not found: {candidate_paths[0]}\")\n\n\ndef _collect_json_candidates(text: str) -> list[str]:\n    if not text:\n        return []\n\n    candidates = [text]\n\n    fence_matches = re.findall(r\"```json\\s*(.*?)```\", text, flags=re.DOTALL | re.IGNORECASE)\n    candidates.extend(match.strip() for match in fence_matches if match.strip())\n\n    balanced = _extract_balanced_json_substring(text)\n    if balanced:\n        candidates.append(balanced)\n\n    deduped: list[str] = []\n    seen: set[str] = set()\n    for candidate in candidates:\n        c = candidate.strip()\n        if c and c not in seen:\n            seen.add(c)\n            deduped.append(c)\n    return deduped\n\n\n_ILLEGAL_CONTROL_CHARS_RE = re.compile(r\"[\\x00-\\x08\\x0B\\x0C\\x0E-\\x1F]\")\n\n\ndef _repair_json_candidate(text: str) -> str:\n    repaired = text.lstrip(\"\\ufeff\").strip()\n    repaired = re.sub(r\"^```json\\s*|```$\", \"\", repaired, flags=re.IGNORECASE | re.DOTALL).strip()\n    balanced = _extract_balanced_json_substring(repaired)\n    if balanced:\n        repaired = balanced\n    repaired = _ILLEGAL_CONTROL_CHARS_RE.sub(\"\", repaired)\n    return repaired\n\n\ndef _extract_balanced_json_substring(text: str) -> str | None:\n    start = None\n    depth = 0\n    in_string = False\n    escape = False\n    for i, ch in enumerate(text):\n        if start is None and ch in \"[{\":\n            start = i\n            depth = 1\n            continue\n        if start is None:\n            continue\n        if in_string:\n            if escape:\n                escape = False\n            elif ch == \"\\\\\":\n                escape = True\n            elif ch == '\"':\n                in_string = False\n            continue\n        if ch == '\"':\n            in_string = True\n        elif ch in \"[{\":\n            depth += 1\n        elif ch in \"]}\":\n            depth -= 1\n            if depth == 0:\n                return text[start:i + 1]\n    return None\n\n\ndef _try_parse_json_candidate(text: str) -> Any | None:\n    for candidate in (text, _repair_json_candidate(text)):\n        try:\n            return json.loads(candidate)\n        except Exception:\n            continue\n    return None\n\n\ndef _normalize_scene_director_candidate(data: Any, *, batch_id: str) -> dict[str, Any]:\n    if not isinstance(data, dict):\n        raise ValueError(\"scene_director candidate must be a JSON object\")\n\n    scenes = data.get(\"scenes\")\n    if not isinstance(scenes, list):\n        raise ValueError(\"scene_director candidate must include a scenes list\")\n\n    normalized_scenes: list[dict[str, Any]] = []\n    for index, scene in enumerate(scenes, start=1):\n        if not isinstance(scene, dict):\n            raise ValueError(f\"scene at index {index} must be an object\")\n\n        scene_local_id = scene.get(\"scene_local_id\") or f\"scene_{index:02d}\"\n        scene_title = scene.get(\"scene_title\") or f\"Scene {index}\"\n        scene_summary = scene.get(\"scene_summary\") or scene_title\n        narrative_function = scene.get(\"narrative_function\") or \"narrative_progression\"\n        narration_original = scene.get(\"narration_original\")\n        if not isinstance(narration_original, str) or not narration_original.strip():\n            raise ValueError(f\"scene {scene_local_id} must include non-empty narration_original\")\n\n        normalized_scenes.append(\n            {\n                \"scene_local_id\": str(scene_local_id),\n                \"scene_title\": str(scene_title),\n                \"scene_summary\": str(scene_summary),\n                \"narrative_function\": str(narrative_function),\n                \"narration_original\": str(narration_original),\n            }\n        )\n\n    return {\n        \"batch_id\": str(data.get(\"batch_id\") or batch_id),\n        \"operator\": str(data.get(\"operator\") or \"scene_director\"),\n        \"scenes\": normalized_scenes,\n    }\n\n\ndef prepared_batches_order(batch_lookup: dict[str, dict[str, Any]], batch_ids: Any) -> list[str]:\n    ordered = [batch_id for batch_id in batch_lookup.keys() if batch_id in set(batch_ids)]\n    return ordered\n\n\ndef _lane_fail(errors: list[dict[str, Any]], warnings: list[dict[str, Any]]) -> dict[str, Any]:\n    return {\"ok\": False, \"errors\": errors, \"warnings\": warnings}\n\n\ndef _failed_result(run_root: Path, errors: list[dict[str, Any]], warnings: list[dict[str, Any]]) -> dict[str, Any]:\n    return summarize_s1_result(\n        run_root=run_root,\n        screenplay_result={},\n        polish_result={},\n        scene_bible_path=None,\n        checkpoints_written=[],\n        warnings=warnings,\n        errors=errors,\n    )\n"}],"isError":false,"timestamp":1775114607254}}
{"type":"message","id":"378c89d3","parentId":"3b43d629","timestamp":"2026-04-02T07:23:27.394Z","message":{"role":"toolResult","toolCallId":"call_eUvlKlO0TBV3O2KThnfuF1ba|fc_0408171ee7a64bae0169ce196f84408190a50645b20fbde964","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport json\nimport re\nfrom pathlib import Path\nfrom typing import Any\n\n\nREQUIRED_TOP_LEVEL_FIELDS = {\n    \"batch_id\",\n    \"scenes\",\n}\n\nREQUIRED_SCENE_FIELDS = {\n    \"scene_id\",\n    \"narration_original\",\n    \"narration_tts\",\n}\n\nERROR_SEVERITY = {\n    \"payload_unreadable\": \"fatal_contract_error\",\n    \"output_unreadable\": \"fatal_contract_error\",\n    \"invalid_top_level_shape\": \"fatal_contract_error\",\n    \"empty_scenes\": \"fatal_contract_error\",\n    \"scene_count_mismatch\": \"batch_regenerate\",\n    \"scene_order_mismatch\": \"batch_regenerate\",\n    \"missing_required_field\": \"structural_patch\",\n    \"missing_scene_output\": \"scene_subset_repair\",\n    \"unexpected_scene_output\": \"batch_regenerate\",\n    \"narration_original_mismatch\": \"scene_subset_repair\",\n    \"empty_narration_tts\": \"scene_subset_repair\",\n    \"meaningful_change_detected\": \"scene_subset_repair\",\n}\n\nCLASSIFICATION_PRIORITY = [\n    \"fatal_contract_error\",\n    \"batch_regenerate\",\n    \"scene_subset_repair\",\n    \"structural_patch\",\n    \"needs_semantic_review\",\n    \"ok\",\n]\n\nNO_CHANGE_NORMALIZED_EQUIVALENTS = {\n    \"°c\": \"degrees celsius\",\n    \"ºc\": \"degrees celsius\",\n    \"��c\": \"degrees celsius\",\n    \"dr.\": \"dr\",\n    \"«\": '\"',\n    \"»\": '\"',\n}\n\n\ndef validate_tts_polish_output(\n    *,\n    batch_payload_path: str | Path,\n    batch_output_path: str | Path,\n) -> dict[str, Any]:\n    errors: list[dict[str, Any]] = []\n    warnings: list[dict[str, Any]] = []\n\n    payload_result = _load_json(batch_payload_path, error_code=\"payload_unreadable\")\n    if not payload_result[\"ok\"]:\n        return _fatal_result(batch_id=None, errors=payload_result[\"errors\"], warnings=warnings)\n\n    output_result = _load_json(batch_output_path, error_code=\"output_unreadable\")\n    if not output_result[\"ok\"]:\n        payload = payload_result[\"data\"]\n        return _fatal_result(\n            batch_id=_extract_batch_id_from_payload(payload),\n            errors=output_result[\"errors\"],\n            warnings=warnings,\n        )\n\n    payload = payload_result[\"data\"]\n    output = output_result[\"data\"]\n    expected_batch_id = _extract_batch_id_from_payload(payload)\n    batch_id = _extract_batch_id(output) or expected_batch_id\n\n    source_scenes = payload.get(\"scenes\") if isinstance(payload, dict) else None\n    if not isinstance(source_scenes, list) or not source_scenes:\n        errors.append(_error(\"invalid_top_level_shape\", \"Batch payload must include non-empty 'scenes' list\"))\n        return _finalize_result(\n            batch_id=batch_id,\n            errors=errors,\n            warnings=warnings,\n            changed_scene_count=0,\n            flagged_scene_count=0,\n            source_scene_count=0,\n        )\n\n    output_scenes = _validate_top_level_output(output, errors)\n    if not output_scenes:\n        return _finalize_result(\n            batch_id=batch_id,\n            errors=errors,\n            warnings=warnings,\n            changed_scene_count=0,\n            flagged_scene_count=0,\n            source_scene_count=len(source_scenes),\n        )\n\n    source_ids = [scene.get(\"scene_id\") for scene in source_scenes if isinstance(scene, dict)]\n    output_ids = [scene.get(\"scene_id\") for scene in output_scenes if isinstance(scene, dict)]\n\n    if expected_batch_id and _extract_batch_id(output) and _extract_batch_id(output) != expected_batch_id:\n        errors.append(_error(\n            \"missing_required_field\",\n            f\"Output batch_id '{_extract_batch_id(output)}' does not match expected '{expected_batch_id}'\",\n        ))\n\n    if len(output_scenes) != len(source_scenes):\n        errors.append(_error(\n            \"scene_count_mismatch\",\n            f\"Expected {len(source_scenes)} scenes but found {len(output_scenes)}\",\n        ))\n\n    _validate_required_scene_fields(output_scenes, errors)\n    _validate_scene_mapping(source_ids, output_ids, errors)\n\n    source_map = {\n        scene.get(\"scene_id\"): scene\n        for scene in source_scenes\n        if isinstance(scene, dict) and scene.get(\"scene_id\")\n    }\n\n    changed_scene_count = 0\n    flagged_scene_ids: set[str] = set()\n\n    for scene in output_scenes:\n        scene_id = scene.get(\"scene_id\")\n        if not isinstance(scene_id, str) or scene_id not in source_map:\n            continue\n\n        source_scene = source_map[scene_id]\n        source_original = source_scene.get(\"narration_original\")\n        output_original = scene.get(\"narration_original\")\n        narration_tts = scene.get(\"narration_tts\")\n\n        if not isinstance(output_original, str) or output_original != source_original:\n            errors.append(_error(\n                \"narration_original_mismatch\",\n                f\"Scene {scene_id} narration_original does not match source payload\",\n                scene_ids=[scene_id],\n            ))\n            flagged_scene_ids.add(scene_id)\n\n        if not isinstance(narration_tts, str) or not narration_tts.strip():\n            errors.append(_error(\n                \"empty_narration_tts\",\n                f\"Scene {scene_id} must include non-empty narration_tts\",\n                scene_ids=[scene_id],\n            ))\n            flagged_scene_ids.add(scene_id)\n            continue\n\n        if isinstance(source_original, str) and _normalize_text(narration_tts) != _normalize_text(source_original):\n            changed_scene_count += 1\n            if _is_meaningfully_different(source_original, narration_tts):\n                errors.append(_error(\n                    \"meaningful_change_detected\",\n                    f\"Scene {scene_id} narration_tts differs from source in a way that may require semantic review\",\n                    scene_ids=[scene_id],\n                ))\n                flagged_scene_ids.add(scene_id)\n\n    return _finalize_result(\n        batch_id=batch_id,\n        errors=errors,\n        warnings=warnings,\n        changed_scene_count=changed_scene_count,\n        flagged_scene_count=len(flagged_scene_ids),\n        source_scene_count=len(source_scenes),\n    )\n\n\ndef _load_json(path: str | Path, *, error_code: str) -> dict[str, Any]:\n    path = Path(path)\n    try:\n        data = json.loads(path.read_text(encoding=\"utf-8\"))\n    except Exception as exc:  # noqa: BLE001\n        return {\n            \"ok\": False,\n            \"errors\": [_error(error_code, f\"Failed to read JSON from {path}: {exc}\")],\n        }\n    return {\"ok\": True, \"data\": data}\n\n\ndef _validate_top_level_output(output: Any, errors: list[dict[str, Any]]) -> list[dict[str, Any]]:\n    if not isinstance(output, dict):\n        errors.append(_error(\"invalid_top_level_shape\", \"TTS polish output must be a JSON object\"))\n        return []\n\n    missing_top_level = sorted(REQUIRED_TOP_LEVEL_FIELDS - set(output.keys()))\n    if missing_top_level:\n        errors.append(_error(\n            \"invalid_top_level_shape\",\n            f\"Output is missing top-level fields: {', '.join(missing_top_level)}\",\n        ))\n\n    scenes = output.get(\"scenes\")\n    if not isinstance(scenes, list):\n        errors.append(_error(\"invalid_top_level_shape\", \"Output 'scenes' must be a list\"))\n        return []\n\n    if not scenes:\n        errors.append(_error(\"empty_scenes\", \"Output 'scenes' list is empty\"))\n        return []\n\n    valid_scenes: list[dict[str, Any]] = []\n    for index, scene in enumerate(scenes, start=1):\n        if not isinstance(scene, dict):\n            errors.append(_error(\n                \"missing_required_field\",\n                f\"Scene at index {index} must be an object\",\n                scene_ids=[f\"scene_index_{index}\"],\n            ))\n            continue\n        valid_scenes.append(scene)\n\n    return valid_scenes\n\n\ndef _validate_required_scene_fields(scenes: list[dict[str, Any]], errors: list[dict[str, Any]]) -> None:\n    for scene in scenes:\n        missing_fields = sorted(REQUIRED_SCENE_FIELDS - set(scene.keys()))\n        if missing_fields:\n            errors.append(_error(\n                \"missing_required_field\",\n                (\n                    f\"Scene {scene.get('scene_id', '<unknown>')} is missing required fields: \"\n                    f\"{', '.join(missing_fields)}\"\n                ),\n                scene_ids=[scene.get(\"scene_id\")],\n            ))\n\n\ndef _validate_scene_mapping(source_ids: list[Any], output_ids: list[Any], errors: list[dict[str, Any]]) -> None:\n    if source_ids != output_ids:\n        errors.append(_error(\n            \"scene_order_mismatch\",\n            \"Output scene order/identity does not match input batch scene_ids\",\n            scene_ids=[str(scene_id) for scene_id in output_ids if scene_id],\n        ))\n\n    source_set = {scene_id for scene_id in source_ids if isinstance(scene_id, str)}\n    output_set = {scene_id for scene_id in output_ids if isinstance(scene_id, str)}\n\n    missing_ids = sorted(source_set - output_set)\n    unexpected_ids = sorted(output_set - source_set)\n\n    for scene_id in missing_ids:\n        errors.append(_error(\n            \"missing_scene_output\",\n            f\"Expected scene {scene_id} is missing from polish output\",\n            scene_ids=[scene_id],\n        ))\n\n    for scene_id in unexpected_ids:\n        errors.append(_error(\n            \"unexpected_scene_output\",\n            f\"Unexpected scene {scene_id} found in polish output\",\n            scene_ids=[scene_id],\n        ))\n\n\ndef _extract_batch_id(output: dict[str, Any]) -> str | None:\n    batch_id = output.get(\"batch_id\") or output.get(\"batch\", {}).get(\"batch_id\")\n    return batch_id if isinstance(batch_id, str) and batch_id.strip() else None\n\n\ndef _extract_batch_id_from_payload(payload: dict[str, Any]) -> str | None:\n    batch = payload.get(\"batch\") if isinstance(payload, dict) else None\n    if not isinstance(batch, dict):\n        return None\n    batch_id = batch.get(\"batch_id\")\n    return batch_id if isinstance(batch_id, str) and batch_id.strip() else None\n\n\ndef _normalize_text(text: str) -> str:\n    text = text.replace(\"\\r\\n\", \" \").replace(\"\\n\", \" \").replace(\"\\t\", \" \")\n    text = re.sub(r\"\\s+\", \" \", text).strip().lower()\n    return text\n\n\ndef _canonicalize_equivalents(text: str) -> str:\n    normalized = _normalize_text(text)\n    for old, new in NO_CHANGE_NORMALIZED_EQUIVALENTS.items():\n        normalized = normalized.replace(old, new)\n    normalized = re.sub(r\"\\bdr\\b\", \"dr.\", normalized)\n    normalized = re.sub(r\"\\b(\\d+)\\s+kilometers\\b\", r\"\\1 km\", normalized)\n    normalized = re.sub(r\"\\b(\\d+)\\s+kilograms\\b\", r\"\\1 kg\", normalized)\n    normalized = re.sub(r\"\\b(\\d+)\\s+meters\\b\", r\"\\1 m\", normalized)\n    normalized = re.sub(r\"(\\d+)degrees celsius\\b\", r\"\\1 °c\", normalized)\n    normalized = re.sub(r\"\\b(\\d+)\\s+degrees celsius\\b\", r\"\\1 °c\", normalized)\n    normalized = normalized.replace(\"��c\", \"°c\")\n    return normalized\n\n\ndef _is_meaningfully_different(source: str, polished: str) -> bool:\n    source_canonical = _canonicalize_equivalents(source)\n    polished_canonical = _canonicalize_equivalents(polished)\n    if source_canonical == polished_canonical:\n        return False\n\n    source_light = re.sub(r'[()“”\"«»]', ' ', source_canonical)\n    polished_light = re.sub(r'[()“”\"«»]', ' ', polished_canonical)\n    source_light = re.sub(r'\\s+', ' ', source_light).strip()\n    polished_light = re.sub(r'\\s+', ' ', polished_light).strip()\n    return source_light != polished_light\n\n\ndef _error(code: str, message: str, *, scene_ids: list[str | None] | None = None) -> dict[str, Any]:\n    clean_scene_ids = [scene_id for scene_id in (scene_ids or []) if scene_id]\n    payload: dict[str, Any] = {\"code\": code, \"message\": message}\n    if clean_scene_ids:\n        payload[\"scene_ids\"] = clean_scene_ids\n    return payload\n\n\ndef _fatal_result(*, batch_id: str | None, errors: list[dict[str, Any]], warnings: list[dict[str, Any]]) -> dict[str, Any]:\n    return {\n        \"ok\": False,\n        \"approved_for_merge\": False,\n        \"batch_id\": batch_id,\n        \"classification\": \"fatal_contract_error\",\n        \"errors\": errors,\n        \"warnings\": warnings,\n        \"stats\": {\n            \"scene_count\": 0,\n            \"changed_scene_count\": 0,\n            \"flagged_scene_count\": 0,\n        },\n    }\n\n\ndef _finalize_result(\n    *,\n    batch_id: str | None,\n    errors: list[dict[str, Any]],\n    warnings: list[dict[str, Any]],\n    changed_scene_count: int,\n    flagged_scene_count: int,\n    source_scene_count: int,\n) -> dict[str, Any]:\n    classification = _classify_errors(errors)\n    return {\n        \"ok\": classification == \"ok\",\n        \"approved_for_merge\": classification == \"ok\",\n        \"batch_id\": batch_id,\n        \"classification\": classification,\n        \"errors\": errors,\n        \"warnings\": warnings,\n        \"stats\": {\n            \"scene_count\": source_scene_count,\n            \"changed_scene_count\": changed_scene_count,\n            \"flagged_scene_count\": flagged_scene_count,\n        },\n    }\n\n\ndef _classify_errors(errors: list[dict[str, Any]]) -> str:\n    if not errors:\n        return \"ok\"\n\n    severities = [ERROR_SEVERITY.get(error.get(\"code\"), \"fatal_contract_error\") for error in errors]\n    for classification in CLASSIFICATION_PRIORITY:\n        if classification in severities:\n            return classification\n    return \"fatal_contract_error\"\n"}],"isError":false,"timestamp":1775114607327}}
{"type":"message","id":"068f0d38","parentId":"378c89d3","timestamp":"2026-04-02T07:23:27.466Z","message":{"role":"toolResult","toolCallId":"call_kgQTLAQ5DHFeS1nDeF9CoNTb|fc_0408171ee7a64bae0169ce196f84488190898acd29b8637408","toolName":"read","content":[{"type":"text","text":"from __future__ import annotations\n\nimport json\nfrom pathlib import Path\nfrom typing import Any\n\n\nREQUIRED_POLISH_FIELDS = {\n    \"scene_id\",\n    \"narration_original\",\n    \"narration_tts\",\n}\n\n\ndef merge_tts_polish_batches(\n    batch_files: list[str | Path],\n    *,\n    screenplay: dict[str, Any],\n    output_path: str | Path | None = None,\n) -> dict[str, Any]:\n    errors: list[dict[str, str]] = []\n    warnings: list[dict[str, str]] = []\n    ordered_files = sorted([Path(p) for p in batch_files], key=lambda p: p.name)\n\n    scenes = screenplay.get(\"scenes\", []) if isinstance(screenplay, dict) else []\n    ordered_scene_ids = [scene.get(\"scene_id\") for scene in scenes if isinstance(scene, dict) and scene.get(\"scene_id\")]\n\n    if not ordered_files:\n        return {\n            \"ok\": False,\n            \"scene_count\": 0,\n            \"tts_polished\": {\"scenes\": []},\n            \"errors\": [{\"code\": \"no_batch_files\", \"message\": \"No tts_polish batch files provided\"}],\n            \"warnings\": [],\n        }\n\n    polish_map: dict[str, dict[str, Any]] = {}\n    loaded_batches: list[dict[str, Any]] = []\n\n    for file_path in ordered_files:\n        if not file_path.exists():\n            errors.append({\n                \"code\": \"missing_batch_file\",\n                \"message\": f\"Polish batch file not found: {file_path}\",\n            })\n            continue\n\n        try:\n            payload = json.loads(file_path.read_text(encoding=\"utf-8\"))\n        except Exception as exc:  # noqa: BLE001\n            errors.append({\n                \"code\": \"invalid_batch_json\",\n                \"message\": f\"Failed to parse polish batch file {file_path}: {exc}\",\n            })\n            continue\n\n        batch_id = payload.get(\"batch_id\")\n        batch_scenes = payload.get(\"scenes\", [])\n        if not isinstance(batch_scenes, list):\n            errors.append({\n                \"code\": \"invalid_batch_scenes\",\n                \"message\": f\"Polish batch file {file_path} has invalid 'scenes' payload\",\n            })\n            continue\n\n        if not batch_scenes:\n            warnings.append({\n                \"code\": \"empty_polish_batch\",\n                \"message\": f\"Polish batch file {file_path} produced zero scenes\",\n            })\n\n        loaded_batches.append(\n            {\n                \"batch_id\": batch_id,\n                \"file_path\": str(file_path),\n                \"scene_count\": len(batch_scenes),\n            }\n        )\n\n        for scene in batch_scenes:\n            if not isinstance(scene, dict):\n                errors.append({\n                    \"code\": \"invalid_scene_payload\",\n                    \"message\": f\"Polish batch {batch_id or file_path.name} contains a non-object scene entry\",\n                })\n                continue\n\n            missing_fields = sorted(REQUIRED_POLISH_FIELDS - set(scene.keys()))\n            if missing_fields:\n                errors.append({\n                    \"code\": \"missing_polish_fields\",\n                    \"message\": (\n                        f\"Polish batch {batch_id or file_path.name} scene is missing required fields: \"\n                        f\"{', '.join(missing_fields)}\"\n                    ),\n                })\n                continue\n\n            scene_id = scene.get(\"scene_id\")\n            if scene_id in polish_map:\n                warnings.append({\n                    \"code\": \"duplicate_scene_polish\",\n                    \"message\": f\"Scene {scene_id} appeared more than once across polish batches; latest entry kept\",\n                })\n            polish_map[scene_id] = scene\n\n    merged_scenes: list[dict[str, Any]] = []\n    for scene_id in ordered_scene_ids:\n        polished_scene = polish_map.get(scene_id)\n        if not polished_scene:\n            errors.append({\n                \"code\": \"missing_polish_scene\",\n                \"message\": f\"No polish output found for screenplay scene {scene_id}\",\n            })\n            continue\n        merged_scenes.append(polished_scene)\n\n    tts_polished = {\n        \"scene_count\": len(merged_scenes),\n        \"scenes\": merged_scenes,\n    }\n\n    if output_path is not None:\n        output_path = Path(output_path)\n        output_path.parent.mkdir(parents=True, exist_ok=True)\n        output_path.write_text(json.dumps(tts_polished, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    return {\n        \"ok\": len(errors) == 0,\n        \"scene_count\": len(merged_scenes),\n        \"batch_count\": len(loaded_batches),\n        \"tts_polished\": tts_polished,\n        \"loaded_batches\": loaded_batches,\n        \"output_path\": str(output_path) if output_path is not None else None,\n        \"errors\": errors,\n        \"warnings\": warnings,\n    }\n"}],"isError":false,"timestamp":1775114607395}}
{"type":"message","id":"b16c5baa","parentId":"068f0d38","timestamp":"2026-04-02T07:23:49.967Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"**Inspecting production runs**\n\nI need to check whether I should run the actual production path instead of the tmp workspace because that's where the current monitored runs are. It could be useful to run the supervisor on the tmp run to identify the failure since it might be caused by stale code. I'll also look for any missing checkpoints and consider whether the latest failures in the production run could help clarify things. Running tests or searching for recent checkpoint files might be necessary too.","thinkingSignature":"{\"id\":\"rs_0408171ee7a64bae0169ce197a2f948190b152072507eb176f\",\"type\":\"reasoning\",\"encrypted_content\":\"gAAAAABpzhmG6_D8H4Brw9LMqY6BjLUoBlhVHv3QhhEuwpyJuHc4QFc1koZMnV8oS1NIsne7b3vzjoyjPg1MoTomEErfnnzoD0x_cLGyzaU0FOrZ1JH3nb5jAk-_sigH0K9l2z0qCJn9mtGhN1OVDE22WXxOM10L4_HF4kOPzP3-kRbmpZWNNCy80bRbvReSzU695xzpjgWrkVOTZW_XNbjU25bOJisj1VfO9omtz5XIfDgMwfA1EB2wbMSmu5BNH_9pDq8GcdP71UhjNhS54ZHN124ZKTOY2sfyzu-DxmbpbV9JbhmrSywuBCp3hkFz44sjBn239Ctn8g9LJv7SsR-4d_xrfxHQY1UDOF2JaEqvt_VDTdFB89wq6yLFgXCQXNfvGizQ-nhfPmaEpNhnGq9goCfrHWaK_QUcL5gy8jjaZusyR40yaSwRAPC1y2G4-cL5x4ywUqA3Wtc30HXZ1BcjzdkT1_KVRVoGW8qwXQvZ4ozU6xlm6QPIP4poeL5yd3gW3oZ7YzRwciRgbTxnF1MXnXE6agsvoVjzO_pLgMlzsIKRQcU4xSh_-pp0LdweXHzuQRkuHTBVbumE5LmcYpbHeoAx4UhxYrpAlo-5rZZ7XuBu-3MyrUg99vDndfH2YHlqlb9LSmKVG4fyHWCbHNVktQ2cQ1_Oqgz8YGKacz_aigC6IWU3XVwJEOawY4HQtmQMuD8Tv2YUl7ZL0eO7nUpBnLkYTKAkM3thIHcSmEdnvlaEAYHTN80hB82CwQMMU0iO-bRvioW14rew2I0dNidPM_QnuDnyxAZcpfmux1k8bg66RRfO4gdvKjnWkLWCgTXKnb8da32GYIQs8x7twm77-Bwslo_6ntwm2dklfeqpVK-MUVZlVxFCq8UsVNMDtyVtA_vxjNT4sYv68iVs2_DtbHczzhwBPrpDUMQnFjKndbvPPGqwtO6UnSLg8UaTV9KBSCL6wPWDnAX_NUNe5qG9EQuiFM3qGX-Ac6t7OU8WQN48geooxi_22fzvq6dlPWJb9P4UXEaNnLji4mPOIoQaCQRK9X5qFoWI0JWJPj7iAjeh92_8o2GZgdizwzwjalfcNDVkK8fQkw2l-F_a8nXfEIw-G_3_Rh07parrB1V-FUir5V-LSnrn0bqy1r8btPdOklwO5a3VYo0xC9K9hUJINrYFWAdU2u