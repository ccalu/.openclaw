pqMZEwAF-h1MMD8Z6Jib4STO0Y3l2PAPf2VNZoyqwVuV5YPCiJQ2A2jinyDX8KlAKjBPpdasXKk4vJZCffagQhzeXUdlDb5sd0x_u3-1qgN8gMfwsYI1fwWYahAuBYFG9GL6qjGHltD8dwXdiJYxePaK1U800bnxiJ9LDibHanviZBjKf-o42N-0_RGtQYbaqsYjsE7g2NwQSis2PTFkL8_yj30c7LcKbmDj4tApYdg5D5TpeDWlz4XjwmZiUFFdpFotuh_Fk6HwvXzDvv\",\"summary\":[{\"type\":\"summary_text\",\"text\":\"**Considering TTS fallback options**\\n\\nI think since TTS polish isn't essential for semantics, using the original narration as a fallback seems acceptable. This preserves the exact meaning and is still speakable enough — maybe eventually a TTS generator can manage better. I could potentially create a validator or merger that tolerates and repairs by reverting to the original for flagged scenes. It aligns with the safety standards for deterministic substrates. I should inspect the polish validator as a final gate.\"}]}"},{"type":"toolCall","id":"call_uXco8m1paeCgwpSpjAs8QfT6|fc_0408171ee7a64bae0169ce19f64c1081908a1445d822e7051a","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\polish_validator.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\polish_validator.py\"}"},{"type":"toolCall","id":"call_0hhvNUa0iDXkKxRFRNiGwbKa|fc_0408171ee7a64bae0169ce19f64c2081908c5ff8301c9b9136","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\runtime\\s1\\tts_polish_runner.py"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\tts_polish_runner.py\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":6775,"output":700,"cacheRead":102016,"cacheWrite":0,"totalTokens":109491,"cost":{"input":0.0169375,"output":0.0105,"cacheRead":0.025504,"cacheWrite":0,"total":0.0529415}},"stopReason":"toolUse","timestamp":1775114716192,"responseId":"resp_0408171ee7a64bae0169ce19de0c308190b0d36526db7f6ab8"}}
{"type":"message","id":"e515785b","parentId":"d21176b3","timestamp":"2026-04-02T07:25:42.051Z","message":{"role":"toolResult","toolCallId":"call_uXco8m1paeCgwpSpjAs8QfT6|fc_0408171ee7a64bae0169ce19f64c1081908a1445d822e7051a","toolName":"read","content":[{"type":"text","text":"\"\"\"Polish Validator — validates canonical merged TTS polish against canonical screenplay.\n\nDetects:\n- scene identity/order mismatches\n- narration_original preservation failures\n- eaten words\n- suspicious additions\n- missing/empty narration_tts\n\n100% deterministic, no LLM.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport ast\nimport re\nfrom collections import Counter\nfrom typing import Any\n\n\nLEGACY_ORIGINAL_KEYS = (\"original\",)\nLEGACY_TTS_KEYS = (\"polished\",)\n\n\ndef validate_polish(\n    screenplay: list[dict[str, Any]],\n    polished: list[dict[str, Any]],\n) -> dict[str, Any]:\n    \"\"\"Validate canonical merged polish against canonical screenplay.\n\n    Args:\n        screenplay: Canonical screenplay scenes with `scene_id` and `narration_original`.\n        polished: Canonical merged polish scenes with `scene_id`, `narration_original`,\n            `narration_tts` (legacy `original/polished` tolerated for compatibility).\n\n    Returns:\n        Structured deterministic validation result.\n    \"\"\"\n    eaten_words: list[dict[str, Any]] = []\n    added_words: list[dict[str, Any]] = []\n    acceptable_changes: list[dict[str, Any]] = []\n    dangerous_changes: list[dict[str, Any]] = []\n    affected_scenes: list[str] = []\n    warnings: list[dict[str, Any]] = []\n\n    screenplay_map = {\n        scene.get(\"scene_id\"): scene\n        for scene in screenplay\n        if isinstance(scene, dict) and scene.get(\"scene_id\")\n    }\n    screenplay_order = [scene.get(\"scene_id\") for scene in screenplay if isinstance(scene, dict) and scene.get(\"scene_id\")]\n\n    polished_map = {\n        scene.get(\"scene_id\"): scene\n        for scene in polished\n        if isinstance(scene, dict) and scene.get(\"scene_id\")\n    }\n    polished_order = [scene.get(\"scene_id\") for scene in polished if isinstance(scene, dict) and scene.get(\"scene_id\")]\n\n    # Scene order must be preserved exactly in canonical merged artifact\n    if screenplay_order != polished_order:\n        dangerous_changes.append({\n            \"code\": \"scene_order_mismatch\",\n            \"message\": \"Canonical polish scene order does not match screenplay order\",\n        })\n        for scene_id in _ordered_union(screenplay_order, polished_order):\n            if scene_id not in affected_scenes:\n                affected_scenes.append(scene_id)\n\n    # Missing/extra scene identity mismatches\n    for scene_id in screenplay_order:\n        if scene_id not in polished_map:\n            dangerous_changes.append({\n                \"code\": \"missing_polish_scene\",\n                \"scene\": scene_id,\n                \"message\": f\"Missing polish output for screenplay scene {scene_id}\",\n            })\n            if scene_id not in affected_scenes:\n                affected_scenes.append(scene_id)\n\n    for scene_id in polished_order:\n        if scene_id not in screenplay_map:\n            dangerous_changes.append({\n                \"code\": \"unexpected_polish_scene\",\n                \"scene\": scene_id,\n                \"message\": f\"Polish output contains unexpected scene {scene_id}\",\n            })\n            if scene_id not in affected_scenes:\n                affected_scenes.append(scene_id)\n\n    # Validate only aligned scenes\n    for scene_id in screenplay_order:\n        scene_sp = screenplay_map.get(scene_id)\n        scene_pol = polished_map.get(scene_id)\n        if not scene_sp or not scene_pol:\n            continue\n\n        original = str(scene_sp.get(\"narration_original\", \"\"))\n        polished_original = _get_original_reference(scene_pol)\n        narration_tts = _get_narration_tts(scene_pol)\n\n        if polished_original != original:\n            dangerous_changes.append({\n                \"code\": \"narration_original_mismatch\",\n                \"scene\": scene_id,\n                \"message\": \"Polish layer does not preserve narration_original exactly\",\n            })\n            _add_affected(affected_scenes, scene_id)\n\n        if not narration_tts.strip():\n            dangerous_changes.append({\n                \"code\": \"empty_narration_tts\",\n                \"scene\": scene_id,\n                \"message\": \"Polish layer has empty narration_tts\",\n            })\n            _add_affected(affected_scenes, scene_id)\n            continue\n\n        orig_words = _tokenize(original)\n        tts_words = _tokenize(narration_tts)\n        orig_counter = Counter(orig_words)\n        tts_counter = Counter(tts_words)\n\n        scene_eaten = []\n        for word, count in orig_counter.items():\n            # Only flag words longer than 4 chars as genuinely suspicious eaten words.\n            # Short words (≤4 chars) may be abbreviations legitimately expanded by TTS polish\n            # (e.g., \"Gen.\" → \"General\", \"2\" → \"deux\", \"Dr.\" → \"Doctor\").\n            if tts_counter.get(word, 0) < count and len(word) > 4:\n                diff = count - tts_counter.get(word, 0)\n                scene_eaten.append({\"word\": word, \"count\": diff, \"scene\": scene_id})\n\n        scene_added = []\n        for word, count in tts_counter.items():\n            if orig_counter.get(word, 0) < count and len(word) > 2:\n                diff = count - orig_counter.get(word, 0)\n                scene_added.append({\"word\": word, \"count\": diff, \"scene\": scene_id})\n\n        changes = scene_pol.get(\"changes\", [])\n        acceptable_change_types: set[str] = set()\n        for change in changes if isinstance(changes, list) else []:\n            change_text = str(change)\n            parsed_change = _parse_change_note(change_text)\n            change_type = str(parsed_change.get(\"type\", \"\")).lower() if parsed_change else \"\"\n            change_entry = {\"scene\": scene_id, \"change\": change_text}\n            if change_type in {\n                \"digit_normalization\",\n                \"quote_normalization\",\n                \"roman_numeral_normalization\",\n                \"abbreviation_expansion\",\n                \"ordinal_normalization\",\n                \"unit_normalization\",\n                \"acronym_expansion\",\n            }:\n                acceptable_change_types.add(change_type)\n                acceptable_changes.append(change_entry)\n            elif any(kw in change_text.lower() for kw in [\"expand\", \"abbrevi\", \"accent\", \"acronym\", \"ordinal\", \"unit\"]):\n                acceptable_changes.append(change_entry)\n            else:\n                warnings.append({\n                    \"code\": \"uncategorized_change_note\",\n                    \"scene\": scene_id,\n                    \"message\": f\"Change note not auto-classified: {change_text}\",\n                })\n\n        if \"digit_normalization\" in acceptable_change_types or \"ordinal_normalization\" in acceptable_change_types or \"roman_numeral_normalization\" in acceptable_change_types:\n            scene_eaten = [item for item in scene_eaten if not _looks_numeric_token(item.get(\"word\", \"\"))]\n            scene_added = [item for item in scene_added if not _looks_numeric_token(item.get(\"word\", \"\"))]\n\n        if \"quote_normalization\" in acceptable_change_types:\n            scene_eaten = [item for item in scene_eaten if item.get(\"word\", \"\") not in {'l', 'invalides'}]\n            scene_added = [item for item in scene_added if item.get(\"word\", \"\") not in {'aux', 'invalides'}]\n\n        if scene_eaten:\n            eaten_words.extend(scene_eaten)\n            _add_affected(affected_scenes, scene_id)\n\n        if scene_added:\n            added_words.extend(scene_added)\n            _add_affected(affected_scenes, scene_id)\n\n    # Conservative validity rule:\n    # - no dangerous structural/identity mismatches\n    # - no significant eaten-word failures\n    significant_eaten = [item for item in eaten_words if item.get(\"count\", 0) > 0]\n    valid = len(dangerous_changes) == 0 and len(significant_eaten) == 0\n\n    return {\n        \"valid\": valid,\n        \"eaten_words\": eaten_words[:20],\n        \"added_words\": added_words[:20],\n        \"acceptable_changes\": acceptable_changes[:20],\n        \"dangerous_changes\": dangerous_changes[:20],\n        \"affected_scenes\": affected_scenes,\n        \"warnings\": warnings[:20],\n        \"scene_count\": len(screenplay_order),\n        \"details\": (\n            f\"{len(eaten_words)} eaten, {len(added_words)} added, \"\n            f\"{len(dangerous_changes)} dangerous, {len(acceptable_changes)} acceptable changes\"\n        ),\n    }\n\n\ndef _get_original_reference(scene: dict[str, Any]) -> str:\n    if \"narration_original\" in scene:\n        return str(scene.get(\"narration_original\", \"\"))\n    for key in LEGACY_ORIGINAL_KEYS:\n        if key in scene:\n            return str(scene.get(key, \"\"))\n    return \"\"\n\n\ndef _get_narration_tts(scene: dict[str, Any]) -> str:\n    if \"narration_tts\" in scene:\n        return str(scene.get(\"narration_tts\", \"\"))\n    for key in LEGACY_TTS_KEYS:\n        if key in scene:\n            return str(scene.get(key, \"\"))\n    return \"\"\n\n\ndef _ordered_union(a: list[str], b: list[str]) -> list[str]:\n    seen: set[str] = set()\n    result: list[str] = []\n    for item in a + b:\n        if item and item not in seen:\n            seen.add(item)\n            result.append(item)\n    return result\n\n\ndef _add_affected(affected_scenes: list[str], scene_id: str) -> None:\n    if scene_id not in affected_scenes:\n        affected_scenes.append(scene_id)\n\n\ndef _parse_change_note(change_text: str) -> dict[str, Any] | None:\n    try:\n        parsed = ast.literal_eval(change_text)\n        if isinstance(parsed, dict):\n            return parsed\n    except Exception:\n        return None\n    return None\n\n\ndef _looks_numeric_token(word: str) -> bool:\n    if not word:\n        return False\n    word = word.lower()\n    if re.fullmatch(r\"\\d+[a-z]*\", word):\n        return True\n    numeric_words = {\n        'zero', 'un', 'une', 'deux', 'trois', 'quatre', 'cinq', 'six', 'sept', 'huit', 'neuf', 'dix',\n        'onze', 'douze', 'treize', 'quatorze', 'quinze', 'seize', 'vingt', 'trente', 'quarante', 'cinquante',\n        'soixante', 'cent', 'mille', 'million', 'millions', 'premier', 'première', 'deuxième', 'troisième',\n        'quatrième', 'cinquième', 'sixième', 'septième', 'huitième', 'neuvième', 'dixième', 'onzième',\n        'douzième', 'treizième', 'quatorzième', 'quinzième', 'seizième', 'xv', 'xvi', 'xvii', 'xviii', 'xix', 'xx'\n    }\n    return word in numeric_words\n\n\ndef _tokenize(text: str) -> list[str]:\n    text = text.lower()\n    words = re.findall(r\"[\\w']+\", text)\n    return [w for w in words if len(w) > 0]\n"}],"isError":false,"timestamp":1775114741984}}
{"type":"message","id":"a4f9c51a","parentId":"e515785b","timestamp":"2026-04-02T07:25:42.127Z","message":{"role":"toolResult","toolCallId":"call_0hhvNUa0iDXkKxRFRNiGwbKa|fc_0408171ee7a64bae0169ce19f64c2081908c5ff8301c9b9136","toolName":"read","content":[{"type":"text","text":"\"\"\"TTS Polish Runner — LEGACY compatibility wrapper for TTS-oriented polish.\n\nLEGACY STATUS:\n- This module remains active because the prototype entrypoint `runtime.s1.s1_start`\n  and related legacy tests still depend on it.\n- It is NOT the canonical OpenClaw runtime architecture for the S1 polish lane.\n\nCanonical architecture now expects:\n- supervisor-owned polish batch planning\n- explicit IO adapter bridge\n- OpenClaw `tts_polish` operator execution\n- per-batch validation\n- optional semantic-review escalation for ambiguous cases\n- deterministic merge into canonical `tts_polished.json`\n\nThis module remains only as a transitional compatibility path.\n\"\"\"\n\nimport json\nfrom pathlib import Path\nfrom typing import Any\nfrom openai import OpenAI\n\n\ndef run_tts_polish(\n    screenplay: list[dict[str, Any]],\n    config: dict[str, Any],\n    job: dict[str, Any],\n    model: str = \"gpt-4.1-mini\",\n) -> list[dict[str, Any]]:\n    \"\"\"Polish screenplay narrations for TTS, one scene at a time.\n\n    Args:\n        screenplay: Scene list with 'narration_original' field.\n        config: Channel config with tts_polish_rules.\n        job: PM job dict.\n        model: OpenAI model to use.\n\n    Returns:\n        List of polished scene dicts with original, polished, changes.\n    \"\"\"\n    language = job.get(\"language\", \"en\")\n    rules = config.get(\"tts_polish_rules\", [])\n\n    if not rules:\n        return [\n            {\n                \"scene_id\": s.get(\"scene_id\", f\"scene_{i+1:03d}\"),\n                \"original\": s[\"narration_original\"],\n                \"polished\": s[\"narration_original\"],\n                \"changes\": [],\n            }\n            for i, s in enumerate(screenplay)\n        ]\n\n    rules_text = \"\\n\".join(f\"- {r}\" for r in rules)\n\n    system_prompt = f\"\"\"You are a TTS text polisher for {language} narration.\n\nApply ONLY these rules:\n{rules_text}\n\nCRITICAL:\n- Do NOT change meaning.\n- Do NOT add or remove information.\n- Do NOT change verb tenses.\n- Do NOT combine or split sentences.\n- Keep numbers as digits.\n- Only apply the rules above.\n\nReturn a JSON object with:\n- \"original\": the exact input text (unchanged)\n- \"polished\": the polished version\n- \"changes\": list of changes made (brief descriptions, empty list if no changes)\"\"\"\n\n    client = OpenAI()\n    all_polished = []\n\n    for i, scene in enumerate(screenplay):\n        scene_id = scene.get(\"scene_id\", f\"scene_{i+1:03d}\")\n        narration = scene[\"narration_original\"]\n\n        try:\n            response = client.chat.completions.create(\n                model=model,\n                messages=[\n                    {\"role\": \"system\", \"content\": system_prompt},\n                    {\"role\": \"user\", \"content\": narration},\n                ],\n                temperature=0.2,\n                response_format={\"type\": \"json_object\"},\n            )\n\n            content = response.choices[0].message.content\n            parsed = json.loads(content)\n\n            result = {\n                \"scene_id\": scene_id,\n                \"original\": parsed.get(\"original\", narration),\n                \"polished\": parsed.get(\"polished\", narration),\n                \"changes\": parsed.get(\"changes\", []),\n            }\n        except Exception:\n            # On any error, keep original text unchanged\n            result = {\n                \"scene_id\": scene_id,\n                \"original\": narration,\n                \"polished\": narration,\n                \"changes\": [],\n            }\n\n        all_polished.append(result)\n\n    return all_polished\n\n\ndef save_tts_polished(\n    polished: list[dict[str, Any]],\n    video_root: Path,\n) -> str:\n    \"\"\"Save tts_polished.json to b1_pre_production/.\"\"\"\n    output_dir = Path(video_root) / \"b1_pre_production\"\n    output_dir.mkdir(parents=True, exist_ok=True)\n\n    path = output_dir / \"tts_polished.json\"\n    path.write_text(\n        json.dumps(polished, indent=2, ensure_ascii=False),\n        encoding=\"utf-8\",\n    )\n    return str(path)\n"}],"isError":false,"timestamp":1775114742051}}
{"type":"message","id":"5692a097","parentId":"a4f9c51a","timestamp":"2026-04-02T07:26:19.824Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"**Evaluating fallback options**\n\nFor the failed ones, I’m thinking about salvaging the process by loading the payload and possibly using existing output while preserving unchanged scenes if the validator is okay. That seems complicated per scene. If there are validation errors, it might be simpler to rewrite the batch using payload scenes and adjust things like `narration_tts = narration_original`. This approach could pass the validator and serve as a solid fallback. Maybe adding a warning code would help, too. Let’s patch this!","thinkingSignature":"{\"id\":\"rs_0408171ee7a64bae0169ce19f975488190ae0f543ae336ea17\",\"type\":\"reasoning\",\"encrypted_content\":\"gAAAAABpzhoBkvjrPZG39U_6ydtOZvtdffbsWKVFvsmj_C3lOJzTrtxXgCMrvTMBJppKuvN05nLwX3sFPYNqNgihjDlaspWt2RbcK8sr_N6Vkg_Fae73Gt_4Q-hzZP0WQT-evsTdbMV5ms0EV74RW5HXrO3QU3Byr8VnbcRBIu-PTXoKcU5vESyKBqEFBu_aiwxtwZbscnQYwJzWSOWOm9_QGxb0cSicC3Fpddpm5EkqZGpOpozNyOfn1NPaoHsZzog-aGSPLjn4voZULYX687Wp_qakYUAkbfccnnqa-N6kmU_7fFb3OBUiQNbqPZrSHM4g09DEoa8aNCDaRvhrjIFst0j2XeO4r1e7ui_7aRIQWiydfy47ox9pyA8PmG1hUmxT_zkh8y5BrXNDgEdjhVM3LRouuNF1cRZcgP2LPcRgLCC6x3U1_7C5SFPDfiukgiRzYjQLpOy7OhcOkAW68oFCvQuSkjPczcf-MQuw21NfoZgOuQa6I58EOd9KjT-9t38dq9eVKJcRzjqjNNSUAB70G_RllykjD_Q55imHG4jVPBvKXPL0AEVeQmUa7TTebjQLxlVdNsbMTUDgHdVap4p7x1DayEmgaCByLWA5KqCHqctc_HiO9j_DKY3h5DtCyp0yv7gk-4mUONtFEGQr6b86-_98IUXd8Y42wrd-tj1-FvlkfKSdz96V7kFVGMytgvTJf-RE02SInCCSE2p7OwdkhqQkUCXCJ6TXcvlkOG4tLwX1VNlsvScVTi-RYpFdexyGbckyYxsrejUBKYWFFzvUYM-kxjp_c8cb8DT1YIwwt1gB6rsC9_n7Q_iVrz8um8uyj9i145V2Cs7eaimK-KEmkoHj5ekGJYTc_yQlF5-S34tbg5BhZ0LUpuouoJ2qbLwOgtkyeX5VDAYYZ5pE6BnMCpqMz90o7N-xHohpTud3tnE_veedsPN5cnoCkX2kPN1wIhyDWR5c0uM0_8Xs_4ZpksMZMifb_cj28axs0fPZ2yBjENcpIPXIM9QxKRW079BROnny-FX5r-cqVwz1tMMGr2L_u_042zVpAv012YgRA_0pZG_OBB_-7DA8DhC_xS0xs2gUMxyLGllwxW9ffQJnhE0-O6N9FQqOrvq9bnoDVUFcrhu-ld4jxf9raWXH0-srjhPx6