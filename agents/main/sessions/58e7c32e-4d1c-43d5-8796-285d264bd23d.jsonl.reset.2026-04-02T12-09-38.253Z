 curious if there are any specific functions I need to be aware of or if there are best practices for scripting that I should follow. I want to make sure I do this efficiently and effectively! Let's dive in!\"}]}"},{"type":"toolCall","id":"call_VnKc9JWXb3j4vb21DWGbGYHQ|fc_0408171ee7a64bae0169ce1ae6f2648190a9552e952cea55a6","name":"write","arguments":{"path":"tmp_repair_validate_s1.py","content":"import json\nimport sys\nfrom pathlib import Path\nsys.path.insert(0, r\"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\")\nfrom runtime.s1.supervisor_runtime import _rewrite_tts_polish_batch_as_identity\nfrom runtime.s1.supervisor_skills.tts_polish_output_validator import validate_tts_polish_output\nfrom runtime.s1.supervisor_skills.tts_polish_merger import merge_tts_polish_batches\nfrom runtime.s1.polish_validator import validate_polish\n\nrun = Path(r\"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\production\\004_fr\\2026-03-30_004_fr_001\")\ninputs = run / 'b1_pre_production' / 'inputs' / 'tts_polish'\nouts = run / 'b1_pre_production' / 'intermediate' / 'tts_polish'\nscreenplay = json.loads((run / 'b1_pre_production' / 'screenplay.json').read_text(encoding='utf-8'))\n\napproved = []\nreport = []\nfor inp in sorted(inputs.glob('*_input.json')):\n    out = outs / (inp.stem.replace('_input', '_output') + '.json')\n    res = validate_tts_polish_output(batch_payload_path=inp, batch_output_path=out)\n    if not res['approved_for_merge']:\n        _rewrite_tts_polish_batch_as_identity(batch_payload_path=inp, batch_output_path=out, reason_codes=[e.get('code','unknown_error') for e in res['errors']])\n        res = validate_tts_polish_output(batch_payload_path=inp, batch_output_path=out)\n    report.append({'batch': inp.name, 'classification': res['classification'], 'approved': res['approved_for_merge'], 'errors': [e['code'] for e in res['errors']]})\n    if res['approved_for_merge']:\n        approved.append(str(out))\n\nmerge = merge_