nal = scene.get(\"narration_original\")\n        if not isinstance(scene_id, str) or not isinstance(narration_original, str):\n            continue\n        fallback_output[\"scenes\"].append(\n            {\n                \"scene_id\": scene_id,\n                \"narration_original\": narration_original,\n                \"narration_tts\": narration_original,\n                \"changes\": [],\n            }\n        )\n\n    if not fallback_output[\"scenes\"]:\n        return {\n            \"ok\": False,\n            \"warnings\": [],\n            \"errors\": [{\"code\": \"tts_polish_identity_fallback_empty\", \"message\": \"Deterministic fallback produced zero scenes.\"}],\n        }\n\n    output_path.parent.mkdir(parents=True, exist_ok=True)\n    output_path.write_text(json.dumps(fallback_output, indent=2, ensure_ascii=False), encoding=\"utf-8\")\n\n    return {\n        \"ok\": True,\n        \"warnings\": [\n            {\n                \"code\": \"tts_polish_identity_fallback_applied\",\n                \"message\": (\n                    f\"Applied deterministic identity fallback for {fallback_output['batch_id']} \"\n                    f\"after validation errors: {sorted(set(reason_codes or []))}\"\n                ),\n            }\n        ],\n        \"errors\": [],\n    }\n\n\ndef _build_scene_director_agent_message(input_path: str, output_path: str) -> str:\n"},"partialJson":"{\"file_path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\runtime\\\\s1\\\\supervisor_runtime.py\",\"oldText\":\"def _build_scene_director_agent_message(input_path: str, output_path: str) -> str:\\n\",\"newText\":\"def _rewrite_tts_polish_batch_as_identity(\\n    *,\\n    batch_payload_path: str | Path,\\n    batch_output_path: str | Path,\\n    reason_codes: list[str] | None = None,\\n) -> dict[str, Any]:\\n    payload_path = Path(batch_payload_path)\\n    output_path = Path(batch_output_path)\\n\\n    try:\\n        payload = json.lo