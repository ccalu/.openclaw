\\\\\Users\\\\\\\\User-OEM\\\\\\\\.openclaw\\\\\\\\workspace\\\\\\\\tmp_s1_supervisor_run\\\",\\r\\n  \\\"batch\\\": {\\r\\n    \\\"batch_id\\\": \\\"tp_001\\\",\\r\\n    \\\"scene_ids\\\": [\\r\\n      \\\"scene_001\\\",\\r\\n      \\\"scene_002\\\",\\r\\n      \\\"scene_003\\\"\\r\\n    ],\\r\\n    \\\"scene_count\\\": 3,\\r\\n    \\\"word_count\\\": 201\\r\\n  },\\r\\n  \\\"tts_polish_rules\\\": [\\r\\n    \\\"Expand abbreviations: M->Monsieur, Mme->Madame, Dr->Docteur, Gen->General, etc->et caetera, n->numero\\\",\\r\\n    \\\"Expand av. J.-C./ap. J.-C. consistently: avant Jesus-Christ/apres Jesus-Christ\\\",\\r\\n    \\\"Keep cardinal numbers as digits always - TTS reads them perfectly\\\",\\r\\n    \\\"French kings use CARDINAL numbers (not ordinals): Louis XIV->Louis Quatorze, Henri IV->Henri Quatre\\\",\\r\\n    \\\"Exception: I/Ier becomes Premier: Francois Ier->Francois Premier (never Un)\\\",\\r\\n    \\\"For centuries use ordinals: XVIe siecle->seizieme siecle\\\",\\r\\n    \\\"Expand units: km->kilometres, kg->kilogrammes, keeping numbers as digits\\\",\\r\\n    \\\"Remove or replace guillemets (angle quotes) with standard quotes\\\",\\r\\n    \\\"Do NOT expand weapon designations, military orgs, country codes (AK-47, NATO, FBI, DNA)\\\",\\r\\n    \\\"Fix missing accents: evenement->evenement, etait->etait, francais->francais\\\",\\r\\n    \\\"Translate acronyms: NATO->OTAN, USSR->URSS, USA->Etats-Unis, UN->ONU\\\",\\r\\n    \\\"Never change verb tense arbitrarily or combine separate sentences\\\"\\r\\n  ],\\r\\n  \\\"style_context\\\": {\\r\\n    \\\"channel_name\\\": null,\\r\\n    \\\"reason\\\": null\\r\\n  },\\r\\n  \\\"instructions\\\": {\\r\\n    \\\"task\\\": \\\"Polish the narration text for TTS without changing meaning.\\\",\\r\\n    \\\"requirements\\\": [\\r\\n      \\\"Preserve scene order and scene IDs.\\\",\\r\\n      \\\"Do not remove the original narration layer.\\\",\\r\\n      \\\"Return narration_tts for each scene.\\\",\\r\\n      \\\"Keep meaning intact while improving speakability.\\\",\\r\\n      \\\"Return changes metadata for each scene when possible.\\\"\\r\\n    ]\\r\\n  },\\r\\n  \\\"scenes\\\": [\\r\\n    {\\r\\n      \\\"source_batch_id\\\": \\\"sd_001\\\",\\r\\n      \\\"source_batch_scene_index\\\": 1,\\r\\n      \\\"source_scene_local_id\\\": \\\"scene_01\\\",\\r\\n      \\\"scene_local_id\\\": \\\"scene_01\\\",\\r\\n      \\\"scene_title\\\": \\\"La déportation des enfants réunionnais\\\",\\r\\n      \\\"scene_summary\\\": \\\"Présente le programme de déplacement forcé et son mécanisme, en montrant comment des milliers d'enfants ont été arrachés à leurs familles et envoyés vers la métropole.\\\",\\r\\n      \\\"narrative_function\\\": \\\"historical setup and inciting injustice\\\",\\r\\n      \\\"narration_original\\\": \\\"En 1963, un programme gouvernemental français a arraché des milliers d'enfants réunionnais à leurs familles. Sous prétexte de repeupler la France métropolitaine, ces enfants, certains âgés de seulement 2 ans, ont été déportés vers des départements ruraux comme la Creuse. Les familles réunionnaises, souvent pauvres et vulnérables, n'ont parfois jamais donné leur consentement. Les enfants ont été placés dans des familles d'accueil ou des institutions, où beaucoup ont subi maltraitance et exploitation.\\\",\\r\\n      \\\"start_word\\\": 1,\\r\\n      \\\"end_word\\\": 72,\\r\\n      \\\"estimated_scene_word_count\\\": 72,\\r\\n      \\\"scene_id\\\": \\\"scene_001\\\"\\r\\n    },\\r\\n    {\\r\\n      \\\"source_batch_id\\\": \\\"sd_001\\\",\\r\\n      \\\"source_batch_scene_index\\\": 2,\\r\\n      \\\"source_scene_local_id\\\": \\\"scene_02\\\",\\r\\n      \\\"scene_local_id\\\": \\\"scene_02\\\",\\r\\n      \\\"scene_title\\\": \\\"Perte d'identité et reconnaissance tardive\\\",\\r\\n      \\\"scene_summary\\\": \\\"Décrit les conséquences humaines de l'arrachement, puis introduit la reconnaissance officielle de l'État comme une réparation arrivée trop tard pour beaucoup.\\\",\\r\\n      \\\"narrative_function\\\": \\\"aftermath and institutional acknowledgment\\\",\\r\\n      \\\"narration_original\\\": \\\"Coupés de leur culture, de leur langue créole et de leur identité, ils ont grandi dans l'isolement et la confusion. Ce n'est qu'en 2014 que l'Assemblée nationale a officiellement reconnu la responsabilité de l'État dans cette tragédie. Mais pour de nombreux anciens enfants de la Creuse, la reconnaissance est venue trop tard. Certains n'ont jamais retrouvé leurs parents biologiques. D'autres portent encore les cicatrices psychologiques de cet arrachement.\\\",\\r\\n      \\\"start_word\\\": 73,\\r\\n      \\\"end_word\\\": 140,\\r\\n      \\\"estimated_scene_word_count\\\": 68,\\r\\n      \\\"scene_id\\\": \\\"scene_002\\\"\\r\\n    },\\r\\n    {\\r\\n      \\\"source_batch_id\\\": \\\"sd_001\\\",\\r\\n      \\\"source_batch_scene_index\\\": 3,\\r\\n      \\\"source_scene_local_id\\\": \\\"scene_03\\\",\\r\\n      \\\"scene_local_id\\\": \\\"scene_03\\\",\\r\\n      \\\"scene_title\\\": \\\"Une mémoire encore en lutte\\\",\\r\\n      \\\"scene_summary\\\": \\\"Ouvre sur la portée historique et politique du scandale, puis conclut avec les efforts actuels des survivants et des associations pour obtenir vérité et justice.\\\",\\r\\n      \\\"narrative_function\\\": \\\"broader implications and present-day advocacy\\\",\\r\\n      \\\"narration_original\\\": \\\"Cette page sombre de l'histoire française reste largement méconnue du grand public. Elle soulève des questions fondamentales sur la politique coloniale, les droits de l'enfant et la mémoire collective. Aujourd'hui, des associations continuent de se battre pour la vérité et la justice. Les survivants témoignent, écrivent des livres et participent à des documentaires pour que cette histoire ne soit jamais oubliée.\\\",\\r\\n      \\\"start_word\\\": 141,\\r\\n      \\\"end_word\\\": 201,\\r\\n      \\\"estimated_scene_word_count\\\": 61,\\r\\n      \\\"scene_id\\\