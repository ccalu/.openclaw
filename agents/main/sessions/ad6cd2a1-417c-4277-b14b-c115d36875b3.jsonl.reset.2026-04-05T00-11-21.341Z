"native\":  \"auto\",\r\n                     \"nativeSkills\":  \"auto\",\r\n                     \"restart\":  true,\r\n                     \"ownerDisplay\":  \"raw\"\r\n                 },\r\n    \"session\":  {\r\n                    \"dmScope\":  \"per-channel-peer\"\r\n                },\r\n    \"channels\":  {\r\n                     \"telegram\":  {\r\n                                      \"enabled\":  true,\r\n                                      \"dmPolicy\":  \"pairing\",\r\n                                      \"botToken\":  \"8733780416:AAEZ_6ktfDKSL0VnUayUw1KSHgB6VaQoV4A\",\r\n                                      \"groups\":  {\r\n                                                     \"*\":  {\r\n                                                               \"requireMention\":  true\r\n                                                           }\r\n                                                 },\r\n                                      \"groupPolicy\":  \"allowlist\",\r\n                                      \"streaming\":  \"partial\"\r\n                                  }\r\n                 },\r\n    \"gateway\":  {\r\n                    \"port\":  18789,\r\n                    \"mode\":  \"local\",\r\n                    \"bind\":  \"loopback\",\r\n                    \"auth\":  {\r\n                                 \"mode\":  \"token\",\r\n                                 \"token\":  \"f523030955237327eee6b248e83bcd2e44b20c36601f90d2\"\r\n                             },\r\n                    \"tailscale\":  {\r\n                                      \"mode\":  \"off\",\r\n                                      \"resetOnExit\":  false\r\n                                  },\r\n                    \"nodes\":  {\r\n                                  \"denyCommands\":  [\r\n\r\n                                                   ]\r\n                              }\r\n                },\r\n    \"plugins\":  {\r\n                    \"entries\"