ut informative.\\\" --light-context --model \\\"anthropic/claude-haiku-4-5\\\" --announce --channel telegram --to \\\"1962323981\\\"\",\"yieldMs\":10000}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":140762,"output":225,"cacheRead":19968,"cacheWrite":0,"totalTokens":160955,"cost":{"input":0.351905,"output":0.003375,"cacheRead":0.004992,"cacheWrite":0,"total":0.36027200000000004}},"stopReason":"toolUse","timestamp":1774634490251,"responseId":"resp_0a7381f2013991140169c6c5fb6bcc8191943c05e4e5742ff0"}}
