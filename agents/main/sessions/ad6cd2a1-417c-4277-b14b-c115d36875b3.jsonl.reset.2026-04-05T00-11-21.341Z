{"type":"message","id":"60958af2","parentId":"be1909df","timestamp":"2026-03-26T14:28:33.354Z","message":{"role":"toolResult","toolCallId":"call_mNFtHCn1F1uB9GzRpa1TNIuS|fc_0a7381f2013991140169c54291d1e4819181e900f39eea1073","toolName":"web_search","content":[{"type":"text","text":"{\n  \"query\": \"Groq speech to text transcription model whisper cheap pricing 2026\",\n  \"provider\": \"brave\",\n  \"count\": 5,\n  \"tookMs\": 1025,\n  \"externalContent\": {\n    \"untrusted\": true,\n    \"source\": \"web_search\",\n    \"provider\": \"brave\",\n    \"wrapped\": true\n  },\n  \"results\": [\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"2b52b8f8f594996b\\\">>>\\nSource: Web Search\\n---\\nWhisper Large v3 Turbo – Fast Speech Recognition Now on Groq | Groq is fast, low cost inference.\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"2b52b8f8f594996b\\\">>>\",\n      \"url\": \"https://groq.com/blog/whisper-large-v3-turbo-now-available-on-groq-combining-speed-quality-for-speech-recognition\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"0f1e652cd884c619\\\">>>\\nSource: Web Search\\n---\\nTry Whisper Large v3 Turbo for blazing-fast, multilingual speech recognition on GroqCloud. Boost your apps with affordable, real-time ASR—get started today.\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"0f1e652cd884c619\\\">>>\",\n      \"siteName\": \"groq.com\"\n    },\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"43d1de3ecff9fb4d\\\">>>\\nSource: Web Search\\n---\\nWhisper Large v3 - GroqDocs\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"43d1de3ecff9fb4d\\\">>>\",\n      \"url\": \"https://console.groq.com/docs/model/whisper-large-v3\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"80dcaeb519d69de9\\\">>>\\nSource: Web Search\\n---\\nText GenerationSpeech to TextText to SpeechOrpheusOCR and Image RecognitionReasoningContent ModerationStructured OutputsPrompt Caching · Tool UseOverviewGroq Built-In ToolsWeb SearchVisit WebsiteBrowser AutomationCode ExecutionWolfram AlphaBrowser Search (GPT OSS Models)Remote Tools and MCPConnectorsLocal Tool CallingIntegrations CatalogCoding with GroqFactory DroidOpenCodeKilo CodeRoo CodeCline ... Whisper Large v3 is OpenAI&#x27;s most advanced and capable speech recognition model, delivering state-of-the-art accuracy across a wide range of audio conditions and languages.\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"80dcaeb519d69de9\\\">>>\",\n      \"siteName\": \"console.groq.com\"\n    },\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"59a6cc281b88fd7a\\\">>>\\nSource: Web Search\\n---\\nA complete guide to Groq pricing in 2025\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"59a6cc281b88fd7a\\\">>>\",\n      \"url\": \"https://www.eesel.ai/blog/groq-pricing\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"ac6d723b5670a35d\\\">>>\\nSource: Web Search\\n---\\nText-to-Speech (PlayAI Dialog v1.0): This will run you $50.00 for every million characters generated. Automatic Speech Recognition (Whisper Large v3): This is priced at <strong>$0.111 per hour of audio you get transcribed</strong>.\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"ac6d723b5670a35d\\\">>>\",\n      \"siteName\": \"www.eesel.ai\"\n    },\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"74fcddae412f277d\\\">>>\\nSource: Web Search\\n---\\nSpeech to Text - GroqDocs\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"74fcddae412f277d\\\">>>\",\n      \"url\": \"https://console.groq.com/docs/speech-to-text\",\n      \"description\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"810dc7900502a4a9\\\">>>\\nSource: Web Search\\n---\\nIntegrate Groq&#x27;s fast speech-to-text API for instant audio transcription and translation in your applications.\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"810dc7900502a4a9\\\">>>\",\n      \"siteName\": \"console.groq.com\"\n    },\n    {\n      \"title\": \"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"5deb0c490f2db038\