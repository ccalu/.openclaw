n        \"job_id\": b2_bootstrap[\"job_id\"],\n        \"video_id\": b2_bootstrap.get(\"job_id\"),\n        \"account_id\": b2_bootstrap[\"account_id\"],\n        \"language\": b2_bootstrap[\"language\"],\n        \"run_root\": str(run_root),\n        \"sector_root\": str(sector_root),\n        \"source_package_path\": str(source_package_path),\n        \"checkpoints_dir\": str(sector_root / \"checkpoints\"),\n        \"operators_dir\": str(sector_root / \"operators\"),\n        \"compiled_dir\": str(sector_root / \"compiled\"),\n        \"logs_dir\": str(sector_root / \"logs\"),\n        \"dispatch_dir\": str(sector_root / \"dispatch\"),\n        \"bootstrap_checkpoint_path\": str(sector_root / \"checkpoints\" / \"s3_bootstrap_ready.json\")\n    }\n\n    out_path = output_dir / \"s3_supervisor_bootstrap.json\"\n    write_json(out_path, bootstrap)\n    write_json(Path(bootstrap[\"bootstrap_checkpoint_path\"]), {\n        \"event\": \"s3_bootstrap_ready\",\n        \"job_id\": b2_bootstrap[\"job_id\"],\n        \"sector\": \"s3_visual_planning\",\n        \"created_at\": utc_now(),\n        \"source_package_path\": str(source_package_path)\n    })\n\n    print(str(out_path))\n\n\nif __name__ == \"__main__\":\n    main()\n"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\.openclaw\\\\workspace\\\\content_factory_block2\\\\helpers\\\\build_s3_bootstrap_from_b2.py\",\"content\":\"import json\\nimport sys\\nfrom datetime import datetime, timezone\\nfrom pathlib import Path\\n\\n\\ndef utc_now():\\n    return datetime.now(timezone.utc).isoformat()\\n\\n\\ndef write_json(path: Path, data: dict):\\n    path.parent.mkdir(parents=True, exist_ok=True)\\n    path.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding=\\\"utf-8\\\")\\n\\n\\ndef main():\\n    if len(sys.argv) != 3:\\n        raise SystemExit(\\\"usage: build_s3_bootstrap_from_b2.py <b2_bootstrap_path> <output_dir>\\\")\\n\\n    b2_bootstrap_path = Path(sys.argv[1])\\n    output_dir = Path(sys