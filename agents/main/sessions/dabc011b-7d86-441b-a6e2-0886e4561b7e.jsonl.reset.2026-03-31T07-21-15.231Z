_factory\\workspace_mirror\\branches\\03_visual_planning\\agents\\character_identifier\\TOOLS.md:25:\"account\": \"003\",\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\workspace_mirror\\branches\\03_visual_planning\\agents\\character_identifier\\TOOLS.md:26:\"language\": \"pt\",\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\workspace_mirror\\branches\\03_visual_planning\\agents\\era_context_identifier\\TOOLS.md:23:\"account\": \"003\",\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\workspace_mirror\\branches\\03_visual_planning\\agents\\era_context_identifier\\TOOLS.md:24:\"language\": \"pt\",\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\workspace_mirror\\branches\\03_visual_planning\\agents\\event_identifier\\TOOLS.md:20:\"account\": \"003\",\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\workspace_mirror\\branches\\03_visual_planning\\agents\\event_identifier\\TOOLS.md:21:\"language\": \"en\",\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\workspace_mirror\\branches\\03_visual_planning\\agents\\location_identifier\\TOOLS.md:25:\"account\": \"003\",\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\workspace_mirror\\branches\\03_visual_planning\\agents\\location_identifier\\TOOLS.md:26:\"language\": \"pt\",\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\workspace_mirror\\branches\\03_visual_planning\\agents\\map_diagram_identifier\\TOOLS.md:23:\"account\": \"003\",\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\workspace_mirror\\branches\\03_visual_planning\\agents\\map_diagram_identifier\\TOOLS.md:24:\"language\": \"pt\",\r\nC:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\workspace_mirror\\branches\\03_visual_planning\\agents\\vehicle_weapon_identifier\\TOOLS.md:25:\"account\": \"003\",\r\nC:\\Users\\User-OEM\\Desktop\\co