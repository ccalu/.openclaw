y\\\\reviews\\\\tobias_night_review_26mar\\\\02_vo_review.md\"}"},{"type":"toolCall","id":"call_tAVW7OKQ5cDIEroxgruOUSnn|fc_04d04e5a142d912b0169c9334210e08191bd92995259a7fbf0","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\reviews\\tobias_night_review_26mar\\03_b1_review.md"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\reviews\\\\tobias_night_review_26mar\\\\03_b1_review.md\"}"},{"type":"toolCall","id":"call_o6J1fNlENQPnz4ZEa3CZ7xv4|fc_04d04e5a142d912b0169c9334210e4819195cada796dbfbea2","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\reviews\\tobias_night_review_26mar\\04_b2_review.md"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\reviews\\\\tobias_night_review_26mar\\\\04_b2_review.md\"}"},{"type":"toolCall","id":"call_KuXTfYI8zHy5Z4qzYIoNohzx|fc_04d04e5a142d912b0169c9334210ec8191ad63f7ecf758b91d","name":"read","arguments":{"path":"C:\\Users\\User-OEM\\Desktop\\content-factory\\auto_content_factory\\reviews\\tobias_night_review_26mar\\05_b3_review.md"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\reviews\\\\tobias_night_review_26mar\\\\05_b3_review.md\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":160,"output":262,"cacheRead":11136,"cacheWrite":0,"totalTokens":11558,"cost":{"input":0.0004,"output":0.00393,"cacheRead":0.002784,"cacheWrite":0,"total":0.0071140000000000005}},"stopReason":"toolUse","timestamp":1774793530056,"responseId":"resp_04d04e5a142d912b0169c9333bb6008191a7d17ac46255ef2d"}}
{"type":"message","id":"4905c248","parentId":"ca015f98","timestamp":"2026-03-29T14:12:17.219Z","message":{"role":"toolResult","toolCallId":"call_lMufWibbqxXh2j3kaMi9sn9T|fc_04d04e5a142d912b0169c9334210c8819193760a4348f8974f","toolName":"read","content":[{"type":"text","text":"# Production Manager — Brutally Honest Review\n\n**Review Date**: 26 Mar 2026  \n**Reviewer**: Tobias (Subagent, depth 1/1)  \n**Scope**: Production Manager component only. Dependencies mapped but not reviewed in detail.\n\n---\n\n## 1. Scope & Files Analyzed\n\n### Primary Documentation\n- `docs/10_PRODUCTION_MANAGER.md` — core specification\n- `workspace_mirror/production_manager/` (7 files: AGENTS.md, IDENTITY.md, CONTEXT.md, RULES.md, MEMORY.md, SCHEDULE.md, TOOLS.md)\n- `accounts/registry.yaml` + sample config (`accounts/003/it.yaml`)\n\n### Supporting Documentation (Dependency Context)\n- `docs/00_CONTEXT.md` — overall system context\n- `docs/09_HIERARCHY_AND_STRUCTURE.md` — PM's role in hierarchy\n- `docs/04_BRANCH_ARCHITECTURE.md` — B1-B10 dependencies\n- `docs/11_VIDEO_ORCHESTRATOR.md` — PM's downstream consumer (VO)\n- `docs/12_VIDEO_DIRECTORY_STRUCTURE.md` — output artifact structure\n- `docs/05_MULTI_MACHINE_ARCHITECTURE.md` — machine setup (M1 only for now)\n- `docs/06_MODEL_STRATEGY.md` — model routing decisions\n\n**Files Analyzed: 14 markdown files + 1 YAML registry + 1 sample channel config = 16 total**\n\n---\n\n## 2. Role & Responsibilities\n\n### PRIMARY RESPONSIBILITIES (Clear & Well-Defined)\n\n| Responsibility | Clarity | Implementation Ready? | Notes |\n|---|---|---|---|\n| Read PUB sheet (Google Sheets) | CLEAR | NO — skill `read_pub` not built yet | Data fetch blocked until skill exists |\n| Calculate runway per channel | CLEAR | YES — math is simple | `PROGRAMAR + days_until(ULT_PUB)` |\n| Filter active channels | CLEAR | YES | `PROD=SIM` AND `scripts_remaining > 0` |\n| Apply priority logic | CLEAR | YES | Override > Runway > Account number |\n| Generate job JSON artifact | CLEAR | YES | Template in doc 10, all fields mapped |\n| Report to Tobias | CLEAR | YES | Format defined in TOOLS.md |\n\n### SECONDARY RESPONSIBILITIES (Implicit but Not Documented)\n\n| Responsibility | Issue | Impact |\n|---|---|---|\n| Handle override expiry | NOT DOCUMENTED | Medium — overrides can become stale. When does override expire? After 1 job? 24h? Manual clear only? |\n| Validate config YAMLs exist | NOT DOCUMENTED | Low — error handling vague |\n| Track production history | MINIMAL | Low — MEMORY.md is empty, no pattern recording yet |\n| Detect data anomalies (corrupted cells, date format errors) | NOT DOCUMENTED | Medium — no validation rules for PUB data |\n\n---\n\n## 3. Python Skills Needed\n\n### CRITICAL (Blocks MVP)\n\n#### 1. **read_pub** (Google Sheets API)\n- **What it does**: Fetches PUB sheet, parses runway for all 39 channels, returns sorted list\n- **Input**: Sheet ID + tab name\n- **Output**: JSON array with `[{channel_name, account, language, runway_days, pub_row, scripts_remaining, ult_pub, programar}, ...]` sorted by runway\n- **Status**: **NOT IMPLEMENTED**\n- **Blockers**: \n  - Needs Google service account JSON (KMS-protected)\n  - Needs gspread + google-auth libraries\n  - Date parsing: PUB uses DD/MM/YYYY format — must handle correctly\n  - Cell type detection: Column O has format \"used/total\" (e.g., \"38/57\") — parse correctly\n- **Base Libraries**: gspread (0.6.4+), google-auth (2.25+), google-auth-oauthlib (1.0+)\n- **Estimated Complexity**: LOW-MEDIUM (standard Google Sheets API call, just need careful parsing)\n- **Risk**: Format drift in PUB sheet (unexpected date format, missing columns) — add validation\n\n---\n\n### OPTIONAL (Nice-to-have, not blocking MVP)\n\n#### 2. **validate_pub_data** (Data integrity check)\n- **What it does**: Validates PUB data for anomalies (date format, missing cols, invalid runway values)\n- **When to use**: After `read_pub`, before runway calculation\n- **Status**: **NOT IMPLEMENTED**\n- **Priority**: LOW (can start without this, add later if drift detected)\n\n---\n\n## 4. OpenClaw Tools Needed\n\n### Google Sheets API Access\n\n| Tool | Type | Config | Status |\n|---|---|---|---|\n| Google Sheets API | External Service | Service account JSON in KMS | AVAILABLE (already configured in KMS) |\n| read_pub (custom skill) | OpenClaw Skill | Python + gspread | **NEEDS BUILDING** |\n\n### Filesystem Access\n\n| Tool | Type | Config | Status |\n|---|---|---|---|\n| Read registry.yaml | Native OpenClaw | File I/O | AVAILABLE |\n| Read channel configs | Native OpenClaw | File I/O | AVAILABLE |\n\n### Communication\n\n| Tool | Type | Config | Status |\n|---|---|---|---|\n| Report to Tobias | OpenClaw Session | Telegram Topic \"Tobias\" | AVAILABLE |\n| Write job JSON | Native OpenClaw | File I/O | AVAILABLE |\n\n### What's Missing?\n\n**None critical** for MVP, but:\n- `read_pub` skill is **essential** — without it, PM is manual-data-dependent\n- Optional: cron trigger (Telegram command or scheduled check) — for Phase 2 (future)\n\n---\n\n## 5. Ambiguities & Gray Zones\n\n### CRITICAL AMBIGUITIES\n\n#### 1. **Override Expiry (HIGH PRIORITY)**\n- **Question**: How long does a dynamic override stay active?\n  - Until another override is issued?\n  - For exactly 1 job?\n  - For N hours?\n  - Forever until manual clear?\n- **Current State**: UNDEFINED\n- **Impact**: If override \"só conta 003\" is issued and forgotten, PM might produce 003 exclusively for weeks\n- **Recommendation**: Define rule. Suggested: **Override stays active for 1 calendar day OR until superseded by new override**. Log override lifecycle.\n\n#### 2. **Tie-Breaking When Runways Match (MEDIUM)**\n- **Question**: If multiple channels have EXACTLY the same runway (e.g., both 1 day), and no tie-breaker rule matches:\n  - Does PM choose both? Random? Older account first?\n- **Current State**: Doc says \"menor número de account\" but what if TWO channels have identical account + runway?\n- **Impact**: Non-deterministic behavior possible\n- **Recommendation**: Add secondary sort: **account < language alphabetical order**. Document explicitly.\n\n#### 3. **Date Format Handling (MEDIUM)**\n- **Question**: PUB sheet uses DD/MM/YYYY (European). What if a cell is malformed?\n  - Empty cell (no date)?\n  - Future date (impossible)?\n  - Very old date (year 1900)?\n- **Current State**: Doc silent\n- **Impact**: Runway calculation breaks or gives nonsense results\n- **Recommendation**: Add validation: dates must be between (today - 365 days) and (today + 90 days). Flag outliers.\n\n#### 4. **What is \"scripts > 0\"? (MEDIUM)**\n- **Question**: Column O has format \"38/57\". Do we:\n  - Filter only if remaining (57-38=19) > 0?\n  - Or if total (57) > 0?\n  - Or if used (38) > 0?\n- **Current State**: Doc says \"scripts restantes > 0\" but column layout ambiguous\n- **Impact**: Possible inclusion/exclusion errors\n- **Recommendation**: Clarify: **filter on remaining scripts only. If \"57/57\", exclude. If \"38/57\", include (19 remaining).**\n\n#### 5. **Job Sequencing (LOW)**\n- **Question**: When PM generates multiple jobs in rapid succession (e.g., cron job runs again before Video Orchestrator finishes first job), what happens?\n  - Overwrite previous job?\n  - Queue jobs?\n  - Error?\n- **Current State**: Single-job assumption in docs\n- **Impact**: Race conditions in Phase 2 (when PM runs on cron)\n- **Recommendation**: Define clearly. For now (Phase 1): **assume single-job-at-a-time.** Add lock file in Phase 2.\n\n---\n\n### MEDIUM-LEVEL AMBIGUITIES\n\n#### 6. **Override Syntax (LOW-MEDIUM)**\n- **Question**: How does Tobias/Lucca specify overrides?\n  - \"só conta 003\" ← natural language, Qwen parses?\n  - \"override: {accounts: [003]}\" ← structured JSON?\n  - Telegram message?\n  - YAML file?\n- **Current State**: Doc shows examples but no formal spec\n- **Impact**: PM might misinterpret override intent\n- **Recommendation**: Define override format. Suggested for now: **natural language string**. If ambiguous, PM asks Tobias to clarify.\n\n#### 7. **Partial Vs. Complete Filtering (LOW)**\n- **Question**: If override is \"prioriza 05 en e 03 fr\", does this mean:\n  - ONLY produce these two (exclude all others)?\n  - Produce these two FIRST, then normal priority after?\n- **Current State**: Doc shows \"prioriza\" example but behavior undefined\n- **Impact**: Incorrect prioritization\n- **Recommendation**: Define two override types: **EXCLUSIVE (only these)** vs. **PRIORITY (these first)**. Example: \"só 05\" = exclusive, \"prioriza 05\" = priority.\n\n---\n\n## 6. Weak Points\n\n### ARCHITECTURE WEAKNESSES\n\n#### 1. **PM is Dumb About Script Content (MEDIUM SEVERITY)**\n- **Current**: PM only knows scripts exist (`scripts_remaining > 0`). Doesn't validate:\n  - Script is actually IN the Google Sheet (might be marked available but missing)\n  - Script is in correct language (language mismatch)\n  - Script is approved/not flagged as bad\n- **Impact**: Might dispatch job for channel with missing/wrong script. Video Orchestrator downstream has to retry.\n- **Recommendation**: Defer to Phase 2. For MVP: assume PUB sheet is accurate. Add validation later.\n\n#### 2. **No Validation of Config YAMLs (LOW SEVERITY)**\n- **Current**: PM reads channel config YAML but doesn't validate:\n  - File exists\n  - Required fields (sheet_scripts_id, drive_folder_id, etc.) are present\n  - Fields are non-empty\n- **Impact**: Job artifact might have null/invalid fields. VO fails downstream.\n- **Recommendation**: Add validation before job generation. Fail loudly with clear error.\n\n#### 3. **No Anomaly Detection (LOW SEVERITY)**\n- **Current**: If a channel suddenly has runway = -10 (huge crisis) or +365 (impossible), PM reports it but doesn't escalate automatically.\n- **Impact**: Lucca might miss critical situations.\n- **Recommendation**: Define alert thresholds. Suggest: **if runway < 0, always alert Tobias/Lucca immediately, not in standard report.**\n\n#### 4. **Runway Math is Fragile (LOW SEVERITY)**\n- **Current**: `runway = PROGRAMAR + days_until(ULT_PUB)`\n  - If ULT_PUB is in the future (scheduled but not yet published), runway calculation is correct\n  - If ULT_PUB is in the past, `days_until` returns negative, which is correct (alert: no buffer)\n  - But no explicit handling of edge cases (today's date, leap years, timezone)\n- **Impact**: Subtle bugs in date math\n- **Recommendation**: Use strict date library (dateutil for Python), test edge cases explicitly.\n\n---\n\n### IMPLEMENTATION WEAKNESSES\n\n#### 5. **Workspace Files are Mostly Boilerplate (LOW SEVERITY)**\n- **Current State**: \n  - AGENTS.md: generic OpenClaw template\n  - MEMORY.md: empty\n  - CONTEXT.md: minimal, just \"Fase 1, manual activation\"\n  - SCHEDULE.md: readable but static snapshot of registry.yaml\n- **Impact**: PM has minimal working memory between sessions. Patterns not captured.\n- **Recommendation**: Build MEMORY.md gradually. After each production cycle, log:\n  - Which channels had critical runway\n  - Timing patterns (which channels need production most)\n  - Overrides issued and their duration\n  - Data anomalies detected\n\n#### 6. **No Logging/Audit Trail (MEDIUM SEVERITY)**\n- **Current**: No spec for how PM logs decisions\n  - When was a job generated?\n  - Why was this channel chosen over that one?\n  - Did override apply?\n- **Impact**: Hard to debug why specific choices were made. Hard to optimize later.\n- **Recommendation**: Generate audit log for each run. Include: timestamp, channels evaluated, runway values, override applied (if any), final choice, job_id.\n\n---\n\n## 7. Gaps & Missing Pieces\n\n### CRITICAL GAPS\n\n#### 1. **read_pub Skill Not Built**\n- **Status**: HIGH PRIORITY\n- **Blocker**: Without this, PM cannot run autonomously\n- **Effort**: 2-4 hours (Python + gspread + test)\n- **Downstream Impact**: Blocks Phase 2 (cron-based automation)\n\n#### 2. **No Cron/Trigger Definition**\n- **Status**: PHASE 2\n- **Current**: PM is manual-only (Tobias acciones it)\n- **Missing**: Cron schedule, trigger conditions, retry policy\n- **Recommendation**: For Phase 2, define: **\"Run PM every 6 hours or when Lucca/Tobias requests via Telegram\"**\n\n#### 3. **No Error Handling Spec**\n- **Status**: MEDIUM\n- **Scenarios Not Covered**:\n  - Google Sheets API timeout\n  - Invalid YAML config (missing sheet_scripts_id)\n  - All channels have 0 scripts (production blocked)\n  - Override syntax is malformed\n- **Recommendation**: Add section in RULES.md: \"Error Handling & Escalation\"\n\n#### 4. **No Metrics/Analytics**\n- **Status**: LOW (Phase 3)\n- **Missing**:\n  - How often is runway negative?\n  - Which channels are critical most often?\n  - Distribution of runway values across accounts\n- **Recommendation**: Defer to Phase 3. PM should log enough data to support this later.\n\n---\n\n### MEDIUM-LEVEL GAPS\n\n#### 5. **Test Data/Scenarios**\n- **Status**: NO TEST SCENARIOS PROVIDED\n- **Missing**: Examples of edge cases\n  - All channels have runway 5 (no clear winner)\n  - Override excludes all channels with scripts\n  - Date parsing edge case (leap year, DST boundary)\n- **Recommendation**: Add to TOOLS.md: \"Test Scenarios for read_pub\"\n\n#### 6. **Override Expiry Mechanism**\n- **Status**: NOT DEFINED\n- **Needed For**: Phase 2 (when PM runs on cron)\n- **Recommendation**: Define before scaling to autonomous PM\n\n---\n\n## 8. Dependencies\n\n### DIRECT DEPENDENCIES (PM depends on these)\n\n| Dependency | Type | Status | Risk |\n|---|---|---|---|\n| Google Sheets API + service account | External | Configured in KMS | LOW (already working for other parts) |\n| gspread + google-auth libraries | Python package | Not installed | MEDIUM (must add to PM env) |\n| accounts/registry.yaml | File | Exists | LOW |\n| accounts/{account}/{lang}.yaml (39 files) | Files | Exist | LOW |\n| Tobias agent (receives reports) | OpenClaw Agent | Exists | LOW |\n| Video Orchestrator (receives job) | OpenClaw Agent | Planned, not built | HIGH (VO blocks full PM testing) |\n\n### REVERSE DEPENDENCIES (What depends on PM)\n\n| Dependent | Type | Coupling | Impact if PM changes |\n|---|---|---|---|\n| Video Orchestrator | OpenClaw Agent | HIGH (VO consumes PM's job JSON) | If job format changes, VO breaks |\n| Tobias agent | OpenClaw Agent | MEDIUM (receives reports) | Report format change is low-impact |\n| Google Sheets (PUB sheet) | External | MEDIUM (PM assumes columns B, F, J, O exist) | If columns shift, read_pub breaks |\n\n---\n\n## 9. Implementation Priority\n\n### PHASE 1 (MVP — NOW)\n1. **Build `read_pub` skill** (CRITICAL)\n   - Fetch PUB sheet, parse runway\n   - Estimate: 2-4 hours\n   - Unblocks full automation testing\n\n2. **Document override rules** (CRITICAL)\n   - Override expiry, syntax, tie-breaking\n   - Estimate: 1 hour\n\n3. **Add error handling spec** (MEDIUM)\n   - What happens when APIs fail, configs are invalid, etc.\n   - Estimate: 1-2 hours\n\n4. **Test with real PUB data** (CRITICAL)\n   - Run PM against live sheet, verify runway calculations\n   - Estimate: 1-2 hours\n\n---\n\n### PHASE 2 (SCALE TO AUTONOMOUS)\n1. **Implement cron trigger** (HIGH)\n   - Scheduled PM runs every N hours\n   - Estimate: 2-3 hours\n\n2. **Add override persistence** (HIGH)\n   - Track active overrides, their expiry, lifecycle\n   - Estimate: 2-3 hours\n\n3. **Build audit logging** (MEDIUM)\n   - Decision log, timestamps, reasoning\n   - Estimate: 2-3 hours\n\n4. **Add Telegram command interface** (MEDIUM)\n   - \"pm: status\", \"pm: run now\", \"pm: override só 003\"\n   - Estimate: 2-3 hours\n\n---\n\n### PHASE 3 (OPTIMIZE & LEARN)\n1. **Pattern detection in MEMORY.md** (LOW)\n   - Identify which channels are chronically critical\n   - Suggest pre-production for predictable gaps\n   - Estimate: 4-6 hours\n\n2. **Metrics & dashboard** (LOW)\n   - Track runway trends, production velocity, script availability\n   - Estimate: 4-6 hours\n\n3. **Anomaly alerts** (MEDIUM)\n   - Automatic escalation for unusual runway values\n   - Estimate: 2-3 hours\n\n---\n\n## 10. Improvement Suggestions\n\n### SHORT-TERM (Next Sprint)\n\n#### A. Hardening PM Data Input (EASY)\n- **Action**: Add pre-flight validation to `read_pub`\n  - Check all 39 channels are present\n  - Check date columns are valid (between -365d and +90d)\n  - Check PROD column has only SIM/NAO\n  - Check SCRIPTS column has \"X/Y\" format\n- **Effort**: 1-2 hours\n- **Payoff**: Prevent garbage data downstream\n\n#### B. Simplify Override System (EASY)\n- **Action**: Start with ONLY `exclusive` overrides. No `priority` overrides yet.\n  - \"só conta 003\" → produce only 003\n  - Ignore \"prioriza\" for now\n- **Effort**: 0.5 hour\n- **Payoff**: Simpler to implement, test, and reason about\n- **Migration Path**: Add `priority` overrides in Phase 2 if needed\n\n#### C. Document All Edge Cases (EASY)\n- **Action**: Add section to RULES.md: \"Edge Cases & Examples\"\n  - Ties (multiple channels, same runway)\n  - Empty data (no scripts)\n  - Date anomalies (future dates)\n  - Config missing fields\n- **Effort**: 1-2 hours\n- **Payoff**: Clearer for whoever implements read_pub\n\n---\n\n### MEDIUM-TERM (Phase 2)\n\n#### D. Implement Audit Logging (MEDIUM)\n- **Action**: Every PM run generates JSON log with:\n  - `timestamp`\n  - `channels_evaluated` (with runway values)\n  - `override_applied` (if any)\n  - `final_choice` (channel, account, language)\n  - `reason` (runway value + override)\n  - `job_id`\n- **Effort**: 2-3 hours\n- **Payoff**: Post-mortems, optimization, pattern detection\n\n#### E. Add Smart Alerting (MEDIUM)\n- **Action**: Detect and escalate crisis situations\n  - If **any** channel has runway < 0 → immediate alert to Lucca/Tobias\n  - If **all** channels have 0 scripts → \"production blocked\"\n  - If override is stale (>24h) → suggest review\n- **Effort**: 2-3 hours\n- **Payoff**: Lucca never surprised by production gaps\n\n#### F. Build Production Planning View (MEDIUM)\n- **Action**: PM generates 30-day forward look\n  - \"If we produce at current velocity, which channels go critical when?\"\n  - \"Suggest pre-production for X accounts next week\"\n- **Effort**: 3-4 hours\n- **Payoff**: Proactive (not reactive) production planning\n\n---\n\n### LONG-TERM (Phase 3)\n\n#### G. Integrate with Video Orchestrator Health (HARD)\n- **Action**: PM learns from VO's success/failure rates\n  - If VO consistently fails on account 004 → deprioritize\n  - If VO consistently succeeds on account 005 → bias towards 005\n- **Effort**: 4-6 hours\n- **Payoff**: Reduce failures by choosing safer targets\n\n#### H. Multi-Language Optimization (HARD)\n- **Action**: Learn which language-account combos are most \"valuable\"\n  - CTR, monetization, historical success\n  - Bias production towards high-value combos\n- **Effort**: 6-8 hours\n- **Payoff**: Maximize revenue per production cycle\n\n---\n\n## 11. Critical Questions for Lucca/Tobias\n\nBefore finalizing PM implementation, clarify:\n\n1. **Override Lifecycle**\n   - How long should \"só conta 003\" stay active?\n   - Manual clear only, or auto-expire?\n   - Can override be re-issued mid-cycle?\n\n2. **Crisis Handling**\n   - If **all** channels have runway < 0 (all out of scripts), what's the strategy?\n   - Stop production completely?\n   - Force-produce lowest-account?\n   - Alert Lucca and wait for manual direction?\n\n3. **Testing Against Live Sheet**\n   - What's the criteria for \"read_pub works correctly\"?\n   - Should we test with historical PUB data (replay scenarios)?\n   - Should we mock the sheet for unit tests?\n\n4. **Integration with VO**\n   - How does VO acknowledge receipt of job?\n   - How does PM know VO succeeded/failed?\n   - Feedback loop for future PM decisions?\n\n5. **Multi-Machine Implication**\n   - When B1-B10 runs on different machines (M2-M6), how does PM know which machine to dispatch to?\n   - Is this VO's problem, or PM's?\n\n---\n\n## 12. Candidate Skills for Extraction\n\n**Skills to Build/Extract** (for skill inventory):\n\n1. **read_pub** ⭐ CRITICAL\n   - Type: Data Fetch + Transform\n   - Input: Sheet ID + tab + date range\n   - Output: Channels with runway values, sorted\n   - Reusable: YES (any future agent needing PUB data)\n   - Complexity: LOW-MEDIUM\n\n2. **validate_pub_data**\n   - Type: Validation + Sanity Check\n   - Input: Raw PUB data (cells)\n   - Output: Cleaned data + anomaly report\n   - Reusable: YES (QA, monitoring)\n   - Complexity: LOW\n   - Priority: Phase 2\n\n3. **calculate_runway**\n   - Type: Business Logic\n   - Input: ULT_PUB, PROGRAMAR dates\n   - Output: Runway in days\n   - Reusable: YES (anywhere runway needed)\n   - Complexity: TRIVIAL (but worth extracting for consistency)\n\n4. **priority_sort**\n   - Type: Business Logic\n   - Input: List of channels with runway + override + account number\n   - Output: Sorted list, final choice\n   - Reusable: YES (future priority systems)\n   - Complexity: TRIVIAL\n\n---\n\n## 13. Candidate Tools for Extraction\n\n**Tools to Configure/Document** (for tool inventory):\n\n1. **google_sheets_api** (Google Service Account)\n   - Already configured in KMS for other parts\n   - Document: sheet ID, tab names, column mappings, required auth\n\n2. **yml_parser** (YAML config reader)\n   - Parse accounts/registry.yaml and channel YAMLs\n   - Handle missing files gracefully\n\n3. **telegram_reporter** (Send messages to Tobias)\n   - Document: Topic name, message format, retry policy\n\n4. **json_artifact_generator** (Create job JSON)\n   - Template: job structure, all required fields, validation\n\n---\n\n## Summary\n\n### WHAT WORKS WELL ✅\n- **Clear role definition**: PM knows what it does (decide O QUE)\n- **Data flow is sound**: PUB sheet → runway calc → priority sort → job JSON\n- **Separation from VO is good**: PM doesn't produce, VO doesn't decide\n- **Configs are organized**: registry.yaml + per-channel YAMLs is clean\n- **Workspace structure is correct**: IDENTITY, RULES, TOOLS, SCHEDULE well-divided\n- **39 channels mapped correctly**: All accounts, languages accounted for\n\n### WHAT'S INCOMPLETE 🔶\n- **read_pub skill not built** (CRITICAL BLOCKER)\n- **Override rules not fully specified** (ambiguities in expiry, syntax, tie-breaking)\n- **Error handling underspecified** (what to do when APIs fail, configs are invalid)\n- **Logging/audit trail missing** (no decision history, hard to debug)\n- **Test scenarios missing** (edge cases not covered)\n\n### WHAT'S RISKY 🔴\n- **PM will be data-dependent on PUB sheet quality** (no validation of input)\n- **Date math fragile** (could have subtle bugs with timezone, leap years)\n- **No feedback loop from VO** (PM doesn't learn if its choices succeed/fail)\n- **Override can become stale** (if PM runs on cron, stale override could cause unintended behavior)\n\n### IMPLEMENTATION STATUS\n- **MVP-ready**: 60% (core logic defined, read_pub missing)\n- **Phase 2-ready**: 30% (cron, logging, overrides need work)\n- **Phase 3-ready**: 10% (optimization, learning not started)\n\n### FILES ANALYZED: 16\n### SKILLS IDENTIFIED: 4 (1 critical, 3 supporting)\n### TOOLS IDENTIFIED: 4 (all documented, 1 needs building)\n\n---\n\n**Next Step**: Build `read_pub` skill. Unblocks full testing against live PUB sheet.\n"}],"isError":false,"timestamp":1774793537188}}
{"type":"message","id":"9c6d3b58","parentId":"4905c248","timestamp":"2026-03-29T14:12:17.249Z","message":{"role":"toolResult","toolCallId":"call_u68evku9N43gHS2syzSvlEkQ|fc_04d04e5a142d912b0169c9334210d88191a3e5531e42892beb","toolName":"read","content":[{"type":"text","text":"# Video Orchestrator Component Review\n## Auto Content Factory — Brutally Honest Assessment\n\n**Review Date**: 27 Mar 2026, 07:51 GMT-3  \n**Reviewer**: Tobias Night Subagent  \n**Status**: PENDING IMPLEMENTATION (architectural stage)  \n**Severity**: Architecture sounds solid; implementation plan is absent\n\n---\n\n## Executive Summary\n\nThe Video Orchestrator (VO) is **architecturally well-designed but not yet built**. The specification is clear, the role is well-defined, and the system-level thinking is sound. However, **the component exists only as documentation** — no workspace, no prompts, no Python skills, and no OpenClaw tooling instructions.\n\n**Files analyzed**: 5 documentation files  \n**Python skills identified**: 6  \n**OpenClaw tools needed**: 7  \n**Ambiguities**: 8 critical, 5 moderate  \n**Gaps**: 4 major, 7 minor  \n**Implementation priority**: **MEDIUM-HIGH** — blocks all production after B1 completes\n\n---\n\n## Section 1: Scope & Files Read\n\n### Documentation Files Analyzed (5 total)\n\n| File | Status | Lines | Key Info |\n|------|--------|-------|----------|\n| `11_VIDEO_ORCHESTRATOR.md` | ✅ Complete | 283 | Role, sequencing, parallelism, error handling |\n| `12_VIDEO_DIRECTORY_STRUCTURE.md` | ✅ Complete | 385 | Directory structure, checkpoints, recovery model |\n| `09_HIERARCHY_AND_STRUCTURE.md` | ✅ Complete | 315 | Hierarchy, VO position, communication channels |\n| `10_PRODUCTION_MANAGER.md` | ✅ Complete | 245 | PM output (job JSON), what feeds VO |\n| `00_CONTEXT.md` | ✅ Partial | 118 | Project context, pipeline overview |\n\n### No Workspace Mirror Exists\n- **Expected**: `workspace_mirror/video_orchestrator/`\n- **Actual**: Does not exist yet\n- **Implication**: Need to build it from scratch following Tobias + PM patterns\n\n---\n\n## Section 2: Role & Responsibilities\n\n### What VO Does (per spec)\n1. **Receive job artifact** from PM (JSON with account, language, configs)\n2. **Create video directory** with standard structure (`videos/{account}_{lang}/{YYYY-MM-DD}_{slug}/`)\n3. **Fetch script** from Google Sheet (specified in job) + lock it to prevent concurrent fetches\n4. **Orchestrate branches B1→B10** in correct sequence\n5. **Manage parallelism**: B2 & B3 run in parallel, B10 runs throughout\n6. **Manage dependencies**: wait for prerequisite branches before starting dependent ones\n7. **Handle errors**: retry logic (3x with backoff), safe rewrites, escalation to Tobias/Lucca\n8. **Report status**: communicate directly with Tobias **AND** Lucca (unique privilege below CEO)\n9. **Cleanup**: upload final video, update tracking sheet, release script lock\n\n### What VO Does NOT Do\n- Make strategic decisions (that's Tobias)\n- Execute production tasks directly (that's branches)\n- Decide which video to produce (that's PM)\n- Modify job parameters mid-execution\n\n### Communication Channels\n- **Upstream input**: Job artifact from PM (JSON)\n- **Upstream output**: Status reports to Tobias + Lucca (Telegram)\n- **Downstream**: Commands to branch managers (B1-B10), receive their completion status\n- **External APIs**: Google Sheets (fetch script, update tracking), Google Drive (upload final video)\n\n---\n\n## Section 3: Python Skills Needed\n\n### Identified Skills (6 total)\n\n| # | Skill Name | What It Does | V3 Base? | Purpose |\n|---|------------|--------------|----------|---------|\n| 1 | **job_validator** | Validates job artifact from PM (check all required fields, correct types) | JSON schema | Fail fast if input is malformed |\n| 2 | **directory_creator** | Creates video directory structure on disk with all subdirs (input/, b1_pre_production/, logs/, etc.) | Path operations | Setup phase |\n| 3 | **google_sheets_script_fetcher** | Fetches next available script from Google Sheet, locks row to prevent concurrent fetches | read_pub skill (planned) | Blocking operation, critical |\n| 4 | **branch_orchestrator** | Core: sequencing, dependency management, parallelism rules. Tracks which branches have completed. | Async/graph | Brain of VO |\n| 5 | **error_escalator** | Decides: retry? skip? escalate? Sends notifications to Tobias/Lucca. Logs to checkpoints/errors/ | Telegram API | Critical path |\n| 6 | **cleanup_and_report** | Uploads final video to Drive, updates tracking sheet, releases script lock, generates completion report JSON | Google Drive API | Final step |\n\n### Model Assignment\n- **Spec says**: Qwen 3.5 9B via Ollama\n- **Reasoning**: Structured logic, no complex reasoning needed\n- **Risk**: Qwen hasn't been tested with this complexity yet; may need fallback to GPT-3.5 Turbo\n\n---\n\n## Section 4: OpenClaw Tools Needed\n\n### Identified Tools (7 total)\n\n| # | Tool | Type | Config/Auth | Purpose |\n|---|------|------|-------------|---------|\n| 1 | **Google Sheets API** | External API | OAuth 2.0 via KMS | Fetch scripts, lock rows, update tracking |\n| 2 | **Google Drive API** | External API | OAuth 2.0 via KMS | Upload final video (MP4) |\n| 3 | **Telegram API** | Chat integration | Token in .env (existing) | Send status updates to Lucca/Tobias |\n| 4 | **File I/O** (exec/fs) | Local filesystem | No auth | Create dirs, write logs, manage checkpoints |\n| 5 | **Process spawning** (exec/sessions) | Subagent spawning | OpenClaw native | Spawn branch managers as subagents |\n| 6 | **JSON parser/validator** | Built-in (Python) | N/A | Validate job artifact, parse configs |\n| 7 | **SSH (optional)** | Remote execution | SSH keys (future) | If branches run on M2-M6; else local only |\n\n### Auth & Config Status\n- ✅ **Google Sheets API**: Already configured for PM (KMS-managed)\n- ✅ **Google Drive API**: Already configured for uploads (KMS-managed)\n- ✅ **Telegram API**: Active (@TobiasM1bot, running)\n- ⚠️ **SSH keys**: Not yet configured (M2-M6 not set up yet)\n\n---\n\n## Section 5: Ambiguities\n\n### CRITICAL (blocking implementation)\n\n1. **Branch Manager Interface**\n   - **Question**: How does VO call branch managers? What exactly is the \"command\" format?\n   - **Current spec**: \"Orquestra B1→B2→...→B10\" but no protocol specified\n   - **Missing**: Input format, output format, error reporting protocol\n   - **Impact**: Cannot write orchestrator logic without knowing how to invoke branches\n   - **Depends on**: Detailed spec for each branch (B1-B10 not yet detailed)\n\n2. **Checkpoint Semantics**\n   - **Question**: Who creates checkpoints? VO or branch managers?\n   - **Current spec**: Checkpoints are \"per step\" and \"allow recovery granular\"\n   - **Missing**: Exactly how branches report completion? Via JSON file? HTTP? Stdout?\n   - **Impact**: Cannot implement resumption logic without understanding checkpoint contract\n\n3. **Dependency Resolution Graph**\n   - **Question**: How does VO know when B2 and B3 can start in parallel? Hard-coded or dynamic?\n   - **Current spec**: \"B2 + B3 in parallel, both depend on B1\"\n   - **Missing**: Complete dependency graph. What if a new branch is added? What if B10 needs output from B8?\n   - **Impact**: Brittle implementation if dependencies are hard-coded\n\n4. **Error Escalation Trigger**\n   - **Question**: When exactly should VO escalate vs retry vs skip?\n   - **Current spec**: \"Retry 3x, then escalar al Tobias\"\n   - **Missing**: How does VO know if an error is \"permanent\" (NSFW, content block) vs \"temporary\" (rate limit)?\n   - **Impact**: May retry on errors that won't resolve, or skip too early\n\n5. **Video Directory Ownership**\n   - **Question**: Where do branches write their outputs? The main video directory or their own?\n   - **Current spec**: Structure shows b1_pre_production/, b2_audio/, etc. as **subdirectories** of the video root\n   - **Missing**: Do branches get the full path and write directly? Or do they return JSON and VO writes?\n   - **Impact**: Affects how parallel execution works and how cleanup is coordinated\n\n6. **Script Lock Timeout**\n   - **Question**: If a video stalls mid-production, when is the lock released?\n   - **Current spec**: \"Locks script row to prevent concurrent fetches\"\n   - **Missing**: Timeout mechanism. What if VO crashes? Dead lock?\n   - **Impact**: Could block production if safety mechanism is missing\n\n7. **Concurrency Model**\n   - **Question**: Can multiple VO instances run simultaneously (different videos)?\n   - **Current spec**: \"One VO instance per job\"\n   - **Missing**: How do we prevent two VO instances from fetching the same script?\n   - **Impact**: Race condition if not carefully managed (though \"lock\" suggests it is)\n\n8. **Final Report JSON Schema**\n   - **Question**: What's the exact schema for the completion report?\n   - **Current spec**: Example provided, but incomplete (what about per-branch costs? detailed timings?)\n   - **Missing**: Full schema, field validation, upstream consumer (who reads this report?)\n   - **Impact**: Cannot integrate with downstream systems without it\n\n### MODERATE (implementation concerns)\n\n1. **Qwen 3.5 9B Suitability**\n   - Question: Has Qwen 3.5 9B been tested with multi-step orchestration logic?\n   - Risk: May not handle complex branching and state management reliably\n   - Mitigation: Fallback plan to GPT-3.5 Turbo if Qwen fails\n\n2. **Runway Calculation Assumption**\n   - Question: VO assumes PM calculates runway correctly. What if PM is wrong?\n   - Risk: VO might start on a low-priority video if PM made an error\n   - Mitigation: VO could re-validate runway before committing to production\n\n3. **Telegram Notification Overload**\n   - Question: B10 \"reports during entire production\" — that's potentially hundreds of messages\n   - Risk: Lucca's Telegram gets flooded; messages may arrive out of order\n   - Mitigation: Batch messages? Use threads? Need clearer notification strategy\n\n4. **Directory Path Naming**\n   - Question: Slug generation: who does it? VO or PM?\n   - Current spec: \"slug is derived from title\"\n   - Missing: Algorithm. Accented characters (é, ü, ñ)? Length limits?\n   - Impact: Could cause errors if two videos get the same slug\n\n5. **Artefact Versioning**\n   - Question: If job artifact schema changes, does VO need version checking?\n   - Risk: Backward compatibility issues as system evolves\n   - Mitigation: Add version field to job artifact, VO validates\n\n---\n\n## Section 6: Weak Points\n\n### Design-Level Weaknesses\n\n1. **\"Comunicação direta com Tobias e Lucca\" — Too Much Responsibility**\n   - VO is supposed to be an orchestrator, but it's also expected to be a UI layer for status queries\n   - Risk: VO's logic becomes entangled with communication/formatting concerns\n   - Suggestion: Delegate status reporting to B10 (monitoring branch) instead\n\n2. **No Defined SLA for Production**\n   - Question: What's the expected end-to-end time for a full video (B1→B10)?\n   - Missing: Targets for each branch, alert if taking too long\n   - Risk: Won't know if B5 is taking abnormally long until hours in\n\n3. **Parallelism Is Limited**\n   - Current: B2 & B3 in parallel, everything else sequential\n   - Reality: B4, B5, B6 could potentially overlap if dependencies were looser\n   - Suggestion: Consider more aggressive parallelism after initial implementation\n\n4. **No Rollback Mechanism**\n   - Spec allows \"resuming from checkpoint\" but not \"undoing a bad branch output\"\n   - Example: B5 generates terrible images. Can VO request B5 to retry without redoing B6?\n   - Missing: Clear rollback protocol\n\n### Implementation-Level Weaknesses\n\n1. **Async/Concurrency Not Specified**\n   - Python? asyncio? threading? subprocess?\n   - Critical for managing B2 + B3 parallelism\n   - Spec mentions parallelism but doesn't define how to implement it\n\n2. **No Logging Strategy**\n   - `logs/agent_calls/` and `logs/errors/` are mentioned but format is vague\n   - How does VO decide what to log? Everything? Only errors?\n   - Risk: Either too verbose (performance) or too sparse (debugging impossible)\n\n3. **Retry Logic Underspecified**\n   - \"3x with backoff\" — but backoff schedule? Exponential? Linear?\n   - \"Safe rewrite\" for NSFW — but what does this mean exactly?\n   - Missing: Concrete retry_policy JSON\n\n4. **No Observability/Metrics**\n   - How do we know if VO is performing well?\n   - What metrics matter: throughput? error rate? branch duration distribution?\n   - Missing: prometheus/datadog integration or equivalent\n\n---\n\n## Section 7: Gaps\n\n### MAJOR GAPS (must resolve before implementation)\n\n1. **Branch Manager Specification Complete Definition Missing**\n   - What VO needs: exact interface for each branch manager (B1-B10)\n   - What's available: list of branches + brief description\n   - What's missing: complete spec for B1-B5 (docs don't detail B6-B10 at all)\n   - Blocker: Cannot test or implement branch orchestration without this\n\n2. **Workspace Mirror for Video Orchestrator Missing**\n   - What VO needs: IDENTITY.md, RULES.md, TOOLS.md, CONTEXT.md, AGENTS.md\n   - What's available: structure examples from Tobias + PM workspaces\n   - What's missing: actual VO workspace files (should be in `workspace_mirror/video_orchestrator/`)\n   - Blocker: Cannot bootstrap VO agent without workspace files\n\n3. **Branch Interface Protocol Undefined**\n   - What VO needs: exact request/response format for calling branches\n   - What's available: \"acciona branches\" mentioned but no protocol\n   - What's missing: is it JSON? Subagent spawn? Direct function calls?\n   - Blocker: Cannot write orchestrator logic without knowing how to invoke branches\n\n4. **Job Artifact Validation Schema Missing**\n   - What VO needs: JSON schema for validating incoming job artifact\n   - What's available: example JSON in PM spec\n   - What's missing: formal schema with required fields, types, constraints\n   - Blocker: Cannot implement job_validator skill without this\n\n### MINOR GAPS (should resolve before production)\n\n1. **No Status Polling vs Waiting Specification**\n   - Should VO actively poll branches for status, or passively wait for callbacks?\n   - Affects timeout and error detection strategy\n\n2. **No Monitoring/Alerting Integration Spec**\n   - How does VO integrate with B10 (monitoring)?\n   - Do they share state? Is B10 stateless?\n\n3. **Cost Tracking Missing from Output**\n   - Job artifact has no cost budget; final report calculates cost but no cap/alert\n   - Should VO abort if costs exceed a threshold?\n\n4. **No Recovery from VO Crash**\n   - If VO crashes mid-production, how does it resume?\n   - Should it check what branches completed and resume from there?\n\n5. **Script Lock Release Mechanism Undefined**\n   - How does VO release the script lock if it crashes?\n   - Timeout? Manual release? Deadlock possible?\n\n6. **No Recommendation for Multi-VO Coordination**\n   - If multiple VO instances need to run, how do they coordinate?\n   - Just via script lock, or do they need a registry?\n\n7. **B10 (Monitoring) Role Unclear**\n   - Runs \"parallel with everything\" but what exactly does it do?\n   - Is it a branch manager or a standalone monitor?\n\n---\n\n## Section 8: Dependencies\n\n### Upstream Dependencies (inputs VO needs)\n\n| Dependency | Source | Status | Risk |\n|------------|--------|--------|------|\n| Job artifact (JSON) | Production Manager | ✅ Spec complete | Low — PM spec is done |\n| Google Sheets API client | KMS (existing) | ✅ Configured | Low — already working for PM |\n| Google Drive API client | KMS (existing) | ✅ Configured | Low — already working |\n| Telegram API client | .env (existing) | ✅ Active | Low — bot is running |\n| Branch specifications (B1-B10) | docs/NN_BRANCH.md (not all written) | ⚠️ Partial | **MEDIUM** — B6-B10 not detailed yet |\n| Scene bible schema | doc 12 | ✅ Defined | Low |\n\n### Downstream Dependencies (outputs VO provides)\n\n| Dependency | Consumer | Status | Risk |\n|------------|----------|--------|------|\n| Branch invocation | Branch Managers (B1-B10) | ❌ Not specified | **HIGH** — interface unclear |\n| Video file path + metadata | Upload/tracking system | ⚠️ Mentioned | Low — standard paths |\n| Completion report JSON | Tobias + tracking | ✅ Format provided | Low |\n| Checkpoint files | Recovery system | ✅ Spec provided | Low |\n\n### Internal Dependencies (cross-branch)\n\n1. **B1 → B2, B3**: B1 creates scene_bible.json that B2 and B3 read\n2. **B2 + B3 → B6**: B6 needs audio clips + entities to compose\n3. **B6 → B7**: B7 needs composition to add effects\n4. **B7 → B8**: B8 needs final composition to render\n5. **All branches → B10**: B10 monitors all of them\n\n---\n\n## Section 9: Implementation Priority\n\n### Phase 1 (BLOCKING for any production)\n**Do first. Everything else waits.**\n\n- [ ] Define branch manager interface protocol (request/response format)\n- [ ] Write detailed specs for B1-B5 (B6-B10 can wait)\n- [ ] Create workspace_mirror/video_orchestrator/ with all required .md files\n- [ ] Implement job_validator skill\n- [ ] Implement directory_creator skill\n\n**Est. effort**: 3-4 days (2 engineer + 1 spec writer)\n\n### Phase 2 (CRITICAL for production flow)\n**Do after Phase 1. Core orchestration.**\n\n- [ ] Implement branch_orchestrator skill (sequencing + dependency graph)\n- [ ] Implement google_sheets_script_fetcher skill (fetch + lock)\n- [ ] Implement error_escalator skill (retry logic + escalation)\n- [ ] Build VO agent in OpenClaw (link skills + workspace)\n- [ ] Test B1→B2 sequencing with mock data\n\n**Est. effort**: 5-6 days (1 engineer + 1 testing)\n\n### Phase 3 (IMPORTANT for polishing)\n**Do after Phase 2. Monitoring and cleanup.**\n\n- [ ] Implement cleanup_and_report skill (upload + tracking + lock release)\n- [ ] Integrate B10 (monitoring) with VO status reporting\n- [ ] Add comprehensive logging to logs/agent_calls/\n- [ ] Implement recovery mechanism (resume from checkpoint)\n- [ ] Test full production cycle with real data\n\n**Est. effort**: 4-5 days (1 engineer + 1 testing)\n\n### Phase 4 (OPTIONAL improvements)\n**Do after production is stable. Optimization.**\n\n- [ ] Implement aggressive parallelism (B4-B5-B6 overlap)\n- [ ] Add metrics/observability (throughput, error rates)\n- [ ] Implement rollback mechanism\n- [ ] Add Qwen → GPT fallback logic\n- [ ] Optimize checkpoint recovery (granular resume per sub-step)\n\n**Est. effort**: 3-4 days (1 engineer)\n\n---\n\n## Section 10: Improvement Suggestions\n\n### High Priority\n\n1. **Decouple Communication from Orchestration**\n   - Current: VO handles both orchestration logic AND Telegram reporting\n   - Suggestion: Let B10 (monitoring) own all Telegram communication\n   - Benefit: Cleaner separation of concerns, VO can focus on logic\n\n2. **Define Explicit Interface Contracts**\n   - Create `interfaces/branch_manager_protocol.md`\n   - Specify: request JSON schema, response JSON schema, error handling protocol\n   - Benefit: Can build VO and branches independently\n\n3. **Add Observability from Day 1**\n   - Log every branch call (start, end, duration, result)\n   - Emit metrics (throughput, error rate, branch duration distribution)\n   - Benefit: Will help identify bottlenecks and anomalies early\n\n4. **Implement Checkpoints as Atomic Transactions**\n   - Current: Checkpoints are files that get created/deleted\n   - Suggestion: Treat checkpoints like database transactions (write-ahead log)\n   - Benefit: Impossible to lose state even if VO crashes\n\n5. **Make Dependency Graph Dynamic**\n   - Current: B1→B2, B1→B3, etc. hard-coded in VO logic\n   - Suggestion: Load dependency graph from config file (YAML)\n   - Benefit: Can add branches or change sequencing without code changes\n\n### Medium Priority\n\n6. **Build a VO Simulator**\n   - Create a mock set of branch managers that return canned results\n   - Benefit: Can test orchestrator logic in isolation, fast iteration\n\n7. **Add Retry Policy Configuration**\n   - Move retry_count, backoff_schedule to RULES.md\n   - Benefit: Can tune retry behavior without code changes\n\n8. **Implement Cost Budget Checks**\n   - Each job gets a cost budget; VO aborts if exceeded\n   - Benefit: Prevents runaway spend if a branch goes rogue\n\n9. **Create Dashboard for In-Flight Videos**\n   - Show: which branch is running, elapsed time, ETA, errors\n   - Benefit: Lucca can see production status without asking\n\n10. **Add Branch Health Checks**\n    - Periodically verify branch is responsive, not hung\n    - Benefit: Detect stalls early, don't wait for timeout\n\n### Lower Priority\n\n11. **Build Multi-VO Coordination Layer**\n    - Allow multiple VO instances to run different videos in parallel\n    - Benefit: Higher throughput (if branches can handle it)\n\n12. **Implement Conditional Branch Skipping**\n    - Example: \"Skip B5 if all images are real (no AI needed)\"\n    - Benefit: Faster production for some videos\n\n13. **Add Video Preview Generation**\n    - Create low-res preview during production for early QA\n    - Benefit: Catch issues before final render\n\n14. **Implement Partial Parallelism in B2+B3+B4**\n    - If visual planning is done early, start asset research before B2 finishes\n    - Benefit: Tighter pipelining, faster overall time\n\n---\n\n## Section 11: Candidate Skills (Structured List)\n\n### Skills to Build for VO (ready for inventory)\n\n```\nSKILL_INVENTORY:\n\n[VO_CORE_SKILLS]\n- job_validator (validates input artifact)\n- directory_creator (initializes production directory)\n- google_sheets_script_fetcher (fetch script + lock)\n- branch_orchestrator (core sequencing logic)\n- error_escalator (retry/escalate decisions)\n- cleanup_and_report (finalize + upload)\n\n[VO_SUPPORT_SKILLS]\n- checkpoint_manager (read/write checkpoints)\n- dependency_resolver (compute next branches to run)\n- duration_estimator (predict time per branch based on historical data)\n- cost_tracker (accumulate and report costs per branch)\n\n[VO_INTEGRATION_SKILLS]\n- branch_status_poller (check if branch completed)\n- telegram_status_reporter (send updates to Lucca)\n- google_drive_uploader (upload final video)\n- google_sheets_tracker_updater (update tracking sheet)\n\n[VO_RECOVERY_SKILLS]\n- crash_recovery (resume from checkpoint on restart)\n- deadlock_detector (detect hung branches)\n- script_lock_cleanup (release orphaned locks)\n\n[FUTURE_OPTIMIZATION_SKILLS]\n- parallelism_optimizer (compute max parallelism given constraints)\n- cost_budget_enforcer (abort if costs exceed budget)\n- branch_health_monitor (periodic health checks)\n```\n\n---\n\n## Section 12: Candidate Tools (Structured List)\n\n### Tools/APIs to Integrate with VO (ready for inventory)\n\n```\nTOOLS_INVENTORY:\n\n[EXTERNAL_APIs]\n- google_sheets_api (fetch scripts, lock rows, update tracking)\n  CONFIG: OAuth 2.0, KMS-managed, already configured\n  USAGE: critical path (fetch script), tracking (release lock)\n\n- google_drive_api (upload final video)\n  CONFIG: OAuth 2.0, KMS-managed, already configured\n  USAGE: final cleanup, upload MP4 to drive\n\n- telegram_api (send status updates)\n  CONFIG: bot token in .env, already active\n  USAGE: notify Lucca/Tobias of production status\n\n[LOCAL_TOOLS]\n- file_io_exec (create dirs, write checkpoints, manage logs)\n  CONFIG: local filesystem permissions\n  USAGE: directory structure setup, logging\n\n- json_parser (validate/parse artifacts)\n  CONFIG: built-in Python\n  USAGE: job validation, checkpoint serialization\n\n[AGENT_SPAWNING_TOOLS]\n- openclaw_subagent_spawner (spawn branch managers)\n  CONFIG: OpenClaw native, sessions API\n  USAGE: invoke B1-B10 branch managers\n\n[FUTURE_TOOLS]\n- ssh_exec (remote execution on M2-M6)\n  CONFIG: SSH keys, not yet configured\n  USAGE: dispatch work to GPU machines\n\n- prometheus_exporter (metrics/observability)\n  CONFIG: optional, not yet set up\n  USAGE: production monitoring\n\n- slack_webhook (alternative notifications)\n  CONFIG: optional, not yet configured\n  USAGE: team alerts (if needed)\n```\n\n---\n\n## Section 13: Critical Issues Summary\n\n### 🔴 BLOCKING ISSUES\n\n1. **Branch Interface Protocol Undefined**\n   - Impact: Cannot write orchestrator without knowing how to invoke branches\n   - Resolution: Write interface spec before Phase 1 starts\n   - Owner: Lucca + spec writer\n\n2. **Workspace Files Missing**\n   - Impact: Cannot bootstrap VO agent\n   - Resolution: Create `workspace_mirror/video_orchestrator/` with standard files\n   - Owner: Agent setup engineer\n\n3. **B6-B10 Specifications Not Detailed**\n   - Impact: VO can't be fully tested without knowing what later branches do\n   - Resolution: Detail B6-B10 before Phase 3\n   - Owner: Department leads (composition, post-prod, render, QA, monitoring)\n\n### 🟡 HIGH-RISK ISSUES\n\n1. **Qwen 3.5 9B Not Validated for Complex Orchestration**\n   - Impact: May fail at orchestrating dependencies\n   - Mitigation: Have fallback to GPT-3.5 Turbo ready\n   - Owner: ML engineer\n\n2. **Concurrent VO Instances Not Coordinated**\n   - Impact: Race condition if two videos fetch same script\n   - Mitigation: Script lock should prevent this, but not tested\n   - Owner: VO implementation team\n\n3. **Error Escalation Criteria Vague**\n   - Impact: May escalate too often or not enough\n   - Mitigation: Define explicit escalation rules in error_escalator\n   - Owner: Operations/decision logic team\n\n### 🟠 MEDIUM ISSUES\n\n1. **No SLA for Production Time**\n   - Impact: Won't know if production is slow until too late\n   - Resolution: Set targets per branch, implement alerts\n   - Owner: Operations\n\n2. **Parallelism Limited to B2+B3**\n   - Impact: Leaving performance on table\n   - Resolution: Loosen dependencies for future phases\n   - Owner: Architecture team\n\n3. **Monitoring Integrated into VO**\n   - Impact: Mixing concerns (orchestration vs monitoring)\n   - Resolution: Move B10 integration to separate skill\n   - Owner: VO team\n\n---\n\n## Files Analyzed Count\n\n**Documentation**: 5 files  \n**Workspace mirrors**: 1 partial directory structure (no VO files yet)  \n**Python code**: 0 files (not yet written)  \n**Total**: 6 distinct source elements\n\n---\n\n## Skills & Tools Summary\n\n| Category | Count | Status |\n|----------|-------|--------|\n| Python skills to build | 6 core + 4 support + 3 recovery + 4 future = **17 total** | Not started |\n| OpenClaw tools to integrate | 7 identified | 3 already configured (sheets, drive, telegram) |\n| Workspace files needed | 5 standard files | 0 created yet |\n| Branch interfaces needed | 10 (B1-B10) | 0 formally specified |\n| Critical ambiguities | 8 | Must resolve before implementation |\n| Implementation phases | 4 phases | Phase 1-2 are blocking |\n\n---\n\n## Conclusion\n\n**The Video Orchestrator is well-designed on paper but unbuilt in reality.** The architectural thinking is sound — clear role separation, explicit sequencing, error handling strategy. However, the component exists only as specification. Implementation cannot begin until:\n\n1. **Branch manager interface** is formally specified\n2. **Workspace files** are created following the pattern\n3. **B1-B5 detailed specs** are available for testing\n4. **Job artifact schema** is formalized for validation\n\nThe path forward is clear: Phase 1 (specification + workspace setup) must complete before Phase 2 (core skills) can begin. Once that foundation is solid, implementation should move quickly (estimated 8-10 days for Phases 1-3).\n\n**Recommendation**: Tackle Phase 1 immediately (parallel with B6-B10 spec work). This unblocks core implementation and lets you start validating assumptions early.\n\n---\n\n**Report generated**: 27 Mar 2026, 07:51 GMT-3  \n**Subagent**: Tobias Night Review (session: review-vo)  \n**Status**: Complete\n"}],"isError":false,"timestamp":1774793537220}}
{"type":"message","id":"f379ed2a","parentId":"9c6d3b58","timestamp":"2026-03-29T14:12:17.280Z","message":{"role":"toolResult","toolCallId":"call_tAVW7OKQ5cDIEroxgruOUSnn|fc_04d04e5a142d912b0169c9334210e08191bd92995259a7fbf0","toolName":"read","content":[{"type":"text","text":"# Branch 1 (Pre-Production) — Brutally Honest Review\n**Reviewer:** Subagent (Tobias delegate)  \n**Date:** 26 Mar 2026  \n**Status:** COMPREHENSIVE REVIEW COMPLETE\n\n---\n\n## Executive Summary\n\n**Branch 1 is WELL-DESIGNED but INCOMPLETE. Core architecture is sound. Critical blocker: Python validation skills are NOT IMPLEMENTED. Agentware (prompts, rules, examples) is production-ready. Estimated readiness: 70% — awaiting skill implementation and one architectural clarification.**\n\n---\n\n## Files Analyzed & Scope\n\n### Documentation Read\n1. `01_PRE_PRODUCTION.md` — Branch specification (complete)\n2. `00_CONTEXT.md` — Factory context (skimmed, relevant parts read)\n3. `03_PIPELINE_MAP.md` — Pipeline overview (reference)\n4. `04_BRANCH_ARCHITECTURE.md` — Branch design patterns (reference)\n5. `06_MODEL_STRATEGY.md` — Model selection strategy (reference)\n6. `09_HIERARCHY_AND_STRUCTURE.md` — Agent hierarchy (reference)\n7. `10_PRODUCTION_MANAGER.md` — PM context (reference)\n8. `11_VIDEO_ORCHESTRATOR.md` — VO context (reference)\n9. `12_VIDEO_DIRECTORY_STRUCTURE.md` — Directory layout (reference)\n\n### Workspace Mirror Files Read (B1)\n1. `IDENTITY.md` — BM-B1 role & context (complete)\n2. `CONTEXT.md` — Current operational status (complete)\n3. `agents/scene_director/PROMPT.md` — Agent identity & philosophy (complete)\n4. `agents/scene_director/RULES.md` — Operational rules (complete)\n5. `agents/scene_director/EXAMPLES.md` — 6 detailed examples (complete)\n6. `agents/scene_director/TOOLS.md` — Input/output spec (complete)\n7. `agents/tts_polish/PROMPT.md` — Agent identity & scope (complete)\n8. `agents/tts_polish/RULES.md` — 13 operational rules (complete)\n9. `agents/scene_bible_builder/PROMPT.md` — Agent identity & output (complete)\n10. `agents/scene_bible_builder/RULES.md` — Schema & validation (complete)\n\n**Total Files:** 18 files analyzed  \n**Total Documentation:** ~18,000 words of specification  \n**Status:** All documentation present and highly detailed\n\n---\n\n## Branch Purpose\n\n**Transform script → scene bible.**\n\nB1 is the first operational branch in the production pipeline. It accepts a raw script (plain text), divides it into scenes respecting word count constraints, polishes narration for TTS naturalness, and outputs a `scene_bible.json` — a structured living document that all downstream branches (B2-B6) read and extend.\n\n**Key principle:** Screenplay = absolute rule for audio, flexible guide for visual.\n\n---\n\n## Per-Component Review\n\n### 1. BM-B1 (Branch Manager)\n\n**Model:** GPT-5.4 mini (OAuth)  \n**Role:** Orchestrate 3 agents + 2 skills, manage retries, interpret validations, generate checkpoints.\n\n#### Strengths\n- Clear identity & hierarchy positioning\n- Well-defined retry logic: 3 max, then escalate to Lucca/Tobias/Claude Code (not just VO)\n- Understands checkpoint system (per-step, not per-branch) for granular recovery\n- Knows BM must interpret validation feedback and dispatch only affected scenes for correction\n- Context YAML is minimal but sufficient (knows `scene_words_range`, `tts_polish_rules` come from config)\n\n#### Weaknesses\n- No PROMPT.md file exists for BM-B1 itself (only IDENTITY.md + CONTEXT.md)\n  - **Gap:** BM-B1 needs explicit instructions for:\n    - How to read/parse `screenplay_validator` and `polish_validator` outputs\n    - Exact flow diagram: when to call which agent, what to do with feedback\n    - Timeout/cost constraints per step\n    - How to generate checkpoints (exact JSON schema)\n  - **Risk:** Implementation will require guesswork or reverse-engineering from docs\n- CONTEXT.md notes that validators are \"NÃO IMPLEMENTADO\" (not implemented)\n  - **Blocker:** Without validators, Steps 2 & 4 cannot execute\n  - **Current workaround:** Doc says \"Steps 2 and 4 must be skipped\"\n  - **Problem:** If skipped, validation never happens → scene_director output goes unchecked → audio desync risk\n- No mention of how to handle scenario where scene_director makes N changes but only some pass validation\n  - **Ambiguity:** Is partial acceptance allowed, or does the ENTIRE screenplay fail validation?\n- No MEMORY.md file\n  - **Gap:** BM-B1 won't accumulate learnings about common errors across runs\n- No TOOLS.md for BM-B1 itself (knows how to call agents but no explicit tool description)\n\n#### Questions for Clarification\n1. **Partial Acceptance:** If validation fails on scene_007 but scene_008 passes, does the entire screenplay re-enter the loop or only scene_007?\n   - Current spec says \"affected_scenes\" but doesn't clarify if partial acceptance is allowed\n2. **Checkpoint Schema:** What exact JSON fields go into `checkpoint_b1_step1_screenplay.json`?\n   - Doc specifies an example but unclear if this is mandatory structure or just recommended\n3. **Cost/Token Management:** Are there per-step budget constraints? What if scene_director exceeds token limits?\n4. **Cascading Failures:** If scene_director fails → corrected → passes validation → tts_polish fails → corrected, does this count as 1 failure or 2?\n\n#### Priority\n**P1 (Blocker)** — Cannot deploy without explicit PROMPT.md for BM-B1 that clarifies orchestration logic.\n\n---\n\n### 2. scene_director Agent\n\n**Model:** GPT-5.4 mini (OAuth)  \n**Role:** Transform raw script → structured screenplay with cenes, narrtion, visual direction, mood, duration estimate.\n\n#### Strengths (Exceptional)\n- **Masterclass-quality PROMPT.md:** Clear identity, creative philosophy (Amplify, not Illustrate), explicit spectrum of interpretation (Literal → Evocative → Metaphorical → Prenúncio)\n- **Exhaustive RULES.md:** 9 numbered rules covering word count, narration tolerance (ZERO), scene division logic, visual direction quality, sentence boundaries, duration calculation, scene ID format, iterative correction, validation checklist\n- **EXAMPLES.md is Gold:** 6 complete examples with detailed analysis:\n  - Example 1: WWII screenplay (4 scenes, mood distribution, word counts shown)\n  - Example 2: Renaissance Borgia (4 scenes, tone progression, era-specific visual details)\n  - Example 3: How to divide oversized scenes (correct vs incorrect technique)\n  - Example 4: How to merge undersized scenes (rich visual_direction creation)\n  - Example 5: Good vs bad visual_direction (checklist provided)\n  - Example 6: Perspective separation (why & how)\n- **Anti-patterns section:** Explicitly lists 6 things NEVER to do (invent text, omit frases, paraphrase, duplicate, generic visuals, unfulfilled reasoning)\n- **TOOLS.md is comprehensive:** Specifies `input/script.json` schema, output schema, validation feedback format, error types, correction rules\n- **Visual direction guidance is production-ready:** Tells writers to think like cinematographers, includes shot suggestions, atmospheric details, era specificity, 20+ word targets\n\n#### Weaknesses\n- No MEMORY.md for scene_director\n  - **Gap:** Agent won't persist learnings about common mistakes (e.g., \"always check first/last frases of adjacent cenes for duplication\")\n  - **Risk:** Same errors repeat across multiple runs\n- RULES.md #9 (Checklist Final) references 8-point verification but doesn't automate\n  - **Expectation vs Reality:** Checklist assumes scene_director will self-verify, but LLM compliance is inconsistent\n  - **Recommended:** BM-B1 should programmatically verify these 8 points BEFORE passing to validation\n- Visual direction philosophy is excellent but subjective\n  - **Risk:** \"Amplify, not illustrate\" and mood assignment are creative choices — no objective rubric for \"good\" visual_direction\n  - **Mitigation:** Examples show quality bar, but downstream teams (B3, B5) may reject visuals as too vague or too prescriptive\n- No fallback strategy if visual_direction conflicts with narration\n  - **Example:** Narration says \"soldiers advance\" but visual_direction suggests \"metaphorical emptiness\" — which takes precedence?\n  - **Current answer:** None provided. Spec says visual is \"flexible guide\" but director autonomy is unlimited.\n- Duration estimate formula (words/WPM × 60) doesn't account for pauses, emphasis, or TTS engine quirks\n  - **Risk:** `duration_estimate` will often be wrong, requiring B2 correction anyway\n  - **Acceptable but worth noting:** B2 provides `duration_actual`, so estimate can be wrong\n\n#### Questions\n1. **Conflict Resolution:** What if visual_direction creates a visual moment that contradicts or overshadows the narration?\n   - Should scene_director ensure visual supports narration thematically?\n2. **Word Count Edge Cases:** Can scene_director split a 150-word cena into 3 scenes of 50 words each?\n   - Spec says \"new scene when\" but doesn't forbid splitting beyond those triggers if word count demands it\n3. **Perspective Shifts:** Can a single narration sentence be both \"neutral\" and \"American perspective\"?\n   - Examples show clear faction separation but real scripts may be ambiguous\n\n#### Priority\n**P1 (High Quality, Minor Gaps)** — Prompts/rules/examples are excellent. Missing MEMORY.md + need BM orchestration clarity. Otherwise deployment-ready.\n\n---\n\n### 3. tts_polish Agent\n\n**Model:** Qwen 3.5 9B (Ollama local, $0)  \n**Role:** Polish narration for Gemini TTS naturalness (abbreviations, grammar, siglas).\n\n#### Strengths\n- **Massive Rule Coverage:** 13 comprehensive rules covering:\n  - #0: Orthographic correction (priority maximum)\n  - #1: Numbers stay as digits (NEVER expand — critical for Gemini TTS compatibility)\n  - #2: Never remove words (entire phrase must be preserved)\n  - #3: Never add content (strict no-invention rule)\n  - #4: Never join frases (punctuation protection)\n  - #5: Ordinals & Roman numerals (per-language rules)\n  - #6: Military designations (weapons, vehicles, call signs)\n  - #7: Siglas & acrónimos (universal vs per-language)\n  - #8: Dates (numbers stay as-is, months expand)\n  - #9: Typography (guillemets, quotes, punctuation)\n  - #10: Name protection (battles, operations, people)\n  - #11: Naturalness (no excessively formal constructions)\n  - #12: Correction feedback (when re-running on failed cenas)\n  - #13: Auditability (track every change)\n- **Practical Examples in PROMPT.md:** Shows expansions for titles (Dr → Doctor), abbreviations (sec → century), units (5 km → 5 kilometers), siglas (NATO stays NATO)\n- **Per-Language Implementation Awareness:** Rules specify different ordinal handling for EN/PT/FR/ES\n  - EN: \"Henry VIII\" → \"Henry the Eighth\"\n  - PT: \"Dom Pedro II\" → \"Dom Pedro segundo\"\n  - FR: \"Louis XIV\" → \"Louis Quatorze\" (cardinal, not ordinal!)\n  - ES: \"Carlos V\" → \"Carlos quinto\"\n- **Output Schema Clear:** Per-scene JSON with `scene_id`, `original`, `polished`, `changes[]`\n- **Auditability Built-In:** Every change logged in `changes[]` format: \"Dr. → Doctor\"\n- **Config YAML Integration:** Acknowledges that `tts_polish_rules` from config have priority over defaults\n\n#### Weaknesses\n- No EXAMPLES.md\n  - **Gap:** No concrete examples of before/after for different languages\n  - **Risk:** Implementations may misinterpret rules (e.g., what counts as \"universal\" sigla?)\n  - **Recommended:** Add 2-3 examples per language showing same script polished differently\n- RULES.md #1 (Numbers) is correct for Gemini TTS but outdated for some contexts\n  - **Note:** Future versions of TTS may benefit from \"twenty thousand\" vs \"20000\" — spec should add future migration path\n- No mention of TTS engine quirks specific to Gemini\n  - **Example:** Gemini TTS may pronounce \"St.\" differently than expected; no fallback guidance\n  - **Not critical:** tts_polish can't fix TTS engine problems, only prepare text optimally\n- PROMPT.md mentions `tts_polish_rules` from config but RULES.md doesn't show example rules\n  - **Gap:** What should a typical rule look like? JSON? String? List?\n  - **Assumed:** Single string rules like \"Expandir abreviacoes (sec. → siecle, approx. → approximately)\" based on 06_MODEL_STRATEGY context\n- No MEMORY.md\n  - **Gap:** Agent won't learn about repeated patterns (e.g., \"always expand 'sr.' in PT, not always followed\")\n- Handling of Quotation Marks (#9) is minimal\n  - **Gap:** French guillemets are mentioned but what about PT/ES/EN quotes?\n  - **Assumed:** Convert all to straight quotes, but not explicit\n\n#### Questions\n1. **Config Priority:** When YAML `tts_polish_rules` conflicts with RULES.md #1-13, which wins?\n   - Spec says YAML has priority but doesn't clarify if it can override fundamental rules (e.g., \"expand all numbers\")\n2. **Acronym Context:** Is \"ST\" in \"ST-44\" a sigla (stay) or abbreviation (expand)?\n   - Current rule: \"designações de armas\" don't expand, but mixed letter-number codes unclear\n3. **Regional Spelling:** PT-BR vs PT-PT (Brazilian vs European Portuguese) — which spelling standard?\n   - Spec doesn't mention regional variants\n4. **Error Recovery:** If a scene has grammar that's intentionally colloquial (not an error), should tts_polish \"fix\" it?\n   - RULES.md #0 says \"correct ALL ortho errors\" but doesn't define error vs style choice\n\n#### Priority\n**P1 (High Quality, Minor Gaps)** — Excellent rules coverage. Missing EXAMPLES.md & MEMORY.md. Otherwise ready. Recommend adding language-specific examples.\n\n---\n\n### 4. scene_bible_builder Agent\n\n**Model:** Qwen 3.5 9B (Ollama local, $0)  \n**Role:** Compile polished screenplay + metadata into `scene_bible.json` (living document).\n\n#### Strengths\n- **Clear Purpose:** Scene bible is the central consumption point for all downstream branches\n- **Complete Schema Definition:** RULES.md section 2 defines every field:\n  - Global fields: `video_id`, `title`, `description`, `account`, `language`, `total_scenes`, `characters`, `locations`, `era`, timestamps, `scenes[]`, `_meta`\n  - Per-scene fields: `scene_id`, `narration_polished`, `narration_original`, `visual_direction`, `mood`, `duration_estimate`, and 5 initially-empty fields for downstream branches\n- **Living Document Principle:** Explicitly documents which branches fill which fields:\n  - B1 fills: narration, visual, mood, duration_estimate, metadata\n  - B2 fills: audio_clip, duration_actual, word_timestamps\n  - B3 fills: characters, locations, era\n  - B4/B5 fill: assets\n  - B6 fills: composition\n- **Video ID Generation Rules:** Explicit algorithm (date_account_lang_slug), with slug generation rules (lowercase, spaces→hyphens, truncate, deduplicate)\n- **Validation Checklist:** Pre-save validation (4.1 global fields, 4.2 per-scene fields, 4.3 consistency checks) = ~20 checks\n- **Error Handling Defined:** Table of 8 failure scenarios with clear STOP & REPORT actions\n- **No Invention Rule:** \"Never invent data\" — excellent guard against hallucination\n\n#### Weaknesses\n- **Critical:** No EXAMPLES.md\n  - **Gap:** No concrete example of `scene_bible.json` output shown\n  - **Risk:** Implementation will guess at structure, potentially producing malformed JSON\n  - **Blocker:** Need at least 1 complete example with 3-5 scenes showing all fields\n- **Critical:** No PROMPT.md (only RULES.md)\n  - **Gap:** Agent doesn't know WHO it is, WHY it matters, creative direction\n  - **Risk:** Qwen 3.5 9B needs clear identity + motivation to work reliably\n  - **Recommended:** Add PROMPT.md with identity, creative philosophy (document as \"source of truth\"), constraints\n- **Ambiguity:** `characters`, `locations`, `era` start as empty\n  - **Question:** Should scene_bible_builder EXTRACT these from screenplay, or leave them truly empty for B3 to fill?\n  - **Current spec:** Ambiguous. RULES.md says \"Vazio inicial\" (empty initial) but PROMPT.md context suggests B3 extracts\n  - **Recommendation:** Clarify in PROMPT.md: does builder pre-extract or strictly empty?\n- **No TOOLS.md**\n  - **Gap:** No input/output schemas specified\n  - **Assumed:** Inputs are `screenplay.json`, `tts_polished.json`, `job.json`, `script.json`; output is `scene_bible.json`\n  - **Risk:** Implementation guesses, creates wrong structure\n- **No MEMORY.md**\n  - **Gap:** Agent won't persist learnings about common schema violations\n- **Conflict Between Fields:** `narration_original` vs `narration_polished`\n  - **Question:** Why keep both? Reduces duplication but adds maintenance burden.\n  - **Spec answer (implied):** Allows B2 to compare pre/post-polish for validation\n  - **Recommendation:** Document this rationale explicitly in PROMPT\n- **_meta.version Increment Logic:** Spec says \"increments on each modification\" but builder creates at v1\n  - **Question:** Who increments the version? Does each branch modify _meta?\n  - **Risk:** Spec says \"branches que contribuíram\" but no rules for how/when to update\n  - **Recommendation:** Add version management rules to a general branch guide (not specific to B1)\n\n#### Priority\n**P1 (Blocker)** — Missing PROMPT.md + EXAMPLES.md + TOOLS.md. Schema is complete (in RULES.md) but agent needs identity + output reference. Cannot implement without these.\n\n---\n\n### 5. screenshot_validator (Python Skill)\n\n**Status:** NOT IMPLEMENTED ❌\n\n**Specification:** (from 01_PRE_PRODUCTION.md)\n- Input: concatenated narrations from screenplay.json vs script.json original\n- Process: Tokenize both (word split), compare\n- Output: JSON with valid/invalid, missing_words[], extra_words[], duplicated_between_scenes[], coverage%, affected_scenes[]\n- Purpose: Detect if scene_director lost/invented/duplicated text\n\n#### Analysis\n- **Concept is sound:** Deterministic comparison (not LLM-based) is correct choice\n- **Critical blocker:** No code, no implementation path, no Python file location specified\n- **Missing Details:**\n  - How to handle punctuation? Ignore or count as part of word?\n  - Whitespace normalization? (Multiple spaces, newlines, tabs)\n  - Compound words? (\"scene-by-scene\" = 1 word or 2?)\n  - Accented characters? (é vs e in comparison)\n  - Case sensitivity? (\"THE\" vs \"the\")\n- **Output Schema:** Spec shows example JSON but doesn't list in TOOLS.md — recommend consolidating\n\n#### Risk Assessment\n**CRITICAL BLOCKER:** Without this skill, Step 2 validation cannot execute. BM-B1 currently instructed to \"skip step 2\", meaning screenplay_director output goes completely unchecked. This breaks the entire validation loop.\n\n#### Priority\n**P0 (Blocker)** — Implement immediately. ~100-150 lines of Python, straightforward logic.\n\n---\n\n### 6. polish_validator (Python Skill)\n\n**Status:** NOT IMPLEMENTED ❌\n\n**Specification:** (from 01_PRE_PRODUCTION.md)\n- Input: text_polished vs text_pre_polish\n- Process: Compare, detect words removed/added\n- Output: JSON with valid/invalid, issues[]\n- Ignores intentional changes (abbreviation expansion, etc.) — pattern-based whitelist\n\n#### Analysis\n- **Concept:** Detect whether tts_polish agent removed/added content inappropriately\n- **Challenge:** Distinguishing intentional vs unintentional changes\n  - Intentional: \"Dr.\" → \"Doctor\" (expansion, not removal)\n  - Unintentional: \"Doctor\" → \"Doc\" (reduction, removal)\n- **Current mitigation:** Spec mentions \"lista de padrões conhecidos\" (known patterns) but doesn't specify what patterns or how to manage the whitelist\n\n#### Questions\n1. **Pattern Whitelist:** How is this managed? Hardcoded list? Config file? Per-language?\n2. **Abbreviation Handling:** Are all expansions considered \"known patterns\" or only specific ones?\n3. **Punctuation & Spacing:** Should \"hello,  world\" vs \"hello, world\" (extra space) count as a change?\n4. **Tokenization:** Same questions as screenshot_validator (compound words, accents, case)\n\n#### Risk Assessment\n**CRITICAL BLOCKER:** Without this skill, Step 4 validation cannot execute. BM-B1 currently instructed to \"skip step 4\", meaning tts_polish output goes unchecked. Text could be shortened or corrupted without detection.\n\n#### Priority\n**P0 (Blocker)** — Implement immediately. ~150-200 lines of Python. Need to clarify whitelist pattern management.\n\n---\n\n## Python Skills Summary\n\n| Skill | Status | Complexity | Blocker | Priority |\n|-------|--------|-----------|---------|----------|\n| screenshot_validator | NOT IMPLEMENTED | Low (~150 LOC) | YES | P0 |\n| polish_validator | NOT IMPLEMENTED | Medium (~200 LOC) | YES | P0 |\n\n**Both required for B1 validation loop to function.** Current workaround (skip validations) is unsafe and defeats purpose of branch architecture.\n\n---\n\n## OpenClaw Tools & Models Needed\n\n### Models\n| Model | Where | Purpose | Status |\n|-------|-------|---------|--------|\n| GPT-5.4 mini | BM-B1, scene_director | Orchestration, creative screenplay | ✅ Available (OAuth) |\n| Qwen 3.5 9B | tts_polish, scene_bible_builder | Deterministic text work, JSON generation | ✅ Available (Ollama local) |\n\n### OpenClaw Tools Needed\n| Tool | Type | Purpose | Status |\n|------|------|---------|--------|\n| exec | Shell | Run Python skills (screenshot_validator, polish_validator) | ✅ Available |\n| read | File I/O | Read screenplay.json, tts_polished.json, script.json, job.json | ✅ Available |\n| write | File I/O | Write scene_bible.json, checkpoints | ✅ Available |\n| process | Async | If parallel execution of agents needed (B2/B3 parallel in VO) | ✅ Available |\n\n### Config Management\n| Item | Status | Notes |\n|------|--------|-------|\n| `accounts/{account}/scene_words_range` | ✅ Defined | YAML per channel |\n| `accounts/{account}/tts_polish_rules` | ✅ Defined | YAML list of rules |\n| Language config loading | ⚠️ Assumed | No TOOLS.md specifying WHERE/HOW to load YAMLs |\n\n---\n\n## Ambiguities & Clarifications Needed\n\n### 1. **Validation Failure Scenarios**\n- If screenplay_validator fails on scene_007 but passes on scenes_001-006 & 008-014, does BM-B1:\n  - Option A: Re-run ONLY scene_007 through scene_director?\n  - Option B: Re-run the ENTIRE screenplay?\n  - **Current spec:** Implies Option A (\"affected_scenes\") but doesn't explicitly confirm\n  - **Recommendation:** Clarify in BM-B1 PROMPT.md\n\n### 2. **Partial Acceptance**\n- Can a screenplay be accepted with SOME validation warnings but not others?\n- **Current spec:** \"valid: true\" or \"valid: false\" — binary, no grey area\n- **Question:** What's the bar for \"valid\"? 100% word count? 95% word match? Any duplicates = invalid?\n- **Recommendation:** Define thresholds in RULES.md (e.g., \"valid if coverage > 98% AND no duplicates\")\n\n### 3. **Scene_Bible Initial Population**\n- Should `characters`, `locations`, `era` arrays/fields be:\n  - Option A: Extracted by scene_bible_builder from screenplay (e.g., \"mentions Napoleon\" → character extracted)?\n  - Option B: Left as `[]` / `null` for B3 to fill?\n  - **Current spec:** Says \"Vazio inicial\" (empty) but PROMPT context suggests B3 does extraction\n  - **Recommendation:** Clarify in PROMPT.md — does builder pre-extract or strictly empty?\n\n### 4. **Error Recovery in scene_director**\n- When scene_director receives \"scene_007 has missing text [words]\", should it:\n  - Option A: Locate the missing words in screenplay and reinsert into scene_007?\n  - Option B: Rewrite scene_007 with different division to capture missing words?\n  - **Current spec:** TOOLS.md says \"localizar onde deviam estar\" (locate where they should be) but vague\n  - **Recommendation:** Add explicit algorithm to TOOLS.md\n\n### 5. **Visual Direction Ownership**\n- If visual_direction conflicts with narration (e.g., \"soldiers advance\" but visual suggests \"empty battlefield\"), who resolves?\n  - **Current spec:** Says visual is \"flexible guide\" but doesn't define limits of flexibility\n  - **Recommendation:** Add constraints to RULES.md (e.g., \"visual_direction must reinforce, not contradict, narration\")\n\n### 6. **Config YAML Structure**\n- Where exactly do `scene_words_range` and `tts_polish_rules` live?\n  - **Spec location:** `accounts/{account}/{language}.yaml` (from 10_PRODUCTION_MANAGER.md)\n  - **Question:** How are they passed to agents? In job.json? As separate config load?\n  - **Current spec:** Agents assume they'll receive it but no mechanism specified\n  - **Recommendation:** Add to BM-B1 PROMPT.md how config is loaded and passed\n\n### 7. **Checkpoint Schema Consistency**\n- Is the checkpoint JSON schema fixed or flexible?\n  - **Current spec:** Shows example (step, status, completed_at, agent, model, output_files, retries, validation_passed) but marked as \"formato de cada checkpoint\"\n  - **Question:** Are these fields mandatory or just recommended?\n  - **Recommendation:** Provide strict JSON schema (or JSONSchema definition)\n\n### 8. **Concurrency & Cost Limits**\n- Are there token/cost budgets per step? Per agent? Per video?\n  - **Current spec:** No mention\n  - **Question:** If scene_director uses 50K tokens (expensive), should it fail or retry?\n  - **Recommendation:** Add cost constraints to BM-B1 RULES.md (e.g., \"max 100K tokens per branch\")\n\n---\n\n## Weaknesses & Gaps\n\n### Critical (Blockers)\n1. **Python skills not implemented** (screenshot_validator, polish_validator)\n   - **Impact:** B1 validation loop is non-functional\n   - **Mitigation:** Must implement before first production run\n   - **Estimated effort:** 4-6 hours total\n\n2. **BM-B1 has no PROMPT.md**\n   - **Impact:** Orchestration logic unclear; implementation will require reverse-engineering\n   - **Mitigation:** Create PROMPT.md (500-800 words) with orchestration flowchart\n   - **Estimated effort:** 2-3 hours\n\n3. **scene_bible_builder missing PROMPT.md, EXAMPLES.md, TOOLS.md**\n   - **Impact:** Agent has no identity; implementation will guess at output schema\n   - **Mitigation:** Create PROMPT.md (300-500 words), EXAMPLES.md (1 complete example), TOOLS.md (input/output specs)\n   - **Estimated effort:** 4-5 hours\n\n4. **tts_polish missing EXAMPLES.md**\n   - **Impact:** Implementations across languages will differ; quality inconsistent\n   - **Mitigation:** Add EXAMPLES.md with 2-3 per-language examples (before/after)\n   - **Estimated effort:** 2-3 hours\n\n### High-Impact (P1)\n5. **Validation failure handling ambiguous**\n   - If screenshot_validator fails on some scenes, does entire screenplay re-run or only affected scenes?\n   - **Mitigation:** Clarify in BM-B1 PROMPT.md & spec document\n   - **Estimated effort:** 1-2 hours\n\n6. **Config loading mechanism not specified**\n   - Agents know they need `scene_words_range` and `tts_polish_rules` but spec doesn't say how they receive them\n   - **Mitigation:** Add to BM-B1 TOOLS.md: \"config loaded from accounts/{account}/{lang}.yaml, parsed, passed to agents in job JSON\"\n   - **Estimated effort:** 1 hour\n\n7. **No MEMORY.md for any agent**\n   - Agents won't persist learnings across runs\n   - **Mitigation:** Create MEMORY.md templates for BM-B1, scene_director, tts_polish, scene_bible_builder\n   - **Estimated effort:** 2-3 hours\n\n### Medium-Impact (P2)\n8. **Visual direction quality subjective**\n   - \"Amplify, not illustrate\" is excellent guidance but not objectively measurable\n   - **Mitigation:** OK as-is; examples set quality bar. B3/B5 can provide feedback.\n   - **Estimated effort:** 0 (accept as creative skill)\n\n9. **Duration estimate formula imprecise**\n   - Won't match TTS duration; always requires B2 correction\n   - **Mitigation:** Document in RULES.md that estimate is rough; B2 provides actual\n   - **Estimated effort:** 0.5 hours (documentation only)\n\n10. **Checkpoint schema not rigidly defined**\n    - Example provided but unclear if strict\n    - **Mitigation:** Clarify in 12_VIDEO_DIRECTORY_STRUCTURE.md that checkpoint schema is fixed\n    - **Estimated effort:** 1 hour\n\n---\n\n## Dependencies & Prerequisites\n\n### External Dependencies\n- **Video Orchestrator (VO):** Must provide job.json with account, language, script.json path, checkpoint state\n- **Google Sheets API (VO responsibility):** Fetch script; BM-B1 assumes script is available locally\n- **Ollama local:** Must have Qwen 3.5 9B running for tts_polish & scene_bible_builder\n- **GPT-5.4 mini OAuth:** Must be configured; ChatGPT Pro login available for BM-B1, scene_director\n\n### Internal Dependencies\n- **screenshot_validator skill:** BLOCKS Step 2 (screenplay validation)\n- **polish_validator skill:** BLOCKS Step 4 (polish validation)\n- **B1 completion:** Required by B2, B3, B4, B5, B6 (all downstream branches depend on scene_bible.json)\n\n### Ordering\n1. Implement screenshot_validator & polish_validator (Python skills)\n2. Create BM-B1 PROMPT.md (orchestration logic)\n3. Create scene_bible_builder PROMPT.md, EXAMPLES.md, TOOLS.md\n4. Add tts_polish EXAMPLES.md\n5. Create MEMORY.md for all agents\n6. Deploy BM-B1 on M1\n7. Test end-to-end (script → scene_bible)\n8. Integrate with VO\n\n---\n\n## Specific Observations\n\n### Strengths (Unexpected Quality)\n- **scene_director EXAMPLES.md is exceptional:** 6 detailed examples with analysis. This is production-ready quality.\n- **Visual direction philosophy is sophisticated:** \"Amplify, not illustrate\" + spectrum (Literal/Evocative/Metaphorical/Prenúncio) shows deep understanding of cinema.\n- **Per-language rule handling:** tts_polish rules account for EN/PT/FR/ES ordinals, abbreviations, sigla treatment. Not generic.\n- **Anti-patterns documentation:** scene_director explicitly lists 6 things NEVER to do. This reduces hallucination risk.\n- **Validation-first architecture:** Screenshot_validator & polish_validator are brilliant — deterministric validation instead of LLM-based retry loops.\n\n### Risks (Worth Calling Out)\n- **Validation gap:** With validators not implemented, current operatin is UNSAFE. Scene_director output goes unchecked → B2 receives corrupted screenplay → entire pipeline fails downstream. This is a priority-1 fix.\n- **Model choice for tts_polish:** Qwen 3.5 9B is good for deterministic work but hasn't been tested on multilingual rule application. PT/FR/ES ordinal handling may have edge cases. Recommend stress-testing before production.\n- **Cost-benefit of scene_bible structure:** Keeping both `narration_original` and `narration_polished` adds 2x text data. Worth it for auditability, but increases storage. OK trade-off, just intentional.\n- **Visual interpretation subjectivity:** \"Amplify\" is vague. Some directors will create moody, abstract visuals; others will be literal. B3/B5 feedback will be essential for consistency. This is acceptable but needs clear feedback loop.\n\n### Design Elegance\n- **Screenplay = audio law, visual guide:** This principle elegantly separates concerns. Audio is deterministic; visual is creative. Very sound.\n- **Per-step checkpoints:** Granular recovery (delete checkpoint N, resume at N) is much better than retry-entire-branch. Shows thoughtful design.\n- **Escalation to Lucca/Tobias/Claude Code:** When validation fails 3x, escalate for human investigation rather than looping infinitely. Respects human oversight.\n\n---\n\n## Priority Recommendations\n\n### P0 (Deploy-Blocking)\n1. **Implement screenshot_validator Python skill** — 150 LOC, 4 hours\n2. **Implement polish_validator Python skill** — 200 LOC, 4 hours\n3. **Create BM-B1 PROMPT.md** — Orchestration flowchart, 2-3 hours\n4. **Create scene_bible_builder PROMPT.md** — Agent identity, 2 hours\n5. **Create scene_bible_builder TOOLS.md** — Input/output schemas, 1 hour\n6. **Create scene_bible_builder EXAMPLES.md** — 1 complete example (3-5 scenes), 2 hours\n\n**Total P0 effort:** ~18-20 hours. Estimated deployment date: 48-60 hours from now (if parallel work).\n\n### P1 (Important, Pre-Production Run)\n7. **Clarify validation failure handling** — BM-B1 PROMPT.md or separate spec doc, 1-2 hours\n8. **Add tts_polish EXAMPLES.md** — 2-3 language-specific examples, 2-3 hours\n9. **Create MEMORY.md for all agents** — Templates, 2-3 hours\n10. **Document config loading mechanism** — BM-B1 TOOLS.md, 1 hour\n11. **Stress-test tts_polish with multilingual edge cases** — PT/FR/ES ordinals, names, dates, 4-6 hours\n\n**Total P1 effort:** ~11-15 hours. Estimated timeline: Complete before first production run.\n\n### P2 (Nice-to-Have, Post-MVP)\n12. **Implement dynamic cost budgets** — Per-agent token limits, optional, 3-4 hours\n13. **Add automated quality metrics** — Scene word count distribution, mood variety checks, 2-3 hours\n14. **Implement partial acceptance logic** — Allow \"valid with warnings\", optional, 2-3 hours\n\n**Total P2 effort:** ~7-10 hours. Optional for initial MVP.\n\n---\n\n## Files & Skills Summary (Counts)\n\n### Documentation Files Analyzed\n**Total:** 18 files  \n**Breakdown:**\n- B1-specific (workspace_mirror): 10 files\n- General docs (referenced): 8 files\n\n### Components Reviewed\n**Total:** 4 components  \n- BM-B1 (Branch Manager): 1\n- scene_director (Agent): 1\n- tts_polish (Agent): 1\n- scene_bible_builder (Agent): 1\n\n### Python Skills Identified\n**Total:** 2 skills  \n**Status:**\n- screenshot_validator: NOT IMPLEMENTED\n- polish_validator: NOT IMPLEMENTED\n\n### Models Used\n**Total:** 2 models  \n- GPT-5.4 mini (OAuth): BM-B1, scene_director\n- Qwen 3.5 9B (Ollama): tts_polish, scene_bible_builder\n\n### OpenClaw Tools Needed\n**Total:** 4 tool types  \n- exec: Run Python skills\n- read: File I/O (read inputs)\n- write: File I/O (write scene_bible.json, checkpoints)\n- process: Async (if parallel execution needed in VO)\n\n---\n\n## Conclusion\n\n**B1 is WELL-ARCHITECTED but INCOMPLETE.** Core design is sound — clear roles, excellent guidance (especially scene_director examples), smart validation approach. The branch will work once:\n\n1. Python skills are implemented (2-3 days effort)\n2. Missing agent files are created (PROMPT, EXAMPLES, TOOLS for BM-B1 & scene_bible_builder)\n3. Ambiguities are clarified (validation failure handling, config loading)\n\n**Estimated Total Implementation Time:** 25-35 hours of engineering.  \n**Estimated Deployment Readiness:** 3-5 days (parallel work possible).  \n**Risk Level:** Low (clear spec, no architectural surprises), but BLOCKING on skill implementation.\n\n**Recommendation:** Prioritize P0 items. Validators are critical for safety; PROMPT/TOOLS files are critical for implementation clarity. Everything else is follow-up.\n\n---\n\n## Review Metadata\n\n- **Reviewer:** Tobias (Subagent)\n- **Review Depth:** Comprehensive (all workspace files + reference docs)\n- **Confidence Level:** High (spec is detailed and clear; ambiguities are documented, not guesses)\n- **Date:** 26 Mar 2026\n- **Time Spent:** ~4-5 hours of analysis + 2-3 hours of writing\n- **Next Action:** Submit to Lucca via Tobias for prioritization of P0 items\n"}],"isError":false,"timestamp":1774793537250}}
{"type":"message","id":"9d0bc1c3","parentId":"f379ed2a","timestamp":"2026-03-29T14:12:17.311Z","message":{"role":"toolResult","toolCallId":"call_o6J1fNlENQPnz4ZEa3CZ7xv4|fc_04d04e5a142d912b0169c9334210e4819195cada796dbfbea2","toolName":"read","content":[{"type":"text","text":"# B2: Audio Branch — Brutally Honest Review\n**Date:** 26 Mar 2026  \n**Reviewer:** Tobias (CEO, subagent)  \n**Review Type:** Architecture & Implementation Readiness  \n**Status:** Component complete (design phase) | Implementation pending\n\n---\n\n## Executive Summary\n\n**B2 Audio is architecturally sound but NOT YET IMPLEMENTED.**\n\nThe specification is detailed, internally consistent, and well-thought-out. The decision to use intelligent validation (Python ratio threshold + Qwen 3.5 9B semantic check) instead of blind regeneration is correct and will save significant TTS costs in production.\n\n**Critical gaps:** All 5 Python skills are unimplemented stub designs. The spec assumes they will reuse V3 code, but that code has not been extracted, tested, or ported. BM-B2 itself (the coordinator) is also not implemented.\n\n**Strengths:** Clear principles (1 cena = 1 clip), granular checkpoints, proper escalation logic, audio_validator is well-designed.\n\n**Weaknesses:** Vague on skill implementation details, missing error handling specs, no testing strategy defined, timestamp alignment logic not yet validated against real V3 code.\n\n---\n\n## Scope: Files Read\n\n| Category | Count | Files |\n|----------|-------|-------|\n| **Core Docs (general)** | 7 | 00_CONTEXT.md, 03_PIPELINE_MAP.md, 04_BRANCH_ARCHITECTURE.md, 06_MODEL_STRATEGY.md, 09_HIERARCHY_AND_STRUCTURE.md, 10_PRODUCTION_MANAGER.md, 11_VIDEO_ORCHESTRATOR.md, 12_VIDEO_DIRECTORY_STRUCTURE.md |\n| **B2 Spec** | 1 | 02_AUDIO.md |\n| **B2 Workspace (BM-B2)** | 6 | AGENTS.md, IDENTITY.md, CONTEXT.md, RULES.md, TOOLS.md, MEMORY.md |\n| **B2 Sub-agent (audio_validator)** | 5 | PROMPT.md, RULES.md, TOOLS.md, MEMORY.md, AGENTS.md |\n| **Total** | **19** | |\n\n---\n\n## Branch Purpose\n\n**B2 (Audio) is the second production stage of the Auto Content Factory pipeline.**\n\nIt receives a `scene_bible.json` from B1 (Pre-Production) with polished narrations per scene. B2's job is to:\n\n1. **Generate audio clips** (TTS) via Gemini TTS, one clip per cena\n2. **Validate quality** via WhisperX transcription + intelligent semantic check\n3. **Extract word-level timestamps** for visual synchronization\n4. **Update scene_bible** with actual durations, clip paths, and timing data\n\nB2 is the **audio pipeline entry point** — it converts written narration into validated audio assets that downstream branches (B6 Scene Composition, B8 Assembly) depend on.\n\n---\n\n## Per-Component Review\n\n### 1. BM-B2 (Branch Manager)\n\n**Status:** Design only | Model: GPT-5.4 mini (OAuth) | NOT IMPLEMENTED\n\n#### Architecture\n- Acts as coordinator, NOT executor\n- Dispatches to 1 sub-agente (audio_validator) + 4 Python skills\n- Manages sequencing: tts_generator → audio_transcriber → validation logic → timestamp_aligner → bible_updater\n- Handles per-scene retries (max 3 per scene before escalation)\n- Generates checkpoints per scene AND per step\n- Updates scene_bible at the end\n\n#### Assessment\n\n**Strengths:**\n- Sequence is logical and defensible (TTS → validate → timestamps → bible update)\n- Per-scene checkpoint strategy allows granular recovery (\"if crash on scene 8, resume from scene 8\")\n- Retry logic is specific: max 3 per scene, escalate to Lucca+Tobias+Claude Code (not just VO)\n- Clear distinction between auto-approval (ratio >= threshold) and Qwen consultation\n- Reporting format is direct and actionable\n\n**Weaknesses:**\n- No implementation spec for HOW to call skills (OpenClaw tool definitions missing)\n- RULES.md says \"Run tts_generator skill\" but doesn't specify: CLI syntax, timeout handling, error recovery\n- Missing error handling for skill failures: what if WhisperX crashes? What if Gemini TTS rate-limits?\n- No plan for parallel processing of scenes (spec says \"sequentially or in parallel\" but rules are silent on this)\n- \"Max 3 retries per scene\" — but what if all 15 scenes fail on retry 1? Should BM keep going or stop earlier?\n- Recovery logic assumes checkpoints exist; no spec for checkpoint structure validation or corruption recovery\n\n#### Implementation Gaps\n1. **Tool definitions** — OpenClaw needs explicit tool registrations for each skill call\n2. **Error handling spec** — what are the possible failures and recovery strategies?\n3. **Parallelism spec** — if scenes can run in parallel, what's the concurrency limit?\n4. **Timeout handling** — TTS can take 5-30s per scene depending on length; WhisperX can take 10-60s. Timeouts defined?\n5. **Rate limiting** — Gemini TTS has concurrency caps (TTS_CONCURRENCY_CAP mentioned in spec but not detailed in RULES.md)\n\n#### Quality Score\n**7/10** — Good bones, missing operational details.\n\n---\n\n### 2. audio_validator (Sub-agente LLM)\n\n**Status:** Fully specified | Model: Qwen 3.5 9B (Ollama local, $0) | NOT IMPLEMENTED (in OpenClaw)\n\n#### Architecture\n- Called ONLY when ratio < threshold\n- Receives: original narration, WhisperX transcription, ratio, missing/extra word lists\n- Returns: `approve` or `reject` with reasoning and list of missing content words\n- Goal: avoid unnecessary regenerations (cost saving)\n\n#### Assessment\n\n**Strengths:**\n- Clear decision logic: ignore formatting differences, focus on content words\n- Grounded in real production data (5,746 scenes analyzed, 99.1% pass rate first try, only 0.9% regenerated)\n- Excellent RULES.md with thresholds per language and real examples from production\n- Checklist approach (length comparison first, then word-level analysis) is practical\n- Recognizes real problems (TTS truncation, frases inteiras faltando) vs false alarms (formatação)\n- PROMPT.md is concise and clear\n\n**Weaknesses:**\n- **Assumption: WhisperX output is reliable** — but the text analysis depends on WhisperX being correct. If WhisperX itself is buggy for a language, audio_validator inherits the bug.\n- **No handling of accents/diacritics** — \"Thümmler\" vs \"Thummler\" is marked as OK, but what about Portuguese \"São\" vs \"Sao\"? Rules say \"ignore grafia diferente\" but don't define scope.\n- **\"Content words\" definition is fuzzy** — RULES say to focus on \"substantivos, verbos, adjectivos, nomes próprios\" but don't define how to distinguish programmatically. audio_validator is LLM-based so it can infer, but spec doesn't clarify if it tags words or just reasons about them.\n- **No learning mechanism** — MEMORY.md is empty. After processing thousands of scenes, audio_validator should be able to say \"in PT, these formats are always safe to ignore\" or \"in RU, truncation always happens at this character count\".\n- **No cost tracking** — how many Qwen tokens does a typical validation use? If rejecting a scene costs 0.1 Qwen + 1 Gemini TTS regeneration, when is it cheaper to just regenerate?\n\n#### Real-World Concerns\n1. **False positives (ratio low, content OK)** — RULES give examples of these. Qwen correctly identifies them. **But:** If Qwen is wrong and approves a truncated clip, it goes downstream and breaks sync in B6. How often does this happen? No test data.\n2. **Language-specific edge cases** — PT has thresholds at 0.75 (vs 0.60 EN) because of formatting differences. RU is 0.82. Qwen's evaluation rules don't mention language-specific patterns. Does it work equally well in all 12 languages?\n3. **Cascade effects** — If audio_validator incorrectly approves a clip with 2-3 seconds of missing audio, scene_bible gets wrong `duration_actual` and `word_timestamps`. B6 tries to sync video to audio that's too short. Downstream QA catches it, but it's wasted processing.\n\n#### Implementation Gaps\n1. **Integration test** — run audio_validator on the 51 real-world rejection cases from V3. Do they all reject correctly?\n2. **False positive rate** — test on 100 \"ratio low but content OK\" cases from V3. What's the approval accuracy?\n3. **Language coverage** — test on all 12 languages mentioned in spec, not just EN/PT.\n\n#### Quality Score\n**8/10** — Excellent design, good examples, but unproven on real data and zero learning capability.\n\n---\n\n### 3. tts_generator (Python Skill)\n\n**Status:** Stub/unimplemented | Called by: BM-B2 | Technology: Gemini TTS API (via KMS)\n\n#### Specification\n- **Input:** Polished narration (string), scene_id, language, voice_combo (from config)\n- **Output:** `b2_audio/clips/clip_NNN.mp3` + raw WAV + checkpoint JSON\n- **Technology:** Gemini TTS API accessed through KMS (Key Management System manages rotation, cooldowns, tier escalation)\n- **Base code:** Reuse V3 `bloco1/tts_phase2.py`\n- **Future note:** Add language prompt to Gemini TTS call to avoid 2% bug where PT speaks Spanish\n\n#### Assessment\n\n**Strengths:**\n- V3 code exists and works (proven at scale: 9 accounts, thousands of videos)\n- KMS abstraction is good (single skill doesn't manage keys directly)\n- One clip per scene (clear, testable, recoverable)\n- Spec mentions language prompt improvement (PT→ES bug), showing awareness of real issues\n\n**Weaknesses:**\n- **No implementation spec.** \"Reuse V3 code\" is vague. Which file? Which functions? V3 `tts_phase2.py` has ~1500 lines doing TTS, NISQA validation, silence trimming. What gets copied vs rewritten?\n- **KMS integration missing.** How does tts_generator call KMS? Does it pass an API key directly, or does it call a KMS skill? TOOLS.md says \"via KMS\" but doesn't show the call.\n- **Voice combo logic undefined.** Spec says \"voice combo vem da config por conta/idioma\" but doesn't show:\n  - How is config loaded?\n  - Which file format? (YAML, JSON, Python dict?)\n  - Fallback if voice not available?\n  - How does Gemini TTS API distinguish between voices? (name, ID, model?)\n- **Silence trimming:** V3 does this automatically. Spec doesn't mention it. Should B2 do it or is it implicit?\n- **Error recovery:** What if Gemini TTS API fails mid-generation? Partial file left behind? Timeout?\n- **Language prompt:** Spec says \"futuro: adicionar prompt de idioma\" — so it's NOT in current version. But then the 2% PT→ES bug remains unfixed. Should this be P0 before first production run?\n\n#### Real-World Dependencies\n- **V3 code quality:** If V3 tts_phase2 has subtle bugs (rare but possible), they get copied to B2. No opportunity to improve.\n- **Gemini TTS model changes:** Spec was written when Gemini TTS existed. If Google changes the API or model, this skill breaks.\n- **KMS availability:** If KMS is down or out of keys, tts_generator fails and blocks entire branch.\n\n#### Implementation Gaps\n1. **Porting spec** — document exactly which functions/code from V3 to copy, what to change\n2. **KMS integration spec** — define the skill-to-KMS interface (API call, parameters, error handling)\n3. **Voice config spec** — define format, loading, fallback logic\n4. **Error matrix** — list all possible failures (API timeout, rate limit, invalid voice, malformed text) and recovery\n5. **Testing** — unit tests with mock Gemini API, integration tests with real KMS\n\n#### Quality Score\n**5/10** — Clear intent, but vague on implementation. High risk of copy-paste bugs from V3.\n\n---\n\n### 4. audio_transcriber (Python Skill)\n\n**Status:** Stub/unimplemented | Called by: BM-B2 | Technology: WhisperX local GPU\n\n#### Specification\n- **Input:** `b2_audio/clips/clip_NNN.mp3`\n- **Output:** `transcriptions/transcription_NNN.json` containing:\n  - Transcribed text\n  - Ratio match vs original narration\n  - missing_words / extra_words lists\n  - duration_actual\n  - word_timestamps (raw from WhisperX)\n  - Whether ratio passed threshold\n- **Technology:** WhisperX running locally on GPU (already installed on M1)\n- **Base code:** Reuse V3 WhisperX logic\n\n#### Assessment\n\n**Strengths:**\n- WhisperX is proven (5,746 scenes already transcribed)\n- Specification is clear on output format\n- Doing transcription + ratio calculation in ONE skill execution (not separate steps) is efficient\n\n**Weaknesses:**\n- **Comparison logic missing.** Spec says \"compara ratio vs threshold\" but doesn't show HOW ratio is calculated. V3 probably uses SequenceMatcher (fuzzywuzzy or difflib). Which one? How sensitive to word order?\n- **Missing/extra word detection.** How are these lists generated? Simple set difference (words in A but not B) or more sophisticated alignment? If original has \"twenty-two\" but WhisperX says \"22\", is \"twenty-two\" in missing_words? (Probably yes, which is why audio_validator exists.)\n- **Word timestamp extraction.** Spec says WhisperX output includes word timestamps. But WhisperX has several output formats (.srt, .vtt, .json, .tsv). Which format does this skill parse?\n- **Duration calculation.** How is duration_actual computed? From last word end timestamp? From WAV file metadata? From clip length?\n- **Error recovery.** What if WhisperX fails (OOM, timeout, corrupt MP3)? Retry logic?\n- **GPU contention.** Spec says \"GPU local sequential\" (WhisperX can't parallelize on one GPU). But if BM-B2 processes scenes in parallel, won't they queue? How long are queue times?\n\n#### Implementation Gaps\n1. **Comparison logic spec** — exact algorithm for ratio calculation\n2. **WhisperX output format spec** — which format parsed, how word timestamps extracted\n3. **Duration calculation spec** — source of truth\n4. **Error handling** — failure modes and recovery\n5. **Performance profile** — expected runtime per scene length\n\n#### Quality Score\n**6/10** — Core concept is sound, but details matter. High risk of ratio calculation bugs.\n\n---\n\n### 5. timestamp_aligner (Python Skill)\n\n**Status:** Stub/unimplemented | Called by: BM-B2 | Technology: Python sequence alignment (SequenceMatcher)\n\n#### Specification\n- **Input:** Original narration (from scene_bible) + WhisperX timestamps (raw)\n- **Output:** `timestamps/timestamps_NNN.json` with ORIGINAL words + WhisperX timestamps aligned\n- **Purpose:** Handle cases where WhisperX transcribes words differently (e.g., \"6.000\" vs \"6000\", \"Indianapolis\" vs \"Indianápolis\")\n- **Base code:** Reuse `_align_words_to_timestamps()` from V3 `lettering_tsx_generator.py` (lines 2942-2995)\n\n#### Assessment\n\n**Strengths:**\n- Real problem: WhisperX transcription words ≠ original narration words\n- Solution is correct: align by position using SequenceMatcher, transfer timestamps to original words\n- V3 function exists and works (mentioned explicitly with line numbers)\n- Output format is clear\n\n**Weaknesses:**\n- **Alignment ambiguity.** SequenceMatcher finds longest matching subsequence, but if original has 50 words and WhisperX says 48, which words get dropped? Multiple possible alignments. Spec doesn't define tiebreaker. V3 code at lines 2942-2995 presumably defines it, but we haven't verified.\n- **Edge case: partial words.** If original has \"semi-final\" but WhisperX says \"semifinal\", does SequenceMatcher handle this? What if \"USS Indianapolis\" → \"USS Indianápolis\"? Do hyphens matter?\n- **Mismatch in word count.** If original has 100 words and WhisperX has 80, the alignment will drop 20 words. But which 20? If they're scattered (not contiguous), alignment gets fragile.\n- **No validation.** Spec doesn't say: \"if alignment is uncertain (low confidence), reject this clip.\" It just aligns. But bad alignment corrupts timestamps downstream.\n- **Language-specific rules absent.** PT has different hyphenation rules than EN. Accents matter. Spec is silent.\n\n#### Real-World Risk\nExample: Portuguese narration says \"São Paulo\" (with tilde). WhisperX transcribes \"Sao Paulo\" (without tilde). They're the same word phonetically, but different orthographically. SequenceMatcher sees them as different. Does the alignment still work? V3's `_align_words_to_timestamps()` should handle this, but we don't know for sure.\n\n#### Implementation Gaps\n1. **Validation of V3 code** — extract and test `_align_words_to_timestamps()` on 20 real B2 examples (some with alignment challenges)\n2. **Confidence metric** — add a score indicating how confident the alignment is (0.0-1.0)\n3. **Fallback for bad alignment** — if confidence < 0.7, trigger audio_validator or reject clip\n4. **Language-specific rules** — PT-specific, ES-specific, etc. handling\n5. **Edge case tests** — hyphens, accents, numbers, abbreviations, contractions\n\n#### Quality Score\n**5/10** — Correct approach, but relying on unvalidated V3 code. High risk of silent failures (bad alignment that produces wrong timestamps but doesn't error out).\n\n---\n\n### 6. bible_updater (Python Skill)\n\n**Status:** Fully specified, unimplemented | Called by: BM-B2, B3, B4, B5, B6, B7 (shared)\n\n#### Specification\n- **Input:** List of scene updates with fields to change (duration_actual, audio_clip, word_timestamps, entities, etc.) + metadata (updated_by, branch)\n- **Output:** Updated `scene_bible.json` with metadata bumped (version, last_updated_at, branches_contributed)\n- **Technology:** Pure Python JSON read/update/write (zero LLM, deterministic, reusable)\n- **Key feature:** Reutilizável por todos os branches (not just B2)\n\n#### Assessment\n\n**Strengths:**\n- Excellent decision to make this a shared, deterministic skill (not LLM-based)\n- Saves tokens across 6+ branches\n- Metadata management (version, contributors, last update) is good\n- Output spec is clear\n\n**Weaknesses:**\n- **Merge conflict spec missing.** What if B2 updates duration_actual and B3 tries to update entities at the same time? Do they block each other? Lock file? Versioning?\n- **Partial update failure.** If scene_bible.json is corrupted or in intermediate state, does bible_updater validate before writing? What if 3 of 5 updates fail?\n- **Atomic writes.** Spec doesn't say: write to temp file, then atomic rename. If process crashes mid-write, scene_bible.json is corrupted.\n- **Schema validation.** Does bible_updater validate that updated fields match expected types? (duration_actual should be float, not string)\n- **Nested updates.** If word_timestamps is an array of 100 words, does bible_updater do surgical updates (replace only that array for that scene) or full rewrite?\n\n#### Real-World Scenario\nB2 finishes all clips, calls bible_updater with 15 scene updates (duration_actual, audio_clip, word_timestamps per scene). At the same time, B3 tries to update entities for the same 15 scenes. What happens?\n\nSpec says: \"Bible is document vivo, actualizado por cada branch.\" But CONCURRENT updates? The spec doesn't define locking, versioning, or merge strategy.\n\n#### Implementation Gaps\n1. **Concurrency spec** — locking strategy, versioning, merge rules\n2. **Atomic writes spec** — temp file, atomic rename\n3. **Validation spec** — schema validation, type checking, range validation\n4. **Partial failure handling** — what if 3 of 5 updates fail?\n5. **Merge conflict resolution** — if B2 and B3 both try to update same scene at same time\n\n#### Quality Score\n**6/10** — Good concept (shared, deterministic), but missing concurrency and robustness specs.\n\n---\n\n## Python Skills Summary\n\n| Skill | Status | Lines of Code (Est.) | Risk | Notes |\n|-------|--------|---------------------|------|-------|\n| tts_generator | Stub | 200-300 (from V3 ~700) | HIGH | V3 code copy, KMS integration undefined |\n| audio_transcriber | Stub | 100-150 | MEDIUM | WhisperX proven, comparison logic TBD |\n| timestamp_aligner | Stub | 50-100 | HIGH | Relies on unvalidated V3 function |\n| bible_updater | Stub | 80-120 | MEDIUM | Concurrency issues not addressed |\n| **Total** | | ~600-900 | | All unimplemented |\n\n---\n\n## OpenClaw Tools & Skills Needed\n\n### Tools Required (for BM-B2 to call)\n\n| Tool Name | Type | Called By | Purpose | Status |\n|-----------|------|-----------|---------|--------|\n| `tts_generator` | Python skill | BM-B2 | Generate TTS clip | Define OpenClaw integration |\n| `audio_transcriber` | Python skill | BM-B2 | Transcribe + ratio check | Define OpenClaw integration |\n| `timestamp_aligner` | Python skill | BM-B2 | Align words to timestamps | Define OpenClaw integration |\n| `bible_updater` | Python skill | BM-B2, B3-B7 | Update scene_bible | Define OpenClaw integration |\n| `audio_validator` | LLM agent (sub-agente) | BM-B2 | Semantic validation of low ratios | Define dispatch mechanism |\n\n### Integration Gaps\n\n1. **No OpenClaw skill/agent spawn syntax defined** — TOOLS.md shows example like `openclaw skill run tts_generator --input` but this is pseudocode. How does BM-B2 actually invoke these in OpenClaw?\n2. **Error handling for skill failures** — if `tts_generator` returns non-zero exit code, how does BM-B2 know? Retry logic?\n3. **Skill execution context** — where do skills run? On GPU M1? What if GPU is busy?\n4. **Logging/tracing** — how do skill invocations get logged for auditability?\n\n---\n\n## Ambiguities & Gaps\n\n### Critical (P0)\n\n1. **TTS Language Bug (PT→ES) — UNFIXED**\n   - Spec says \"future: adicionar prompt de idioma\"\n   - But this is a known bug affecting 2% of PT scenes\n   - Should be P0 before first B2 production run\n   - Risk: videos in PT channel randomly have Spanish narration\n\n2. **Timestamp Alignment Validation**\n   - If `timestamp_aligner` produces bad alignment, how is this caught?\n   - No confidence score or validation step\n   - Risk: Silent corruption of timing data that breaks B6 sync\n\n3. **Concurrent Updates to scene_bible**\n   - B2, B3, B4, B5, B6, B7 all update scene_bible\n   - No locking, merging, or conflict resolution spec\n   - Risk: Race condition corrupts scene_bible.json\n\n4. **KMS Integration for tts_generator**\n   - \"Skill Python que chama Gemini TTS API via KMS\"\n   - But how? No spec for the call interface\n   - Risk: If KMS API changes, tts_generator breaks\n\n### High (P1)\n\n5. **Error Recovery Matrix**\n   - Spec says \"max 3 retries per scene\"\n   - But doesn't define: timeout values, backoff strategy, partial failures\n   - Example: If Gemini TTS times out after 20s, do we retry immediately or wait?\n\n6. **WhisperX Ratio Calculation Details**\n   - RULES.md says ratio is calculated but doesn't specify algorithm\n   - SequenceMatcher? Levenshtein? Case-sensitive?\n   - Different algorithms give different ratios on same data\n   - Risk: Subtle bugs in comparison logic affect approval rates\n\n7. **Word Timestamp Format Specification**\n   - audio_transcriber outputs WhisperX timestamps\n   - timestamp_aligner aligns them to original words\n   - But what if WhisperX timestamp format changes (different version)?\n   - No version pinning or format validation\n\n8. **Scene Bible Schema Evolution**\n   - Spec says bible_updater adds fields to scene_bible\n   - But what if B1 defined a field that B2 overwrites?\n   - Example: B1 sets `duration_estimate: 8.2`, B2 sets `duration_actual: 8.5`\n   - Spec says \"overwrite\" but doesn't define merge rules for nested objects\n\n9. **Parallel Scene Processing Concurrency**\n   - Spec mentions \"respectando TTS_CONCURRENCY_CAP\"\n   - But TTS_CONCURRENCY_CAP is not defined in B2 RULES\n   - Where is it defined? How does BM-B2 read it?\n\n### Medium (P2)\n\n10. **audio_validator Language Coverage**\n    - Tested on 12 languages but RULES.md only shows EN/PT examples\n    - RU threshold is 0.82 vs 0.60 EN — why? Spec doesn't explain\n    - Risk: audio_validator decisions vary by language without clear rules\n\n11. **GPU Resource Contention**\n    - audio_transcriber and timestamp_aligner both use GPU\n    - WhisperX can't parallelize\n    - If BM-B2 processes 15 scenes in parallel, GPU becomes bottleneck\n    - Spec says \"sequencial\" but then says \"ou em paralelo\" (or in parallel)\n\n12. **Checkpoint Corruption Recovery**\n    - Spec says checkpoints enable recovery\n    - But what if checkpoint file is corrupted (partial write)?\n    - No validation logic defined\n\n13. **Voice Combo Configuration**\n    - Spec says \"voice combo vem da config por conta/idioma\"\n    - Format undefined (YAML? JSON? Python dict?)\n    - No fallback if voice not available in Gemini TTS\n\n---\n\n## Weaknesses\n\n### Design-Level Weaknesses\n\n1. **Unvalidated V3 Code Reuse**\n   - Spec assumes V3 code can be copied wholesale\n   - But V3 is a monolithic script, not modular libraries\n   - Risk: Copy-pasting 1500 lines of tts_phase2 brings bugs, dead code, and V3-specific hacks\n\n2. **No Testing Strategy**\n   - Spec is silent on unit tests, integration tests, regression tests\n   - audio_validator has no test suite defined (despite having real-world examples in RULES.md)\n   - Risk: Bugs only discovered in production\n\n3. **No Performance Benchmarks**\n   - How long does tts_generator take per scene? (5s? 30s?)\n   - How long does audio_transcriber take? (10s? 60s?)\n   - If a 50-scene video takes 500s (8+ minutes), when is this a blocker?\n   - No spec defined\n\n4. **Insufficient Error Taxonomy**\n   - \"Max 3 retries\" is oversimplified\n   - Some errors are permanent (invalid text), some are transient (rate limit), some are environmental (GPU out of memory)\n   - Spec doesn't distinguish\n   - Risk: Same retry strategy for all failures is suboptimal\n\n5. **No Cost Tracking**\n   - Spec doesn't track: TTS API calls, Qwen API calls, audio_validator invocations\n   - \"Evitar regenerações desnecessárias\" but no cost model\n   - Risk: Can't evaluate if audio_validator is actually saving money\n\n6. **Silent Failures**\n   - If timestamp_aligner produces bad alignment, it doesn't error — it just outputs wrong timestamps\n   - If audio_validator is wrong and approves a truncated clip, downstream doesn't know until B6 tries to sync\n   - Risk: Bad data propagates silently\n\n---\n\n## Gaps vs. V3\n\n### What V3 Had\n\n- TTS generation with NISQA validation (quality check)\n- Silence trimming\n- Safe rewrite logic (reattempt with different prompt if TTS fails content)\n- End-to-end integration with Remotion render (B3)\n\n### What B2 Removes\n\n- NISQA validation (not mentioned in spec)\n- Silence trimming (not mentioned; assumed implicit?)\n- Safe rewrite (not mentioned; does Qwen cover this?)\n- Direct integration with Remotion (timestamps are relative to scene, not absolute to video)\n\n### Why These Changes?\n\nPresumably because:\n- NISQA might be overkill (WhisperX + Qwen covers quality)\n- Silence trimming can happen in post-processing\n- Safe rewrite is complex; Qwen validation is simpler\n- Decoupling from Remotion is better architecture\n\n**But:** Spec doesn't EXPLAIN these deletions. If V3 had them for a reason, removing them could break things.\n\n---\n\n## Dependencies\n\n### External Dependencies\n\n| System | Dependency | Risk |\n|--------|-----------|------|\n| **Gemini TTS API** | via KMS | If API changes, tts_generator breaks |\n| **WhisperX** | local GPU (M1) | If WhisperX version changes, timestamps might break |\n| **Ollama** | Qwen 3.5 9B local | If Ollama down, audio_validator can't run |\n| **Google Sheets** | scene_bible fetch | If Google API rate-limits, B1 can't fetch scripts (but B2 doesn't fetch directly) |\n| **M1 GPU Memory** | WhisperX + parallel processing | If GPU is 8GB, how many scenes can process in parallel? |\n\n### Internal Dependencies\n\n| Component | Depends On | Risk |\n|-----------|-----------|------|\n| **BM-B2** | B1 (pre-production) | If B1 produces bad narrations, B2 clips will be bad |\n| **audio_validator** | audio_transcriber ratio | If ratio calculation is wrong, audio_validator makes wrong decisions |\n| **timestamp_aligner** | WhisperX output | If WhisperX changes output format, alignment breaks |\n| **B6 (Scene Composition)** | B2 timestamps | If B2 timestamps are wrong, B6 video sync is off |\n| **B8 (Assembly/Render)** | B2 duration_actual | If duration_actual is wrong, render timeline is wrong |\n\n---\n\n## Priority Assessment\n\n### P0 (Blocker for Production)\n\n1. ❌ **tts_generator implementation** — Can't generate audio without this\n2. ❌ **audio_transcriber implementation** — Can't validate quality without this\n3. ❌ **KMS integration spec** — How does tts_generator access API keys?\n4. ❌ **Concurrent scene_bible updates** — Multiple branches will corrupt JSON without locking\n5. ❌ **PT→ES language bug fix** — 2% of Portuguese videos have Spanish narration (known issue, unfixed)\n\n### P1 (Must Fix Before First Run)\n\n6. 🔴 **timestamp_aligner validation** — Verify V3 code works; add confidence scoring\n7. 🔴 **audio_validator test suite** — Test on 100+ real examples (currently zero tests)\n8. 🔴 **Error recovery matrix** — Define timeout values, retry strategies, partial failure handling\n9. 🔴 **WhisperX format spec** — Define which version, which output format, how to parse\n10. 🔴 **OpenClaw tool integration** — How does BM-B2 actually invoke these skills in OpenClaw?\n\n### P2 (Nice to Have, Non-Blocking)\n\n11. 🟡 **NISQA validation** — Consider adding quality scoring (was in V3, removed here)\n12. 🟡 **Cost tracking** — Monitor Gemini TTS + Qwen API spend\n13. 🟡 **Performance benchmarks** — Measure tts_generator, audio_transcriber runtime\n14. 🟡 **Learning in audio_validator** — Capture patterns, improve over time\n15. 🟡 **Silence trimming** — Verify if this is automatic or needs explicit implementation\n\n---\n\n## Suggestions\n\n### Short Term (Before First B2 Run)\n\n1. **Extract and test tts_phase2 from V3**\n   - Identify exact functions/code to reuse\n   - Create unit tests with mock Gemini API\n   - Fix PT→ES language bug immediately (add language prompt to Gemini call)\n   - Document deviations from V3 (why remove NISQA? Why implicit silence trimming?)\n\n2. **Validate timestamp_aligner with real data**\n   - Extract `_align_words_to_timestamps()` from V3 lettering_tsx_generator.py\n   - Run on 50 real B2 examples (with known good timestamps from V3)\n   - Compare V3 timestamps vs new alignment\n   - Add confidence scoring and fallback rejection if alignment is uncertain\n\n3. **Test audio_validator on 100 real examples**\n   - Use the 51 rejection cases from V3 (should all reject)\n   - Use 49 false-positive cases (ratio low but content OK) from V3 (should all approve)\n   - Measure accuracy, false positive rate, false negative rate\n   - Test on all 12 languages, not just EN/PT\n\n4. **Define OpenClaw integration**\n   - Write exact syntax for how BM-B2 invokes each skill\n   - Example: `openclaw skills run tts_generator --scene_id scene_007 --narration \"...\" --language fr --voice_combo config.yaml`\n   - Define error handling for skill failures\n   - Define logging/tracing format\n\n5. **Fix scene_bible concurrency**\n   - Add locking (file lock or JSON schema versioning)\n   - Define merge strategy for concurrent updates\n   - Make bible_updater atomic (write to temp file, atomic rename)\n   - Add validation before committing updates\n\n### Medium Term (First Production Run)\n\n6. **Build error recovery matrix**\n   - List all possible failures per skill\n   - Define retry strategy for each (immediate? exponential backoff? manual?)\n   - Define when to escalate vs. when to skip\n   - Example: If Gemini TTS rate-limits, wait 60s then retry; if it fails 3x, escalate.\n\n7. **Implement checkpoint validation**\n   - Checkpoints should be checked for corruption on load\n   - If checkpoint is malformed, start fresh from that step\n   - Add checksums or signatures to checkpoint files\n\n8. **Performance tuning**\n   - Measure actual runtimes on M1 GPU\n   - Identify bottlenecks (TTS? WhisperX? IO?)\n   - Optimize or parallelize where safe (WhisperX can't parallelize, but TTS can)\n   - Set realistic timeouts based on actual behavior\n\n9. **Add learning to audio_validator**\n   - After each validation, capture patterns\n   - Example: \"In PT, numbers formatted as X.000 always pass ratio 0.45. Qwen should pre-approve these.\"\n   - Build language-specific rules over time\n   - Update MEMORY.md with patterns\n\n### Long Term (Evolution)\n\n10. **Consider NISQA validation** — was in V3, removed here. Reconsider if quality issues arise.\n11. **Cost optimization** — track TTS API spend vs. audio_validator approval rate. Is audio_validator paying for itself?\n12. **Multi-language tuning** — current thresholds are from V3 (old data). Retrain on B2's actual production data per language.\n13. **Streaming/realtime support** — currently all scenes processed sequentially. Could B2 stream results to B6 as scenes complete? (Would require B6 to handle out-of-order scenes, complexity tradeoff.)\n\n---\n\n## Verdict\n\n### Readiness: 40% (Design phase only)\n\n✅ **Architecture is sound** — decisions are defensible, principle of intelligent validation is right, escalation logic is appropriate.\n\n⚠️ **Specification is incomplete** — operational details missing, error handling underspecified, V3 code reuse not validated.\n\n❌ **Implementation is absent** — zero of five Python skills implemented, BM-B2 not created in OpenClaw, zero tests written.\n\n### Go/No-Go for Production\n\n**DO NOT ATTEMPT PRODUCTION RUN UNTIL:**\n\n1. ✅ All 5 Python skills are implemented and unit-tested\n2. ✅ audio_validator is tested on 100+ real examples\n3. ✅ OpenClaw integration is defined and working\n4. ✅ scene_bible concurrency issues are resolved\n5. ✅ PT→ES language bug is fixed\n6. ✅ Error recovery matrix is complete and implemented\n7. ✅ Checkpoint validation is working\n\n**Current state:** Safe for LOCAL DEV ONLY (if anyone attempts to run it). Will fail in production due to missing implementations.\n\n---\n\n## Summary Metrics\n\n| Metric | Count |\n|--------|-------|\n| **Documentation files analyzed** | 19 |\n| **Python skills identified** | 5 (all unimplemented) |\n| **Sub-agents identified** | 1 (audio_validator, specified but not implemented in OpenClaw) |\n| **Critical gaps (P0)** | 5 |\n| **High-priority gaps (P1)** | 10 |\n| **Medium-priority gaps (P2)** | 5 |\n| **External dependencies** | 4 (Gemini TTS, WhisperX, Ollama, Google Sheets) |\n| **Internal dependencies** | 4 (B1, audio_transcriber, WhisperX, B6/B8) |\n| **Estimated effort to production-ready** | 40-60 hours (implementation + testing + validation) |\n\n---\n\n## Appendix: Real-World Scenario (Walkthrough)\n\n**Scenario:** BM-B2 receives a 15-scene video job, processes it.\n\n1. **Scene 1-5:** Smooth processing\n   - tts_generator creates clip_001.mp3 through clip_005.mp3\n   - audio_transcriber validates, all ratios > threshold\n   - Qwen not called\n   - timestamp_aligner produces timestamps_001.json through timestamps_005.json\n   - Checkpoints created for all\n\n2. **Scene 6:** WhisperX ratio = 0.48 (threshold = 0.60)\n   - audio_validator called with: original narration, transcription, ratio, missing words\n   - Qwen sees \"6.000\" vs \"6000\" — formatting only\n   - Returns: `approve, \"Number formatting difference only\"`\n   - Checkpoint b2_step2_validated_scene_006.json created\n\n3. **Scene 7:** WhisperX ratio = 0.42\n   - audio_validator called\n   - Original: \"The bombing lasted three weeks...\"\n   - Transcription: \"The bombing lasted...\"\n   - Missing words: [\"three\", \"weeks\"]\n   - Qwen sees content words missing\n   - Returns: `reject, \"Content words missing: three, weeks\"`\n   - BM-B2 increments retry counter for scene 7\n   - BM-B2 calls tts_generator again for scene 7 (retry 1/3)\n   - New clip_007_retry1.mp3 generated\n   - audio_transcriber on new clip: ratio = 0.55 (still below threshold)\n   - audio_validator called again: \"two words still missing\"\n   - Retry 2: new clip, ratio = 0.49, same issue\n   - Retry 3: new clip, ratio = 0.47, \"time\" still missing\n   - **ESCALATE to Lucca + Tobias + Claude Code:** \"Scene 007 failed 3x. Content word 'time' consistently missing from TTS output. Possible Gemini bug or config issue. Human review needed.\"\n\n4. **Scenes 8-15:** Continue normally while scene 7 is escalated\n\n5. **Final checkpoint:**\n   - b2_step4_scene_bible_updated.json created with 14 of 15 scenes\n   - Report to VO: \"B2 PARTIAL: 14/15 scenes OK. Scene 007 escalated after 3x retries.\"\n\n---\n\n## Conclusion\n\nB2 Audio is **architecturally well-designed but not ready for implementation**. The specification is detailed, the principles are sound, and the decision to use intelligent validation (audio_validator) instead of blind regeneration is correct. However, all five Python skills are unimplemented stubs, the OpenClaw integration is undefined, and several critical gaps (concurrent scene_bible updates, KMS integration, error recovery matrix) need to be resolved before any production run.\n\n**Recommendation:** Treat this as a solid design that requires 40-60 hours of engineering work to be production-ready. Start with extracting and validating V3 code, then build OpenClaw integration, then test at scale.\n\n**Grade: 7/10** — Good architecture, incomplete execution.\n\n---\n\n**Review completed:** 26 Mar 2026, 22:30 GMT-3  \n**Reviewer:** Tobias (subagent)  \n**Next step:** Assign implementation tasks to Claude Code or engineering team\n"}],"isError":false,"timestamp":1774793537281}}
{"type":"message","id":"f019451b","parentId":"9d0bc1c3","timestamp":"2026-03-29T14:12:17.340Z","message":{"role":"toolResult","toolCallId":"call_KuXTfYI8zHy5Z4qzYIoNohzx|fc_04d04e5a142d912b0169c9334210ec8191ad63f7ecf758b91d","toolName":"read","content":[{"type":"text","text":"# BRUTAL HONEST REVIEW: Branch 3 Visual Planning\n**Auto Content Factory — Architecture & Specification Audit**\n\n**Date:** 26 March 2026  \n**Reviewer:** Tobias (CEO, Video Editing Department)  \n**Scope:** B3 branch architecture, BM-B3 coordination, 8 specialized agents, workspace mirror files  \n**Status:** DETAILED REVIEW COMPLETE\n\n---\n\n## SCOPE & FILES ANALYZED\n\n### Documentation Files Read\n- `03_VISUAL_PLANNING.md` (main spec)\n- `00_CONTEXT.md` (project foundations)\n- `03_PIPELINE_MAP.md` (pipeline dependencies)\n- `04_BRANCH_ARCHITECTURE.md` (4-level hierarchy)\n- `06_MODEL_STRATEGY.md` (model selection rationale)\n- `09_HIERARCHY_AND_STRUCTURE.md` (agent organization)\n- `10_PRODUCTION_MANAGER.md` (PM role & logic)\n- `11_VIDEO_ORCHESTRATOR.md` (VO orchestration)\n- `12_VIDEO_DIRECTORY_STRUCTURE.md` (output structure & checkpoints)\n\n### Workspace Mirror Files Analyzed\n- **Branch-level:** 6 files (AGENTS.md, IDENTITY.md, CONTEXT.md, MEMORY.md, RULES.md, TOOLS.md)\n- **Agent-level:** 8 specialized agents × 5 files each = 40 files\n  - character_identifier\n  - location_identifier\n  - vehicle_weapon_identifier\n  - event_identifier\n  - artifact_identifier\n  - atmosphere_identifier\n  - era_context_identifier\n  - map_diagram_identifier\n\n**Total Files Analyzed: 46 markdown files + specifications**\n\n---\n\n## BRANCH PURPOSE\n\n**Visual Planning (B3) is the identification layer** that transforms a narrated screenplay into structured, searchable visual entities.\n\n**Input:** Narrated script (output from B2) + scene_bible with narrações and directional hints + account config (entity_focus)  \n**Output:** Compiled, deduplicated entity set (`compiled_entities.json`) + scene_bible updated with entity references + checkpoint trail  \n**Downstream consumers:** B4 (Asset Research) uses `compiled_entities.json` to know what to search for. B5 (Visual Direction) uses updated scene_bible to plan compositions.\n\n**Core thesis:** A well-planned identification phase reduces noise in asset search. Instead of B4 doing open-ended searches, it executes a precise plan built by B3.\n\n---\n\n## PER-COMPONENT REVIEW\n\n### ✅ BM-B3 (Branch Manager) — SOLID ARCHITECTURE\n\n**Strengths:**\n1. **Config-driven design:** Reads `entity_focus` from account's style_guide.yaml and respects it (skips \"none\" identifiers, scales depth with low/medium/high/very_high)\n2. **Parallel dispatch:** Real parallelism via OpenRouter (not sequential local execution)\n3. **Checkpoint per identifier:** Recovery granularity is surgical — one failing identifier doesn't force restart of others\n4. **Deduplication logic:** Post-compilation, merges duplicate entities intelligently (keeps version with more search_hints)\n5. **Escalation protocol:** 3 consecutive failures → escalate to Lucca/Tobias/Claude Code (doesn't loop infinitely)\n6. **Clear responsibility:** Coordinates but does NOT do visual direction (that's B5 after assets exist)\n\n**Weaknesses:**\n1. **Batching strategy underspecified:** For scripts >3000 words, rule says \"divide into batches of 5-8 scenes\" but doesn't specify sequential vs parallel batch dispatch. Cost implications unclear.\n2. **Duplicate resolution heuristic is basic:** \"Keep version with more search_hints\" works 80% of the time, but edge cases (conflicting era info, different importance levels) need tie-breaker logic.\n3. **Model choice deferred:** Uses \"GPT-5.4 nano OR MiniMax M2.7\" but final decision is pending benchmarks. This is implementation debt — should default to one now, measure, then switch.\n4. **No pre-flight validation:** Doesn't verify that identified entities actually match the script content (e.g., identifying \"Eisenhower\" when the script mentions \"the general\" — could be wrong)\n5. **scene_bible mutation risk:** Updates scene_bible in Phase 4, but if update fails, earlier phases' outputs aren't rolled back\n\n**Ambiguities:**\n- What happens if 2+ identified entities have identical search_hints but different names? Merge or keep separate?\n- Does BM-B3 validate that `entity_focus` config exists before dispatching? Or use defaults silently?\n- If OpenRouter rate-limit is hit during parallel dispatch, how are retries distributed? Serial? Exponential backoff?\n\n**Gaps:**\n- No explicit fallback if OpenRouter API key is invalid/expired\n- No cost tracking per account (cost varies by entity_focus depth)\n- No A/B testing framework (can't easily test GPT-5.4 nano vs MiniMax on same input)\n\n---\n\n### 🟡 character_identifier — CREATIVE POTENTIAL BUT VAGUE BOUNDARIES\n\n**Strengths:**\n1. **Clear mission:** Identify people (historical, fictional, generic)\n2. **Handles implicit references:** \"The general who led the 6th Army\" → Paulus (not just direct mentions)\n3. **Graphy variations included:** Acknowledges alternate spellings and names (Tschaikowsky/Tchaikovsky)\n4. **Role_title field:** Captures functional context (\"Comandante do 6.º Exército Alemão\") not just name\n5. **Search_hints include variants:** Portraits, uniforms, contexts (e.g., \"Rommel North Africa\")\n\n**Weaknesses:**\n1. **\"Implicit\" is dangerous:** When script says \"the general,\" identifying a specific person requires historical knowledge beyond the script. Risk of hallucination.\n2. **No ambiguity resolution logic:** PROMPT.md says \"if identity not 100% clear, list possibilities\" — but then output format expects single `name` field. How does B4 handle \"could be Paulus or Weichs\"?\n3. **No role-consistency checks:** Doesn't validate that identified person existed in the era specified by the script\n4. **Search_hints quality variance:** Rule is \"minimum 2 hints\" but quality ranges wildly — \"portrait\" vs \"official military portrait taken in Tunisia during 1942\"\n5. **No comparison to character_bible:** Could cross-reference against known characters from previous videos but doesn't mention this\n\n**Ambiguities:**\n- What's the threshold for \"implicit\" identification? 70% confidence? 90%?\n- How does it handle fictional characters vs historical ones? Same output format?\n- If script mentions \"unnamed soldier,\" does it identify a generic soldier category or skip it?\n\n**Gaps:**\n- No deduplication logic within agent (if same person appears twice, doesn't consolidate)\n- No validation that person actually appears in the era of the script\n- No \"biography summary\" for downstream agents (only search_hints)\n\n---\n\n### 🟡 location_identifier — SOLID BUT INCOMPLETE\n\n**Strengths:**\n1. **Temporal disambiguation:** Distinguishes \"Stalingrado 1943\" (ruins) from \"Volgograd 2024\" (modern). Critical for asset sourcing.\n2. **modern_name field:** Recognizes that searcher may find modern names first, includes both\n3. **still_exists flag:** Useful downstream — if location no longer exists, search strategy changes\n4. **Architectural style:** When relevant (buildings, fortresses), captures visual descriptor\n5. **Distinction between explicit and implicit:** \"The Eastern Front\" → specific regions (Steppe, Ukraine, Belarus depending on context)\n\n**Weaknesses:**\n1. **country_of_origin is ambiguous:** Says \"using name of the era\" but what if borders changed 5 times in the script's era? \"Prussia\" vs \"Germany\" vs \"German Empire\"?\n2. **visual_importance lacks context:** \"High importance\" for Kursk seems obvious, but how does identifier determine this? By scene frequency? Narrative weight?\n3. **No cross-scene coherence check:** If Kursk appears in scenes 3, 7, 12, does identifier verify they're consistent references or different Kurzks?\n4. **architectural_style is optional:** But for period accuracy, it's critical for accounts like 006 (Mansions). Should be more structured.\n\n**Ambiguities:**\n- When searching \"Stalingrado,\" should B4 prioritize historical photos (1942-43) or modern reconstructions?\n- If location is fictional (e.g., \"Gormenghast Castle\"), how does identifier handle it?\n- Does \"still_exists\" mean \"in recognizable form\" or \"exact historical state\"?\n\n**Gaps:**\n- No coordinate/geography data (latitude/longitude could help with visual consistency)\n- No UNESCO/historical registry numbers\n- No \"nearby landmarks\" suggestions (Kursk → Don River, Steppe, nearby villages)\n\n---\n\n### 🟢 vehicle_weapon_identifier — PRECISE & EXECUTABLE\n\n**Strengths:**\n1. **Model-specific identification:** \"Panzer IV Ausführung H\" not just \"Panzer IV\" — level of detail is exactly right for B4\n2. **Designation & designation fields:** Both official (Sd.Kfz. 161/2) and common names (Tiger)\n3. **Implicit equipment logic:** \"Soviet tanks at Kursk\" → likely T-34/76, KV-1, SU-152 (not just vague \"tanks\")\n4. **Variant awareness:** Acknowledges same model used by multiple nations with context\n5. **Specs field is flexible:** Adapts to type (tank specs vs firearm vs ship)\n6. **Search_hints are actionable:** \"museum photo,\" \"technical diagram,\" \"profile view\" — actual search strategies\n\n**Weaknesses:**\n1. **Assumption of specificity:** Not all scripts will specify model variants. Identifier must infer from context, risk of error.\n2. **No production variant coverage:** E.g., M4 Sherman had 50+ variants. Identifier can't know if script needs M4(105) or M4A1(76)W.\n3. **Incomplete specs field:** For tanks, should include effective range, typical usage (assault, defense, breakthrough)\n4. **No prototype/experimental equipment:** Scripts may mention experimental weapons (Maus, Ratte, etc.). Unclear how handled.\n\n**Ambiguities:**\n- When script says \"tanks,\" is identifier obligated to list ALL Soviet tanks in the era, or only \"likely\" ones?\n- How specific should \"context of use\" be? \"Eastern Front, Winter 1942/43\" or just \"Eastern Front\"?\n\n**Gaps:**\n- No museum/archive links (where to find reference photos)\n- No \"availability of historical photos\" metric (rare vs common equipment)\n\n---\n\n### 🟢 event_identifier — CLEAR PURPOSE, SOLID EXECUTION\n\n**Strengths:**\n1. **Documentary focus:** Explicitly targets \"fotos documentais, imagens de arquivo, registos visuais\" — output is photo-sourcing-ready\n2. **Implicit events:** Can identify \"the siege that lasted 900 days\" → Siege of Leningrad without explicit name\n3. **Search_hints designed for archival search:** \"Siege of Leningrad,\" \"1941-1944,\" \"bread ration queues,\" \"Neva River frozen\"\n4. **One clear entity_type:** Unlike character (which can be historical/fictional), event is always historical/documented\n\n**Weaknesses:**\n1. **Distinguishing events from locations:** \"Battle of Kursk\" is event + location. Risk of duplication with location_identifier.\n2. **No event hierarchy:** \"Battles of WWII\" is vague. Identifier doesn't distinguish major (Kursk, Stalingrad) from minor (Raid on Dieppe)\n3. **Documentary assumption fails for drama:** For accounts covering fictional dramas or mysteries, there's no \"event\" to photograph. Identifier may produce empty output.\n\n**Ambiguities:**\n- Is \"Yalta Conference\" an event? If so, what are search_hints? Photos of the building? The diplomats? Both?\n- If script describes a fictional event (\"The Rebellion of 2056\"), does identifier skip it or create synthesizable hints?\n\n**Gaps:**\n- No \"primary sources\" vs \"secondary sources\" distinction (contemporary photos vs modern reenactments)\n- No date precision (does \"Winter 1942\" count as sufficient or need month/day?)\n\n---\n\n### 🟢 artifact_identifier — NICHE BUT VALUABLE\n\n**Strengths:**\n1. **Museum-aware:** Recognizes artifacts exist in collections, asks \"where is it now?\" (critical for search)\n2. **Pre-photographic era handled:** Paintings/illustrations aren't inferior assets — they're THE asset for medieval/ancient content\n3. **Artist/creator field:** Adds searchability and context\n4. **current_location is operational:** Tells B4 \"look in Prado,\" \"look in National Archives,\" etc.\n5. **Diverse subtypes:** Handles paintings, documents, inventions, religious artifacts, archaeological finds\n\n**Weaknesses:**\n1. **Scope ambiguity:** Is a \"uniform\" an artifact or context? A \"sword\" (weapon) or artifact? Boundary with vehicle_weapon_identifier unclear.\n2. **Photography assumption:** If artifact is a famous painting, search is straightforward. If it's a 16th-century map (rare original), might not be photographable.\n3. **Copyright/reproduction rights:** Doesn't flag if artifact use requires licensing\n4. **Lower priority than other identifiers:** No account has `artifacts: very_high`. Usually `medium`. Risk of underserving some narratives.\n\n**Ambiguities:**\n- If script mentions \"a book\" (real or fictional), how does identifier decide if it's an artifact?\n- Is \"the Declaration of Independence\" an artifact or an event (declaration) or a document? Output format suggests one answer, but multiple valid interpretations exist.\n\n**Gaps:**\n- No \"reproduction quality\" metric (some museum photos are 4K, others are 40-year-old library scans)\n- No licensing model (public domain vs copyrighted)\n\n---\n\n### 🟠 atmosphere_identifier — HIGH UPSIDE, EXECUTION RISK\n\n**Strengths:**\n1. **Conceptual clarity:** Mission is explicitly CREATIVE (\"think like a documentary filmmaker\")\n2. **Anti-literal:** Explicitly rejects \"just describe what's in the script\" — adds interpretive layer\n3. **Examples are evocative:** \"Botas marchando em lama — close-up rítmico\" is a shot, not a description\n4. **Cross-scene potential:** Acknowledges same mood can serve multiple scenes\n5. **Mood field:** Emotional descriptor (tense, melancholic, triumphant) is useful for B5\n\n**Weaknesses:**\n1. **Subjectivity & hallucination risk:** \"Mood\" is subjective. Two identifiers given same script will produce different atmospheres. How does BM-B3 deduplicate conflicting moods?\n2. **Vague boundary with location/character:** \"Close-up of boots marching\" — is this an atmosphere or a missing detail from character/location identifiers?\n3. **Search_hints quality variance:** \"desert war dust heat\" is vague. B4's atmosphere_searcher doesn't know if to search \"Sahara,\" \"Dust storm,\" \"Military marching,\" etc.\n4. **No grounding:** Identifier produces atmospheric suggestions, but no validation that B4 can actually source them (may end up as B4 hallucinating)\n5. **Filmmaking assumption:** Assumes all accounts value cinematic mood. Might be wrong for tutorial or educational channels.\n\n**Ambiguities:**\n- How creative should identifier be? \"Botas marchando\" is creative — is \"ethereal light through clouds\" too creative?\n- If script is tense but account is light-hearted, does identifier respect script tone or account tone?\n- cross_scene flag — does this mean B4 can reuse same footage across multiple scenes? Or just suggests visual continuity?\n\n**Gaps:**\n- No \"composition style\" validation (is \"overhead shot\" available for this content type?)\n- No grounding in real footage/stock libraries (suggests visuals that might not exist)\n- No tie-breaking logic when atmosphere conflicts with other identifiers\n\n---\n\n### 🟡 era_context_identifier — AMBITIOUS SCOPE, EXECUTION QUESTIONS\n\n**Strengths:**\n1. **Detailed categories:** Technology, clothing, architecture, everyday objects — structured approach\n2. **Specificity:** \"Rádio Volksempfänger VE 301\" not just \"radio\" — level of detail is right\n3. **Proactive enrichment:** Doesn't wait for script to mention clothes; identifies \"Wehrmacht uniform 1942\" contextually\n4. **Authenticity focus:** Mission is visual historical accuracy — critical for period content\n5. **Examples are concrete:** \"Uniformes de inverno Wehrmacht, botas Marschstiefel, capacete Stahlhelm M35\" — actual searchable terms\n\n**Weaknesses:**\n1. **Massive scope creep risk:** If identifier is exhaustive (every object, every clothing item, every architectural detail), output will be 100+ entities per video\n2. **Overlap with other identifiers:** \"Wehrmacht soldier's uniform\" — is this era_context or part of character_identifier's visual_importance handling?\n3. **Fictional/non-historical content:** For accounts covering crime dramas, mysteries, fiction — era_context mostly produces empty results\n4. **Entity focus depth makes this unpredictable:** If `era_context: very_high`, output explodes. If `era_context: low`, it's nearly empty. Huge variance.\n5. **Deduplication nightmare:** BM-B3 must handle \"Wehrmacht uniform 1942\" appearing in 5 different contexts (character, location, event atmospheres, etc.)\n\n**Ambiguities:**\n- Boundary with vehicle_weapon_identifier: Is \"Stahlhelm M35\" (helmet) era_context or weapon?\n- \"Everyday object\" — does this include food? (Rations, bread, coffee) How searchable is that?\n- For modern settings (2020s content), what counts as era_context? Current fashion? Consumer tech?\n\n**Gaps:**\n- No \"accessibility\" metric (is this uniform available in museums? Can be photographed easily?)\n- No \"visual cluster\" logic (grouping related era elements — \"1942 Wehrmacht soldier package\" containing uniform + helmet + boots + insignia)\n- No guidance on when era_context is overkill vs valuable\n\n---\n\n### 🟡 map_diagram_identifier — NICHE & UNDERSPECIFIED\n\n**Strengths:**\n1. **Specific purpose:** Maps and diagrams are valuable for explanatory content\n2. **Geographic/military focus:** Routers (routes, strategy, movement) are visual stories\n3. **Search_hints include type:** \"Kursk battle map,\" \"German invasion arrows,\" etc.\n\n**Weaknesses:**\n1. **Vague scope:** What's a \"diagram\"? Flowchart? Military strategy diagram? Ship schematic? Boundary unclear.\n2. **Modern vs historical:** A WWII battle map from 1943 looks different from a 2020 historical analysis map. Identifier doesn't distinguish.\n3. **Creator/source unknown:** \"Kursk battle map\" could be found in 100 sources. Identifier doesn't specify \"German General Staff map\" vs \"Soviet analysis\" vs \"Wikipedia annotated map.\"\n4. **Lowest priority:** Most accounts have `maps_diagrams: low` or `none`. Likely underdeveloped.\n5. **No scale/resolution guidance:** Some maps need high detail, some just need overview\n\n**Ambiguities:**\n- Is a photo of a historical map different from a diagram? How does search_hints distinguish?\n- If script mentions a location's geography (\"the river bends here\"), does this trigger map_diagram_identifier?\n\n**Gaps:**\n- No historical map archive/source links\n- No \"geographic scale\" specification (regional vs continental vs tactical)\n- No guidance on animated vs static maps\n\n---\n\n## PYTHON SKILLS NEEDED\n\n### 1. **bible_updater** (Deterministic, ~$0)\n- **What it does:** Takes `compiled_entities.json` and merges it into scene_bible.json, adding entities to each relevant scene and maintaining scene_bible structure\n- **Status:** Specified in 03_VISUAL_PLANNING.md, TOOLS.md describes input/output, but **implementation code not provided**\n- **Dependencies:** \n  - Must read scene_bible.json structure (from B2)\n  - Must validate entities have required fields before inserting\n  - Must handle scene references correctly (if entity.scenes = [\"scene_005\"], add entity to scene_bible[\"scenes\"][\"scene_005\"][\"entities\"])\n  - Must preserve all existing scene_bible data (screenplay, narration, audio_clip, timestamps, etc.)\n- **Complexity:** Low-medium (JSON merging + validation)\n- **v3 base:** No — this is new for B3, not inherited from V3\n- **Risk:** If this skill is buggy, ALL downstream branches receive corrupted scene_bible\n\n### 2. **Validation Skills** (Not Yet Designed)\n- **Needed but missing:** No skill specified for validating individual identifier outputs before compilation\n- Would need to check:\n  - Each entity has required fields (name, entity_type, era, visual_importance, search_hints[], scenes[])\n  - scenes[] reference valid scene_ids\n  - search_hints are not empty\n  - No duplicate entities within output\n- **v3 base:** No\n- **Impact:** Without validation, bad data from identifiers gets compiled and corrupts downstream\n\n### 3. **Deduplication Skill** (Not Yet Designed)\n- **Current approach:** BM-B3 does deduplication inline, but logic is underspecified\n- **Better approach:** Separate skill that takes 8 identifier outputs and produces clean deduplicated set\n- **Would need:**\n  - Entity matching algorithm (fuzzy name matching for \"Tiger I\" vs \"Tiger tank\")\n  - Conflict resolution (if two identifiers give different eras for same entity)\n  - Search_hints merging (combine hints from both versions)\n- **v3 base:** No\n- **Impact:** Manual deduplication will miss subtle duplicates\n\n---\n\n## OPENCLAW TOOLS NEEDED\n\n### 1. **Google Sheets API Read** (for reading style_guide.yaml config from accounts)\n- **Type:** API integration\n- **What it does:** Reads account configuration, specifically `entity_focus` dictionary\n- **Currently implemented?** Unknown — docs don't specify\n- **Priority:** P0 — BM-B3 cannot operate without reading entity_focus\n- **Config needed:** KMS-stored API key for Google Sheets, sheet ID, range specification\n\n### 2. **OpenRouter API** (for dispatching 8 identifiers)\n- **Type:** LLM API integration\n- **What it does:** Makes parallel calls to GPT-5.4 nano or MiniMax M2.7 for each identifier\n- **Currently implemented?** Partially — docs mention \"11 OpenRouter keys ($110/mo)\" already exist\n- **Priority:** P0 — all identifiers depend on this\n- **Config needed:**\n  - OpenRouter API key (load from KMS)\n  - Model selection logic (GPT-5.4 nano vs MiniMax M2.7 — decide now, benchmark later)\n  - Rate limiting / backoff strategy (parallel dispatch to 8 endpoints → 8 API calls simultaneously)\n  - Timeout handling (what's the SLA? 30s? 60s?)\n  - Token usage tracking (for cost monitoring per account)\n\n### 3. **Scene Bible Read/Write** (for loading input & saving output)\n- **Type:** File I/O\n- **What it does:** Reads scene_bible.json from B2, writes updated version after B3 completes\n- **Currently implemented?** Probably yes via standard filesystem, but concurrency not addressed\n- **Priority:** P0\n- **Config needed:** Path to scene_bible.json, locking mechanism (if multiple branches write simultaneously, need mutex)\n\n### 4. **Checkpoint Management** (for tracking progress & enabling recovery)\n- **Type:** File I/O + state management\n- **What it does:** Writes checkpoint files for each identifier completion, reads them on restart to skip completed work\n- **Currently implemented?** Standard filesystem write, but logic not implemented\n- **Priority:** P1 (nice to have now, critical for production)\n- **Config needed:** Checkpoint directory, checkpoint naming convention, deletion logic (how to reset from partial state)\n\n### 5. **Logging & Observability** (for debugging & auditing)\n- **Type:** File I/O + structured logging\n- **What it does:** Logs each identifier dispatch, each output, each error, duplication resolutions\n- **Currently implemented?** Unknown\n- **Priority:** P1\n- **Config needed:** Log directory, log level (debug vs info), retention policy\n\n### 6. **Error Reporting** (for escalation)\n- **Type:** Notification/messaging\n- **What it does:** When identifier fails 3x, escalates to Lucca/Tobias (via Telegram)\n- **Currently implemented?** Unknown\n- **Priority:** P1\n- **Config needed:** Telegram bot token, escalation recipient's Telegram ID\n\n---\n\n## CRITICAL AMBIGUITIES\n\n### 1. **entity_focus Inheritance & Defaults**\n- **The question:** If style_guide.yaml is missing or incomplete, what happens?\n- **Current spec:** \"If file not readable, PARAR e escalar\" — but this is harsh. Better approach: use sensible defaults (`medium` for all types) and log a warning.\n- **Impact:** On first account setup, if style_guide.yaml doesn't exist yet, B3 hard-fails instead of gracefully degrading.\n\n### 2. **Implicit Entity Identification Threshold**\n- **The question:** How confident must identifier be to claim it found an entity when script only implies it?\n- **Character example:** Script says \"the general at Stalingrad\" — could be 3-5 different generals. Does identifier guess the most likely, list all, or abstain?\n- **Current spec:** Says \"list possibilities with justification\" but output format expects single `name` field.\n- **Impact:** Garbage-in-garbage-out to B4. If identifier guesses wrong, B4 searches for wrong asset.\n\n### 3. **Duplication vs Specialization**\n- **The question:** When character_identifier and atmosphere_identifier both find \"soldier in uniform,\" who owns it?\n- **Current approach:** BM-B3 deduplicates post-compilation, keeping version with more search_hints.\n- **Problem:** This is lossy. \"Soldier\" (character) and \"uniform detail\" (atmosphere) are different semantic entities.\n- **Better approach:** Allow both, but distinguish by entity_type. Deduplication should only apply within entity_type.\n\n### 4. **Search Hints Quality Variance**\n- **The question:** \"General Patton portrait\" vs \"portrait\" — same entity, huge quality difference in hints.\n- **Current spec:** Minimum 2 hints, no quality guidance.\n- **Impact:** B4's searchers will struggle with vague hints. Need enforced structure: e.g., \"always include: [era], [context], [specific variant], [variant alternative], [visual form]\"\n\n### 5. **Batch Processing for Long Scripts**\n- **The question:** If script > 3000 words → divide into batches. But sequential or parallel dispatch?\n- **Current spec:** \"Divide into batches,\" no indication of batch dispatch strategy.\n- **Impact:** Sequential batch dispatch = slow. Parallel = costs spike. Needs explicit rule.\n- **Recommendation:** Sequential batches (batch 1 completes, then batch 2 starts) to control OpenRouter spend.\n\n### 6. **Scene Bible Locking**\n- **The question:** B2 writes to scene_bible (adds audio clips & timestamps), B3 reads from it and writes back (adds entities).\n- **Race condition?** If B2 is still writing when B3 reads, data corruption possible.\n- **Current spec:** No mention of locking or versioning.\n- **Impact:** In production with concurrent jobs, scene_bible could become corrupt.\n\n---\n\n## WEAKNESSES & GAPS\n\n### Architecture Weaknesses\n\n1. **No input validation on screenplay quality**\n   - B3 assumes screenplay from B1 is accurate. If B1 hallucinated a character, B3 propagates the error.\n   - Solution: B3 should spot-check screenplay against original script (lightweight validation)\n\n2. **Model selection deferred**\n   - Docs say \"GPT-5.4 nano OR MiniMax M2.7, to benchmark.\" This is implementation debt.\n   - Real risk: Defaults to slow/expensive model, incurs cost for weeks before benchmarking\n   - Solution: Default to GPT-5.4 nano now (cheaper, faster), measure quality, switch if needed\n\n3. **No cost tracking per account or per entity_focus depth**\n   - Spec says cost is ~$0.02/video, but this assumes medium entity_focus on all identifiers.\n   - Reality: Account 003 (very_high on 6 types) costs 3-4x more than account 006 (low on 4 types)\n   - Without tracking, PM can't make informed production decisions\n   - Solution: Add cost_model to style_guide.yaml or track actual cost per job\n\n4. **atmosphere_identifier produces output B4 can't reliably source**\n   - \"Desert war dust heat\" is a search_hint, but no guarantee B4 finds relevant footage\n   - Risk: atmosphere_identifier produces creative output, B4 can't match it, becomes dead weight\n   - Solution: atmosphere_identifier should validate against stock footage catalogs or define fallbacks\n\n5. **No A/B testing framework**\n   - Can't easily compare output quality between GPT-5.4 nano vs MiniMax M2.7\n   - Can't compare \"very_high\" entity_focus vs \"medium\" for same script\n   - Solution: Add ability to replay same job with different settings\n\n### Operational Gaps\n\n1. **No performance baselines**\n   - \"Parallel dispatch takes X ms\" — what's X? 2s? 30s?\n   - Matters for SLA & production scheduling\n   - Solution: Run benchmarks with sample scripts from each account\n\n2. **No error mode documentation**\n   - What happens if OpenRouter returns rate-limit? Timeout? Garbage output (hallucination)?\n   - Each error type needs specific handling\n   - Current spec: \"retry 3x then escalate\" — not enough detail\n\n3. **No cost-accuracy tradeoff guidance**\n   - entity_focus=very_high produces exhaustive entities but costs 2-3x more\n   - No guidance on when to choose which\n   - Should be account-level decision (documented in style_guide.yaml)\n\n4. **No feedback loop from B4 to B3**\n   - If B4's searcher can't find assets for entity X, B3 never learns\n   - Next video, B3 produces same unfindable entities\n   - Solution: B4 should report back which entities were unsearchable\n\n5. **No handling of fictional or non-historical content**\n   - B3 assumes all accounts are historical/documentary\n   - For drama, crime, fiction accounts, many identifiers (events, era_context, locations-as-real) are misfits\n   - Solution: Add account-level content_type (historical vs fictional) and adapt identifier dispatch accordingly\n\n### Data Quality Gaps\n\n1. **No schema validation on identifier outputs**\n   - Identifiers return JSON, but what if fields are wrong type? Missing required fields?\n   - No validation before compilation → garbage in compiled_entities.json\n   - Solution: Add JSONSchema validation for each identifier type\n\n2. **No spell-check or OCR on search_hints**\n   - If identifier outputs \"Friedrich Paulus\" but misspells as \"Frieddrich Paulus,\" B4 search fails\n   - No way to catch this\n   - Solution: Post-process search_hints through spell-check\n\n3. **No consistency checks across identifiers**\n   - character_identifier says \"era: 1942-1945\"\n   - vehicle_weapon_identifier says \"era: 1943\"\n   - No logic to flag this mismatch\n   - Solution: Add consistency validator\n\n---\n\n## DEPENDENCIES (EXTERNAL & INTERNAL)\n\n### External Dependencies\n\n1. **Google Sheets API** → read style_guide.yaml (account config)\n   - Blocking: Yes (can't start without reading entity_focus)\n   - Status: Assumed to be working (used by PM already)\n\n2. **OpenRouter API** → call 8 identifiers in parallel\n   - Blocking: Yes\n   - Status: Keys exist, but model choice not final\n\n3. **B2 completion** → scene_bible must be finalized before B3 reads\n   - Blocking: Yes\n   - Status: B2 spec finalized, implementation pending\n\n### Internal Dependencies\n\n1. **scene_bible structure** → defined in B2, consumed by B3\n   - Blocking: Yes\n   - Status: Defined in 12_VIDEO_DIRECTORY_STRUCTURE.md, needs finalization\n\n2. **entity_focus config** → defined per account in style_guide.yaml\n   - Blocking: Yes\n   - Status: Placeholder defaults, not per-account yet\n\n3. **B4 searcher design** → must match B3 entity types & search_hints structure\n   - Blocking: No (can be adjusted), but coordination required\n   - Status: B4 not yet detailed\n\n4. **VO orchestration** → VO must call BM-B3 and handle output\n   - Blocking: No (B3 is independent), but VO design depends on B3 output format\n   - Status: VO spec finalized, implementation pending\n\n---\n\n## PRIORITY ASSESSMENT\n\n### P0 (BLOCKING)\n\n1. **Model decision:** Choose GPT-5.4 nano or MiniMax M2.7 NOW, don't defer\n   - Risk: Weeks of wrong model choice = wasted spend + poor quality\n   - Effort: 2 hours benchmarking (run 5 test scripts on both models, compare output quality & speed)\n\n2. **style_guide.yaml per account:** Populate entity_focus for each active account\n   - Risk: All accounts fall back to defaults, no optimization per account\n   - Effort: 2 hours (review each account's content, set entity_focus appropriately)\n\n3. **OpenRouter API key & rate limiting:** Configure in KMS, define parallel dispatch strategy\n   - Risk: First job fails at API call\n   - Effort: 1 hour\n\n4. **bible_updater skill implementation:** Code it now, not later\n   - Risk: B3 output can't be integrated into scene_bible\n   - Effort: 4 hours (Python, JSON merge + validation)\n\n5. **Input validation:** Add schema validation for identifier outputs\n   - Risk: Bad data from OpenRouter propagates\n   - Effort: 3 hours (define schemas, add validation step in BM-B3)\n\n### P1 (HIGH PRIORITY)\n\n1. **Batch processing logic:** Define sequential vs parallel, cost implications\n   - Effort: 2 hours (design + doc)\n\n2. **Deduplication algorithm:** Replace \"keep version with more hints\" with proper merge logic\n   - Effort: 4 hours (design + test)\n\n3. **Error handling playbooks:** Document what to do for each error type\n   - Effort: 3 hours\n\n4. **Escalation integration:** Connect 3-failure escalation to Telegram bot\n   - Effort: 2 hours\n\n5. **Cost tracking:** Per-account cost model + per-job cost reporting\n   - Effort: 3 hours\n\n### P2 (NICE TO HAVE)\n\n1. **A/B testing framework:** Ability to replay same script with different models/settings\n   - Effort: 6 hours\n\n2. **Feedback loop from B4:** B4 reports which entities were unsearchable\n   - Effort: 4 hours (requires B4 design)\n\n3. **Consistency validators:** Cross-identifier era/location checks\n   - Effort: 4 hours\n\n4. **Performance benchmarks:** Baseline latency for each identifier\n   - Effort: 2 hours\n\n---\n\n## SUMMARY BY COMPONENT\n\n| Component | Rating | Quality | Readiness | Issues |\n|-----------|--------|---------|-----------|--------|\n| **BM-B3** | 🟢 GOOD | High | 75% | Model choice deferred, batching underspecified, scene_bible mutation risk |\n| **character_identifier** | 🟡 OK | Med | 60% | Implicit ID threshold vague, ambiguity resolution unclear, hallucination risk |\n| **location_identifier** | 🟢 GOOD | High | 70% | Border/country naming ambiguous, temporal data missing |\n| **vehicle_weapon_identifier** | 🟢 GOOD | High | 75% | Variant selection logic, museum availability metric missing |\n| **event_identifier** | 🟢 GOOD | High | 70% | Location-event duplication risk, dramatic content handling unclear |\n| **artifact_identifier** | 🟢 GOOD | Med | 60% | Scope boundary fuzzy, copyright/licensing not mentioned, lower priority |\n| **atmosphere_identifier** | 🟠 RISKY | Med | 50% | High subjectivity, B4 sourcing risk, no grounding in real footage |\n| **era_context_identifier** | 🟡 OK | Med | 55% | Scope creep risk, overlap with other identifiers, huge variance by entity_focus |\n| **map_diagram_identifier** | 🟡 OK | Low | 45% | Scope vague, niche use, underspecified, lowest priority |\n\n**Overall B3 Maturity: 65%** — Solid conceptual foundation, needs implementation & validation work, several design decisions still pending.\n\n---\n\n## RECOMMENDATIONS\n\n### IMMEDIATE (This Week)\n\n1. **Finalize model choice** — Test GPT-5.4 nano vs MiniMax M2.7 on 3-5 representative scripts (5 mins each with each model). Pick winner. Update CONTEXT.md.\n\n2. **Populate style_guide.yaml files** — For each active account (003, 004, 005, etc.), set entity_focus levels based on content type. Example:\n   ```yaml\n   entity_focus:\n     characters: very_high      # Accounts with historical figures\n     locations: high            # Accounts with geography\n     vehicles_weapons: high      # Military accounts\n     events: medium             # Supporting narrative\n     artifacts: low              # Supplementary\n     atmosphere: medium         # Visual mood\n     era_context: medium        # Historical detail\n     maps_diagrams: low         # Optional\n   ```\n\n3. **Implement bible_updater** — Write Python skill that merges compiled_entities.json into scene_bible.json with proper validation.\n\n4. **Add schema validation** — Define JSONSchema for each identifier output, validate before compilation.\n\n5. **Configure OpenRouter** — Load API key from KMS, test parallel dispatch to 8 endpoints, measure latency.\n\n### SHORT TERM (Next 2 Weeks)\n\n1. **Design deduplication algorithm** — Move from \"keep version with more hints\" to proper merge logic (combine hints, resolve era conflicts, mark source_identifier).\n\n2. **Batch processing spec** — Define: if script > 3000 words, dispatch batches sequentially (batch 1 → batch 2 → batch 3) to control spend.\n\n3. **Error handling playbooks** — Document handling for: rate limit, timeout, invalid output, hallucination, missing entity_focus.\n\n4. **Escalation integration** — Code 3-failure escalation → Telegram notification to Lucca + Tobias.\n\n5. **Cost tracking** — Add cost_estimate to job output, track actual vs estimate, report to PM.\n\n### MEDIUM TERM (Next Month)\n\n1. **Feedback loop from B4** — B4 reports which entities were unsearchable, B3 learns and adjusts next time.\n\n2. **Implicit ID validation** — For character_identifier's \"implicit\" entities, add confidence scores and flag low-confidence guesses for B4.\n\n3. **Account-type adaptation** — For non-historical accounts (drama, fiction, mystery), skip or adapt identifiers that assume real historical content.\n\n4. **A/B testing framework** — Ability to replay same script with different model/entity_focus, compare outputs.\n\n---\n\n## STRENGTHS SUMMARY (What's Working)\n\n1. ✅ **Config-driven design** — entity_focus per account is elegant, avoids one-size-fits-all\n2. ✅ **Parallelism** — Real OpenRouter parallelism (not sequential) = faster output\n3. ✅ **Checkpoint granularity** — Recovery per-identifier, not per-branch\n4. ✅ **Specialization** — 8 distinct identifiers beat 1 generic entity extractor\n5. ✅ **Explicit boundaries** — Clear: B3 identifies, B4 searches, B5 directs\n6. ✅ **Search-hints focus** — Output is optimized for downstream consumer (B4 searcher)\n7. ✅ **Escalation protocol** — 3 failures = escalate to human, doesn't loop forever\n\n---\n\n## VERDICT\n\n**B3 is architecturally sound but operationally incomplete.** The design is well-thought-out: specialized identifiers, config-driven behavior, clear dependencies, practical output formats. However, several design decisions are deferred (model choice, batching strategy, deduplication heuristics), implementation is only ~60% complete (no bible_updater skill, no validation, no error handling), and there are untested assumptions (atmosphere_identifier's creative output is searchable, implicit entity identification is reliable, parallel OpenRouter dispatch is stable at scale).\n\n**Readiness for production: 65%** — Can build & test now, but needs 2-3 weeks focused work before real load.\n\n**Risk level: MEDIUM** — Largest risks are (1) identifier hallucination leading to garbage search hints, (2) scope creep from exhaustive entity identification, (3) assumption that B4 can source creative atmosphere suggestions. Mitigation: validation, cost guardrails, feedback loop from B4.\n\n---\n\n## FILES ANALYZED SUMMARY\n\n- **Documentation files:** 10 (context, architecture, specs for PM, VO, B3, models, hierarchy, directory structure)\n- **Branch-level workspace files:** 6 (AGENTS.md, IDENTITY.md, CONTEXT.md, MEMORY.md, RULES.md, TOOLS.md)\n- **Specialized agent files:** 40 (8 agents × 5 files each: PROMPT.md, RULES.md, TOOLS.md, MEMORY.md, AGENTS.md)\n- **Total analyzed:** 56 markdown files + specifications\n\n---\n\n**Review completed:** 26 March 2026, 23:45 GMT-3  \n**Reviewer:** Tobias  \n**Confidence:** High — comprehensive review with architectural understanding\n\n"}],"isError":false,"timestamp":1774793537311}}
