ontinental\"]\n    },\n    {\n      \"entity_id\": \"symbolic_event_003\",\n      \"type\": \"symbolic_event\",\n      \"label\": \"Fechamento do cassino pelo decreto\",\n      \"scene_ids\": [\"scene_026\", \"scene_027\", \"scene_028\", \"scene_031\", \"scene_032\", \"scene_033\"],\n      \"note\": \"Choque regulatório súbito; o centro do complexo é encerrado por lei.\",\n      \"visual_elements\": [\"decreto assinado\", \"cassinos fechados\", \"porta do cassino\", \"silêncio institucional\", \"fim da operação\"]\n    },\n    {\n      \"entity_id\": \"symbolic_event_004\",\n      \"type\": \"symbolic_event\",\n      \"label\": \"Vazio após a perda do propósito\",\n      \"scene_ids\": [\"scene_046\", \"scene_047\", \"scene_048\", \"scene_049\", \"scene_050\", \"scene_053\", \"scene_054\", \"scene_055\"],\n      \"note\": \"O hotel sobrevive, mas vira casca; luxo sem motor econômico.\",\n      \"visual_elements\": [\"salas vazias\", \"mármore aparente\", \"hotel adaptado\", \"estrutura grande demais\", \"invólucro arquitetônico\"]\n    },\n    {\n      \"entity_id\": \"symbolic_event_005\",\n      \"type\": \"symbolic_event\",\n      \"label\": \"Salão de baile vazio como presença\",\n      \"scene_ids\": [\"scene_065\", \"scene_066\", \"scene_067\", \"scene_068\", \"scene_102\", \"scene_103\", \"scene_104\", \"scene_105\"],\n      \"note\": \"O vazio ganha peso dramático; a ausência de pessoas vira imagem central.\",\n      \"visual_elements\": [\"salão de baile vazio\", \"silêncio\", \"escadaria ampla\", \"proporções excessivas\", \"ausência de festa\"]\n    },\n    {\n      \"entity_id\": \"symbolic_event_006\",\n      \"type\": \"symbolic_event\",\n      \"label\": \"Mármore e telhados sobrevivem ao propósito\",\n      \"scene_ids\": [\"scene_071\", \"scene_072\", \"scene_073\", \"scene_088\", \"scene_089\", \"scene_090\", \"scene_091\"],\n      \"note\": \"Persistência material contrasta com a morte do conceito original.\",\n      \"visual_elements\": [\"mármore europeu\", \"telhados normandos\", \"manchas de umidade\", \"reparos antigos\", \"estrutura de pé\"]\n    },\n    {\n      \"entity_id\": \"symbolic_event_007\",\n      \"type\": \"symbolic_event\",\n      \"label\": \"Lago e varanda como cenário sem enredo\",\n      \"scene_ids\": [\"scene_142\", \"scene_143\", \"scene_144\", \"scene_145\", \"scene_146\", \"scene_147\"],\n      \"note\": \"Paisagem preservada, mas sem cassino; a imagem fica incompleta.\",\n      \"visual_elements\": [\"lago artificial\", \"varanda\", \"hotel\", \"paisagem contemplativa\", \"cenário sem enredo\"]\n    },\n    {\n      \"entity_id\": \"symbolic_event_008\",\n      \"type\": \"symbolic_event\",\n      \"label\": \"Quitandinha como monumento à insegurança regulatória\",\n      \"scene_ids\": [\"scene_059\", \"scene_060\", \"scene_061\", \"scene_062\", \"scene_063\", \"scene_064\", \"scene_094\", \"scene_095\", \"scene_096\", \"scene_097\"],\n      \"note\": \"A arquitetura vira símbolo da instabilidade das regras do jogo no Brasil.\",\n      \"visual_elements\": [\"complexo monumental\", \"investimento de longo prazo\", \"mudança de lei\", \"mármore em silêncio\", \"monumento econômico\"]\n    }\n  ]\n}\n"},"partialJson":"{\"path\":\"C:\\\\Users\\\\User-OEM\\\\Desktop\\\\content-factory\\\\auto_content_factory\\\\data\\\\006_pt\\\\o_quitandinha_ia_ser_o_maior_casino_do_mundo_-_o_brasil_proibiu_o_jogo_2_anos_depois_de_inaugurar\\\\b2\\\\sectors\\\\s3_visual_planning\\\\operators\\\\symbolic_event_extractor\\\\output.json\",\"content\":\"{\\n  \\\"contract_version\\\": \\\"s3.symbolic_event.output.v1\\\",\\n  \\\"job_id\\\": \\\"job_006_pt_1775251204\\\",\\n  \\\"video_id\\\": \\\"job_006_pt_1775251204\\\",\\n  \\\"language\\\": \\\"pt\\\",\\n  \\\"entities\\\": [\\n    {\\n      \\\"entity_id\\\": \\\"symbolic_event_001\\\",\\n      \\\"type\\\": \\\"symbolic_event\\\",\\n      \\\"label\\\": \\\"Chegada ao Quitandinha na neblina\\\",\\n      \\\"scene_ids\\\": [\\\"scene_001\\\", \\\