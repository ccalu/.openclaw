{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Video Direction Frame",
  "type": "object",
  "required": [
    "frame_version",
    "dominant_visual_era",
    "dominant_style_mode",
    "grounding_baseline",
    "identity_integrity_priority",
    "motion_policy",
    "kit_complexity_ceiling",
    "allowed_generation_modes",
    "visual_era_guidance"
  ],
  "properties": {
    "frame_version": { "type": "string" },
    "video_id": { "type": "string" },
    "dominant_visual_era": { "type": "string" },
    "dominant_style_mode": { "type": "string" },
    "tonal_palette_posture": { "type": "string" },
    "grounding_baseline": { "type": "string", "enum": ["high", "medium", "low"] },
    "identity_integrity_priority": { "type": "string", "enum": ["high", "medium", "low"] },
    "copyright_safety_posture": { "type": "string" },
    "allowed_generation_modes": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "motion_policy": { "type": "string" },
    "kit_complexity_ceiling": { "type": "string", "enum": ["low", "medium", "high"] },
    "asset_density_guidance": { "type": "string" },
    "visual_era_guidance": { "type": "string" },
    "global_style_notes": { "type": "string" },
    "generated_at": { "type": "string" }
  }
}
